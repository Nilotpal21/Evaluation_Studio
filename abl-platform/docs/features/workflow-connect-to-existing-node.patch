+// INT-5: Keyboard navigation
+// =============================================================================
+
+describe('ConnectToExistingSection — INT-5 keyboard navigation', () => {
+  beforeEach(() => {
+    useWorkflowCanvasStore.setState({
+      nodes: [
+        makeNode('start', 'start'),
+        makeNode('A', 'function', 'NodeA'),
+        makeNode('B', 'function', 'NodeB'),
+        makeNode('C', 'end', 'NodeC'),
+      ],
+      edges: [],
+      isDirty: false,
+      changeVersion: 0,
+    });
+  });
+
+  test('ArrowDown moves focus through rows; Enter triggers pick on focused row', () => {
+    const onClose = vi.fn();
+    renderSection({ sourceNodeId: 'start', sourceHandle: 'on_success', onClose });
+
+    const search = screen.getByTestId('connect-to-existing-search');
+    search.focus();
+    fireEvent.keyDown(search, { key: 'ArrowDown' });
+
+    // First row should now be focused (rowRefs[0])
+    const firstRow = screen.getByTestId('connect-to-existing-row-A');
+    expect(document.activeElement).toBe(firstRow);
+
+    // ArrowDown again → row 2
+    fireEvent.keyDown(firstRow, { key: 'ArrowDown' });
+    const secondRow = screen.getByTestId('connect-to-existing-row-B');
+    expect(document.activeElement).toBe(secondRow);
+
+    // Enter on focused row triggers pick + close
+    fireEvent.keyDown(secondRow, { key: 'Enter' });
+    const { edges } = useWorkflowCanvasStore.getState();
+    expect(edges.some((e) => e.source === 'start' && e.target === 'B')).toBe(true);
+    expect(onClose).toHaveBeenCalled();
+  });
+});
