+describe('ConnectToExistingSection — INT-4 search filter', () => {
+  beforeEach(() => {
+    useWorkflowCanvasStore.setState({
+      nodes: [
+        makeNode('start', 'start'),
+        makeNode('fn-format', 'function', 'Format Response'),
+        makeNode('fn-tax', 'function', 'Compute Tax'),
+        makeNode('agent-refund', 'agent', 'Refund Agent'),
+        makeNode('end', 'end', 'End'),
+      ],
+      edges: [],
+      isDirty: false,
+      changeVersion: 0,
+    });
+  });
+
+  test('matches by label substring; case-insensitive; renders no-matches state', async () => {
+    renderSection({ sourceNodeId: 'start', sourceHandle: 'on_success' });
+
+    // All 4 candidates visible initially
+    expect(screen.queryAllByTestId(/^connect-to-existing-row-/)).toHaveLength(4);
+
+    const search = screen.getByTestId('connect-to-existing-search') as HTMLInputElement;
+
+    // Label match: "format" → only fn-format
+    await userEvent.type(search, 'format');
+    let visible = screen.queryAllByTestId(/^connect-to-existing-row-/);
+    expect(visible.map((r) => r.getAttribute('data-testid'))).toEqual([
+      'connect-to-existing-row-fn-format',
+    ]);
+
+    // Clear → all visible again
+    await userEvent.clear(search);
+    expect(screen.queryAllByTestId(/^connect-to-existing-row-/)).toHaveLength(4);
+
+    // Type match: "function" → both function nodes
+    await userEvent.type(search, 'function');
+    visible = screen.queryAllByTestId(/^connect-to-existing-row-/);
+    expect(visible.map((r) => r.getAttribute('data-testid'))).toEqual(
+      expect.arrayContaining([
+        'connect-to-existing-row-fn-format',
+        'connect-to-existing-row-fn-tax',
+      ]),
+    );
+    expect(visible).toHaveLength(2);
+
+    // Case-insensitive: "AGENT" → matches agent-refund (both label and type)
+    await userEvent.clear(search);
+    await userEvent.type(search, 'AGENT');
+    visible = screen.queryAllByTestId(/^connect-to-existing-row-/);
+    expect(visible).toHaveLength(1);
+    expect(visible[0].getAttribute('data-testid')).toBe('connect-to-existing-row-agent-refund');
+
+    // No matches → empty row list + no-matches marker
+    await userEvent.clear(search);
+    await userEvent.type(search, 'xyz123nope');
+    expect(screen.queryAllByTestId(/^connect-to-existing-row-/)).toHaveLength(0);
+    expect(screen.getByTestId('connect-to-existing-no-matches')).toBeTruthy();
+  });
+});
