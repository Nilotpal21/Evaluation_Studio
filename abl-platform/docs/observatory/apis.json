        "queryParams": {
          "limit": { "type": "number", "max": 200, "default": 50 },
          "offset": { "type": "number", "default": 0 },
          "status": {
            "type": "string",
            "values": ["active", "ended", "completed", "escalated", "abandoned"]
          },
          "channel": { "type": "string", "values": ["web_debug", "slack", "whatsapp", "voice"] }
        }
      },
      "response": {
        "shape": {
          "success": true,
          "total": 142,
          "offset": 0,
          "limit": 50,
          "sessions": [
