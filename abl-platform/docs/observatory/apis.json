      "status": "exists",
      "purpose": "Close a session with an explicit disposition",
      "auth": null,
      "request": {
        "body": { "disposition": "completed" },
        "validDispositions": [
          "completed",
          "abandoned",
          "agent_hangup",
          "transferred",
          "failed",
          "timeout"
        ]
      },
      "response": {
        "shape": {
          "success": true,
          "message": "Session closed with disposition: completed",
          "status": "completed",
          "disposition": "completed"
        }
      },
      "consumedBy": ["Voice pipeline (call end)", "Studio session close action"],
      "missingFields": []
