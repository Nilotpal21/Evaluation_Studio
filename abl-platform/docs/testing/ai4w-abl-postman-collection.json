                  "pm.test('has sessionId starting with ai4w:', () => pm.expect(body.data.sessionId).to.match(/^ai4w:/));",
                  "pm.test('X-Response-Mode-Used echoed', () => pm.expect(pm.response.headers.get('X-Response-Mode-Used')).to.exist);"
                ]
