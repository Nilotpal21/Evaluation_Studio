        {
          "name": "POST /message — tampered body → uniform 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Response-Mode", "value": "sync" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Signed for one text, but body is different\",\n  \"agentContextId\": \"{{agentContextId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/channels/ai4w/{{connectionId}}/message",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "channels", "ai4w", "{{connectionId}}", "message"]
            },
            "description": "Overrides the folder-level pre-request signature with a wrong one so the body-tamper path is exercised."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// After the folder-level signer runs, overwrite X-Signature with a bad value.",
                  "pm.request.headers.upsert({ key: 'X-Signature', value: 'sha256=deadbeef' });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('401', () => pm.response.to.have.status(401));",
                  "const body = pm.response.json();",
                  "pm.test('UNAUTHORIZED', () => pm.expect(body.error.code).to.eql('UNAUTHORIZED'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /message — replay (duplicate X-Signature-Nonce) → 409",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Response-Mode", "value": "sync" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Replay check\",\n  \"agentContextId\": \"{{agentContextId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/channels/ai4w/{{connectionId}}/message",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "channels", "ai4w", "{{connectionId}}", "message"]
            },
            "description": "Run twice — the second call returns 409 REPLAY_DETECTED because X-Signature-Nonce is a fixed value. Set `replayRequestId` in env to seed this, or run once then the Collection Runner again."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Re-sign using a fixed requestId pinned in env.",
                  "const secret = pm.environment.get('connectionSecret');",
                  "const requestId = pm.environment.get('replayRequestId') || '00000000-0000-4000-8000-000000000000';",
                  "pm.environment.set('replayRequestId', requestId);",
                  "const timestamp = new Date().toISOString();",
                  "const rawBody = pm.request.body.raw;",
                  "const payload = 'inbound:' + requestId + '.' + timestamp + '.' + rawBody;",
                  "const signature = CryptoJS.HmacSHA256(payload, secret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'X-Signature-Nonce', value: requestId });",
                  "pm.request.headers.upsert({ key: 'X-Timestamp', value: timestamp });",
                  "pm.request.headers.upsert({ key: 'X-Signature', value: 'sha256=' + signature });",
                  "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.environment.get('jwt') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('first call 200 or 409 (on rerun)', () => pm.expect([200, 409]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
