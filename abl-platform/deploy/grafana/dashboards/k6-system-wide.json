{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for k6 remote write metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "12.3.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "5.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "5.0.0" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "5.0.0" }
  ],
  "id": null,
  "uid": "abl-k6-system-wide",
  "title": "ABL Platform - k6 System-Wide Stress Tests",
  "description": "System-wide stress test results: steady-state soak, ramp-to-saturation, multi-tenant isolation, burst traffic, failover/recovery, and disk pressure tests.",
  "tags": ["k6", "benchmark", "abl-platform", "stress-test", "system-wide"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m"],
    "time_options": ["1h", "6h", "12h", "24h", "2d"]
  },
  "templating": {
    "list": [
      {
        "name": "test_type",
        "type": "custom",
        "label": "Stress Test",
        "description": "System-wide stress test type",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "steady-state-soak", "value": "steady-state-soak", "selected": false },
          { "text": "ramp-to-saturation", "value": "ramp-to-saturation", "selected": false },
          {
            "text": "multi-tenant-isolation",
            "value": "multi-tenant-isolation",
            "selected": false
          },
          { "text": "burst-traffic", "value": "burst-traffic", "selected": false },
          { "text": "failover-recovery", "value": "failover-recovery", "selected": false },
          { "text": "disk-pressure", "value": "disk-pressure", "selected": false }
        ],
        "query": "steady-state-soak,ramp-to-saturation,multi-tenant-isolation,burst-traffic,failover-recovery,disk-pressure",
        "includeAll": true,
        "multi": true
      },
      {
        "name": "tenant",
        "type": "query",
        "label": "Tenant",
        "description": "Filter by tenant ID (relevant for multi-tenant isolation tests)",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(k6_http_reqs_total{scenario=~\"$test_type\"}, tenant)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Overall Throughput Over Time",
      "description": "Aggregate request throughput across all services and test scenarios. Shows how the system handles increasing or sustained load. During ramp-to-saturation tests, look for the throughput plateau -- that is the saturation point.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "axisLabel": "req/s",
            "gradientMode": "opacity"
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(k6_http_reqs_total{scenario=~\"$test_type\", tenant=~\"$tenant\"}[1m]))",
          "legendFormat": "Total throughput",
          "refId": "A"
        },
        {
          "expr": "sum by (service) (rate(k6_http_reqs_total{scenario=~\"$test_type\", tenant=~\"$tenant\"}[1m]))",
          "legendFormat": "{{service}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Peak Throughput",
      "description": "Maximum observed aggregate throughput during the stress test window",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "max_over_time(sum(rate(k6_http_reqs_total{scenario=~\"$test_type\"}[1m]))[6h:])",
          "legendFormat": "Peak req/s",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Saturation VU Count",
      "description": "VU count at which the system reached saturation (error rate exceeded 1%). Derived from the ramp-to-saturation test.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "k6_vus{scenario=\"ramp-to-saturation\"} and (sum(rate(k6_http_req_failed_total{scenario=\"ramp-to-saturation\"}[1m])) / sum(rate(k6_http_reqs_total{scenario=\"ramp-to-saturation\"}[1m])) > 0.01)",
          "legendFormat": "Saturation VUs",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Active VUs",
      "description": "Number of active virtual users during the stress test",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(k6_vus{scenario=~\"$test_type\"})",
          "legendFormat": "Active VUs",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Test Duration",
      "description": "Elapsed time for the current stress test run",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "max(k6_test_duration_seconds{scenario=~\"$test_type\"})",
          "legendFormat": "Duration",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Rates Over Time",
      "description": "Error rate as a percentage of total requests. During soak tests, watch for gradual drift upward indicating resource exhaustion. During burst tests, spikes are expected -- measure how quickly they recover to baseline.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "axisLabel": "%"
          },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(k6_http_req_failed_total{scenario=~\"$test_type\", tenant=~\"$tenant\"}[1m])) / sum(rate(k6_http_reqs_total{scenario=~\"$test_type\", tenant=~\"$tenant\"}[1m]))",
          "legendFormat": "Overall Error %",
          "refId": "A"
        },
        {
          "expr": "sum by (service) (rate(k6_http_req_failed_total{scenario=~\"$test_type\", tenant=~\"$tenant\"}[1m])) / sum by (service) (rate(k6_http_reqs_total{scenario=~\"$test_type\", tenant=~\"$tenant\"}[1m]))",
          "legendFormat": "{{service}} Error %",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "Latency Under Load (p50 / p95 / p99)",
      "description": "System-wide latency percentiles during stress testing. During soak tests, gradual latency increase indicates memory leaks or connection pool exhaustion.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "axisLabel": "ms"
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "avg(k6_http_req_duration_p50{scenario=~\"$test_type\", tenant=~\"$tenant\"})",
          "legendFormat": "System p50",
          "refId": "A"
        },
        {
          "expr": "avg(k6_http_req_duration_p95{scenario=~\"$test_type\", tenant=~\"$tenant\"})",
          "legendFormat": "System p95",
          "refId": "B"
        },
        {
          "expr": "avg(k6_http_req_duration_p99{scenario=~\"$test_type\", tenant=~\"$tenant\"})",
          "legendFormat": "System p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "Recovery Time After Burst / Failover",
      "description": "Measures the time from a traffic burst or pod kill event until error rate returns below 1% and latency returns within 2x baseline. Key metric for SLA validation.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_duration_p95{scenario=~\"burst-traffic|failover-recovery\"}",
          "legendFormat": "{{scenario}} p95 latency",
          "refId": "A"
        },
        {
          "expr": "sum(rate(k6_http_req_failed_total{scenario=~\"burst-traffic|failover-recovery\"}[30s])) / sum(rate(k6_http_reqs_total{scenario=~\"burst-traffic|failover-recovery\"}[30s])) * 10000",
          "legendFormat": "Error rate (scaled ×100 for visibility)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "title": "Multi-Tenant Isolation - Per-Tenant Latency",
      "description": "Compares p95 latency across tenants during the multi-tenant isolation stress test. A noisy-neighbor problem shows up as one tenant's latency spiking while others remain stable.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisLabel": "ms"
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_duration_p95{scenario=\"multi-tenant-isolation\"} by (tenant)",
          "legendFormat": "Tenant {{tenant}} - p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Soak Test - Memory & Pool Exhaustion Indicators",
      "description": "Track VU count alongside error rate and latency during long-running soak tests. Divergence between stable VUs and increasing errors/latency indicates resource leaks.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "VUs" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*latency.*" },
            "properties": [{ "id": "unit", "value": "ms" }]
          }
        ]
      },
      "targets": [
        {
          "expr": "k6_vus{scenario=\"steady-state-soak\"}",
          "legendFormat": "VUs",
          "refId": "A"
        },
        {
          "expr": "k6_http_req_duration_p95{scenario=\"steady-state-soak\"}",
          "legendFormat": "p95 latency",
          "refId": "B"
        },
        {
          "expr": "rate(k6_http_req_failed_total{scenario=\"steady-state-soak\"}[5m]) * 100",
          "legendFormat": "Errors/s (×100)",
          "refId": "C"
        }
      ]
    },
    {
      "id": 11,
      "title": "Disk Pressure - Hourly Growth Rate",
      "description": "Estimated disk growth rate per data store during the disk-pressure stress test. Measures write throughput to MongoDB, ClickHouse, OpenSearch, Qdrant, and Restate.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisLabel": "MB/hr"
          },
          "unit": "MBs"
        }
      },
      "targets": [
        {
          "expr": "rate(k6_data_sent_total{scenario=\"disk-pressure\", service=\"mongodb\"}[10m]) * 3600 / 1048576",
          "legendFormat": "MongoDB",
          "refId": "A"
        },
        {
          "expr": "rate(k6_data_sent_total{scenario=\"disk-pressure\", service=\"clickhouse\"}[10m]) * 3600 / 1048576",
          "legendFormat": "ClickHouse",
          "refId": "B"
        },
        {
          "expr": "rate(k6_data_sent_total{scenario=\"disk-pressure\", service=\"opensearch\"}[10m]) * 3600 / 1048576",
          "legendFormat": "OpenSearch",
          "refId": "C"
        },
        {
          "expr": "rate(k6_data_sent_total{scenario=\"disk-pressure\", service=\"qdrant\"}[10m]) * 3600 / 1048576",
          "legendFormat": "Qdrant",
          "refId": "D"
        },
        {
          "expr": "rate(k6_data_sent_total{scenario=\"disk-pressure\", service=\"restate\"}[10m]) * 3600 / 1048576",
          "legendFormat": "Restate",
          "refId": "E"
        }
      ]
    },
    {
      "id": 12,
      "title": "Overall Error Rate",
      "description": "Current aggregate error rate across all stress test scenarios",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(k6_http_req_failed_total{scenario=~\"$test_type\"}[5m])) / sum(rate(k6_http_reqs_total{scenario=~\"$test_type\"}[5m]))",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(k6_http_reqs_total{scenario=~\"$test_type\"})",
          "legendFormat": "Total",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 14,
      "title": "Total Failures",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(k6_http_req_failed_total{scenario=~\"$test_type\"})",
          "legendFormat": "Failures",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 15,
      "title": "Data Transferred",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(k6_data_sent_total{scenario=~\"$test_type\"}) + sum(k6_data_received_total{scenario=~\"$test_type\"})",
          "legendFormat": "Total Data",
          "refId": "A",
          "instant": true
        }
      ]
    }
  ]
}
