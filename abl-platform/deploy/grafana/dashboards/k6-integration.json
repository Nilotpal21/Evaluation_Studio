{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for k6 remote write metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "12.3.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "5.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "5.0.0" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "5.0.0" },
    { "type": "panel", "id": "table", "name": "Table", "version": "5.0.0" }
  ],
  "id": null,
  "uid": "abl-k6-integration",
  "title": "ABL Platform - k6 Integration Benchmarks",
  "description": "End-to-end integration benchmark results across critical user journeys: agent conversations, KB ingestion, search queries, workflow execution, multi-agent orchestration, and channel message processing.",
  "tags": ["k6", "benchmark", "abl-platform", "integration", "e2e"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h"]
  },
  "templating": {
    "list": [
      {
        "name": "journey",
        "type": "custom",
        "label": "Journey",
        "description": "Critical user journey / integration scenario",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          {
            "text": "agent-conversation-e2e",
            "value": "agent-conversation-e2e",
            "selected": false
          },
          { "text": "kb-ingestion-e2e", "value": "kb-ingestion-e2e", "selected": false },
          { "text": "search-query-e2e", "value": "search-query-e2e", "selected": false },
          {
            "text": "workflow-execution-e2e",
            "value": "workflow-execution-e2e",
            "selected": false
          },
          {
            "text": "multi-agent-orchestration",
            "value": "multi-agent-orchestration",
            "selected": false
          },
          {
            "text": "channel-message-processing",
            "value": "channel-message-processing",
            "selected": false
          }
        ],
        "query": "agent-conversation-e2e,kb-ingestion-e2e,search-query-e2e,workflow-execution-e2e,multi-agent-orchestration,channel-message-processing",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "E2E Latency by Journey (p50 / p95 / p99)",
      "description": "End-to-end latency for each integration journey, measured from the first request to final response across all services in the pipeline",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "axisLabel": "ms"
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_duration_p50{scenario=~\"$journey\"}",
          "legendFormat": "{{scenario}} - p50",
          "refId": "A"
        },
        {
          "expr": "k6_http_req_duration_p95{scenario=~\"$journey\"}",
          "legendFormat": "{{scenario}} - p95",
          "refId": "B"
        },
        {
          "expr": "k6_http_req_duration_p99{scenario=~\"$journey\"}",
          "legendFormat": "{{scenario}} - p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "title": "Service Breakdown - Agent Conversation E2E",
      "description": "Time spent in each service during an agent conversation: Studio API, Runtime agent execution, LLM inference, MongoDB persistence, ClickHouse trace emission",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.8,
        "groupWidth": 0.7,
        "stacking": "normal"
      },
      "targets": [
        {
          "expr": "avg(k6_http_req_duration_p50{scenario=\"agent-conversation-e2e\", service=\"studio\"})",
          "legendFormat": "Studio API",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "avg(k6_http_req_duration_p50{scenario=\"agent-conversation-e2e\", service=\"runtime\"})",
          "legendFormat": "Runtime",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "avg(k6_custom_llm_duration_p50{scenario=\"agent-conversation-e2e\"})",
          "legendFormat": "LLM Inference",
          "refId": "C",
          "instant": true
        },
        {
          "expr": "avg(k6_custom_mongodb_duration_p50{scenario=\"agent-conversation-e2e\"})",
          "legendFormat": "MongoDB",
          "refId": "D",
          "instant": true
        },
        {
          "expr": "avg(k6_custom_clickhouse_duration_p50{scenario=\"agent-conversation-e2e\"})",
          "legendFormat": "ClickHouse",
          "refId": "E",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Service Breakdown - KB Ingestion E2E",
      "description": "Time spent in each service during knowledge base ingestion: Search AI orchestration, Docling document parsing, BGE-M3 embedding, OpenSearch/Qdrant indexing, Neo4j graph creation",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "stacking": { "mode": "normal" },
            "fillOpacity": 80
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.8,
        "groupWidth": 0.7,
        "stacking": "normal"
      },
      "targets": [
        {
          "expr": "avg(k6_http_req_duration_p50{scenario=\"kb-ingestion-e2e\", service=\"search-ai\"})",
          "legendFormat": "Search AI",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "avg(k6_custom_docling_duration_p50{scenario=\"kb-ingestion-e2e\"})",
          "legendFormat": "Docling",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "avg(k6_custom_embedding_duration_p50{scenario=\"kb-ingestion-e2e\"})",
          "legendFormat": "BGE-M3 Embedding",
          "refId": "C",
          "instant": true
        },
        {
          "expr": "avg(k6_custom_indexing_duration_p50{scenario=\"kb-ingestion-e2e\"})",
          "legendFormat": "OpenSearch + Qdrant Indexing",
          "refId": "D",
          "instant": true
        },
        {
          "expr": "avg(k6_custom_graph_duration_p50{scenario=\"kb-ingestion-e2e\"})",
          "legendFormat": "Neo4j Graph",
          "refId": "E",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Bottleneck Identification - Slowest Service per Journey",
      "description": "Identifies which service contributes the most latency for each integration journey. Shows the max p95 latency per service label within each scenario.",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "custom": { "displayMode": "color-background-solid" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "scenario" },
            "properties": [{ "id": "custom.width", "value": 250 }]
          },
          {
            "matcher": { "id": "byName", "options": "service" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          }
        ]
      },
      "targets": [
        {
          "expr": "topk(1, k6_http_req_duration_p95{scenario=~\"$journey\"}) by (scenario)",
          "legendFormat": "{{scenario}} - {{service}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "scenario": "Journey",
              "service": "Bottleneck Service",
              "Value": "p95 Latency (ms)"
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Journey Throughput (req/s)",
      "description": "Request throughput per integration journey over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisLabel": "req/s"
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum by (scenario) (rate(k6_http_reqs_total{scenario=~\"$journey\"}[1m]))",
          "legendFormat": "{{scenario}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Journey Error Rates",
      "description": "Error rate per integration journey. A non-zero error rate during integration testing indicates a service in the chain is failing under load.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "axisLabel": "%"
          },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "sum by (scenario) (rate(k6_http_req_failed_total{scenario=~\"$journey\"}[5m])) / sum by (scenario) (rate(k6_http_reqs_total{scenario=~\"$journey\"}[5m]))",
          "legendFormat": "{{scenario}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Concurrent Conversations (Agent E2E)",
      "description": "Number of concurrent active conversations during the agent conversation E2E benchmark. Maps to WebSocket connections on the Runtime.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "k6_vus{scenario=\"agent-conversation-e2e\"}",
          "legendFormat": "Active Conversations",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Docs Ingested/Hour (KB E2E)",
      "description": "Estimated document ingestion throughput based on k6 iteration rate for the KB ingestion journey",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(k6_iterations_total{scenario=\"kb-ingestion-e2e\"}[5m]) * 3600",
          "legendFormat": "Docs/hour",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Search Query p95 (Search E2E)",
      "description": "p95 latency for the full search query pipeline: preprocessing, embedding, vector search, graph enrichment",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_duration_p95{scenario=\"search-query-e2e\"}",
          "legendFormat": "p95",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Workflow Step Latency (Workflow E2E)",
      "description": "Average latency per workflow step in the workflow execution E2E benchmark",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(k6_custom_workflow_step_duration_p50{scenario=\"workflow-execution-e2e\"})",
          "legendFormat": "Avg Step Latency",
          "refId": "A",
          "instant": true
        }
      ]
    }
  ]
}
