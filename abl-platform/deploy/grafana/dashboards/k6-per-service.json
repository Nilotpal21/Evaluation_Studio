{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for k6 remote write metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "12.3.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "5.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "5.0.0" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "5.0.0" }
  ],
  "id": null,
  "uid": "abl-k6-per-service",
  "title": "ABL Platform - k6 Per-Service Benchmarks",
  "description": "Per-service micro-benchmark results from k6 Prometheus remote write. Covers Tier 1 (compute), Tier 2 (stateful), and Tier 3 (application) services.",
  "tags": ["k6", "benchmark", "abl-platform", "per-service"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h"]
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "description": "Select the ABL Platform service to display benchmark results for",
        "current": { "text": "runtime", "value": "runtime" },
        "options": [
          { "text": "runtime", "value": "runtime", "selected": true },
          { "text": "bge-m3", "value": "bge-m3", "selected": false },
          { "text": "docling", "value": "docling", "selected": false },
          { "text": "search-ai", "value": "search-ai", "selected": false },
          { "text": "search-ai-runtime", "value": "search-ai-runtime", "selected": false },
          { "text": "workflow-engine", "value": "workflow-engine", "selected": false },
          { "text": "studio", "value": "studio", "selected": false },
          { "text": "admin", "value": "admin", "selected": false },
          { "text": "multimodal", "value": "multimodal", "selected": false },
          { "text": "preprocessing", "value": "preprocessing", "selected": false },
          { "text": "nlu-sidecar", "value": "nlu-sidecar", "selected": false },
          { "text": "crawler-go", "value": "crawler-go", "selected": false },
          { "text": "mongodb", "value": "mongodb", "selected": false },
          { "text": "clickhouse", "value": "clickhouse", "selected": false },
          { "text": "opensearch", "value": "opensearch", "selected": false },
          { "text": "redis", "value": "redis", "selected": false },
          { "text": "neo4j", "value": "neo4j", "selected": false },
          { "text": "qdrant", "value": "qdrant", "selected": false },
          { "text": "restate", "value": "restate", "selected": false }
        ],
        "query": "runtime,bge-m3,docling,search-ai,search-ai-runtime,workflow-engine,studio,admin,multimodal,preprocessing,nlu-sidecar,crawler-go,mongodb,clickhouse,opensearch,redis,neo4j,qdrant,restate",
        "includeAll": false,
        "multi": false
      },
      {
        "name": "scenario",
        "type": "query",
        "label": "Scenario",
        "description": "k6 scenario name (auto-populated from metrics)",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(k6_http_reqs_total{service=\"$service\"}, scenario)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Virtual Users (VUs)",
      "description": "Current number of active virtual users executing the benchmark scenario",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "axisLabel": "VUs"
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "k6_vus{service=\"$service\", scenario=~\"$scenario\"}",
          "legendFormat": "{{scenario}} - active VUs",
          "refId": "A"
        },
        {
          "expr": "k6_vus_max{service=\"$service\", scenario=~\"$scenario\"}",
          "legendFormat": "{{scenario}} - max VUs",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "description": "HTTP request throughput per second, broken down by scenario",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisLabel": "req/s"
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "rate(k6_http_reqs_total{service=\"$service\", scenario=~\"$scenario\"}[1m])",
          "legendFormat": "{{scenario}} - {{method}} {{url}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency Percentiles (p50 / p95 / p99)",
      "description": "HTTP request duration at p50, p95, and p99 percentiles using native histograms from k6 Prometheus remote write",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "axisLabel": "ms"
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_duration_p50{service=\"$service\", scenario=~\"$scenario\"}",
          "legendFormat": "{{scenario}} - p50",
          "refId": "A"
        },
        {
          "expr": "k6_http_req_duration_p95{service=\"$service\", scenario=~\"$scenario\"}",
          "legendFormat": "{{scenario}} - p95",
          "refId": "B"
        },
        {
          "expr": "k6_http_req_duration_p99{service=\"$service\", scenario=~\"$scenario\"}",
          "legendFormat": "{{scenario}} - p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Current Error Rate",
      "description": "Percentage of failed HTTP requests in the current window",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(k6_http_req_failed_total{service=\"$service\", scenario=~\"$scenario\"}[5m])) / sum(rate(k6_http_reqs_total{service=\"$service\", scenario=~\"$scenario\"}[5m]))",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Error Rate Over Time",
      "description": "Failed request rate plotted over time, useful for identifying error bursts during load ramp-up",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "axisLabel": "errors/s"
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "rate(k6_http_req_failed_total{service=\"$service\", scenario=~\"$scenario\"}[1m])",
          "legendFormat": "{{scenario}} - errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Requests",
      "description": "Cumulative total HTTP requests completed during the benchmark run",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(k6_http_reqs_total{service=\"$service\", scenario=~\"$scenario\"})",
          "legendFormat": "Total Requests",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Total Failures",
      "description": "Cumulative total HTTP request failures during the benchmark run",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(k6_http_req_failed_total{service=\"$service\", scenario=~\"$scenario\"})",
          "legendFormat": "Total Failures",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Peak p99 Latency",
      "description": "Maximum observed p99 latency during the benchmark window",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max_over_time(k6_http_req_duration_p99{service=\"$service\", scenario=~\"$scenario\"}[1h])",
          "legendFormat": "Peak p99",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Avg Request Duration",
      "description": "Average HTTP request duration across all scenarios for the selected service",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(k6_http_req_duration_p50{service=\"$service\", scenario=~\"$scenario\"})",
          "legendFormat": "Avg Duration",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Data Sent / Received",
      "description": "Network throughput: bytes sent to and received from the service under test",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisLabel": "bytes/s"
          },
          "unit": "Bps"
        }
      },
      "targets": [
        {
          "expr": "rate(k6_data_sent_total{service=\"$service\", scenario=~\"$scenario\"}[1m])",
          "legendFormat": "{{scenario}} - sent",
          "refId": "A"
        },
        {
          "expr": "rate(k6_data_received_total{service=\"$service\", scenario=~\"$scenario\"}[1m])",
          "legendFormat": "{{scenario}} - received",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "title": "Iterations Completed",
      "description": "Rate of completed k6 test iterations per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "axisLabel": "iter/s"
          },
          "unit": "ipm"
        }
      },
      "targets": [
        {
          "expr": "rate(k6_iterations_total{service=\"$service\", scenario=~\"$scenario\"}[1m])",
          "legendFormat": "{{scenario}} - iterations/s",
          "refId": "A"
        }
      ]
    }
  ]
}
