# arch-eval — only top-level analysis docs (REVIEW, AUDIT-AND-FIXES,
# RUNTIME-AUDIT, arch-vs-me.md/json, summary/scoring/findings) are
# tracked. Per-scenario raw output (s11-*..s30-*/topology.json, agents.json,
# abl/*.abl, compile/*.json, health.json, etc.) and timestamped smoke/run
# folders are ignored — they're regenerable from the harness and bloat
# the repo (one full round = ~400 files, ~5MB).
docs/testing/arch-eval/**/events.ndjson
docs/testing/arch-eval/**/session.json
docs/testing/arch-eval/**/project.json
docs/testing/arch-eval/**/agents.error.json
docs/testing/arch-eval/**/in-project/**/events.ndjson
docs/testing/arch-eval/**/in-project/in-project-summary.json
# Per-scenario raw output (numbered scenario folders at any depth):
# ignore the subfolders + JSON dumps inside, but keep the directory
# itself trackable so deep-review.md / other analysis markdown can be
# committed alongside the raw run. (git can't re-include a file
# whose parent dir is excluded, so we ignore CONTENTS, not the dir.)
docs/testing/arch-eval/**/s[0-9]*-*/abl/
docs/testing/arch-eval/**/s[0-9]*-*/compile/
docs/testing/arch-eval/**/s[0-9]*-*/*.json
docs/testing/arch-eval/**/s[0-9]*-*/*.ndjson
# Timestamped smoke / regen / postfix runs (only their analysis markdown
# is worth tracking — and that should be lifted to a named folder, not
# left in a timestamped dir).
docs/testing/arch-eval/run-*/
docs/testing/arch-eval/smoke-test/
docs/testing/arch-eval/postfix-*/
docs/testing/arch-eval/round*-postfix-*/

# Stray runtime env file (potentially contains secrets)
apps/runtime/.env1

# Arch AI in-project battle test runs — large, ephemeral, local-only.
# The harness scripts, logs, and findings are intentionally left out of git;
# they live locally under tests/arch-ai-battle/ for review.
tests/arch-ai-battle/
