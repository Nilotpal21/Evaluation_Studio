{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "noEmit": false,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@abl/core": ["packages/core/src"],
      "@abl/core/*": ["packages/core/src/*"],
      "@abl/analyzer": ["packages/analyzer/src"],
      "@abl/analyzer/*": ["packages/analyzer/src/*"],
      "@abl/compiler": ["packages/compiler/dist/index.d.ts"],
      "@abl/compiler/platform": ["packages/compiler/dist/platform/index.d.ts"],
      "@abl/compiler/platform/logger.js": ["packages/compiler/dist/platform/logger.d.ts"],
      "@abl/compiler/platform/constructs": [
        "packages/compiler/dist/platform/constructs/index.d.ts"
      ],
      "@abl/compiler/platform/contracts": ["packages/compiler/dist/platform/contracts/index.d.ts"],
      "@abl/compiler/platform/contracts/*": ["packages/compiler/dist/platform/contracts/*"],
      "@abl/compiler/platform/ir": ["packages/compiler/dist/platform/ir/index.d.ts"],
      "@abl/compiler/platform/ir/compiler.js": ["packages/compiler/dist/platform/ir/compiler.d.ts"],
      "@abl/compiler/platform/llm": ["packages/compiler/dist/platform/llm/index.d.ts"],
      "@abl/compiler/platform/observability": [
        "packages/compiler/dist/platform/observability/index.d.ts"
      ],
      "@abl/compiler/platform/security": ["packages/compiler/dist/platform/security/index.d.ts"],
      "@abl/compiler/platform/stores": ["packages/compiler/dist/platform/stores/index.d.ts"],
      "@abl/compiler/*": ["packages/compiler/src/*"],
      "@abl/eventstore": ["packages/eventstore/dist/index.d.ts"],
      "@abl/eventstore/*": ["packages/eventstore/dist/*"],
      "@abl/nl-parser": ["packages/nl-parser/src"],
      "@abl/nl-parser/*": ["packages/nl-parser/src/*"],
      "@abl/editor": ["packages/editor/src"],
      "@abl/editor/*": ["packages/editor/src/*"],
      "@abl/language-service": ["packages/language-service/src"],
      "@abl/language-service/*": ["packages/language-service/src/*"],
      "@agent-platform/observatory": ["packages/observatory/src"],
      "@agent-platform/observatory/*": ["packages/observatory/src/*"],
      "@koredotcom/agents-mcp-tools": ["packages/mcp-debug/src"],
      "@koredotcom/agents-mcp-tools/*": ["packages/mcp-debug/src/*"],
      "@agent-platform/circuit-breaker": ["packages/circuit-breaker/src"],
      "@agent-platform/circuit-breaker/*": ["packages/circuit-breaker/src/*"],
      "@agent-platform/database": ["packages/database/src"],
      "@agent-platform/database/*": ["packages/database/src/*"],
      "@agent-platform/shared-kernel": ["packages/shared-kernel/src"],
      "@agent-platform/shared-kernel/*": ["packages/shared-kernel/src/*"],
      "@agent-platform/shared": ["packages/shared/src"],
      "@agent-platform/shared/*": ["packages/shared/src/*"],
      "@agent-platform/shared-observability": ["packages/shared-observability/src"],
      "@agent-platform/shared-observability/*": ["packages/shared-observability/src/*"],
      "@agent-platform/config": ["packages/config/src"],
      "@agent-platform/config/*": ["packages/config/src/*"],
      "@agent-platform/redis": ["packages/redis/src"],
      "@agent-platform/redis/*": ["packages/redis/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/dist/**"]
}
