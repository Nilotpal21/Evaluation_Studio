{
  "name": "agent-blueprint-language",
  "version": "2026.04.0",
  "private": true,
  "description": "Agent Blueprint Language (ABL) platform for building AI agents with multi-agent orchestration",
  "scripts": {
    "dev": "NODE_ENV=development turbo dev --filter=@agent-platform/studio --filter=@agent-platform/runtime --filter=@agent-platform/web-sdk",
    "dev:all": "NODE_ENV=development turbo dev",
    "dev:studio": "NODE_ENV=development turbo dev --filter=@agent-platform/studio --filter=@agent-platform/web-sdk",
    "dev:workflows": "NODE_ENV=development LIGHT_DEV=1 turbo dev:workflows --filter=@agent-platform/studio --filter=@agent-platform/runtime --filter=@agent-platform/workflow-engine",
    "dev:runtime": "NODE_ENV=development turbo dev --filter=@agent-platform/runtime",
    "helix": "node tools/helix/run.mjs",
    "helix:mcp": "node tools/helix/run.mjs --mcp",
    "workspace:paths:check": "tsx tools/verify-workspace-export-paths.ts",
    "abl:docs:generate": "tsx tools/abl-docs/generate.ts",
    "abl:docs:check": "tsx tools/abl-docs/check.ts",
    "abl:contract:test": "pnpm --filter @abl/compiler test:knowledge-drift && pnpm --filter @abl/compiler test -- src/__tests__/contracts/abl-contract-registry.test.ts src/__tests__/examples/banknexus-smoke.test.ts src/__tests__/docs/phase6-doc-alignment.test.ts src/__tests__/docs/phase8-long-form-contract-governance.test.ts src/__tests__/ir/abl-spec-examples-validation.test.ts && pnpm --filter @agent-platform/project-io test -- src/__tests__/entity-schemas.test.ts src/__tests__/layer-disassemblers.test.ts src/__tests__/cross-ref-resolver.test.ts src/__tests__/guardrails-assembler.test.ts && pnpm --filter @agent-platform/arch-ai test -- src/__tests__/abl-contract-backed-knowledge.test.ts src/__tests__/golden-corpus/in-project-accuracy-gates.test.ts",
    "abl:contract:check": "pnpm abl:docs:check && pnpm --filter @agent-platform/shared-kernel build && pnpm --filter @agent-platform/database build && pnpm --filter @agent-platform/shared build && pnpm --filter @abl/compiler build && pnpm --filter @agent-platform/project-io build && pnpm --filter @agent-platform/arch-ai build && pnpm abl:contract:test",
    "build": "pnpm abl:contract:check && pnpm workspace:paths:check && turbo build",
    "build:changed": "pnpm abl:contract:check && pnpm workspace:paths:check && bash ./tools/local-verify.sh build",
    "build:low-mem": "pnpm abl:contract:check && pnpm workspace:paths:check && pnpm build:packages:raw && pnpm build:studio-low-mem:raw",
    "build:packages": "pnpm abl:contract:check && pnpm workspace:paths:check && pnpm build:packages:raw",
    "build:packages:raw": "turbo build --filter=!@agent-platform/studio --concurrency=1",
    "build:studio-low-mem": "pnpm abl:contract:check && pnpm workspace:paths:check && pnpm build:studio-low-mem:raw",
    "build:studio-low-mem:raw": "NODE_OPTIONS=\"--expose-gc --max-old-space-size=7168\" turbo build --filter=@agent-platform/studio",
    "test:low-mem": "NODE_OPTIONS=\"--max-old-space-size=6144\" turbo test:fast --concurrency=1",
    "test": "turbo test",
    "test:repro": "turbo test:repro --continue --filter=@abl/core --filter=@abl/compiler --filter=@agent-platform/project-io --filter=@agent-platform/a2a --filter=@agent-platform/pipeline-engine --filter=@agent-platform/runtime --filter=@agent-platform/studio",
    "lint:public-response-leak": "node tools/public-response-leak-check.mjs --staged",
    "lint:public-response-leak:all": "node tools/public-response-leak-check.mjs --all",
    "lint:structured-diagnostics": "node tools/structured-diagnostics-check.mjs --staged",
    "lint:structured-diagnostics:all": "node tools/structured-diagnostics-check.mjs --all",
    "test:repro-quality": "node tools/repro-test-quality-check.mjs --staged",
    "test:repro-quality:all": "node tools/repro-test-quality-check.mjs --all",
    "test:cluster": "docker compose -f docker-compose.cluster.yml up -d && pnpm vitest run --config vitest.cluster.config.ts; status=$?; docker compose -f docker-compose.cluster.yml down -v; exit $status",
    "test:smart": "node tools/run-tests.mjs",
    "test:smart:both": "REDIS_TEST_MODE=both node tools/run-tests.mjs",
    "test:smart:detect": "node tools/run-tests.mjs detect",
    "test:changed": "bash ./tools/local-verify.sh test",
    "test:changed:pr": "bash ./tools/local-verify.sh test",
    "lint:mock-export-drift": "node tools/mock-export-drift-check.mjs",
    "test:report": "tsx tools/test-capture.ts",
    "test:report:fast": "tsx tools/test-capture.ts --tier test:fast",
    "test:report:failures": "tsx tools/aggregate-failures.ts",
    "test:coverage": "turbo test:coverage",
    "coverage:check": "tsx scripts/coverage-check.ts",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "typecheck:changed": "bash ./tools/local-verify.sh typecheck",
    "verify:local": "bash ./tools/local-verify.sh all",
    "verify:local:plan": "bash ./tools/local-verify.sh plan",
    "clean": "turbo clean && rm -rf node_modules",
    "coverage:report": "npx tsx scripts/coverage-report.ts",
    "insights": "bash scripts/conversation-testing/run.sh",
    "jira:create": "tsx scripts/jira-create.ts",
    "jira:update": "tsx scripts/jira-update.ts",
    "jira:list": "tsx scripts/list-my-jira-tickets.ts",
    "jira:assigned": "tsx scripts/list-my-jira-tickets.ts --assigned",
    "studio:video:evidence": "node tools/studio-video-evidence/run.mjs",
    "seed:core": "tsx packages/database/seed-mongo.ts",
    "seed:dev": "tsx packages/database/seed-mongo.ts --dev",
    "seed:all": "pnpm seed:dev",
    "seed:status": "tsx packages/database/seed-mongo.ts --status",
    "seed:validate": "tsx packages/database/seed-mongo.ts --validate",
    "seed:kafka": "tsx packages/eventstore/seed-kafka.ts",
    "seed:kafka:status": "tsx packages/eventstore/seed-kafka.ts --status",
    "seed:kafka:dry-run": "tsx packages/eventstore/seed-kafka.ts --dry-run",
    "seed:secrets": "tsx scripts/seed-secrets.ts",
    "validate:secrets": "tsx scripts/validate-secrets-completeness.ts",
    "db:seed": "pnpm --filter @agent-platform/database db:seed",
    "db:seed:fresh": "pnpm --filter @agent-platform/database db:seed:fresh",
    "db:seed:status": "pnpm --filter @agent-platform/database db:seed:status",
    "db:seed:validate": "pnpm --filter @agent-platform/database db:seed:validate",
    "db:migrate:mongo": "pnpm --filter @agent-platform/database db:migrate:mongo",
    "db:migrate:mongo:status": "pnpm --filter @agent-platform/database db:migrate:mongo:status",
    "db:migrate:mongo:validate": "pnpm --filter @agent-platform/database db:migrate:mongo:validate",
    "db:migrate:mongo:rollback": "pnpm --filter @agent-platform/database db:migrate:mongo:rollback",
    "db:init": "pnpm db:migrate:mongo && pnpm seed:dev",
    "db:init:core": "pnpm db:migrate:mongo && pnpm seed:core",
    "init": "pnpm db:init && pnpm seed:kafka",
    "init:core": "pnpm db:init:core && pnpm seed:kafka",
    "infra": "docker compose up -d mongo clickhouse redis",
    "infra:stop": "docker compose stop mongo clickhouse redis",
    "infra:down": "docker compose down",
    "pm2:start": "mkdir -p logs && pm2 start ecosystem.config.js --env development",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "platform:start": "pnpm infra && pnpm pm2:start",
    "platform:stop": "pnpm pm2:stop && pnpm infra:stop",
    "cli": "node packages/kore-platform-cli/dist/index.js",
    "apx": "./apx",
    "up": "./apx up",
    "up:infra": "./apx up infra",
    "up:apps": "./apx up apps",
    "down": "./apx down",
    "restart": "./apx restart",
    "logs": "./apx logs",
    "status": "./apx status",
    "health": "./apx health",
    "doctor": "./apx doctor",
    "connectors:import-providers": "tsx scripts/import-nango-providers.ts",
    "connectors:discover-pieces": "tsx scripts/discover-activepieces.ts",
    "connectors:generate-catalog": "pnpm --filter @agent-platform/connectors generate-catalog",
    "connectors:fetch-icons": "tsx scripts/fetch-connector-icons.ts",
    "boundary-check": "depcruise apps/runtime/src apps/search-ai/src apps/search-ai-runtime/src apps/studio/src packages/shared/src packages/compiler/src packages/core/src --config .dependency-cruiser.cjs",
    "boundary-check:report": "depcruise apps/runtime/src apps/search-ai/src apps/search-ai-runtime/src apps/studio/src packages/shared/src packages/compiler/src packages/core/src --config .dependency-cruiser.cjs --output-type err-html > docs/boundary-report.html",
    "boundary-check:arch-ai": "depcruise apps/studio/src/app/api/arch-ai apps/studio/src/lib/arch-ai packages/arch-ai/src --config .dependency-cruiser.cjs",
    "audit:propagation:lint": "vitest run packages/shared-kernel/src/__tests__/propagation-audit-lint.test.ts",
    "audit:propagation:platform-lint": "vitest run packages/shared-kernel/src/__tests__/platform-propagation-audit-lint.test.ts",
    "manifest:generate": "tsx tools/agents/e2e-smoke/manifest-generator.ts > tools/agents/e2e-smoke/route-manifest.json",
    "e2e:smoke": "tsx tools/agents/e2e-smoke/run.ts",
    "e2e:cleanup-stale": "tsx tools/agents/e2e-smoke/cleanup-stale.ts",
    "audit:pre-commit": "tsx tools/agents/pre-commit-audit.ts",
    "review:multi": "tsx tools/agents/multi-review.ts",
    "arch:blueprint:battle": "tsx tools/arch-eval/blueprint-battle-test.ts",
    "arch:in-project:battle": "tsx tools/arch-eval/in-project-playbook.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@rollup/wasm-node": "4.60.1",
    "@swc/wasm": "1.15.26",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "dependency-cruiser": "^17.3.8",
    "husky": "^9.1.7",
    "ioredis": "5.9.3",
    "lint-staged": "^16.2.7",
    "mongodb": "^7.1.0",
    "pm2": "^7.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "@opensearch-project/opensearch": "^3.1.0",
    "aws4": "^1.13.2",
    "mongoose": "^8.23.0"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.15.2",
      "tar": ">=7.5.11",
      "express@4.22.1>path-to-regexp": "0.1.13",
      "router@2.2.0>path-to-regexp": "8.4.0",
      "@types/express": "^4.17.21",
      "@xmldom/xmldom": "0.8.13",
      "ajv": "8.18.0",
      "@eslint/eslintrc>ajv": "^6.14.0",
      "eslint>ajv": "^6.14.0",
      "fast-xml-parser": "5.7.0",
      "fast-xml-builder": "1.1.7",
      "minimatch": ">=10.2.1",
      "multer": ">=2.0.2",
      "ioredis": "5.9.3",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "nodemailer": ">=7.0.11",
      "katex": ">=0.16.10",
      "undici": "7.24.7",
      "socket.io-parser": ">=4.2.6",
      "protobufjs": "7.5.6",
      "picomatch@~2": ">=2.3.2",
      "picomatch@~4": ">=4.0.4",
      "basic-ftp": "5.3.1",
      "fast-uri": "3.1.2",
      "markdown-it": "14.1.1",
      "postcss": "8.5.10",
      "uuid": "14.0.0",
      "lodash": ">=4.18.1",
      "lodash-es": ">=4.18.1"
    },
    "patchedDependencies": {
      "@activepieces/piece-zendesk@0.2.7": "patches/@activepieces__piece-zendesk@0.2.7.patch"
    }
  },
  "config": {
    "mongodbMemoryServer": {
      "version": "7.0.20",
      "arch": "arm64"
    }
  }
}
