{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": ["src/**/*.ts", "test/**/*.ts", "src/**/generated/*.json"],
      "passThroughEnv": [
        "ANTHROPIC_API_KEY",
        "OPENAI_API_KEY",
        "LLM_API_KEY",
        "RUNTIME_TEST_LANE_TIMEOUT_MS"
      ]
    },
    "test:fast": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": ["src/**/*.ts", "test/**/*.ts", "src/**/generated/*.json"],
      "passThroughEnv": [
        "ANTHROPIC_API_KEY",
        "OPENAI_API_KEY",
        "LLM_API_KEY",
        "RUNTIME_TEST_LANE_TIMEOUT_MS"
      ]
    },
    "test:repro": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": ["src/**/*.repro.test.ts", "src/**/*.repro.test.tsx"],
      "passThroughEnv": [
        "ANTHROPIC_API_KEY",
        "OPENAI_API_KEY",
        "LLM_API_KEY",
        "RUNTIME_TEST_LANE_TIMEOUT_MS"
      ]
    },
    "test:smoke": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": ["src/**/*.ts", "test/**/*.ts", "src/**/generated/*.json"],
      "passThroughEnv": ["ANTHROPIC_API_KEY", "OPENAI_API_KEY", "LLM_API_KEY"]
    },
    "test:coverage": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.ts", "test/**/*.ts", "src/**/generated/*.json"],
      "passThroughEnv": ["ANTHROPIC_API_KEY", "OPENAI_API_KEY", "LLM_API_KEY"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:light": {
      "cache": false,
      "persistent": true
    },
    "dev:workflows": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "format:check": {
      "outputs": []
    },
    "boundary-check": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.ts"],
      "cache": false
    },
    "@agent-platform/studio#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../docs/reference/ABL_SPEC.md",
        "../../docs/reference/ABL_QUICK_REFERENCE.md",
        "../../tools/abl-docs/**/*.ts",
        "../../packages/compiler/src/platform/contracts/**/*.ts"
      ]
    },
    "@agent-platform/studio#build:docker": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "inputs": ["$TURBO_DEFAULT$", "../../docs/features/**/*.md", "../../docs/testing/**/*.md"]
    },
    "@agent-platform/admin#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@agent-platform/docs-internal#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../docs/reference/ABL_SPEC.md",
        "../../docs/reference/ABL_QUICK_REFERENCE.md",
        "../../tools/abl-docs/**/*.ts",
        "../../packages/compiler/src/platform/contracts/**/*.ts"
      ]
    },
    "@abl/compiler#test": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../docs/reference/**/*.md",
        "../../apps/docs-internal/content/abl-reference/**/*.mdx",
        "../../apps/docs-internal/content/guides/**/*.mdx",
        "../../apps/studio/content/abl-reference/**/*.mdx",
        "../../apps/studio/content/guides/**/*.mdx",
        "../../examples/**/*.abl",
        "../../examples/**/*.md"
      ],
      "passThroughEnv": ["ANTHROPIC_API_KEY", "OPENAI_API_KEY", "LLM_API_KEY"]
    },
    "@abl/compiler#test:fast": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../docs/reference/**/*.md",
        "../../apps/docs-internal/content/abl-reference/**/*.mdx",
        "../../apps/docs-internal/content/guides/**/*.mdx",
        "../../apps/studio/content/abl-reference/**/*.mdx",
        "../../apps/studio/content/guides/**/*.mdx",
        "../../examples/**/*.abl",
        "../../examples/**/*.md"
      ],
      "passThroughEnv": ["ANTHROPIC_API_KEY", "OPENAI_API_KEY", "LLM_API_KEY"]
    },
    "@abl/compiler#test:coverage": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../docs/reference/**/*.md",
        "../../apps/docs-internal/content/abl-reference/**/*.mdx",
        "../../apps/docs-internal/content/guides/**/*.mdx",
        "../../apps/studio/content/abl-reference/**/*.mdx",
        "../../apps/studio/content/guides/**/*.mdx",
        "../../examples/**/*.abl",
        "../../examples/**/*.md"
      ],
      "passThroughEnv": ["ANTHROPIC_API_KEY", "OPENAI_API_KEY", "LLM_API_KEY"]
    }
  }
}
