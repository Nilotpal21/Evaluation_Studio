AGENT: Order_Tracking
VERSION: "1.0"
DESCRIPTION: "Scripted order tracking agent with structured flow for lookup, status, shipping, and reorder"
GOAL: "Help customers look up orders, track shipping, manage delivery preferences, and reorder previous purchases"

PERSONA: |
  Efficient and detail-oriented order specialist.
  Provides clear, accurate status updates without unnecessary chatter.
  Proactively offers tracking details and delivery options.
  Empathetic when orders are delayed.

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Cannot modify order contents after placement"
  - "Cannot process refunds — routes to returns specialist"
  - "Cannot override shipping carrier decisions"
  - "Maximum 3 order lookup attempts per session"

# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATES — multi-channel order display
# ─────────────────────────────────────────────────────────────────────────────

TEMPLATES:
  order_status_card:
    DEFAULT: |
      Order: {{order_id}}
      Status: {{status}}
      Items: {{item_count}} item(s)
      Placed: {{placed_date}}
      {{#if tracking_number}}Tracking: {{tracking_number}}{{/if}}
      {{#if estimated_delivery}}Estimated Delivery: {{estimated_delivery}}{{/if}}

      What would you like to do?
      - Track shipping
      - Change delivery preferences
      - Reorder these items
    MARKDOWN: |
      ## Order {{order_id}} — {{status}}

      | Detail | Value |
      |--------|-------|
      | **Items** | {{item_count}} item(s) |
      | **Placed** | {{placed_date}} |
      {{#if tracking_number}}| **Tracking** | `{{tracking_number}}` |{{/if}}
      {{#if estimated_delivery}}| **Delivery** | {{estimated_delivery}} |{{/if}}
    HTML: |
      <div class="order-card" data-id="{{order_id}}">
        <h2>Order {{order_id}}</h2>
        <span class="status-badge">{{status}}</span>
        <p><strong>Items:</strong> {{item_count}}</p>
        <p><strong>Placed:</strong> {{placed_date}}</p>
        {{#if tracking_number}}<p><strong>Tracking:</strong> {{tracking_number}}</p>{{/if}}
        {{#if estimated_delivery}}<p><strong>Delivery:</strong> {{estimated_delivery}}</p>{{/if}}
        <div class="actions">
          <button data-action="track">Track Shipping</button>
          <button data-action="delivery_prefs">Delivery Preferences</button>
          <button data-action="reorder">Reorder</button>
        </div>
      </div>
    VOICE INSTRUCTIONS: "State the order ID, then current status. If there's a delivery estimate, read it clearly. Then offer options — track shipping, change delivery, or reorder."

  shipping_timeline:
    DEFAULT: |
      Shipping Status for {{tracking_number}}:
      Carrier: {{carrier}}
      Current Status: {{status}}
      Current Location: {{location}}

      Tracking History:
      {{#each history}}
      {{this.date}} — {{this.status}} ({{this.location}})
      {{/each}}
    MARKDOWN: |
      ## Shipping Timeline 📦

      **Carrier:** {{carrier}} | **Status:** {{status}}
      **Location:** {{location}}

      | Date | Status | Location |
      |------|--------|----------|
      {{#each history}}
      | {{this.date}} | {{this.status}} | {{this.location}} |
      {{/each}}
    HTML: |
      <div class="shipping-timeline">
        <h2>Shipping Timeline</h2>
        <p><strong>Carrier:</strong> {{carrier}} | <strong>Status:</strong> {{status}}</p>
        <div class="timeline">
          {{#each history}}
          <div class="timeline-event">
            <span class="date">{{this.date}}</span>
            <span class="status">{{this.status}}</span>
            <span class="location">{{this.location}}</span>
          </div>
          {{/each}}
        </div>
      </div>

  delivery_updated:
    DEFAULT: "Your delivery preference has been updated. {{new_instructions}}"
    MARKDOWN: "**Delivery updated!** ✅ {{new_instructions}}"
    HTML: "<div class='delivery-updated'><strong>Delivery updated!</strong> {{new_instructions}}</div>"
    VOICE INSTRUCTIONS: "Confirm the update clearly and read the new delivery instructions."

  reorder_confirmation:
    DEFAULT: |
      I've added the items from order {{original_order_id}} to your cart.
      Total: {{total}} {{currency}}
      Would you like to proceed to checkout?
    MARKDOWN: |
      ## Reorder Ready 🔄

      Items from order `{{original_order_id}}` added to your cart.
      **Total:** {{total}} {{currency}}

      Ready to checkout?
    HTML: |
      <div class="reorder-confirmation">
        <h2>Reorder Ready</h2>
        <p>Items from order {{original_order_id}} added to your cart.</p>
        <p><strong>Total:</strong> {{total}} {{currency}}</p>
        <button data-action="checkout">Proceed to Checkout</button>
      </div>

  order_not_found: "I couldn't find an order with that information. Please double-check and try again, or I can look it up by email address."

TOOLS:
  lookup_order(order_id: string, email: string) -> {order_id: string, status: string, items: object[], placed_date: string, estimated_delivery: string, tracking_number: string, item_count: number}
    description: "Look up an order by order ID or email address"

  get_shipping_details(tracking_number: string) -> {carrier: string, status: string, location: string, history: object[]}
    description: "Get detailed shipping and tracking information"

  request_delivery_update(order_id: string, preference: string) -> {confirmed: boolean, new_instructions: string}
    description: "Update delivery preferences — leave at door, hold at facility, or reschedule"

  reorder(order_id: string) -> {new_order_id: string, cart_items: object[], total: number, currency: string}
    description: "Add all items from a previous order to the cart for reorder"

# ─────────────────────────────────────────────────────────────────────────────
# FLOW — structured order tracking flow
# ─────────────────────────────────────────────────────────────────────────────

FLOW:
  entry_point: identify_order

  steps:
    - identify_order
    - lookup
    - show_status
    - shipping_details
    - delivery_preferences
    - reorder_flow
    - retry_or_exit

identify_order:
  GATHER:
    - order_id:
        prompt: "What's your order number? (Format: ORD-XXXXX) Or I can look it up by email."
        type: string
        required: false
    - email:
        prompt: "What email address did you use for the order?"
        type: string
        required: false
  THEN: lookup

lookup:
  CALL: lookup_order(order_id, email)
  ON_SUCCESS:
    SET: current_order = result
    SET: tracking_number = result.tracking_number
    THEN: show_status
  ON_FAIL:
    RESPOND: TEMPLATE(order_not_found)
    THEN: retry_or_exit

show_status:
  RESPOND: TEMPLATE(order_status_card)
  ON_INPUT:
    - IF: input contains "track" OR input contains "shipping"
      THEN: shipping_details
    - IF: input contains "delivery" OR input contains "change delivery" OR input contains "leave at door"
      THEN: delivery_preferences
    - IF: input contains "reorder" OR input contains "order again"
      THEN: reorder_flow
    - ELSE:
      THEN: complete

shipping_details:
  CALL: get_shipping_details(tracking_number)
  ON_SUCCESS:
    RESPOND: TEMPLATE(shipping_timeline)
    THEN: show_status
  ON_FAIL:
    RESPOND: "I'm unable to retrieve shipping details at the moment. Please try again later."
    THEN: show_status

delivery_preferences:
  GATHER:
    - delivery_preference:
        prompt: "How would you like your delivery handled? (leave at door, hold at facility, reschedule)"
        type: string
        required: true
  CALL: request_delivery_update(order_id, delivery_preference)
  ON_SUCCESS:
    RESPOND: TEMPLATE(delivery_updated)
    THEN: complete
  ON_FAIL:
    RESPOND: "I wasn't able to update your delivery preference. Would you like to try again or speak with a specialist?"
    THEN: show_status

reorder_flow:
  CALL: reorder(order_id)
  ON_SUCCESS:
    RESPOND: TEMPLATE(reorder_confirmation)
    THEN: complete
  ON_FAIL:
    RESPOND: "I wasn't able to set up the reorder. Some items may no longer be available."
    THEN: show_status

retry_or_exit:
  ON_INPUT:
    - IF: input contains "try again" OR input contains "yes"
      THEN: identify_order
    - ELSE:
      THEN: complete

CONSTRAINTS:
  - REQUIRE order_id matches "^ORD-[A-Z0-9]{5}$" OR email IS SET
    ON_FAIL: "Please provide a valid order number (format: ORD-XXXXX) or an email address."

  - REQUIRE lookup_attempts <= 3
    ON_FAIL: "I've been unable to find your order after several attempts. Let me connect you with a specialist who can help."

HANDOFF:
  - TO: Sales_Agent
    WHEN: reorder_ready == true AND user.ready_to_checkout == true
    CONTEXT:
      pass: [customer_id, cart_items, total]
      summary: "Customer reordering — cart ready for checkout"
    EXPECT_RETURN: false

  - TO: Returns_And_Refunds
    WHEN: intent.category == "return" OR intent.category == "refund"
    CONTEXT:
      pass: [customer_id, order_id, item_id]
      summary: "Customer wants to return or get refund for an item in this order"
    EXPECT_RETURN: false

COMPLETE:
  - WHEN: order_status_shown == true
    RESPOND: "Is there anything else I can help you with?"
