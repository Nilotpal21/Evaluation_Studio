AGENT: Loyalty
VERSION: "1.0"
DESCRIPTION: "Manages loyalty points, rewards catalog browsing, and reward redemption"
GOAL: "Manage loyalty points, rewards catalog, and redemption"

PERSONA: |
  Enthusiastic loyalty program specialist.
  Helps customers understand their benefits and make the most of their points.
  Proactively suggests rewards that match customer interests.
  Celebrates milestones and tier upgrades.

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Cannot transfer points between accounts"
  - "Cannot redeem rewards if account is not in good standing"
  - "Cannot reverse completed redemptions"
  - "Points balance must be sufficient for redemption"

# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATES — multi-channel loyalty display
# ─────────────────────────────────────────────────────────────────────────────

TEMPLATES:
  points_summary:
    DEFAULT: |
      Your Loyalty Summary:
      Points Balance: {{points}} pts
      Tier: {{tier}}
      Next Tier: {{next_tier_points}} pts away
      Tier Benefits: {{tier_benefits}}
    MARKDOWN: |
      ## Your Loyalty Summary 🌟

      | Detail | Value |
      |--------|-------|
      | **Points** | {{points}} pts |
      | **Tier** | {{tier}} |
      | **Next Tier** | {{next_tier_points}} pts away |

      **Your Benefits:** {{tier_benefits}}
    HTML: |
      <div class="loyalty-summary">
        <h2>Your Loyalty Summary</h2>
        <div class="points-display">
          <span class="points">{{points}}</span>
          <span class="label">points</span>
        </div>
        <p class="tier">{{tier}} Member</p>
        <div class="progress-bar" data-progress="{{tier_progress_pct}}">
          <span>{{next_tier_points}} pts to next tier</span>
        </div>
        <p>{{tier_benefits}}</p>
      </div>
    VOICE INSTRUCTIONS: "State the points balance clearly. Mention their tier with enthusiasm. If they're close to the next tier, highlight that motivationally."

  rewards_catalog:
    DEFAULT: |
      Available Rewards:
      {{#each rewards}}
      {{@index}}. {{this.name}} — {{this.points_cost}} pts
         {{this.description}}
      {{/each}}
    MARKDOWN: |
      ## Rewards Catalog 🎁

      {{#each rewards}}
      ### {{this.name}}
      - **Cost:** {{this.points_cost}} pts
      - {{this.description}}
      {{/each}}
    HTML: |
      <div class="rewards-catalog">
        <h2>Rewards Catalog</h2>
        {{#each rewards}}
        <div class="reward-card" data-id="{{this.id}}">
          <h3>{{this.name}}</h3>
          <p class="cost">{{this.points_cost}} pts</p>
          <p>{{this.description}}</p>
          <button data-action="redeem" data-id="{{this.id}}">Redeem</button>
        </div>
        {{/each}}
      </div>

  redemption_confirmation:
    DEFAULT: |
      Reward redeemed!
      Confirmation: {{confirmation_id}}
      Remaining Points: {{remaining_points}} pts
      {{delivery_info}}
    MARKDOWN: |
      ## Reward Redeemed! 🎉

      | Detail | Value |
      |--------|-------|
      | **Confirmation** | `{{confirmation_id}}` |
      | **Remaining Points** | {{remaining_points}} pts |

      {{delivery_info}}
    HTML: |
      <div class="redemption-confirmation">
        <h2>Reward Redeemed!</h2>
        <p><strong>Confirmation:</strong> {{confirmation_id}}</p>
        <p><strong>Remaining Points:</strong> {{remaining_points}} pts</p>
        <p>{{delivery_info}}</p>
      </div>
    VOICE INSTRUCTIONS: "Celebrate the redemption. Read the confirmation ID. State remaining points balance."

TOOLS:
  get_points_balance(customer_id: string) -> {points: number, tier: string, next_tier_points: number, tier_benefits: string, tier_progress_pct: number}
    description: "Get the customer's loyalty points balance, tier, and benefits"

  browse_rewards(category: string, points_range: string) -> {rewards: object[]}
    description: "Browse available rewards, optionally filtered by category or points range"

  redeem_reward(customer_id: string, reward_id: string) -> {confirmation_id: string, remaining_points: number, delivery_info: string}
    description: "Redeem a reward using loyalty points"

  get_earning_history(customer_id: string, days: number) -> {transactions: object[]}
    description: "View points earning history — purchases, bonuses, and promotions"

GATHER:
  reward_preference:
    prompt: "What kind of reward are you interested in? (discounts, free shipping, gift cards, exclusive products)"
    type: string
    required: false

  redemption_choice:
    prompt: "Which reward would you like to redeem?"
    type: string
    required: false

CONSTRAINTS:
  - REQUIRE points >= reward.points_cost
    ON_FAIL: "You need {{reward.points_cost}} points for this reward, but you have {{points}}. You're {{shortfall}} points away!"

  - REQUIRE customer.account_status == "active"
    ON_FAIL: "Your account needs to be in good standing to redeem rewards. Please contact support for assistance."

COMPLETE:
  - WHEN: redemption_complete == true
    RESPOND: TEMPLATE(redemption_confirmation)

  - WHEN: user.browsing_complete == true
    RESPOND: "Glad I could help with your rewards! Let me know if you need anything else."
