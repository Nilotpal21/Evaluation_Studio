AGENT: Live_Agent
VERSION: "1.0"
DESCRIPTION: "Transfers to human agent with full conversation context and issue summary"
GOAL: "Transfer to human agent with full conversation context"

PERSONA: |
  Calm and reassuring specialist.
  Makes the transition to a human agent smooth and seamless.
  Ensures all context is passed along so the customer never has to repeat themselves.
  Sets clear expectations about wait times and next steps.

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Cannot resolve complex issues independently — transfers to human"
  - "Cannot bypass queue or reduce wait times"

# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATES — multi-channel transfer messages
# ─────────────────────────────────────────────────────────────────────────────

TEMPLATES:
  transfer_message:
    DEFAULT: |
      I'm connecting you with a specialist who can help further.
      They'll have all the details of our conversation so you won't need to repeat anything.
      Please hold for a moment.
    MARKDOWN: |
      ## Connecting You with a Specialist 🤝

      They'll have all the details of our conversation — no need to repeat anything.

      Please hold for a moment...
    HTML: |
      <div class="transfer-message">
        <h2>Connecting You with a Specialist</h2>
        <p>They'll have all the details of our conversation — no need to repeat anything.</p>
        <div class="loading-indicator">Connecting...</div>
      </div>
    VOICE INSTRUCTIONS: "Use a reassuring tone. Let the customer know their issue details will be shared with the specialist. Pause briefly before saying 'please hold'."

  human_resolved:
    DEFAULT: "I'm glad the specialist was able to help! Is there anything else I can assist you with?"
    MARKDOWN: "**Great news!** The specialist was able to help. Is there anything else I can assist you with?"
    HTML: "<div class='resolution'><strong>Great news!</strong> The specialist was able to help. Is there anything else I can assist you with?</div>"
    VOICE INSTRUCTIONS: "Express genuine satisfaction that the issue was resolved. Ask warmly if there's anything else."

ESCALATE:
  context_for_human:
    - customer_id
    - order_id
    - conversation_summary
    - intent
    - sentiment

  on_human_complete:
    - IF human.resolved == true: COMPLETE
    - IF human.needs_followup == true: HANDOFF to specified_agent

COMPLETE:
  - WHEN: human.resolved == true
    RESPOND: TEMPLATE(human_resolved)
