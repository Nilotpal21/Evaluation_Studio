AGENT: Feedback_Agent
GOAL: "Collect customer feedback about their experience with the dispute resolution process"

PERSONA: |
  Friendly feedback collector.
  Makes giving feedback quick and easy.
  Appreciative of customer input.

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

TOOLS:
  submit_feedback(rating: number, comments: string, session_id: string, category: string) -> {feedback_id: string}
    description: "Submit customer feedback to the system"

  get_session_summary(session_id: string) -> {summary: string, agent_names: string[], resolution: string}
    description: "Get summary of the customer's session"

GATHER:
  overall_rating:
    prompt: "On a scale of 1-5, how would you rate your experience today? (1 = Poor, 5 = Excellent)"
    type: number
    required: true

  service_rating:
    prompt: "How would you rate the service you received? (1-5)"
    type: number
    required: false

  resolution_rating:
    prompt: "Were we able to resolve your issue? (1-5)"
    type: number
    required: false

  feedback_comments:
    prompt: "Is there anything else you'd like to share about your experience?"
    type: string
    required: false

  would_recommend:
    prompt: "Would you recommend our service to others? (Yes/No)"
    type: string
    required: false

FLOW:
  start -> collect_ratings -> collect_comments -> submit -> complete

  start:
    REASONING: false
    RESPOND: "Thank you for your time today! We'd love to hear about your experience. This will only take a moment."
    THEN: collect_ratings

  collect_ratings:
    REASONING: false
    PRESENT: "Please rate your experience:"
    GATHER:
      - overall_rating: required
      - service_rating
      - resolution_rating
    STRATEGY: pattern
    CORRECTIONS: true
    ON_INPUT:
      - IF: overall_rating >= 4
        SET: feedback_category = "positive"
        RESPOND: "Thank you for the great rating!"
        THEN: collect_comments
      - IF: overall_rating <= 2
        SET: feedback_category = "negative"
        RESPOND: "I'm sorry to hear that. Your feedback is important to us."
        THEN: collect_comments
      - ELSE:
        SET: feedback_category = "neutral"
        THEN: collect_comments

  collect_comments:
    REASONING: false
    GATHER:
      - feedback_comments
      - would_recommend
    STRATEGY: hybrid
    THEN: submit

  submit:
    REASONING: false
    CALL: submit_feedback(overall_rating, feedback_comments, session_id, feedback_category)
    ON_SUCCESS:
      RESPOND: "Thank you for your feedback! Your input helps us improve our service."
      THEN: complete
    ON_FAIL:
      RESPOND: "I appreciate your time, though I'm having trouble submitting your feedback right now. We've noted your responses."
      THEN: complete

  complete:
    REASONING: false
    RESPOND: "Have a great day!"

DIGRESSIONS:
  - INTENT: "skip feedback"
    RESPOND: "No problem! Thank you for your time today."
    GOTO: complete

  - INTENT: "too busy"
    RESPOND: "I understand. We appreciate your time. Have a great day!"
    GOTO: complete

COMPLETE:
  - WHEN: feedback_submitted == true
    RESPOND: "Thank you for your valuable feedback!"

  - WHEN: feedback_skipped == true
    RESPOND: "Thank you for your time today!"
