AGENT: Entity_Flow_Test
GOAL: "Process customer service requests by collecting structured information through guided steps."

ENTITIES:
  request_type:
    TYPE: enum
    VALUES: [REQ_REFUND, REQ_EXCHANGE, REQ_CANCEL, REQ_UPGRADE, REQ_COMPLAINT]
    SYNONYMS:
      REQ_REFUND: [refund, money back, get my money back, reimburse]
      REQ_EXCHANGE: [exchange, swap, switch, change my booking]
      REQ_CANCEL: [cancel, cancellation, cancel my trip]
      REQ_UPGRADE: [upgrade, change cabin, better seat, premium]
      REQ_COMPLAINT: [complaint, complain, bad experience, issue, problem]

  urgency_level:
    TYPE: enum
    VALUES: [URG_LOW, URG_MED, URG_HIGH, URG_CRITICAL]
    SYNONYMS:
      URG_LOW: [low, not urgent, whenever, no rush]
      URG_MED: [medium, normal, regular, moderate]
      URG_HIGH: [high, urgent, soon, asap, important]
      URG_CRITICAL: [critical, emergency, immediately, right now, very urgent]

  satisfaction_rating:
    TYPE: enum
    VALUES: [SAT_1, SAT_2, SAT_3, SAT_4, SAT_5]
    SYNONYMS:
      SAT_1: [terrible, awful, worst, 1 star, very bad]
      SAT_2: [bad, poor, disappointing, 2 stars]
      SAT_3: [okay, average, fine, 3 stars, alright]
      SAT_4: [good, nice, 4 stars, pretty good, satisfied]
      SAT_5: [excellent, amazing, perfect, 5 stars, great, wonderful]

  ticket_ref:
    TYPE: pattern
    PATTERN: "^TKT-[A-Z]{2}[0-9]{4}$"

ON_START:
  RESPOND: "Hello! Welcome to SkyWay Airlines customer service. How can I assist you today?"

PERSONA: |
  You are a customer service agent for SkyWay Airlines.
  Guide customers through the service request process step by step.
  Be empathetic and professional. Collect information in the order defined by each step.

TOOLS:
  lookup_booking(booking_ref: string) -> {status: string, route: string, date: string, cabin: string, passenger: string}
    Look up an existing booking by reference number

  process_refund(booking_ref: string, reason: string, amount: number) -> {refund_id: string, status: string, estimated_days: number}
    Process a refund for a booking

  submit_complaint(booking_ref: string, category: string, description: string, urgency: string) -> {ticket_id: string, status: string}
    Submit a formal complaint

FLOW:
  identify_customer:
    REASONING: false
    RESPOND: "Let me start by getting your contact details."
    GATHER:
      - contact_email:
          TYPE: email
          PROMPT: "What is your email address?"
          SENSITIVE: true
          SENSITIVE_DISPLAY: mask
          PII_TYPE: email
      - contact_phone:
          TYPE: phone
          PROMPT: "What is your phone number?"
          SENSITIVE: true
          SENSITIVE_DISPLAY: mask
          MASK_CONFIG:
            show_first: 0
            show_last: 4
            char: "*"
          PII_TYPE: phone
    THEN: collect_request

  collect_request:
    REASONING: false
    RESPOND: "Thank you. Now, what can I help you with today?"
    GATHER:
      - request:
          ENTITY_REF: request_type
          PROMPT: "What type of request do you have? (refund, exchange, cancel, upgrade, or complaint)"
      - urgency:
          ENTITY_REF: urgency_level
          PROMPT: "How urgent is this?"
      - booking_reference:
          TYPE: string
          PROMPT: "What is your booking reference number?"
    THEN: collect_details

  collect_details:
    REASONING: false
    RESPOND: "Let me get some more details about your request."
    GATHER:
      - incident_date:
          TYPE: date
          PROMPT: "When did this occur?"
      - wants_callback:
          TYPE: boolean
          PROMPT: "Would you like a callback about this?"
      - expected_amount:
          TYPE: currency
          PROMPT: "If this involves a refund, what amount are you expecting?"
      - num_affected:
          TYPE: number
          PROMPT: "How many passengers are affected?"
          DEFAULT: 1
      - description:
          TYPE: string
          PROMPT: "Please describe your issue in detail."
    THEN: process_request

  process_request:
    REASONING: true
    RESPOND: "Let me process your request now."
    CALL: lookup_booking
      WITH: booking_ref = booking_reference
    THEN: collect_feedback

  collect_feedback:
    REASONING: false
    RESPOND: "Before we finish, I'd like to collect your feedback."
    GATHER:
      - satisfaction:
          ENTITY_REF: satisfaction_rating
          PROMPT: "How would you rate your experience today? (1-5 stars)"
      - preferred_contact_time:
          TYPE: datetime
          PROMPT: "If we need to follow up, when is a good time to reach you?"
      - additional_notes:
          TYPE: string
          PROMPT: "Any additional comments?"
    THEN: complete

  complete:
    REASONING: true
    RESPOND: "Thank the customer and provide a summary of their request with next steps."

COMPLETE:
  - WHEN: all_fields_gathered == true
    RESPOND: "Your request has been processed. Here is a summary of what we discussed."
