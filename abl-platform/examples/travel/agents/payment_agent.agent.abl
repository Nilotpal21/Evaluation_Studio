AGENT: Payment_Agent
VERSION: "2.0"
DESCRIPTION: "Handles secure payment flow for travel bookings"
GOAL: "Guide customers through secure payment for their travel quotes — validate quote, initiate payment session, and confirm booking"

PERSONA: |
  Professional and reassuring payment specialist.
  Clear about what the customer is paying for and the total amount.
  Reassures customers about payment security.
  Never rushes the customer through payment.

EXECUTION:
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Cannot store or view full payment card details — handled by payment provider"
  - "Cannot apply discounts or modify pricing — quote is final"
  - "Cannot process payments for expired quotes"
  - "Cannot split payments across multiple methods"

# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATES — reusable messages for SDK and voice channels
# ─────────────────────────────────────────────────────────────────────────────

TEMPLATES:
  quote_verify_fail: "I couldn't verify your quote. Let me connect you with support."
  quote_saved_reminder: "No problem. Your quote is saved and valid for 24 hours. You can return anytime to complete your booking."
  confirm_pay_prompt: "Please confirm — would you like to proceed to payment? (yes/no)"
  payment_link: |
    Opening secure payment...
    Payment link: {{start_payment.payment_url}}
    This link expires in {{start_payment.expires_in}} minutes.
    Please complete your payment, and I'll confirm your booking once it's processed.
  payment_start_fail: "There was an issue starting the payment session. Let me try again."
  payment_pending: "Still waiting for your payment. Take your time — I'm here when you're ready."
  payment_check_fail: "I'm having trouble checking your payment status. Let me try again."
  booking_success: |
    Payment confirmed! Your booking is all set.
    Booking reference: **{{booking_reference}}**
    A confirmation email has been sent to your email address.
    Have a wonderful trip!
  payment_failed_msg: |
    It looks like the payment didn't go through. This could be due to:
    - Insufficient funds
    - Card declined by your bank
    - Session timeout

    Would you like to try again?
  quote_still_valid: "No problem. Your quote is still valid — you can return within 24 hours to try again."
  quote_expired_msg: |
    Unfortunately, your quote has expired. Prices are based on real-time availability and may have changed.
    Would you like me to run a fresh search?
  quote_expired_bye: "No problem. Feel free to come back anytime!"
  booking_confirmed_short: "Booking confirmed! Reference: {{booking_reference}}"
  quote_saved_short: "Your quote is saved for 24 hours."
  payment_processing_error: "Payment processing issue. Let me try again..."
  payment_slow: "The payment system is slow. Please wait..."

TOOLS:
  validate_quote(quote_id: string) -> {valid: boolean, expired: boolean, total: number, currency: string, items: object[], valid_until: datetime}
    description: "Validate that a quote is still active and hasn't expired"

  start_payment(quote_id: string) -> {payment_session_id: string, payment_url: string, expires_in: number}
    description: "Initialize a secure payment session — returns a URL for the payment form"

  check_payment_status(payment_session_id: string) -> {status: string, confirmed: boolean, transaction_id: string, booking_reference: string}
    description: "Check whether payment has been completed"

  send_confirmation(booking_reference: string, email: string) -> {sent: boolean}
    description: "Send booking confirmation email to the customer"

MEMORY:
  session:
    - quote_id
      TYPE: string
      DESCRIPTION: "The quote ID being paid for, passed from Sales_Agent"
    - payment_session_id
      TYPE: string
      DESCRIPTION: "Active payment session ID from the payment provider"
    - payment_status
      TYPE: string
      DESCRIPTION: "Current payment status — pending, confirmed, or failed"
    - booking_reference
      TYPE: string
      DESCRIPTION: "Booking reference number after successful payment"

# ─────────────────────────────────────────────────────────────────────────────
# FLOW — validate → present summary → pay → confirm
# ─────────────────────────────────────────────────────────────────────────────

FLOW:
  entry_point: validate
  steps:
    - validate
    - present_summary
    - initiate_payment
    - await_payment
    - payment_confirmed
    - payment_failed
    - quote_expired

validate:
  REASONING: false
  CALL: validate_quote(quote_id)
  ON_SUCCESS:
    - IF: validate_quote.valid == true
      THEN: present_summary
    - IF: validate_quote.expired == true
      THEN: quote_expired
  ON_FAIL:
    RESPOND: TEMPLATE(quote_verify_fail)
    THEN: escalate

present_summary:
  REASONING: false
  PRESENT: |
    Here's your booking summary:

    {{#each validate_quote.items}}
    - {{this.description}}: {{this.price}} {{../validate_quote.currency}}
    {{/each}}

    **Total: {{validate_quote.total}} {{validate_quote.currency}}**

    Quote valid until: {{validate_quote.valid_until}}
  GATHER:
    - proceed_to_pay: required
  ON_INPUT:
    - IF: input contains "yes" OR input contains "proceed" OR input contains "pay"
      THEN: initiate_payment
    - IF: input contains "no" OR input contains "cancel"
      RESPOND: TEMPLATE(quote_saved_reminder)
      THEN: complete
    - ELSE:
      RESPOND: TEMPLATE(confirm_pay_prompt)
      THEN: present_summary

initiate_payment:
  REASONING: false
  CALL: start_payment(quote_id)
  ON_SUCCESS:
    SET: payment_session_id = start_payment.payment_session_id
    RESPOND: TEMPLATE(payment_link)
    THEN: await_payment
  ON_FAIL:
    RESPOND: TEMPLATE(payment_start_fail)
    THEN: initiate_payment

await_payment:
  REASONING: false
  CALL: check_payment_status(payment_session_id)
  ON_SUCCESS:
    - IF: check_payment_status.confirmed == true
      SET: booking_reference = check_payment_status.booking_reference
      THEN: payment_confirmed
    - IF: check_payment_status.status == "pending"
      RESPOND: TEMPLATE(payment_pending)
      THEN: await_payment
    - IF: check_payment_status.status == "failed"
      THEN: payment_failed
  ON_FAIL:
    RESPOND: TEMPLATE(payment_check_fail)
    THEN: await_payment

payment_confirmed:
  REASONING: false
  CALL: send_confirmation(booking_reference, customer_email)
  RESPOND: TEMPLATE(booking_success)
  THEN: complete

payment_failed:
  REASONING: false
  RESPOND: TEMPLATE(payment_failed_msg)
  GATHER:
    - retry_payment: required
  ON_INPUT:
    - IF: input contains "yes" OR input contains "try" OR input contains "again"
      THEN: initiate_payment
    - IF: input contains "no" OR input contains "cancel"
      RESPOND: TEMPLATE(quote_still_valid)
      THEN: complete
    - ELSE:
      THEN: payment_failed

quote_expired:
  REASONING: false
  RESPOND: TEMPLATE(quote_expired_msg)
  GATHER:
    - search_again: required
  ON_INPUT:
    - IF: input contains "yes" OR input contains "search"
      THEN: handoff_to_sales
    - ELSE:
      RESPOND: TEMPLATE(quote_expired_bye)
      THEN: complete

# ─────────────────────────────────────────────────────────────────────────────
# CONSTRAINTS
# ─────────────────────────────────────────────────────────────────────────────

CONSTRAINTS:
  pre_payment:
    - REQUIRE validate_quote.valid == true
      ON_FAIL: "This quote is no longer valid. Let me help you search again."

    - REQUIRE validate_quote.expired == false
      ON_FAIL: "Your quote has expired. Prices may have changed — would you like a fresh search?"

HANDOFF:
  - TO: Sales_Agent
    WHEN: quote_expired == true AND user.wants_new_search == true
    CONTEXT:
      pass: [previous_search_criteria, destination, origin]
      summary: "Quote expired, customer wants fresh search"
    RETURN: false

  - TO: Live_Agent_Transfer
    WHEN: user.requests_agent == true OR payment_failures >= 3
    CONTEXT:
      pass: [quote_id, payment_session_id, conversation_summary]
      summary: "Customer needs help with payment"
    RETURN: false

COMPLETE:
  - WHEN: booking_reference IS SET
    RESPOND: TEMPLATE(booking_confirmed_short)

  - WHEN: user.cancelled_payment == true
    RESPOND: TEMPLATE(quote_saved_short)

ON_ERROR:
  payment_error:
    RESPOND: TEMPLATE(payment_processing_error)
    RETRY: 1
    THEN: CONTINUE

  tool_timeout:
    RESPOND: TEMPLATE(payment_slow)
    RETRY: 2
    THEN: ESCALATE
