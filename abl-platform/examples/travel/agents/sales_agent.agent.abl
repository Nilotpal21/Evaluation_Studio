AGENT: Sales_Agent
VERSION: "2.0"
DESCRIPTION: "Helps customers search and book new travel — flights, hotels, and bundled packages"
GOAL: "Help customers find the best travel options within their budget, generate quotes valid for 24 hours, and hand off to secure payment when ready"

PERSONA: |
  Enthusiastic and knowledgeable travel sales specialist for our travel service.
  Finds the best value for the customer's budget without being pushy.
  Presents options clearly with prices, and proactively suggests packages when they save money.
  Transparent about availability windows and price guarantees.

EXECUTION:
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Cannot guarantee prices after search results expire"
  - "Cannot book flights departing within 2 hours"
  - "Origin and destination must be different cities"
  - "Cannot process payments directly — hands off to secure payment flow"
  - "Cannot create custom multi-city itineraries — routes to human specialist"

# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATES — reusable messages for SDK and voice channels
# ─────────────────────────────────────────────────────────────────────────────

TEMPLATES:
  booking_confirmed:
    DEFAULT: |
      Your booking is confirmed! You'll receive a confirmation email shortly.
      Booking reference: {{booking_reference}}
      Have a wonderful trip!
    MARKDOWN: |
      ## Booking Confirmed! ✅

      | Detail | Value |
      |--------|-------|
      | **Reference** | `{{booking_reference}}` |
      | **Total** | {{total_price}} {{currency}} |

      You'll receive a confirmation email shortly. Have a wonderful trip!
    HTML: |
      <div class="booking-confirmation">
        <h2>Booking Confirmed!</h2>
        <p><strong>Reference:</strong> {{booking_reference}}</p>
        <p><strong>Total:</strong> {{total_price}} {{currency}}</p>
        <p>You'll receive a confirmation email shortly.</p>
      </div>
    VOICE INSTRUCTIONS: "Announce the confirmation with enthusiasm. Read the booking reference slowly, letter by letter. Pause before wishing them a great trip."

  quote_saved:
    DEFAULT: |
      Your quote has been saved and emailed to you.
      Quote ID: {{quote_id}}
      Total: {{total_price}} {{currency}}
      Valid until: {{valid_until}}
      You can return anytime within 24 hours to complete your booking.
    MARKDOWN: |
      ## Quote Saved 📋

      | Detail | Value |
      |--------|-------|
      | **Quote ID** | `{{quote_id}}` |
      | **Total** | {{total_price}} {{currency}} |
      | **Valid until** | {{valid_until}} |

      You can return anytime within 24 hours to complete your booking.
    HTML: |
      <div class="quote-card">
        <h2>Quote Saved</h2>
        <p><strong>Quote ID:</strong> {{quote_id}}</p>
        <p><strong>Total:</strong> {{total_price}} {{currency}}</p>
        <p><strong>Valid until:</strong> {{valid_until}}</p>
        <p>Return within 24 hours to complete your booking.</p>
      </div>
    VOICE INSTRUCTIONS: "Read the quote details clearly. Emphasize the 24-hour validity window."

  search_results:
    DEFAULT: |
      I found {{result_count}} options for you.
      Here are the top matches:
      {{#each results}}
      {{this.rank}}. {{this.name}} — {{this.price}} {{this.currency}}
         {{this.details}}
      {{/each}}
      Would you like more details on any of these, or shall I search with different criteria?
    MARKDOWN: |
      ## Search Results ({{result_count}} found) 🔍

      {{#each results}}
      ### {{this.rank}}. {{this.name}}
      - **Price:** {{this.price}} {{this.currency}}
      - **Details:** {{this.details}}
      - **Rating:** {{this.rating}}
      {{/each}}

      Would you like more details or different search criteria?
    HTML: |
      <div class="search-results">
        <h2>Search Results ({{result_count}} found)</h2>
        {{#each results}}
        <div class="result-card" data-id="{{this.id}}">
          <h3>{{this.name}}</h3>
          <p class="price">{{this.price}} {{this.currency}}</p>
          <p class="details">{{this.details}}</p>
          <button data-action="select" data-id="{{this.id}}">Select</button>
          <button data-action="details" data-id="{{this.id}}">Details</button>
        </div>
        {{/each}}
      </div>
    VOICE INSTRUCTIONS: "Read the top 3 results. For each, say the name, price, and one key detail. Pause between results. After the third, ask if they want to hear more."

  search_timeout: "The search is taking longer than usual. Let me try again..."
  search_error: "I had trouble searching. Let me try a different approach."
  payment_start_error: "There was an issue starting the payment. Please try again in a moment."

TOOLS:
  # ── HTTP tools with CONTEXT_ACCESS (declarative) ──────────────────────────
  # These tools auto-receive session context and can write back state updates.

  search_flights(origin: string, destination: string, departure_date: string, return_date: string, passengers: number) -> {flights: Flight[], search_id: string, expires_at: datetime}
    description: "Search for available flights between two cities"
    CONTEXT_ACCESS:
      READ: [preferred_currency, loyalty_tier]
      WRITE: [search_expires_at, user.preferred_destinations, popular_destinations]
    store_result: false
    on_result:
      SET:
        flight_count = result.flights.length
        flight_search_id = result.search_id
        search_expires_at = result.expires_at
        cheapest_flight_price = result.flights.0.price
        search_status = 'completed'
    on_error:
      SET:
        search_status = 'failed'
        search_error_msg = result.error

  search_hotels(destination: string, checkin: string, checkout: string, guests: number, rooms: number) -> {hotels: Hotel[], search_id: string, expires_at: datetime}
    description: "Search for available hotels at a destination"
    CONTEXT_ACCESS:
      READ: [preferred_currency, loyalty_tier]
      WRITE: []
    store_result: false
    on_result:
      SET:
        hotel_count = result.hotels.length
        hotel_search_id = result.search_id
        cheapest_hotel_price = result.hotels.0.price
    on_error:
      SET:
        search_status = 'failed'

  search_packages(origin: string, destination: string, departure_date: string, return_date: string, travelers: number) -> {packages: Package[], search_id: string, expires_at: datetime}
    description: "Search for bundled flight+hotel packages (often cheaper than booking separately)"
    CONTEXT_ACCESS:
      READ: [preferred_currency, loyalty_tier, active_promotions]
      WRITE: []
    store_result: false
    on_result:
      SET:
        package_count = result.packages.length
        cheapest_package_price = result.packages.0.price

  check_availability(product_id: string, date: string) -> {available: boolean, price: number, seats_left: number, currency: string}
    description: "Check real-time availability and current price for a specific flight or hotel"
    on_result:
      SET:
        selected_price = result.price
        is_available = result.available
        seats_remaining = result.seats_left

  create_quote(items: object[], customer_email: string) -> {quote_id: string, total: number, currency: string, valid_until: datetime, breakdown: object[]}
    description: "Create a price quote valid for 24 hours — emailed to customer"
    on_result:
      SET:
        quote_id = result.quote_id
        total_price = result.total
        currency = result.currency
        quote_valid_until = result.valid_until
        quote_created = true

  start_payment(quote_id: string) -> {payment_session_id: string, payment_url: string, expires_in: number}
    description: "Initialize secure payment session for a quote"

  check_flight_departure(flight_id: string) -> {departure_time: datetime, hours_until_departure: number}
    description: "Check how soon a flight departs — blocks booking if within 2 hours"

  # ── Sandbox tool (implementation in Project Tools) ─────────────────────────
  # Code tools automatically get the `memory` API injected — no config needed.
  # memory.get_content / memory.set_content / memory.delete_content
  # Scope is auto-resolved from MEMORY declarations below.
  # See examples/travel/tools/sales_tools.md for implementation reference.

  build_search_summary(search_type: string) -> object
    description: "Build a personalized search summary using memory API — combines user preferences, active promotions, and session search results"

GATHER:
  destination:
    prompt: "Where would you like to travel to?"
    type: string
    required: true

  origin:
    prompt: "Where will you be traveling from?"
    type: string
    required: true

  departure_date:
    prompt: "When would you like to depart?"
    type: date
    required: true

  return_date:
    prompt: "When would you like to return? (Leave blank for one-way)"
    type: date
    required: false

  num_travelers:
    prompt: "How many travelers?"
    type: number
    required: true
    default: 1

  budget:
    prompt: "Do you have a budget in mind? (per person or total)"
    type: number
    required: false

  travel_type:
    prompt: "Are you looking for flights only, hotels only, or a package deal?"
    type: string
    required: false

# ─────────────────────────────────────────────────────────────────────────────
# MEMORY — 3-scope model: session (in-memory), user (per-user DB), project (shared DB)
# ─────────────────────────────────────────────────────────────────────────────

MEMORY:
  session:
    - search_results
      TYPE: object
      DESCRIPTION: "Latest search results from flight, hotel, or package queries"
    - selected_items
      TYPE: object[]
      DESCRIPTION: "Items the customer has selected for quoting"
    - quote_id
      TYPE: string
      DESCRIPTION: "Active quote identifier for the current booking"
    - search_expires_at
      TYPE: datetime
      DESCRIPTION: "When the current search results expire and need refreshing"
    - quote_created
      TYPE: boolean
      DESCRIPTION: "Whether a quote has been successfully created in this session"
    - preferred_currency
      TYPE: string
      DESCRIPTION: "User's preferred display currency for search results"
    - loyalty_tier
      TYPE: string
      DESCRIPTION: "User's loyalty program tier for pricing"
    - last_search_summary
      TYPE: object
      DESCRIPTION: "Personalized search summary built by sandbox tool"

  persistent:
    # ── User-scoped (per-user, private) ──────────────────────────────────────
    - PATH: user.preferred_destinations
      SCOPE: user
      ACCESS: readwrite
      TYPE: array
      DESCRIPTION: "Destinations this user has searched or booked before"
    - PATH: user.travel_preferences
      SCOPE: user
      ACCESS: readwrite
      TYPE: object
      DESCRIPTION: "Learned preferences — destinations, traveler count, budget range"
    - PATH: user.loyalty_tier
      SCOPE: user
      ACCESS: read
      TYPE: string
      DESCRIPTION: "Loyalty tier from CRM — read-only, managed externally"

    # ── Project-scoped (shared across all users) ─────────────────────────────
    - PATH: active_promotions
      SCOPE: project
      ACCESS: read
      TYPE: array
      DESCRIPTION: "Current promotions available to all customers — managed by ops team"
    - PATH: business_config
      SCOPE: project
      ACCESS: read
      TYPE: object
      DESCRIPTION: "Shared business configuration — search limits, supported currencies, etc."
    - PATH: popular_destinations
      SCOPE: project
      ACCESS: readwrite
      TYPE: array
      DESCRIPTION: "Trending destinations updated from aggregate search data"

  remember:
    - WHEN quote_created == true
      STORE: {destination: destination, travelers: num_travelers} -> user.travel_preferences
      TTL: 90d
    # Persist user destinations after search completes (context_updates sets the session value, REMEMBER persists to DB)
    - WHEN search_status == 'completed'
      STORE: user.preferred_destinations -> user.preferred_destinations
      TTL: 90d
    # Persist popular destinations after search (project-scoped — routes to project FactStore)
    - WHEN search_status == 'completed'
      STORE: popular_destinations -> popular_destinations
      TTL: 90d

  recall:
    - ON: session:start
      ACTION: inject_context
      PATHS: [user.preferred_destinations, user.loyalty_tier, active_promotions]
    - ON: tool:search_flights:after
      ACTION: inject_context
      PATHS: [user.travel_preferences]
    - ON: tool:search_hotels:after
      ACTION: inject_context
      PATHS: [user.travel_preferences]
    - ON: agent:Payment_Agent:before
      ACTION: inject_context
      PATHS: [user.travel_preferences]

# ─────────────────────────────────────────────────────────────────────────────
# CONSTRAINTS — business rules (flat, auto-guarded)
# ─────────────────────────────────────────────────────────────────────────────

CONSTRAINTS:
  # Origin and destination must be different cities (auto-guarded when not set)
  - REQUIRE destination != origin
    ON_FAIL: "Your destination must be different from your origin city. Please choose a different destination."

  # Cannot book flights within 2 hours of departure
  - REQUIRE check_flight_departure.hours_until_departure > 2
    ON_FAIL: "Unfortunately, flights departing within 2 hours cannot be booked online. Would you like to search for later flights?"

  # Must have availability confirmed before booking
  - REQUIRE check_availability.available == true
    ON_FAIL: "This option is no longer available. Let me search for alternatives."

  # Budget check (soft — warn, don't block)
  - WARN total_price <= budget OR budget == null
    ON_FAIL: "This exceeds your budget of {{budget}}. Would you like to see cheaper options or proceed anyway?"

  # Search results expire
  - REQUIRE search_expires_at > now
    ON_FAIL: "Your search results have expired. Let me run a fresh search with current prices."

# ─────────────────────────────────────────────────────────────────────────────
# HANDOFFS
# ─────────────────────────────────────────────────────────────────────────────

HANDOFF:
  # Complex/custom itineraries go to human travel specialist
  - TO: Live_Agent_Transfer
    WHEN: is_complex_itinerary == true OR user.needs_custom_package == true
    CONTEXT:
      pass: [search_criteria, destination, origin, departure_date, return_date, num_travelers, budget, conversation_summary]
      summary: "Customer needs custom itinerary beyond automated search — multi-city, special requirements, or complex routing"
    RETURN: false

  # Payment handoff
  - TO: Payment_Agent
    WHEN: quote_id IS SET AND user.ready_to_pay == true
    CONTEXT:
      pass: [quote_id, total_price, quote_breakdown, customer_email]
      summary: "Customer ready to pay for quote {{quote_id}} — total {{total_price}}"
    RETURN: true
    ON_RETURN: "booking_confirmed"

  # Customer wants to speak to human
  - TO: Live_Agent_Transfer
    WHEN: user.requests_agent == true
    CONTEXT:
      pass: [search_criteria, conversation_summary]
      summary: "Customer requesting human assistance during travel search"
    RETURN: false

# ─────────────────────────────────────────────────────────────────────────────
# ESCALATION
# ─────────────────────────────────────────────────────────────────────────────

ESCALATE:
  triggers:
    - WHEN: search_failures >= 3
      REASON: "Multiple search failures — possible system issue"
      PRIORITY: high

    - WHEN: user.frustration_detected == true
      REASON: "Customer showing frustration during search"
      PRIORITY: high
      TAGS: [sentiment, retention]

  context_for_human:
    - search_criteria
    - destination
    - budget
    - conversation_history

  on_human_complete:
    - IF human.resolved == true: COMPLETE
    - IF human.booked == true: CONTINUE

# ─────────────────────────────────────────────────────────────────────────────
# COMPLETION
# ─────────────────────────────────────────────────────────────────────────────

COMPLETE:
  - WHEN: payment_confirmed == true
    RESPOND: TEMPLATE(booking_confirmed)

  - WHEN: quote_created == true AND user.ready_to_pay == false
    RESPOND: TEMPLATE(quote_saved)

ON_ERROR:
  tool_timeout:
    RESPOND: TEMPLATE(search_timeout)
    RETRY: 2
    THEN: CONTINUE

  tool_error:
    RESPOND: TEMPLATE(search_error)
    RETRY: 1
    THEN: CONTINUE

  payment_error:
    RESPOND: TEMPLATE(payment_start_error)
    RETRY: 1
    THEN: CONTINUE
