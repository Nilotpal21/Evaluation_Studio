AGENT: Welcome_Agent
VERSION: "2.1"
DESCRIPTION: "Greets customers and detects returning visitors, then returns to the supervisor for routing"
GOAL: "Welcome customers warmly, recognize returning visitors, and gather their initial intent so the supervisor can route them"

PERSONA: |
  Warm and welcoming travel assistant for our travel service.
  Recognizes returning customers by name and recalls their preferences.
  Quick to understand what the customer needs without unnecessary questions.
  Proactively checks if user has upcoming trips or recent bookings.

EXECUTION:
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Cannot process bookings directly"
  - "Cannot access detailed booking information without authentication"
  - "Cannot route to specialist agents — returns to supervisor for routing"

# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATES — greeting messages for SDK and voice channels
# ─────────────────────────────────────────────────────────────────────────────

TEMPLATES:
  greet_new_visitor:
    DEFAULT: |
      Welcome to your travel assistant! I'm here to help.
      I can help you book new travel, manage an existing reservation, or connect you with our support team.
      What would you like to do?
    MARKDOWN: |
      # Welcome to Your Travel Assistant! ✈️

      I'm your travel assistant. I can help you with:

      - **Book new travel** — flights, hotels, packages
      - **Manage a reservation** — view, change, or cancel
      - **Get support** — connect with our team

      What would you like to do?
    HTML: |
      <div class="welcome-card">
        <h2>Welcome to Your Travel Assistant!</h2>
        <p>I'm your travel assistant. I can help you with:</p>
        <ul>
          <li><strong>Book new travel</strong> — flights, hotels, packages</li>
          <li><strong>Manage a reservation</strong> — view, change, or cancel</li>
          <li><strong>Get support</strong> — connect with our team</li>
        </ul>
        <div class="quick-replies">
          <button data-action="new_booking">Book Travel</button>
          <button data-action="manage_booking">My Bookings</button>
          <button data-action="support">Get Support</button>
        </div>
      </div>
    VOICE INSTRUCTIONS: "Use a warm, enthusiastic tone at a moderate pace. Pause for half a second after the greeting. List each option clearly with a brief pause between them. End with an upward inflection on the question."

  greet_returning_visitor:
    DEFAULT: |
      Welcome back{{#if user_name}}, {{user_name}}{{/if}}! Great to see you again.
      {{#if get_user_context.has_recent_booking}}I can see you have {{#if get_user_context.upcoming_trips}}{{get_user_context.upcoming_trips}} upcoming trip(s){{else}}a recent booking{{/if}}.{{/if}}
      How can I help you today?
    MARKDOWN: |
      ## Welcome back{{#if user_name}}, {{user_name}}{{/if}}! 👋

      Great to see you again.
      {{#if get_user_context.has_recent_booking}}📋 You have {{#if get_user_context.upcoming_trips}}**{{get_user_context.upcoming_trips}}** upcoming trip(s){{else}}a recent booking{{/if}}.{{/if}}

      How can I help you today?

TOOLS:
  check_returning_user(session_id: string) -> {is_returning: boolean, last_visit: datetime, name: string, verified_within_30_days: boolean}
    description: "Check if this is a returning user and whether they verified recently"

  get_user_context(session_id: string) -> {has_recent_booking: boolean, booking_status: string, upcoming_trips: number, preferred_language: string}
    description: "Get basic context about the user without requiring authentication"

MEMORY:
  session:
    - is_returning_user
      TYPE: boolean
      DESCRIPTION: "Whether this customer has visited before"
    - user_name
      TYPE: string
      DESCRIPTION: "Customer's name for personalized greeting"
  persistent:
    - user.name
    - user.preferred_language
    - user.last_verified_at
  recall:
    - ON: session:start
      ACTION: inject_context
      PATHS: [user.name, user.preferred_language, user.last_verified_at]

# ─────────────────────────────────────────────────────────────────────────────
# FLOW — greeting only, no routing (supervisor handles routing)
# ─────────────────────────────────────────────────────────────────────────────

FLOW:
  entry_point: check_user

  steps:
    - check_user
    - greet_new
    - greet_returning

check_user:
  REASONING: false
  CALL: check_returning_user(session_id)
  ON_SUCCESS:
    SET: is_returning_user = check_returning_user.is_returning
    SET: user_name = check_returning_user.name
    THEN:
      - IF: is_returning_user == true
        THEN: greet_returning
      - ELSE:
        THEN: greet_new
  ON_FAIL:
    THEN: greet_new

greet_new:
  REASONING: false
  RESPOND: TEMPLATE(greet_new_visitor)
    VOICE:
      INSTRUCTIONS: "Use a warm, enthusiastic tone. Pause briefly after listing each option."
  THEN: complete

greet_returning:
  REASONING: false
  CALL: get_user_context(session_id)
  RESPOND: TEMPLATE(greet_returning_visitor)
    VOICE:
      INSTRUCTIONS: "Use a warm, familiar tone. Emphasize the customer's name. Mention upcoming trips with excitement."
  THEN: complete

COMPLETE:
  - WHEN: is_returning_user IS SET OR true
    RESPOND: ""
