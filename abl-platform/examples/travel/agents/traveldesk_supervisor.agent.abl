SUPERVISOR: TravelDesk_Supervisor
VERSION: "2.0"
DESCRIPTION: "Top-level orchestrator for the virtual travel booking assistant"
GOAL: "Route customers to the right specialist — booking, sales, support, or human agent — with full context preservation"

PERSONA: |
  Professional travel booking assistant for our travel service.
  Friendly, efficient, and helpful. Never keeps the customer waiting.
  Recognizes returning visitors and adapts tone accordingly.
  Routes requests to the right specialist quickly and transparently.

EXECUTION:
  temperature: 0.3
  max_tokens: 1500
  max_iterations: 5
  inline_gather: true
  pipeline:
    enabled: true
    mode: sequential
    model: qwen35-a3b-35b
    shortCircuit:
      enabled: true
      confidenceThreshold: 0.85

LIMITATIONS:
  - "Cannot make bookings or process payments directly"
  - "Cannot access or modify user account information directly"
  - "Cannot provide specific prices without checking live availability"
  - "Must not share personal information about other customers"
  - "Cannot override system policies or grant special exceptions"

# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATES — reusable messages for SDK and voice channels
# ─────────────────────────────────────────────────────────────────────────────

TEMPLATES:
  welcome: |
    Welcome! I'm your travel assistant.
    I can help you search and book flights, hotels, or packages — manage an existing booking — or connect you with our support team.
    What can I help you with today?
  handoff_success: "I've connected you with the right specialist."
  session_goodbye: "Thank you for using our travel service. Have a great trip!"
  routing_error: "I'm having trouble understanding your request. Let me connect you with someone who can help."
  agent_unavailable_msg: "That service is temporarily unavailable. Let me try an alternative."
  timeout_msg: "I apologize for the delay. Let me try again."

# ─────────────────────────────────────────────────────────────────────────────
# ON_START — greet immediately without waiting for user input
# ─────────────────────────────────────────────────────────────────────────────

ON_START:
  RESPOND: TEMPLATE(welcome)

MEMORY:
  session:
    - current_intent
      TYPE: string
      DESCRIPTION: "The detected intent category for the current user message"
    - routing_history
      TYPE: object[]
      DESCRIPTION: "History of agent handoffs in this session for loop detection"
    - conversation_context
      TYPE: object
      DESCRIPTION: "Accumulated context from the conversation for handoff summaries"
    - handoff_count
      TYPE: number
      DESCRIPTION: "Number of agent handoffs in this session"
    - user_name
      TYPE: string
      DESCRIPTION: "Customer's name if provided or recalled from persistent memory"
    - user_language
      TYPE: string
      DESCRIPTION: "Customer's preferred language for communication"
    - user_id
      TYPE: string
      DESCRIPTION: "Authenticated user identifier for account-scoped operations"
    - conversation_summary
      TYPE: string
      DESCRIPTION: "Running summary of the conversation for context-preserving handoffs"
    - session_context
      TYPE: object
      DESCRIPTION: "Current session state snapshot passed to child agents on handoff"
    - booking_context
      TYPE: object
      DESCRIPTION: "Active booking details including reference, status, and itinerary"
    - transfer_reason
      TYPE: string
      DESCRIPTION: "Why the customer is being transferred to a human agent"
    - search_context
      TYPE: object
      DESCRIPTION: "Travel search parameters including origin, destination, dates, and passengers"
    - user_preferences
      TYPE: object
      DESCRIPTION: "Customer travel preferences such as seat class, airline, hotel rating"
    - budget
      TYPE: string
      DESCRIPTION: "Customer's stated budget or price range for the trip"
    - auth_token
      TYPE: string
      DESCRIPTION: "Authentication token for the verified user session"
    - return_to
      TYPE: string
      DESCRIPTION: "Agent name to route back to after authentication completes"
    - last_message
      TYPE: string
      DESCRIPTION: "The most recent user message for intent reclassification"
  persistent:
    - user.preferred_agent
    - user.language
    - user.last_verified_at
    - user.name
  remember:
    - WHEN: user_name IS SET
      STORE: user_name -> user.name
    - WHEN: user_language IS SET
      STORE: user_language -> user.language
  recall:
    - ON: session:start
      ACTION: inject_context
      PATHS: [user.name, user.language, user.preferred_agent, user.last_verified_at]

# ─────────────────────────────────────────────────────────────────────────────
# ROUTING — ordered by priority (highest first)
# ─────────────────────────────────────────────────────────────────────────────

HANDOFF:
  # P1 — Immediate human escalation (frustration, complaint, explicit request)
  - TO: Live_Agent_Transfer
    WHEN: intent.category == "escalation" OR user.wants_human_agent == true OR user.frustration_detected == true
    CONTEXT:
      pass: [user_id, conversation_summary, transfer_reason, booking_context]
      summary: "User requests human assistance or is showing frustration"
    RETURN: false

  # P2 — Complaint (always goes to human, critical priority)
  - TO: Live_Agent_Transfer
    WHEN: intent.category == "complaint"
    CONTEXT:
      pass: [user_id, conversation_summary, booking_context]
      summary: "Customer complaint — critical priority"
    RETURN: false

  # P3 — Farewell / end conversation
  - TO: Farewell_Agent
    WHEN: intent.category == "farewell"
    CONTEXT:
      pass: [session_context, conversation_summary]
      summary: "User ending conversation"
    RETURN: false

  # P4 — Manage existing booking (requires auth gate)
  - TO: Authentication_Agent
    WHEN: user.is_authenticated == false AND intent.category == "manage_existing_booking"
    CONTEXT:
      pass: [session_context, return_to]
      summary: "User needs to authenticate to manage booking"
      grant_memory: [user.last_verified_at]
    RETURN: true
    ON_RETURN: "route_to_booking_manager"

  - TO: Booking_Manager
    WHEN: user.is_authenticated == true AND intent.category == "manage_existing_booking"
    CONTEXT:
      pass: [user_id, booking_context, auth_token]
      summary: "Authenticated user managing their reservation"
    RETURN: false

  # P5 — New bookings and travel search
  - TO: Sales_Agent
    WHEN: intent.category == "new_booking" OR intent.category == "travel_search"
    CONTEXT:
      pass: [search_context, user_preferences, budget]
      summary: "User looking to book new travel"
    RETURN: false

  # P6 — Pure greeting
  - TO: Welcome_Agent
    WHEN: intent.category == "greeting" AND NOT intent.has_specific_request
    CONTEXT:
      pass: [session_context]
      summary: "User greeting"
    RETURN: true
    ON_RETURN: "await_next_request"

  # P7 — Fallback for unclear intents
  - TO: Fallback_Handler
    WHEN: intent.unclear == true OR intent.confidence < 0.5
    CONTEXT:
      pass: [session_context, last_message]
      summary: "Need clarification on user intent"
    RETURN: true
    ON_RETURN: "reclassify_intent"

# ─────────────────────────────────────────────────────────────────────────────
# ESCALATION — system-level triggers
# ─────────────────────────────────────────────────────────────────────────────

ESCALATE:
  triggers:
    - WHEN: routing_failures >= 3
      REASON: "Multiple routing failures — system issue"
      PRIORITY: high

    - WHEN: user.frustration_detected == true
      REASON: "User showing signs of frustration"
      PRIORITY: high
      TAGS: [sentiment, retention]

    - WHEN: intent.category == "complaint"
      REASON: "Customer complaint requires immediate attention"
      PRIORITY: critical
      TAGS: [complaint]

    - WHEN: handoff_count >= 4
      REASON: "Customer bounced between too many agents"
      PRIORITY: high
      TAGS: [ux_failure]

  context_for_human:
    - user_id
    - conversation_history
    - routing_history
    - last_intent

  on_human_complete:
    - IF human.resolved == true: COMPLETE
    - IF human.needs_agent == true: HANDOFF to specified_agent

# ─────────────────────────────────────────────────────────────────────────────
# ERROR HANDLING
# ─────────────────────────────────────────────────────────────────────────────

ON_ERROR:
  routing_failure:
    RESPOND: TEMPLATE(routing_error)
    RETRY: 1
    THEN: HANDOFF Live_Agent_Transfer

  agent_unavailable:
    RESPOND: TEMPLATE(agent_unavailable_msg)
    RETRY: 2
    THEN: ESCALATE

  timeout:
    RESPOND: TEMPLATE(timeout_msg)
    RETRY: 1
    THEN: CONTINUE

COMPLETE:
  - WHEN: handoff_successful == true
    RESPOND: TEMPLATE(handoff_success)

  - WHEN: user.session_ended == true
    RESPOND: TEMPLATE(session_goodbye)
