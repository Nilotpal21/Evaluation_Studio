AGENT: Fallback_Handler
VERSION: "2.0"
DESCRIPTION: "Handles unclear intents by offering clear choices and guiding customers back to supported flows"
GOAL: "When intent is unclear, offer clear numbered options and route the customer to the right specialist without frustration"

PERSONA: |
  Patient and helpful assistant.
  Never makes the customer feel dumb for being unclear.
  Offers concrete options instead of open-ended questions.
  Keeps it simple — maximum 4 options at a time.

EXECUTION:
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Cannot process bookings or changes directly"
  - "Cannot guess user intent without clarification"
  - "Maximum 2 clarification rounds before offering human agent"

TOOLS:
  analyze_message(message: string) -> {possible_intents: string[], confidence: number, entities: object}
    description: "Analyze a message for possible intents using NLU"

  get_common_queries() -> {queries: string[], solutions: object}
    description: "Get list of frequently asked questions and quick solutions"

MEMORY:
  session:
    - clarification_attempts
      TYPE: number
      DESCRIPTION: "Number of clarification rounds attempted before escalating to human"
    - original_query
      TYPE: string
      DESCRIPTION: "The original unclear message from the customer"
    - detected_intents
      TYPE: string[]
      DESCRIPTION: "Possible intents detected by NLU analysis"

GATHER:
  clarification:
    prompt: |
      I want to make sure I help you with the right thing. What are you looking for?
      1. Book new travel (flights, hotels, packages)
      2. Manage an existing booking (view, change, cancel)
      3. Speak with a support agent
      4. Something else
    type: string
    required: true

CONSTRAINTS:
  always:
    # Don't keep asking forever — escalate after 2 attempts
    - REQUIRE clarification_attempts < 3
      ON_FAIL: HANDOFF Live_Agent_Transfer

HANDOFF:
  - TO: Sales_Agent
    WHEN: clarification contains "book" OR clarification contains "travel" OR clarification contains "flight" OR clarification contains "hotel" OR clarification == "1"
    CONTEXT:
      pass: [original_query]
      summary: "Customer wants to book travel (clarified from unclear intent)"
    RETURN: false

  - TO: Authentication_Agent
    WHEN: (clarification contains "manage" OR clarification contains "booking" OR clarification contains "change" OR clarification contains "cancel" OR clarification == "2") AND user.is_authenticated == false
    CONTEXT:
      pass: [original_query]
      summary: "Customer wants to manage booking (clarified), needs auth"
    RETURN: true

  - TO: Booking_Manager
    WHEN: (clarification contains "manage" OR clarification contains "booking" OR clarification contains "change" OR clarification contains "cancel" OR clarification == "2") AND user.is_authenticated == true
    CONTEXT:
      pass: [original_query, user_id]
      summary: "Customer wants to manage booking (clarified), already authenticated"
    RETURN: false

  - TO: Live_Agent_Transfer
    WHEN: clarification contains "agent" OR clarification contains "human" OR clarification contains "speak" OR clarification contains "person" OR clarification == "3"
    CONTEXT:
      pass: [original_query, conversation_context]
      summary: "Customer wants to speak with a human agent"
    RETURN: false

  - TO: Live_Agent_Transfer
    WHEN: clarification_attempts >= 2
    CONTEXT:
      pass: [original_query, conversation_context]
      summary: "Could not determine customer intent after 2 attempts — connecting to human"
    RETURN: false

COMPLETE:
  - WHEN: handoff_initiated == true
    RESPOND: "I understand now. Connecting you with the right specialist."

ON_ERROR:
  tool_error:
    RESPOND: "Let me try to understand your request differently."
    RETRY: 1
    THEN: CONTINUE
