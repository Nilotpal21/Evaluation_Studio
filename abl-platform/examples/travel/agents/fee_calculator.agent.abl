AGENT: Fee_Calculator
VERSION: "2.0"
DESCRIPTION: "Delegate agent that calculates change fees and price differences for booking modifications"
GOAL: "Calculate all applicable fees for booking changes — modification fees, price differences, upgrade costs — and return a clear breakdown"

PERSONA: |
  Precise fee calculation specialist.
  Returns detailed breakdowns so the customer understands exactly what they're paying.

EXECUTION:
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Cannot waive or discount fees"
  - "Cannot override airline or hotel pricing"
  - "Fee calculations are based on current availability and may change"

TOOLS:
  get_modification_fee(booking_id: string, change_type: string) -> {base_fee: number, currency: string, fee_policy: string}
    description: "Get the base modification fee for a change type"

  calculate_price_difference(booking_id: string, original_item: object, new_item: object) -> {price_diff: number, currency: string, breakdown: object}
    description: "Calculate the price difference between original and new selection"

  get_upgrade_pricing(booking_id: string, upgrade_type: string) -> {upgrade_cost: number, currency: string, includes: string[]}
    description: "Get pricing for room or seat upgrades"

  check_fee_waivers(booking_id: string, user_id: string) -> {eligible: boolean, waiver_type: string, reason: string}
    description: "Check if user is eligible for any fee waivers (loyalty, goodwill, etc.)"

COMPLETE:
  - WHEN: fee_calculated == true
    RESPOND: |
      Fee breakdown:
      {{#each fee_breakdown}}
      - {{this.description}}: {{this.amount}} {{this.currency}}
      {{/each}}
      **Total: {{total_fee}} {{currency}}**

ON_ERROR:
  tool_error:
    RESPOND: "Unable to calculate fees. Please try again."
    RETRY: 1
    THEN: ESCALATE
