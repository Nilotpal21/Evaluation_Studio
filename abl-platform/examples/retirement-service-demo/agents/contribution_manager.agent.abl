AGENT: Contribution_Manager
VERSION: "1.0"
DESCRIPTION: "Handles IRA contribution room checks and demo contribution scheduling"
GOAL: "Check IRA limits for tax year 2026 and schedule a clean demo contribution when it fits"

PERSONA: |
  Precise contribution specialist.
  Explains limits clearly, confirms what account is being used, and only
  schedules a contribution when the user request fits the demo rules.

LIMITATIONS:
  - "Uses demo-safe 2026 IRA rules only"
  - "Does not determine deductibility, eligibility, or tax filing strategy"
  - "Routes over-limit or exception cases to an advisor callback"

TOOLS:
  extract_contribution_amount(text: string) -> {amountFound: boolean, amount?: number, amountDisplay?: string}
    description: "Extract a likely contribution amount from the user's original request when one was explicitly provided"
  check_ira_limits(contribution_year: string, age: number, planned_amount: number, existing_amount?: number, account_type?: string) -> {contributionYear: string, annualLimit: number, annualLimitDisplay: string, remainingRoom: number, remainingRoomDisplay: string, roomAfterPlanned: number, roomAfterPlannedDisplay: string, withinLimit: boolean, ageBandLabel: string, plannedAmountDisplay: string, overLimitAmountDisplay: string, guidance: string}
    description: "Calculate the applicable IRA limit and remaining demo room for a planned contribution"
  execute_contribution(account_id: string, amount: number, contribution_year: string, schedule_date?: string) -> {success: boolean, confirmationId: string, accountId: string, accountName: string, amountDisplay: string, scheduledFor: string, scheduledForLabel: string, contributionYear: string, summary: string}
    description: "Create a demo contribution confirmation for the selected IRA account"

GATHER:
  investor_age:
    prompt: "How old will the investor be on December 31, 2026?"
    type: number
    required: true
    validate: min(18)
    retry_prompt: "Please enter an age of 18 or older for this retirement contribution demo."
    max_retries: 2

  planned_amount:
    prompt: "How much would you like to contribute for tax year 2026?"
    type: number
    required: true
    validate: min(1)
    retry_prompt: "Please enter a contribution amount greater than $0."
    max_retries: 2

MEMORY:
  session:
    - customer_id
      TYPE: string
      DESCRIPTION: "Demo customer id for the current household"
    - customer_name
      TYPE: string
      DESCRIPTION: "Display name for the demo customer"
    - selected_account_id
      TYPE: string
      DESCRIPTION: "IRA account selected for the contribution flow"
    - selected_account_label
      TYPE: string
      DESCRIPTION: "Human-readable label for the selected account"
    - contribution_year
      TYPE: string
      DESCRIPTION: "Contribution year under discussion"
    - investor_age
      TYPE: number
      DESCRIPTION: "Investor age on December 31 of the contribution year"
    - planned_amount
      TYPE: number
      DESCRIPTION: "Amount the user wants to contribute in the demo"
    - schedule_requested
      TYPE: boolean
      DESCRIPTION: "Whether the user explicitly asked to schedule the contribution"
  persistent:
    - PATH: workflow.customer_id
      SCOPE: execution_tree
      ACCESS: read
      TYPE: string
    - PATH: workflow.customer_name
      SCOPE: execution_tree
      ACCESS: read
      TYPE: string
    - PATH: workflow.default_account_id
      SCOPE: execution_tree
      ACCESS: readwrite
      TYPE: string

FLOW:
  entry_point: init

  steps:
    - init
    - choose_traditional_input
    - choose_saved_traditional
    - choose_default_roth
    - detect_schedule_request
    - default_schedule_request
    - capture_requested_amount
    - ask_age
    - resolve_planned_amount
    - resolve_missing_amount
    - prepare_limit_only
    - ask_amount
    - evaluate_limit
    - schedule_contribution
    - present_scheduled
    - share_annual_limit
    - share_limit
    - over_limit_review

  init:
    REASONING: false
    SET:
      customer_id = "demo-vanguard-household"
      customer_name = "Vanguard client"
      contribution_year = "2026"
      workflow.customer_id = "demo-vanguard-household"
      workflow.customer_name = "Vanguard client"
    THEN: choose_traditional_input

  choose_traditional_input:
    REASONING: false
    CHECK: LOWER(input) contains "traditional"
    ON_FAIL: choose_saved_traditional
    SET:
      selected_account_id = "ira-trad-001"
      selected_account_label = "Traditional IRA"
      workflow.default_account_id = "ira-trad-001"
    THEN: detect_schedule_request

  choose_saved_traditional:
    REASONING: false
    CHECK: workflow.default_account_id == "ira-trad-001"
    ON_FAIL: choose_default_roth
    SET:
      selected_account_id = "ira-trad-001"
      selected_account_label = "Traditional IRA"
      workflow.default_account_id = "ira-trad-001"
    THEN: detect_schedule_request

  choose_default_roth:
    REASONING: false
    SET:
      selected_account_id = "ira-roth-001"
      selected_account_label = "Roth IRA"
      workflow.default_account_id = "ira-roth-001"
    THEN: detect_schedule_request

  detect_schedule_request:
    REASONING: false
    CHECK: LOWER(input) contains "schedule" OR LOWER(input) contains "deposit" OR LOWER(input) contains "go ahead" OR LOWER(input) contains "make"
    ON_FAIL: default_schedule_request
    SET: schedule_requested = true
    THEN: capture_requested_amount

  default_schedule_request:
    REASONING: false
    SET: schedule_requested = false
    THEN: capture_requested_amount

  capture_requested_amount:
    REASONING: false
    CALL: extract_contribution_amount
      WITH:
        text: _raw_input
      AS: requested_amount_result
    THEN: ask_age

  ask_age:
    REASONING: false
    PRESENT: "How old will the investor be on December 31, 2026?"
    GATHER:
      - investor_age: required
    STRATEGY: hybrid
    THEN: resolve_planned_amount

  resolve_planned_amount:
    REASONING: false
    CHECK: requested_amount_result.amountFound == true
    ON_FAIL: resolve_missing_amount
    SET: planned_amount = requested_amount_result.amount
    THEN: evaluate_limit

  resolve_missing_amount:
    REASONING: false
    CHECK: schedule_requested == true
    ON_FAIL: prepare_limit_only
    THEN: ask_amount

  prepare_limit_only:
    REASONING: false
    CALL: check_ira_limits
      WITH:
        contribution_year: contribution_year
        age: investor_age
        planned_amount: 0
        existing_amount: 0
        account_type: selected_account_label
      AS: contribution_check
    ON_SUCCESS:
      THEN: share_annual_limit

  ask_amount:
    REASONING: false
    PRESENT: "How much would you like to contribute for tax year 2026?"
    GATHER:
      - planned_amount: required
    STRATEGY: hybrid
    THEN: evaluate_limit

  evaluate_limit:
    REASONING: false
    CALL: check_ira_limits
      WITH:
        contribution_year: contribution_year
        age: investor_age
        planned_amount: planned_amount
        existing_amount: 0
        account_type: selected_account_label
      AS: contribution_check
    ON_RESULT:
      - IF: contribution_check.withinLimit == true AND schedule_requested == true
        THEN: schedule_contribution
      - IF: contribution_check.withinLimit == true
        THEN: share_limit
      - ELSE:
        THEN: over_limit_review

  schedule_contribution:
    REASONING: false
    CALL: execute_contribution
      WITH:
        account_id: selected_account_id
        amount: planned_amount
        contribution_year: contribution_year
        schedule_date: "2026-04-21"
      AS: contribution_execution
    ON_RESULT:
      - IF: contribution_execution.success == true
        THEN: present_scheduled
      - ELSE:
        RESPOND: "I confirmed the contribution fits, but I couldn't finalize the demo confirmation right now."
        THEN: COMPLETE

  present_scheduled:
    REASONING: false
    RESPOND: |
      {{contribution_execution.summary}}
      Applicable limit: {{contribution_check.annualLimitDisplay}} for {{contribution_check.ageBandLabel}}.
      Remaining demo room after this contribution: {{contribution_check.roomAfterPlannedDisplay}}.
    THEN: COMPLETE

  share_annual_limit:
    REASONING: false
    RESPOND: |
      For tax year {{contribution_check.contributionYear}}, the annual IRA limit for {{contribution_check.ageBandLabel}} is {{contribution_check.annualLimitDisplay}}.
      Current demo room before any new contribution is {{contribution_check.remainingRoomDisplay}} for the {{selected_account_label}}.
      If you want to test or schedule a specific amount next, ask with the amount you have in mind.
    THEN: COMPLETE

  share_limit:
    REASONING: false
    RESPOND: |
      For tax year {{contribution_check.contributionYear}}, the annual IRA limit for {{contribution_check.ageBandLabel}} is {{contribution_check.annualLimitDisplay}}.
      A planned contribution of {{contribution_check.plannedAmountDisplay}} to the {{selected_account_label}} is within that limit.
      Demo remaining room after this contribution: {{contribution_check.roomAfterPlannedDisplay}}.
      If you want, I can also schedule that contribution in the demo flow.
    THEN: COMPLETE

  over_limit_review:
    REASONING: false
    RESPOND: |
      The planned contribution of {{contribution_check.plannedAmountDisplay}} is above the remaining demo room for tax year {{contribution_check.contributionYear}}.
      Over-limit amount: {{contribution_check.overLimitAmountDisplay}}.
      I packaged demo follow-up with the IRA Servicing queue so a specialist can review the exception.
    THEN: COMPLETE
