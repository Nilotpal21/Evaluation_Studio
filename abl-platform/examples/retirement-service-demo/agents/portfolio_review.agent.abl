AGENT: Portfolio_Review
VERSION: "1.0"
DESCRIPTION: "Reviews demo household retirement accounts and position snapshots"
GOAL: "Summarize the most relevant retirement account and tee up the next best action"

PERSONA: |
  Clear portfolio specialist for a high-trust wealth experience.
  Highlights the account the user likely cares about, explains what is in it,
  and naturally bridges to contributions or rollover work.

LIMITATIONS:
  - "Uses a curated demo household instead of live market data"
  - "Does not rebalance or trade"
  - "Does not provide individualized investment advice"

TOOLS:
  get_household_accounts(customer_id: string) -> {customerId: string, accounts: array, householdSummary: string}
    description: "Return the demo Vanguard household account list and a top-line summary"
  get_portfolio_snapshot(account_id: string) -> {accountId: string, accountName: string, accountType: string, balanceDisplay: string, topPositionsText: string, allocationNote: string, nextStep: string}
    description: "Return the demo position snapshot for the selected account"

MEMORY:
  session:
    - customer_id
      TYPE: string
      DESCRIPTION: "Demo customer id for the current household"
    - customer_name
      TYPE: string
      DESCRIPTION: "Display name for the demo customer"
    - selected_account_id
      TYPE: string
      DESCRIPTION: "Account selected for the portfolio review"
    - selected_account_label
      TYPE: string
      DESCRIPTION: "Human-readable label for the selected account"
  persistent:
    - PATH: workflow.customer_id
      SCOPE: execution_tree
      ACCESS: read
      TYPE: string
    - PATH: workflow.customer_name
      SCOPE: execution_tree
      ACCESS: read
      TYPE: string
    - PATH: workflow.default_account_id
      SCOPE: execution_tree
      ACCESS: readwrite
      TYPE: string

FLOW:
  entry_point: init

  steps:
    - init
    - choose_brokerage
    - choose_employer_plan
    - choose_traditional_ira
    - choose_saved_brokerage
    - choose_saved_employer_plan
    - choose_saved_traditional_ira
    - choose_default_roth
    - fetch_accounts
    - fetch_snapshot
    - present_review

  init:
    REASONING: false
    SET:
      customer_id = "demo-vanguard-household"
      customer_name = "Vanguard client"
      workflow.customer_id = "demo-vanguard-household"
      workflow.customer_name = "Vanguard client"
    THEN: choose_brokerage

  choose_brokerage:
    REASONING: false
    CHECK: LOWER(input) contains "brokerage" OR LOWER(input) contains "joint"
    ON_FAIL: choose_employer_plan
    SET:
      selected_account_id = "brokerage-001"
      selected_account_label = "Joint Brokerage"
      workflow.default_account_id = "brokerage-001"
    THEN: fetch_accounts

  choose_employer_plan:
    REASONING: false
    CHECK: LOWER(input) contains "401" OR LOWER(input) contains "401k" OR LOWER(input) contains "employer"
    ON_FAIL: choose_traditional_ira
    SET:
      selected_account_id = "401k-001"
      selected_account_label = "Former Employer 401(k)"
      workflow.default_account_id = "401k-001"
    THEN: fetch_accounts

  choose_traditional_ira:
    REASONING: false
    CHECK: LOWER(input) contains "traditional"
    ON_FAIL: choose_saved_brokerage
    SET:
      selected_account_id = "ira-trad-001"
      selected_account_label = "Traditional IRA"
      workflow.default_account_id = "ira-trad-001"
    THEN: fetch_accounts

  choose_saved_brokerage:
    REASONING: false
    CHECK: workflow.default_account_id == "brokerage-001"
    ON_FAIL: choose_saved_employer_plan
    SET:
      selected_account_id = "brokerage-001"
      selected_account_label = "Joint Brokerage"
      workflow.default_account_id = "brokerage-001"
    THEN: fetch_accounts

  choose_saved_employer_plan:
    REASONING: false
    CHECK: workflow.default_account_id == "401k-001"
    ON_FAIL: choose_saved_traditional_ira
    SET:
      selected_account_id = "401k-001"
      selected_account_label = "Former Employer 401(k)"
      workflow.default_account_id = "401k-001"
    THEN: fetch_accounts

  choose_saved_traditional_ira:
    REASONING: false
    CHECK: workflow.default_account_id == "ira-trad-001"
    ON_FAIL: choose_default_roth
    SET:
      selected_account_id = "ira-trad-001"
      selected_account_label = "Traditional IRA"
      workflow.default_account_id = "ira-trad-001"
    THEN: fetch_accounts

  choose_default_roth:
    REASONING: false
    SET:
      selected_account_id = "ira-roth-001"
      selected_account_label = "Roth IRA"
      workflow.default_account_id = "ira-roth-001"
    THEN: fetch_accounts

  fetch_accounts:
    REASONING: false
    CALL: get_household_accounts
      WITH:
        customer_id: customer_id
      AS: accounts_result
    ON_RESULT:
      - IF: accounts_result.accounts != null AND LENGTH(accounts_result.accounts) > 0
        THEN: fetch_snapshot
      - ELSE:
        RESPOND: "I couldn't load the demo household accounts right now."
        THEN: COMPLETE

  fetch_snapshot:
    REASONING: false
    CALL: get_portfolio_snapshot
      WITH:
        account_id: selected_account_id
      AS: snapshot_result
    ON_RESULT:
      - IF: snapshot_result.accountId != null
        THEN: present_review
      - ELSE:
        RESPOND: "I found the household, but I couldn't load the position snapshot for that account right now."
        THEN: COMPLETE

  present_review:
    REASONING: false
    RESPOND: |
      I pulled the {{snapshot_result.accountName}} snapshot for {{customer_name}}.
      Balance: {{snapshot_result.balanceDisplay}}
      Top holdings: {{snapshot_result.topPositionsText}}
      Why it matters: {{snapshot_result.allocationNote}}
      Household context: {{accounts_result.householdSummary}}
      Natural next step: {{snapshot_result.nextStep}}
    THEN: COMPLETE
