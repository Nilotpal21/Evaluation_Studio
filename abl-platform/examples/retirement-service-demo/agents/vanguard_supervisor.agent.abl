SUPERVISOR: Vanguard_Supervisor
VERSION: "1.0"
DESCRIPTION: "Top-level orchestrator for the Vanguard multi-agent retirement-service demo"
GOAL: |
  Route investors to the right specialist for portfolio review, contribution
  management, rollover coordination, or market and policy insights while
  preserving account context across turns.

EXECUTION:
  temperature: 0.2
  max_tokens: 1200
  max_iterations: 5
  inline_gather: true
  pipeline:
    enabled: true
    mode: sequential
    shortCircuit:
      enabled: true
      confidenceThreshold: 0.85

PERSONA: |
  Calm, executive-ready service coordinator for a Vanguard digital experience.
  Routes quickly, preserves context across specialists, and keeps every answer
  clear enough for a live customer demo.

LIMITATIONS:
  - "Does not perform portfolio analysis, contribution execution, or rollover orchestration directly"
  - "Does not provide personalized tax, legal, or investment advice"
  - "Escalates exception-heavy cases through specialist flows"

MEMORY:
  session:
    - default_account_id
    - last_portfolio_summary
    - last_rollover_case_id
  persistent:
    - PATH: workflow.customer_id
      SCOPE: execution_tree
      ACCESS: readwrite
      TYPE: string
    - PATH: workflow.customer_name
      SCOPE: execution_tree
      ACCESS: readwrite
      TYPE: string
    - PATH: workflow.default_account_id
      SCOPE: execution_tree
      ACCESS: readwrite
      TYPE: string

ON_START:
  - SET: workflow.customer_id = "demo-vanguard-household"
  - SET: workflow.customer_name = "Vanguard client"

HANDOFF:
  - TO: Rollover_Specialist
    WHEN: LOWER(input) contains "rollover" OR LOWER(input) contains "transfer" OR LOWER(input) contains "old 401" OR LOWER(input) contains "old 403" OR LOWER(input) contains "advisor" OR LOWER(input) contains "human" OR LOWER(input) contains "specialist"
    CONTEXT:
      pass: [default_account_id]
      summary: "User wants rollover coordination or a specialist callback"
      history: summary_only
      memory_grants:
        - path: workflow.customer_id
          access: read
        - path: workflow.customer_name
          access: read
        - path: workflow.default_account_id
          access: readwrite
    RETURN: false

  - TO: Market_Insights
    WHEN: LOWER(input) contains "market" OR LOWER(input) contains "fund" OR LOWER(input) contains "outlook" OR LOWER(input) contains "policy" OR LOWER(input) contains "deadline" OR LOWER(input) contains "april" OR LOWER(input) contains "insight"
    CONTEXT:
      pass: [default_account_id]
      summary: "User wants market or policy insight"
      history: summary_only
      memory_grants:
        - path: workflow.customer_id
          access: read
        - path: workflow.customer_name
          access: read
        - path: workflow.default_account_id
          access: read
    RETURN: true
    ON_RETURN:
      ACTION: continue

  - TO: Contribution_Manager
    WHEN: LOWER(input) contains "contribut" OR LOWER(input) contains "deposit" OR LOWER(input) contains "limit" OR LOWER(input) contains "room" OR LOWER(input) contains "schedule"
    CONTEXT:
      pass: [default_account_id]
      summary: "User wants contribution guidance or execution"
      history: summary_only
      memory_grants:
        - path: workflow.customer_id
          access: read
        - path: workflow.customer_name
          access: read
        - path: workflow.default_account_id
          access: readwrite
    RETURN: false

  - TO: Portfolio_Review
    WHEN: LOWER(input) contains "portfolio" OR LOWER(input) contains "balance" OR LOWER(input) contains "position" OR LOWER(input) contains "ira" OR LOWER(input) contains "account" OR LOWER(input) contains "401"
    CONTEXT:
      pass: [default_account_id]
      summary: "User wants a portfolio or account review"
      history: summary_only
      memory_grants:
        - path: workflow.customer_id
          access: read
        - path: workflow.customer_name
          access: read
        - path: workflow.default_account_id
          access: readwrite
    RETURN: true
    ON_RETURN:
      ACTION: continue
      MAP: { selected_account_id: default_account_id, household_summary: last_portfolio_summary }

ON_ERROR:
  routing_failure:
    RESPOND: "I can help with portfolio reviews, contributions, rollovers, or broader market and policy questions."
    RETRY: 0
    THEN: COMPLETE

COMPLETE:
  - WHEN: true
    RESPOND: ""
