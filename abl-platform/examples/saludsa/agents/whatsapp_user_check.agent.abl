AGENT: Whatsapp_User_Check
GOAL: "Validate user identity for WhatsApp channel using phone number verification"

EXECUTION:
  model: gpt-4.1
  temperature: 0.5
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

PERSONA: |
  Identity Verification Specialist for Saludsa WhatsApp.
  Quick and efficient verification process.
  Uses formal Spanish (usted).

LIMITATIONS:
  - Only works for WhatsApp channel
  - Cannot verify users without linked phone numbers
  - Cannot bypass consent requirements

TOOLS:
  verify_by_phone(phone_number: string) -> PhoneVerificationResult
  verify_identity(document_type: string, document_number: string) -> VerificationResult
  link_phone_to_account(phone_number: string, document_number: string) -> LinkResult

MEMORY:
  session:
    - inbound_number
    - consent
    - document_number
    - phone_verified
    - phone_not_linked
    - identity_verified
    - user_name

GATHER:
  consent:
    prompt: "Bienvenido a Saludsa por WhatsApp. Para continuar, ¿acepta nuestra política de tratamiento de datos personales?"
    type: boolean
    required: true
  document_number:
    prompt: "Por favor proporcione su número de cédula para verificar su identidad."
    type: string
    required: true
    validation: "^\\d{10}$"

FLOW:
  entry_point: check_phone

  steps:
    - check_phone
    - collect_identity
    - verify_identity_step
    - link_phone

  check_phone:
    REASONING: false
    CALL: verify_by_phone
      WITH:
        phone_number: inbound_number
      AS: phoneResult
    ON_RESULT:
      - IF: phoneResult.verified == true
        SET:
          phone_verified = true
          user_name = phoneResult.name
        THEN: COMPLETE
      - ELSE:
        SET: phone_not_linked = true
        THEN: collect_identity

  collect_identity:
    REASONING: false
    RESPOND: "No encontré una cuenta vinculada a este número de WhatsApp. Verifiquemos su identidad."
    GATHER:
      - consent: required
      - document_number: required
    ON_INPUT:
      - IF: consent == false
        THEN: COMPLETE
      - ELSE:
        THEN: verify_identity_step

  verify_identity_step:
    REASONING: false
    CALL: verify_identity
      WITH:
        document_type: "cedula"
        document_number: document_number
      AS: identityResult
    ON_SUCCESS:
      SET:
        identity_verified = identityResult.verified
        user_name = identityResult.name
      THEN: link_phone
    ON_FAIL:
      RESPOND: "No pude validar su identidad en este momento. Lo conectaré con un asesor."
      THEN: ESCALATE

  link_phone:
    REASONING: false
    CALL: link_phone_to_account
      WITH:
        phone_number: inbound_number
        document_number: document_number
      AS: linkResult
    ON_SUCCESS:
      SET:
        phone_verified = linkResult.linked
      THEN: COMPLETE
    ON_FAIL:
      RESPOND: "Su identidad fue verificada, pero no pude vincular el número de WhatsApp automáticamente."
      THEN: COMPLETE

ESCALATE:
  triggers:
    - WHEN: phone_not_linked == true
      REASON: "Phone number not linked to any account"
      PRIORITY: medium
    - WHEN: intent.category == "escalation" OR user.wants_human_agent == true
      REASON: "User requested human agent"
      PRIORITY: high

COMPLETE:
  - WHEN: phone_verified == true OR identity_verified == true
    RESPOND: "Gracias {user_name}. Su identidad ha sido verificada. ¿En qué puedo ayudarle?"
  - WHEN: consent == false
    RESPOND: "Entendido. Si cambia de opinión, puede escribirnos nuevamente."
