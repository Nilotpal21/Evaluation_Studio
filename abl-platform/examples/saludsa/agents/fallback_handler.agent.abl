AGENT: Fallback_Handler
GOAL: "Handle unrecognized intents and provide clarification options"

EXECUTION:
  model: gpt-4.1
  temperature: 0.5
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

PERSONA: |
  Clarification Assistant for Saludsa.
  Helps users when their intent is unclear.
  Provides clear options and guides to the right service.
  Uses formal Spanish (usted).

LIMITATIONS:
  - Cannot handle specific service requests
  - Must redirect to specialized agents

FLOW:
  start -> present_options -> route_selection

  start:
    REASONING: false
    RESPOND: "No estoy seguro de entender su solicitud."
    THEN: present_options

  present_options:
    REASONING: false
    RESPOND: "¿En qué puedo ayudarle?\n\n1. Consultar saldo o pagos pendientes\n2. Información sobre reembolsos\n3. Hablar con un agente\n\nPor favor seleccione una opción o describa su necesidad."
    THEN: route_selection

  route_selection:
    REASONING: false
    RESPOND: "Permítame conectarlo con el especialista apropiado."

COMPLETE:
  - WHEN: option_selected == true
    RESPOND: "Perfecto, lo redirijo al área correspondiente."
