SUPERVISOR: Apple_Care_Supervisor
VERSION: "1.0"
DESCRIPTION: "Multi-agent Apple customer care supervisor for device support, account help, repairs, and subscriptions"
GOAL: "Route customers to the right Apple support specialist based on their issue"

PERSONA: |
  Friendly, knowledgeable Apple support coordinator.
  Uses clear, jargon-free language.
  Always empathetic about device issues.
  Recognizes urgency and routes appropriately.
  Maintains Apple's brand voice — helpful, calm, and confident.

EXECUTION:
  temperature: 0.3
  max_tokens: 1500
  max_iterations: 5
  inline_gather: true
  pipeline:
    enabled: true
    mode: sequential
    shortCircuit:
      enabled: true
      confidenceThreshold: 0.85

LIMITATIONS:
  - "Cannot perform remote diagnostics or repairs directly"
  - "Cannot access customer financial information or payment details"
  - "Cannot override warranty terms or Apple policies"
  - "Must not share information about unreleased products"

# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATES — reusable messages for SDK and voice channels
# ─────────────────────────────────────────────────────────────────────────────

TEMPLATES:
  welcome:
    DEFAULT: |
      Welcome to Apple Support. I'm here to help with your Apple devices, account, subscriptions, or repairs.
      What can I help you with today?
    MARKDOWN: |
      # Welcome to Apple Support 🍎

      I'm here to help with:

      - **Device issues** — iPhone, iPad, Mac, Apple Watch, AirPods
      - **Apple ID & iCloud** — account, passwords, storage
      - **Repairs & warranty** — in-store service, mail-in service
      - **Subscriptions** — Apple One, Music, TV+, iCloud+

      What can I help you with today?
    HTML: |
      <div class="welcome-card apple-support">
        <h2>Welcome to Apple Support</h2>
        <p>I'm here to help with:</p>
        <ul>
          <li><strong>Device issues</strong> — iPhone, iPad, Mac, Apple Watch, AirPods</li>
          <li><strong>Apple ID & iCloud</strong> — account, passwords, storage</li>
          <li><strong>Repairs & warranty</strong> — in-store service, mail-in service</li>
          <li><strong>Subscriptions</strong> — Apple One, Music, TV+, iCloud+</li>
        </ul>
        <div class="quick-replies">
          <button data-action="device">Device Issue</button>
          <button data-action="account">Apple ID</button>
          <button data-action="repair">Repairs</button>
          <button data-action="subscription">Subscriptions</button>
        </div>
      </div>
    VOICE INSTRUCTIONS: "Use a warm, calm tone. Speak at a moderate pace. Pause after the greeting before listing options."

  session_goodbye:
    DEFAULT: "Thank you for contacting Apple Support. We hope we've resolved your issue. Have a great day!"
    MARKDOWN: |
      ---
      ## Thank you for contacting Apple Support 🍎

      We hope we've resolved your issue. Have a great day!
    HTML: |
      <div class="farewell-card">
        <h2>Thank you for contacting Apple Support</h2>
        <p>We hope we've resolved your issue. Have a great day!</p>
      </div>
    VOICE INSTRUCTIONS: "Use a warm, sincere farewell tone. Express confidence that the issue was addressed."

  handoff_success: "I've connected you with the right specialist."
  routing_error: "I'm having trouble understanding your request. Let me connect you with an Apple specialist who can help."

# ─────────────────────────────────────────────────────────────────────────────
# ON_START — greet immediately without waiting for user input
# ─────────────────────────────────────────────────────────────────────────────

ON_START:
  RESPOND: TEMPLATE(welcome)

MEMORY:
  session:
    - device_type
    - issue_category
    - issue_description
    - issue_summary
    - steps_tried
    - serial_number
    - apple_id
    - issue_type
    - session_context
    - subscription_name
    - data_loss_risk
    - routing_history
    - handoff_count

AGENTS:
  live: Live_Agent
  device: Device_Support
  account: Account_Support
  repair: Repair_And_Warranty
  subscription: Subscription_Support

# ─────────────────────────────────────────────────────────────────────────────
# ROUTING — ordered by priority (highest first)
# ─────────────────────────────────────────────────────────────────────────────

HANDOFF:
  # P1 — Immediate human escalation
  - TO: Live_Agent
    WHEN: intent.category == "escalation" OR user.wants_human_agent == true OR user.repeated_failures == true
    CONTEXT:
      pass: [apple_id, device_type, serial_number, issue_summary, steps_tried, conversation_summary]
      summary: "User requests human specialist or has had repeated failures"
    EXPECT_RETURN: false

  # P2 — Device issues, troubleshooting, setup, performance
  - TO: Device_Support
    WHEN: intent.category == "device_issue" OR intent.category == "troubleshooting" OR intent.category == "setup" OR intent.category == "performance"
    CONTEXT:
      pass: [device_type, serial_number, issue_description, apple_id, session_context]
      summary: "Customer has a device issue that needs troubleshooting"
    EXPECT_RETURN: false

  # P3 — Apple ID, iCloud, passwords, two-factor
  - TO: Account_Support
    WHEN: intent.category == "apple_id" OR intent.category == "icloud" OR intent.category == "password" OR intent.category == "two_factor"
    CONTEXT:
      pass: [apple_id, issue_type, session_context]
      summary: "Customer needs help with Apple ID or iCloud account"
    EXPECT_RETURN: false

  # P4 — Repairs, warranty, in-store service, physical damage
  - TO: Repair_And_Warranty
    WHEN: intent.category == "repair" OR intent.category == "warranty" OR intent.category == "in_store_service" OR intent.category == "physical_damage"
    CONTEXT:
      pass: [device_type, serial_number, issue_description, session_context]
      summary: "Customer needs repair service or warranty check"
    EXPECT_RETURN: false

  # P5 — Subscriptions, billing, Apple One, Music, TV+
  - TO: Subscription_Support
    WHEN: intent.category == "subscription" OR intent.category == "billing" OR intent.category == "apple_one" OR intent.category == "apple_music"
    CONTEXT:
      pass: [apple_id, subscription_name, session_context]
      summary: "Customer asking about subscriptions or billing"
    EXPECT_RETURN: false

# ─────────────────────────────────────────────────────────────────────────────
# ESCALATION — system-level triggers
# ─────────────────────────────────────────────────────────────────────────────

ESCALATE:
  triggers:
    - WHEN: user.sentiment == "frustrated" AND handoff_count > 2
      REASON: "Frustrated customer bounced between multiple agents"
      PRIORITY: critical
      TAGS: [sentiment, ux_failure]

    - WHEN: data_loss_risk == true
      REASON: "Device issue may involve data loss — requires specialist attention"
      PRIORITY: high
      TAGS: [data_loss]

    - WHEN: handoff_count >= 3
      REASON: "Customer bounced between too many agents"
      PRIORITY: high
      TAGS: [ux_failure]

  context_for_human:
    - apple_id
    - device_type
    - serial_number
    - conversation_history
    - routing_history
    - diagnostic_results

  on_human_complete:
    - IF human.resolved == true: COMPLETE
    - IF human.needs_agent == true: HANDOFF to specified_agent

# ─────────────────────────────────────────────────────────────────────────────
# ERROR HANDLING
# ─────────────────────────────────────────────────────────────────────────────

ON_ERROR:
  routing_failure:
    RESPOND: TEMPLATE(routing_error)
    RETRY: 1
    THEN: HANDOFF Live_Agent

COMPLETE:
  - WHEN: handoff_successful == true
    RESPOND: TEMPLATE(handoff_success)

  - WHEN: user.session_ended == true
    RESPOND: TEMPLATE(session_goodbye)
