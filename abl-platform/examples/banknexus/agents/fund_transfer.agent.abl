AGENT: Fund_Transfer
VERSION: "2.0"
DESCRIPTION: "Handles fund transfers with validation, limits checking, fee calculation, and execution"
GOAL: "Guide customers through secure fund transfers with recipient validation, limit checks, fee transparency, and confirmation"

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

PERSONA: |
  Precise and security-conscious transfer specialist.
  Always confirms details before executing transfers.
  Transparent about fees and limits.
  Guides customers through each step clearly.

LIMITATIONS:
  - "Cannot override daily or per-transaction transfer limits"
  - "Cannot reverse completed transfers"
  - "Cannot transfer to accounts flagged for fraud"
  - "Maximum 3 transfer attempts per session"

TOOLS:
  get_accounts(customer_id: string) -> {accounts: array, status: string}
    description: "Retrieve available funding accounts for a customer"

  validate_recipient(routing_number: string, account_number: string) -> {status: string, bank_name: string, account_holder: string}
    description: "Validate recipient bank routing and account number"

  check_transfer_limits(customer_id: string, amount: number) -> {status: string, daily_limit: number, daily_used: number, single_limit: number, remaining: number}
    description: "Check if transfer amount is within customer limits"

  calculate_fee(amount: number, transfer_type: string) -> {fee: number, fee_waived: boolean, waiver_reason: string}
    description: "Calculate transfer fee based on amount and type"

  execute_transfer(transfer_id: string, from_account: string, to_routing: string, to_account: string, amount: number, memo: string) -> {status: string, confirmation_number: string, estimated_arrival: string, new_balance: number}
    description: "Execute the fund transfer"

MEMORY:
  session:
    - customer_id
    - customer_name
    - transfer_id
    - from_account
    - recipient_routing
    - recipient_account
    - transfer_amount
    - transfer_memo
  persistent:
    - PATH: workflow.customer_id
      SCOPE: execution_tree
      ACCESS: read
      TYPE: string
    - PATH: workflow.customer_name
      SCOPE: execution_tree
      ACCESS: read
      TYPE: string
    - PATH: workflow.default_account_id
      SCOPE: execution_tree
      ACCESS: readwrite
      TYPE: string

# ─────────────────────────────────────────────────────────────────────────────
# FLOW — init → collect → validate → amount → limits → fees → review → execute
# ─────────────────────────────────────────────────────────────────────────────

FLOW:
  entry_point: start

  steps:
    - start
    - fetch_source_accounts
    - no_source_accounts
    - choose_source_account
    - collect_recipient
    - validate_recipient_step
    - invalid_recipient
    - collect_amount
    - check_limits_step
    - exceeds_limits
    - calculate_fees_step
    - review_transfer
    - execute_transfer_step
    - transfer_complete
    - transfer_failed
    - cleanup

  start:
    REASONING: false
    SET:
      customer_id = COALESCE(customer_id, workflow.customer_id, user.customer_id, user_id)
      customer_name = COALESCE(customer_name, workflow.customer_name, user.name, "customer")
      transfer_id = UNIQUE_ID(10)
      transfer_type = COALESCE(transfer_type, "standard")
      from_account = COALESCE(from_account, workflow.default_account_id)
      initiated_at = NOW()
    RESPOND: "Let's set up your transfer. I'll guide you through each step."
    THEN: fetch_source_accounts

  fetch_source_accounts:
    REASONING: false
    CALL: get_accounts
      WITH:
        customer_id: customer_id
      AS: accountsResult
    ON_RESULT:
      - IF: accountsResult.accounts != null AND LENGTH(accountsResult.accounts) > 0
        SET:
          available_account_count = LENGTH(accountsResult.accounts)
        THEN: choose_source_account
      - IF: accountsResult.accounts != null AND LENGTH(accountsResult.accounts) == 0
        THEN: no_source_accounts
      - ELSE:
        RESPOND: "I couldn't load your funding accounts right now. Please try again later."
        THEN: COMPLETE

  no_source_accounts:
    REASONING: false
    RESPOND: "It looks like there are no eligible accounts available for transfers right now."
    THEN: COMPLETE

  choose_source_account:
    REASONING: false
    RESPOND: |
      Available source accounts ({{available_account_count}} found):
      {{#each accountsResult.accounts}}
      {{this.id}} — {{this.name}} ({{UPPER(this.type)}})
      {{/each}}
      Reply with the account ID you want to transfer from.
    GATHER:
      - from_account: required
        type: string
    ON_INPUT:
      - ELSE:
        SET:
          workflow.default_account_id = COALESCE(from_account, workflow.default_account_id)
        THEN: collect_recipient

  collect_recipient:
    REASONING: false
    GATHER:
      - recipient_routing: required
      - recipient_account: required
    ON_INPUT:
      - ELSE:
        THEN: validate_recipient_step

  validate_recipient_step:
    REASONING: false
    CALL: validate_recipient
      WITH:
        routing_number: recipient_routing
        account_number: recipient_account
      AS: recipientResult
    ON_RESULT:
      - IF: recipientResult.status == "valid"
        SET:
          recipient_bank = recipientResult.bank_name
          recipient_name = recipientResult.account_holder
        THEN: collect_amount
      - IF: recipientResult.status == "INVALID_ROUTING"
        RESPOND: "The routing number is invalid. Please double-check and try again."
        THEN: collect_recipient
      - IF: recipientResult.status == "ACCOUNT_CLOSED"
        RESPOND: "That account appears to be closed. Please verify with the recipient."
        THEN: collect_recipient
      - ELSE:
        RESPOND: "We couldn't verify the recipient details. Please try again."
        THEN: collect_recipient

  collect_amount:
    REASONING: false
    RESPOND: "Sending to the verified recipient at {{recipient_bank}}."
    GATHER:
      - raw_amount: required
        type: number
    ON_INPUT:
      - ELSE:
        SET:
          transfer_amount = TO_NUMBER(REPLACE(REPLACE(raw_amount, "$", ""), ",", ""))
        THEN: check_limits_step

  check_limits_step:
    REASONING: false
    CALL: check_transfer_limits
      WITH:
        customer_id: customer_id
        amount: transfer_amount
      AS: limitsResult
    ON_RESULT:
      - IF: limitsResult.status == "within_limits"
        SET:
          daily_remaining = SUB(limitsResult.daily_limit, limitsResult.daily_used)
          daily_remaining_formatted = FORMAT_CURRENCY(ROUND(daily_remaining, 2), "USD")
        THEN: calculate_fees_step
      - IF: limitsResult.status == "EXCEEDS_DAILY"
        SET:
          max_available = MIN(limitsResult.remaining, limitsResult.single_limit)
          max_available_formatted = FORMAT_CURRENCY(max_available, "USD")
        RESPOND: "This transfer exceeds your daily limit. Maximum available: {{max_available_formatted}}."
        THEN: collect_amount
      - IF: limitsResult.status == "EXCEEDS_SINGLE"
        SET:
          single_limit_formatted = FORMAT_CURRENCY(limitsResult.single_limit, "USD")
        RESPOND: "This exceeds the per-transaction limit of {{single_limit_formatted}}."
        THEN: collect_amount
      - ELSE:
        RESPOND: "Unable to verify transfer limits. Please try again."
        THEN: collect_amount

  calculate_fees_step:
    REASONING: false
    CALL: calculate_fee
      WITH:
        amount: transfer_amount
        transfer_type: transfer_type
      AS: feeResult
    ON_RESULT:
      - IF: feeResult.fee_waived == true
        SET:
          transfer_fee = 0
          fee_note = feeResult.waiver_reason
        THEN: review_transfer
      - ELSE:
        SET:
          transfer_fee = ROUND(feeResult.fee, 2)
          fee_note = "Standard transfer fee"
        THEN: review_transfer

  review_transfer:
    REASONING: false
    SET:
      formatted_amount = FORMAT_CURRENCY(transfer_amount, "USD")
      formatted_fee = FORMAT_CURRENCY(transfer_fee, "USD")
      formatted_total = FORMAT_CURRENCY(ADD(transfer_amount, transfer_fee), "USD")
    RESPOND: |
      Transfer Summary:
      From: {{MASK(from_account, "last4")}}
      To: {{MASK(recipient_account, "last4")}} at {{recipient_bank}}
      Amount: {{formatted_amount}}
      Fee: {{formatted_fee}} ({{fee_note}})
      Total: {{formatted_total}}
      Transfer ID: {{transfer_id}}
    GATHER:
      - confirm_transfer: required
    ON_INPUT:
      - IF: input contains "yes" OR input contains "confirm"
        THEN: execute_transfer_step
      - IF: input contains "cancel" OR input contains "no"
        THEN: cleanup
      - IF: input contains "change" OR input contains "amount"
        CLEAR: transfer_amount, raw_amount, limitsResult, feeResult, transfer_fee
        THEN: collect_amount
      - ELSE:
        RESPOND: "Please confirm with yes, no, or change amount."
        THEN: review_transfer

  execute_transfer_step:
    REASONING: false
    CALL: execute_transfer
      WITH:
        transfer_id: transfer_id
        from_account: from_account
        to_routing: recipient_routing
        to_account: recipient_account
        amount: transfer_amount
        memo: COALESCE(transfer_memo, "")
      AS: execResult
    ON_RESULT:
      - IF: execResult.status == "completed"
        SET:
          confirmation_number = execResult.confirmation_number
          new_balance_formatted = FORMAT_CURRENCY(execResult.new_balance, "USD")
        THEN: transfer_complete
      - IF: execResult.status == "pending"
        SET:
          confirmation_number = execResult.confirmation_number
        RESPOND: "Your transfer is being processed. Confirmation: {{confirmation_number}}. Estimated arrival: {{execResult.estimated_arrival}}."
        THEN: cleanup
      - IF: execResult.status == "INSUFFICIENT_FUNDS"
        SET:
          shortfall = ABS(SUB(execResult.new_balance, 0))
          shortfall_formatted = FORMAT_CURRENCY(shortfall, "USD")
        RESPOND: "Insufficient funds. You need {{shortfall_formatted}} more to complete this transfer."
        THEN: collect_amount
      - ELSE:
        SET:
          error_detail = COALESCE(execResult.status, "unknown error")
        RESPOND: "Transfer failed: {{error_detail}}. Please try again or contact support."
        THEN: transfer_failed

  transfer_complete:
    REASONING: false
    RESPOND: |
      Transfer successful!
      Confirmation: {{confirmation_number}}
      New balance: {{new_balance_formatted}}
    THEN: cleanup

  transfer_failed:
    REASONING: false
    RESPOND: "Would you like to try again or speak with an agent?"
    GATHER:
      - retry_choice: required
    ON_INPUT:
      - IF: input contains "try" OR input contains "again" OR input contains "yes"
        THEN: collect_amount
      - IF: input contains "agent" OR input contains "human" OR input contains "support"
        THEN: ESCALATE
      - ELSE:
        THEN: cleanup

  cleanup:
    REASONING: false
    CLEAR: transfer_amount, raw_amount, recipient_routing, recipient_account, recipientResult, limitsResult, feeResult, execResult
    RESPOND: "Is there anything else I can help you with?"
    THEN: COMPLETE

# ─────────────────────────────────────────────────────────────────────────────
# CONSTRAINTS
# ─────────────────────────────────────────────────────────────────────────────

CONSTRAINTS:
  always:
    - REQUIRE transfer_amount > 0
      ON_FAIL: "Transfer amount must be greater than zero."

# ─────────────────────────────────────────────────────────────────────────────
# ESCALATION
# ─────────────────────────────────────────────────────────────────────────────

ESCALATE:
  triggers:
    - WHEN: user.requests_human == true
      REASON: "User requested human agent during transfer"
      PRIORITY: high

    - WHEN: transfer_failures >= 3
      REASON: "Multiple transfer failures"
      PRIORITY: high
      TAGS: [transfer, failure]

  context_for_human:
    - customer_id
    - customer_name
    - transfer_id
    - from_account
    - transfer_amount
    - recipient_account
    - conversation_history

COMPLETE:
  - WHEN: confirmation_number IS SET
    RESPOND: "Transfer complete. Reference: {{confirmation_number}}"

  - WHEN: user.cancelled_transfer == true
    RESPOND: "Transfer cancelled."

ON_ERROR:
  tool_timeout:
    RESPOND: "The banking system is responding slowly. Please wait..."
    RETRY: 2
    THEN: ESCALATE

  tool_error:
    RESPOND: "Something went wrong with the transfer system."
    RETRY: 1
    THEN: CONTINUE
