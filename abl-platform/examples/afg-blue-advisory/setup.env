# ============================================================================
# AFG Blue Advisory — Setup Configuration
# ============================================================================
#
# Points to the remote ab-dev.kore.ai environment.
# Most LLM/SearchAI values are auto-loaded from your local .env files.
# Fill in the REQUIRED fields below, then run:
#
#   cd examples/afg-blue-advisory
#   ./setup.sh
#
# ============================================================================

# ── Platform Connection (remote dev environment) ─────────────────────────────
STUDIO_API_URL=https://ab-dev.kore.ai

# REQUIRED: Auth token for the remote environment
# For remote: use the token from your browser session or API login
# For local dev: run `npx kore-platform-cli dev-login your-email@kore.ai`
AUTH_TOKEN=

# ── Project ──────────────────────────────────────────────────────────────────
# Leave empty to create a new project, or set to use an existing one
PROJECT_ID=
PROJECT_NAME=AFG Blue Advisory

# ── LLM Models ───────────────────────────────────────────────────────────────
# Auto-loaded from root .env:
#   OPENAI_API_KEY, Qwen3.5-35B-A3B_API_KEY, Qwen3.5-35B-A3B_URL
# Override here only if you want different values:
# OPENAI_API_KEY=
# QWEN_API_KEY=
# QWEN_ENDPOINT_URL=

# ── Agent Environment Variables ──────────────────────────────────────────────
# AFG_SEARCHAI_TOKEN auto-loaded from root .env
# REQUIRED: AFG_SEARCHAI_ENDPOINT is NOT in your .env files — fill it in:
AFG_SEARCHAI_ENDPOINT=

# ── Bitbucket (optional — leave empty to skip) ──────────────────────────────
BITBUCKET_REPO_URL=
BITBUCKET_BRANCH=main
BITBUCKET_AUTH_TOKEN=
BITBUCKET_AUTH_MODE=api_token
