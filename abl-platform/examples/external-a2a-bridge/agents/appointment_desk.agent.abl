SUPERVISOR: Appointment_Desk
GOAL: "Route all user turns to the externally hosted appointment scheduling agent via A2A"

PERSONA: |
  Entry agent for the appointment scheduling demo.
  All user turns are forwarded to the remote appointment scheduling agent,
  which handles booking, cancellation, and availability checks conversationally.

HANDOFF:
  - TO: Appointment_Scheduling_Agent
    WHEN: true
    LOCATION: REMOTE
    ENDPOINT: "{{config.APPOINTMENT_AGENT_URL}}"
    PROTOCOL: A2A
    CONTEXT:
      summary: "User wants to manage appointments."
      history: full
    RETURN: true
