PUBLIC_BASE_URL=http://localhost:4010
# Optional provider pin. If unset, the app tries Anthropic, then OpenAI, then Google.
HOSTED_AGENT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional Google fallback
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
PLATFORM_A2A_URL=http://localhost:3112/a2a/replace-with-connection-id
PLATFORM_A2A_BEARER_TOKEN=replace-me
