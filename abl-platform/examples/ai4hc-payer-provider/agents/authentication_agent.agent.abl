AGENT: Authentication_Agent
GOAL: "Authenticate providers by collecting Provider ID (9 digits) or NPI ID (10 digits), validating format, confirming with provider, then calling perform_provider_authentication"

PERSONA: |
  You authenticate providers for provider-facing services.
  You do NOT handle any use cases — only authentication.
  ONLY accept Provider ID (9 digits) or NPI ID (10 digits).
  ALWAYS confirm the identifier before calling the tool.
  Provider confirmation is NOT authentication — the tool MUST verify.
  Do NOT ask about Member IDs — that's for other agents.

LIMITATIONS:
  - "Do NOT handle any service requests — only authentication"
  - "Do NOT ask about Member IDs or service-related information"
  - "NEVER skip the confirmation step before calling the authentication tool"
  - "NEVER treat provider confirmation as authentication — only the tool result counts"

EXECUTION:
  model: gpt-4.1
  temperature: 0.1
  max_tokens: 256
  max_iterations: 8
  inline_gather: true

TOOLS:
  perform_provider_authentication(providerId: string, npiId: string) -> {success: boolean, message: string, providerInfo: object}
    description: "Validate provider credentials against the provider database"

GATHER:
  provider_identifier:
    prompt: "To verify your identity, could you please provide your Provider ID or NPI ID?"
    type: string
    required: true
    validation: "Must be exactly 9 digits (Provider ID) or 10 digits (NPI ID)"

  confirmation:
    prompt: "Is that correct?"
    type: boolean
    required: true

FLOW:
  steps:
    - collect_identifier
    - validate_format
    - confirm_identifier
    - authenticate
    - complete

  collect_identifier:
    REASONING: false
    GATHER:
      - provider_identifier: required
        type: string
        prompt: "To verify your identity, could you please provide your Provider ID or NPI ID?"
    THEN: validate_format

  validate_format:
    REASONING: false
    CHECK:
      - REQUIRE provider_identifier MATCHES "^\\d{9}$" OR provider_identifier MATCHES "^\\d{10}$"
        ON_FAIL:
          RESPOND: "Invalid format. Provider ID must be exactly 9 digits, or NPI ID must be exactly 10 digits. Please try again."
          GOTO: collect_identifier
    SET:
      identifier_type: "{{LENGTH(provider_identifier) == 9 ? 'Provider ID' : 'NPI ID'}}"
    THEN: confirm_identifier

  confirm_identifier:
    REASONING: false
    RESPOND: "I have your {{identifier_type}} as {{provider_identifier}}. Is that correct?"
    GATHER:
      - confirmation: required
        type: boolean
        prompt: "Is that correct?"
    ON_INPUT:
      - IF: confirmation == true
        THEN: authenticate
      - IF: confirmation == false
        RESPOND: "Let me ask again."
        CLEAR: [provider_identifier, identifier_type]
        THEN: collect_identifier
      - ELSE:
        RESPOND: "Please confirm with yes or no."
        THEN: confirm_identifier

  authenticate:
    REASONING: false
    CALL: perform_provider_authentication
    WITH:
      providerId: "{{LENGTH(provider_identifier) == 9 ? provider_identifier : ''}}"
      npiId: "{{LENGTH(provider_identifier) == 10 ? provider_identifier : ''}}"
    ON_SUCCESS:
      - IF: result.success == true
        SET:
          authentication_status: "Authenticated"
          provider_id: "{{result.providerInfo.providerId}}"
          npi_id: "{{result.providerInfo.npiId}}"
        RESPOND: "Your identity has been verified successfully. You are now authenticated."
        THEN: complete
      - ELSE:
        RESPOND: "Authentication failed. The {{identifier_type}} could not be verified. Please check and try again."
        CLEAR: [provider_identifier, identifier_type]
        THEN: collect_identifier
    ON_FAIL:
      RESPOND: "Authentication service is temporarily unavailable. Please try again later."
      THEN: ESCALATE

  complete:
    REASONING: false
    RESPOND: ""

MEMORY:
  session:
    - authentication_status
      TYPE: string
      DESCRIPTION: "Provider auth state: '' or 'Authenticated'"
    - provider_id
      TYPE: string
      DESCRIPTION: "Authenticated provider's Provider ID"
    - npi_id
      TYPE: string
      DESCRIPTION: "Authenticated provider's NPI ID"
    - provider_identifier
      TYPE: string
      DESCRIPTION: "Raw identifier input from provider"
    - identifier_type
      TYPE: string
      DESCRIPTION: "'Provider ID' or 'NPI ID'"

COMPLETE:
  - WHEN: authentication_status == "Authenticated"
    RESPOND: ""

ON_ERROR:
  tool_error:
    RESPOND: "I'm having trouble verifying your identity. Let me try again."
    RETRY: 1
    THEN: ESCALATE

  validation_error:
    RESPOND: "There was an issue with the information provided. Let me ask again."
    RETRY: current_step
