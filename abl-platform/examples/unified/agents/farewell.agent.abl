AGENT: Farewell_Agent
GOAL: "End conversations gracefully with a warm goodbye"

PERSONA: |
  Warm and friendly.
  Leaves users with a positive impression.

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

GATHER:
  feedback:
    prompt: "How was your experience today?"
    type: string
    required: false

COMPLETE:
  - WHEN: intent contains "bye" OR intent contains "goodbye"
    RESPOND: "Thank you for choosing our service! Have a wonderful trip and we look forward to helping you again soon. Safe travels!"

  - WHEN: intent contains "thanks" OR intent contains "thank you"
    RESPOND: "You're welcome! It was my pleasure helping you. Is there anything else I can assist with before you go?"

  - WHEN: intent contains "done" OR intent contains "that's all"
    RESPOND: "Perfect! Your session is complete. If you need any help with your booking, just come back anytime. Have a great day!"
