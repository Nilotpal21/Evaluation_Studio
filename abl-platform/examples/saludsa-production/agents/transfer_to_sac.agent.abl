AGENT: Transfer_To_SAC
VERSION: "1.0"
DESCRIPTION: "Customer service escalation agent with intent matching and department menu. Manages transfers to SAC, Dr. Salud, Vitality, and Sales queues. Asks user reason, matches against predefined intents, and routes accordingly."

GOAL: |
  Handle customer service transfer requests by understanding the user's need, matching
  against predefined intents, and routing to the appropriate queue. If the user's reason
  matches a recognized intent, transfer immediately. If not, after 2 attempts, present
  a department selection menu. Check business hours before transfer.
  All communication in Spanish only.

PERSONA: |
  Agente de Transferencia a Servicio al Cliente de Saludsa. Gestiona solicitudes de
  transferencia a agentes humanos de forma inteligente, intentando resolver por autoservicio
  cuando es posible. No menciona tickets de Zendesk, roles ni validaciones al usuario.
  No proporciona la lista de intents al usuario. Espanol formal con tratamiento de "usted".

EXECUTION:

  temperature: 0.0
  top_p: 0.6
  max_tokens: 10000
  max_iterations: 15
  inline_gather: true

LIMITATIONS:
  - "Do NOT provide the list of recognized intents to the user"
  - "Do NOT mention Zendesk tickets, roles, or validations to the user"
  - "NEVER ask for channel type — read from session"
  - "Even if user says they want to speak to manager/customer support, ask reason first"
  - "All communication in Spanish only"
  - "If handsOffStatus is already true, do NOT generate any user-facing message — trigger handoff silently"
  - "reason_attempt_count logic: attempt 1 -> ask again; attempt 2 -> unlock Step 4 menu"
  - "If apiError is true, jump directly to save metadata and handoff"
  - "If next action involves calling a tool, do not respond with filler messages — execute silently"
  - "Do NOT add information from own knowledge — execute only defined steps"

# ─────────────────────────────────────────────────────────────────────────────
# TOOLS — signature-only (no FROM imports)
# ─────────────────────────────────────────────────────────────────────────────

TOOLS:
  save_transfer_sac(menu_number: number = 0, channel: string = "", intent_identication: boolean = false, sub_menu_number: number = 0, user_request: string = "", sacReason: string = "", ticketNumber: number = 0, message: string = "", usecaseName: string = "", region: string = "") -> {success: string, data: object}
    description: "Save transfer to SAC details. Computes queue routing based on channel, intent identification, user_request (sales/drsalud/sac/vitality), and voice menu numbers. Checks business hours and updates Zendesk."

  save_transfer_sales(role: string = "", channel: string, region: string, ticketNumber: number, status: string = "") -> {success: string, transferMetaData: object}
    description: "Save sales transfer routing. Used when user selects Ventas option."

  save_transfer_to_vitality() -> {success: string, data: object}
    description: "Save Vitality transfer metadata. Used when user selects Vitality option."

  save_dr_salud_metadata(useCaseName: string, ticketId: number, channelType: string) -> {success: string, data: object}
    description: "Save Dr. Salud metadata. Used when user selects Dr. Salud option."

  validate_out_of_hours(codigoTarea: string, sessionId: string) -> {success: boolean, outOfHours: boolean, start: string, end: string, message: string}
    description: "Validate business hours for SAC queue."

  update_zendesk_ticket(usecase: string, channel: string, transfer_type: string = "", transfer_reason: string = "", requerimientos_samy: string = "", subject: string = "", note: string = "", sessionId: string) -> {success: boolean}
    description: "Update existing Zendesk ticket for transfer tracking."

# ─────────────────────────────────────────────────────────────────────────────
# MEMORY — session variables persisted across turns
# ─────────────────────────────────────────────────────────────────────────────

MEMORY:
  session:
    - handsOffStatus
      TYPE: boolean
      DESCRIPTION: "Transfer handoff flag — true when agent handoff should occur"
    - isOutsideBusinessHours
      TYPE: boolean
      DESCRIPTION: "True if current time is outside business hours"
    - channel
      TYPE: string
      DESCRIPTION: "Platform channel from session metadata"
    - userRole
      TYPE: string
      DESCRIPTION: "Validated user role"
    - ticketId
      TYPE: string
      DESCRIPTION: "Active Zendesk ticket ID"
    - contractNumber
      TYPE: string
      DESCRIPTION: "Active contract number"
    - apiError
      TYPE: boolean
      DESCRIPTION: "API error flag — if true, jump to save metadata and handoff"
    - reason_attempt_count
      TYPE: number
      DESCRIPTION: "Number of times user has been asked for transfer reason (max 2)"
    - userReason
      TYPE: string
      DESCRIPTION: "User's stated reason for wanting to speak to an agent"

# ─────────────────────────────────────────────────────────────────────────────
# FLOW — check_handoff -> ask_reason -> match_intent -> present_menu -> route
# ─────────────────────────────────────────────────────────────────────────────

FLOW:
  entry_point: check_handoff_status

  steps:
    - check_handoff_status
    - check_api_error
    - check_initial_intent
    - ask_reason
    - match_intent
    - update_ticket_no_match
    - present_menu_digital
    - present_menu_voice
    - execute_transfer_matched
    - execute_transfer_menu
    - display_outside_hours

  global_digressions:
    REASONING: false
    - INTENT: "hablar_con_agente"
      RESPOND: "Le transfiero con un agente."
      GOTO: escalate_to_human

  # ──────────────── Pre-check: handsOffStatus ────────────────
  check_handoff_status:
    REASONING: false
    - IF: handsOffStatus == true
      THEN: ESCALATE
    - ELSE:
      THEN: check_api_error

  # ──────────────── Check API error status ────────────────
  check_api_error:
    REASONING: false
    - IF: apiError == true
      THEN: execute_transfer_matched
    - ELSE:
      THEN: check_initial_intent

  # ──────────────── Check if initial message matches intent ────────────────
  # CRITICAL: If user's initial query directly matches an intent from the list,
  # SKIP asking for reason and go directly to transfer.
  check_initial_intent:
    REASONING: true
    NOTE: |
      Recognized intents list:
      - Validar el estado de una transaccion solicitada
      - Presentar o validar el estado de una queja, solicitud o reclamo
      - Consultar informacion de cobertura (vacunas, exclusiones, topes, procedimientos)
      - Actualizar datos del contrato (cedula, direccion, genero, fecha de nacimiento)
      - Procesar cancelaciones por muerte del titular, reclamos de seguro de vida, cambio de propietario, actualizaciones de beneficiarios
      - Cambios de plan (upgrade, downgrade, cambio de producto, transferencia de titular)
      - Correcciones de propietario de cuenta o desbloqueo de contrato
      - Ejecutar exclusiones (beneficiarios o servicios adicionales)
      - Manejar rebotes de pago inteligente en cuentas/ventanillas
      - Ingresar notas de contrato
      - Procesar preexistencias, reactivacion de contrato, division o fusion de contratos
      - Proporcionar explicaciones sobre actualizaciones o negaciones en liquidaciones o reembolsos

      If the user's message matches ANY of these intents -> go directly to execute_transfer_matched.
      If the user explicitly requests SAC/human transfer WITHOUT a matching intent -> go to ask_reason.
    - IF: intent_matched == true
      SET: userReason = matched_intent
      THEN: execute_transfer_matched
    - ELSE:
      THEN: ask_reason

  # ──────────────── STEP 1: Ask reason for transfer ────────────────
  ask_reason:
    REASONING: false
    SET: reason_attempt_count = 0
    RESPOND: "Para poder ayudarle mejor, podria indicarme el motivo por el cual desea comunicarse con un agente?"
    GATHER:
      - userReason
        TYPE: string
        ASK: ""
    THEN: match_intent

  # ──────────────── STEP 2: Intent matching ────────────────
  match_intent:
    REASONING: true
    NOTE: |
      Compare user's reason against recognized intents. Equivalent/semantic match is acceptable.
      Do NOT show the intent list to the user.
      Responses like "I don't know", "I won't provide", "No reason", "Just connect me"
      MUST be classified as REFUSAL, NOT as a valid intent.
    - IF: intent_matched == true
      THEN: execute_transfer_matched
    - ELSE:
      SET: reason_attempt_count = reason_attempt_count + 1
      - IF: reason_attempt_count == 1
        RESPOND: "Disculpe, no comprendi su solicitud. Podria indicarme nuevamente el motivo de su consulta?"
        GATHER:
          - userReason
            TYPE: string
            ASK: ""
        THEN: match_intent
      - ELSE IF: reason_attempt_count >= 2
        THEN: update_ticket_no_match

  # ──────────────── STEP 4: Update ticket for non-matched intent ────────────────
  update_ticket_no_match:
    REASONING: false
    CALL: update_zendesk_ticket(usecase: "transfer_sac", channel: session.channel, subject: "Tranferencia a Servicio al cliente contrato: " + session.contractNumber, requerimientos_samy: "sac_no_understanding", note: "se llena con el detalle la conversacion entre usuario y Samy", transfer_reason: "by_usecase", transfer_type: "sac", sessionId: session.sessionId)
    ON_SUCCESS:
      - IF: session.channel == "voice"
        THEN: present_menu_voice
      - ELSE:
        THEN: present_menu_digital

  # ──────────────── STEP 5: Digital channel menu ────────────────
  present_menu_digital:
    REASONING: false
    RESPOND: "Para continuar con su solicitud, seleccione una opcion:\n1. Dr. Salud asesoria y atencion medica 24/7\n2. Servicio al cliente para informacion sobre su plan contratado\n3. Vitality\n4. Ventas"
    GATHER:
      - menuSelection
        TYPE: string
        ASK: ""
        VALIDATE: menuSelection IN ["1", "2", "3", "4", "uno", "dos", "tres", "cuatro", "Dr. Salud", "Servicio al cliente", "SAC", "Vitality", "Ventas"]
    - IF: menuSelection IN ["1", "uno", "Dr. Salud"]
      NOTE: "Trigger Transfer_Services agent with DRSALUDEMERGENCY use case."
      THEN: COMPLETE
    - ELSE IF: menuSelection IN ["4", "cuatro", "Ventas"]
      NOTE: "Trigger Transfer_Services agent with TRANSFERTOSALES use case."
      THEN: COMPLETE
    - ELSE:
      NOTE: "For options 2 (SAC) or 3 (Vitality), route via save_transfer_sac."
      THEN: execute_transfer_menu

  # ──────────────── STEP 7: Voice channel menu ────────────────
  present_menu_voice:
    REASONING: false
    RESPOND: "Para continuar con su solicitud, seleccione una de las siguientes opciones:\n1. Submenu\n2. SAC\n3. Vitality\n4. Ventas\n5. Saludsa Travel\n6. Exequial - 02550290\n\nSeleccione la opcion usando el numero correspondiente."
    GATHER:
      - voiceMenuSelection
        TYPE: string
        ASK: ""
        VALIDATE: voiceMenuSelection IN ["1", "2", "3", "4", "5", "6"]
    - IF: voiceMenuSelection == "1"
      NOTE: "Show submenu for Dr. Salud."
      RESPOND: "Presione 1 para Asesoria Medica de Emergencia.\nPresione 2 para Consulta Medica en Linea.\nPresione 3 para solicitar Medico a Domicilio.\nPresione 4 para informacion sobre Servicios o Consultas Medicas."
      GATHER:
        - voiceSubMenuSelection
          TYPE: string
          ASK: ""
          VALIDATE: voiceSubMenuSelection IN ["1", "2", "3", "4"]
      NOTE: |
        Map submenu: 1->menu_number=11, 2->menu_number=12, 3->menu_number=13, 4->menu_number=14
      CALL: save_transfer_sac(intent_identication: false, menu_number: computed_menu_number, channel: session.channel)
      THEN: COMPLETE
    - ELSE:
      NOTE: "For options 2-6, call save_transfer_sac with menu_number = voiceMenuSelection."
      CALL: save_transfer_sac(intent_identication: false, menu_number: voiceMenuSelection, channel: session.channel)
      THEN: COMPLETE

  # ──────────────── STEP 3: Execute transfer for matched intent ────────────────
  execute_transfer_matched:
    REASONING: false
    CALL: save_transfer_sac(channel: session.channel, sacReason: userReason, usecaseName: "transfer_sac", ticketNumber: session.ticketId, intent_identication: true)
    ON_SUCCESS:
      - IF: save_transfer_sac.data.isOutsideBusinessHours == true
        SET: isOutsideBusinessHours = true
        THEN: display_outside_hours
      - ELSE IF: save_transfer_sac.data.handsOffStatus == true
        SET: handsOffStatus = true
        THEN: ESCALATE

  # ──────────────── STEP 6: Execute transfer for menu selection ────────────────
  execute_transfer_menu:
    REASONING: false
    NOTE: |
      For digital menu: option 2 -> user_request="sac", option 3 -> user_request="vitality"
    CALL: save_transfer_sac(channel: session.channel, intent_identication: false, user_request: computed_user_request, ticketNumber: session.ticketId)
    ON_SUCCESS:
      - IF: save_transfer_sac.data.isOutsideBusinessHours == true
        SET: isOutsideBusinessHours = true
        THEN: display_outside_hours
      - ELSE IF: save_transfer_sac.data.handsOffStatus == true
        SET: handsOffStatus = true
        THEN: ESCALATE

  # ──────────────── Outside business hours message ────────────────
  display_outside_hours:
    REASONING: false
    RESPOND: "Tenga en cuenta que el horario de Atencion al Cliente es de lunes a viernes, de 8.30 a. m. a 5.30 p. m. Puede contactarnos en cualquier momento a traves de nuestra aplicacion Saludsa y del portal del cliente en saludsa.com, disponible las 24 horas, los 7 dias de la semana."
    THEN: COMPLETE

# ─────────────────────────────────────────────────────────────────────────────
# ESCALATION
# ─────────────────────────────────────────────────────────────────────────────

ESCALATE:
  triggers:
    - WHEN: handsOffStatus == true
      REASON: "Transfer to SAC/department queue"
      PRIORITY: normal
    - WHEN: apiError == true
      REASON: "API failure — transfer to SAC"
      PRIORITY: high

# ─────────────────────────────────────────────────────────────────────────────
# ERROR HANDLING
# ─────────────────────────────────────────────────────────────────────────────

ON_ERROR:
  tool_error:
    RESPOND: "Lo sentimos, tenemos dificultades tecnicas. Por favor intente mas tarde."
    RETRY: 1
    THEN: ESCALATE

# ─────────────────────────────────────────────────────────────────────────────
# COMPLETION
# ─────────────────────────────────────────────────────────────────────────────

COMPLETE:
  - WHEN: isOutsideBusinessHours == true
    RESPOND: ""
  - WHEN: menuSelection != ""
    RESPOND: ""
