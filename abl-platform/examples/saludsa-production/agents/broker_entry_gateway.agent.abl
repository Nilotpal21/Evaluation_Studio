AGENT: Broker_Entry_Gateway
VERSION: "1.0"
DESCRIPTION: "Validates Broker and Business Representative identity through a 3-step chain: Broker ID, OTP verification, and Client ID validation"

GOAL: |
  Validate broker identity through a 3-step chain (Broker ID -> OTP -> Client ID)
  before allowing service access. userValidation is set to true ONLY after
  client_id_validator succeeds. Intent routing remains disabled until that point.

PERSONA: |
  Agente de validacion de identidad para Representantes de Negocio y Brokers de Saludsa.
  Gestiona la validacion en tres pasos: identificacion del broker, verificacion OTP,
  y validacion del cliente. No menciona roles ni validaciones internas. Espanol formal.

EXECUTION:

  temperature: 0.1
  top_p: 0.5
  max_tokens: 10000
  max_iterations: 20
  inline_gather: true

LIMITATIONS:
  - "Intent routing is strictly disabled until full 3-step chain completes (Broker ID -> OTP -> Client ID)"
  - "Must not route to any other agent during validation"
  - "Must not mention internal roles, validation results, or API logic to the user"
  - "Must not ask the user for their channel — read from session"
  - "All communication must be in Spanish only"
  - "OTP failure after 2 attempts triggers transfer to SAC — NOT session close"
  - "userValidation is set to true ONLY after client_id_validator succeeds"
  - "Maximum 2 attempts for each identification step (Broker ID, OTP, Client ID)"
  - "Must discard and ignore any business intent detected before validation completion"

# ─────────────────────────────────────────────────────────────────────────────
# TOOLS — signature-only (no FROM/USE imports)
# ─────────────────────────────────────────────────────────────────────────────

TOOLS:
  broker_id_validator(idCardOrPassport: string, userRole: string) -> {success: boolean, userDetails: object}
    description: "Validate broker national ID or passport. userDetails contains: apiError, message, idInvalidCountBR, userRole."

  client_id_validator(idCard: string) -> {success: boolean, userDetails: object}
    description: "Validate client ID in broker flow. userDetails contains: userValidation, priorityTransfer, customerDetails, idInvalidCountC, BRNotEligibleCount, customerName, contractNumber."

  otp_generator() -> {success: boolean, message: string}
    description: "Generate OTP sent to registered phone"

  otp_validator(userProvidedCodigoOtp: string) -> {success: boolean, userDetails: object}
    description: "Validate user-entered OTP. userDetails contains: otpValidated, otpInvalidCount, apiError, message."

  otp_failure_sac_transfer() -> {success: string, data: object}
    description: "Handle SAC transfer on OTP failure after 2 attempts. data contains: handsOffStatus, isOutsideBusinessHours."

  handle_service_failure() -> {success: string, data: object}
    description: "Global API failure handler"

  user_validation(telePhoneNum: string, inboundNumber: string, channel: string, sessionId: string) -> {userType: string, timeSlot: string, title: string, surName: string}
    description: "Validate user type by phone number"

# ─────────────────────────────────────────────────────────────────────────────
# MEMORY — session variables
# ─────────────────────────────────────────────────────────────────────────────

MEMORY:
  session:
    - userType
      TYPE: string
      DESCRIPTION: "User type from phone validation (Broker, Business Representative)"
    - userRole
      TYPE: string
      DESCRIPTION: "Selected role from menu or derived from userType"
    - userValidation
      TYPE: boolean
      DESCRIPTION: "Primary validation flag — true ONLY after client_id_validator succeeds"
    - idInvalidCountBR
      TYPE: number
      DESCRIPTION: "Count of invalid broker ID attempts"
    - otpInvalidCount
      TYPE: number
      DESCRIPTION: "Count of invalid OTP attempts"
    - idInvalidCountC
      TYPE: number
      DESCRIPTION: "Count of invalid client ID attempts"
    - BRNotEligibleCount
      TYPE: number
      DESCRIPTION: "Count of client IDs not in broker portfolio"
    - priorityTransfer
      TYPE: string
      DESCRIPTION: "Priority product flag (XPR, PCA, SAC, or NA)"
    - timeSlot
      TYPE: string
      DESCRIPTION: "Time-of-day greeting (Buenos dias, Buenas tardes, etc.)"
    - title
      TYPE: string
      DESCRIPTION: "User title (Sr., Sra., etc.)"
    - surName
      TYPE: string
      DESCRIPTION: "User surname"
    - closeConversation
      TYPE: string
      DESCRIPTION: "Session termination flag (yes to close)"
    - customerDetails
      TYPE: object
      DESCRIPTION: "Customer details returned from client_id_validator"

# ─────────────────────────────────────────────────────────────────────────────
# FLOW — 14-step broker validation: Broker ID -> OTP -> Client ID
# ─────────────────────────────────────────────────────────────────────────────

FLOW:
  entry_point: pre_check

  steps:
    - pre_check
    - role_identification
    - ask_broker_id
    - validate_broker_id
    - generate_otp
    - ask_otp
    - validate_otp
    - ask_client_id
    - validate_client_id
    - check_client_priority
    - validation_success
    - broker_session_closed
    - client_session_closed
    - portfolio_closed

  global_digressions:
    REASONING: false
    - INTENT: "hablar_con_agente"
      RESPOND: "Le transfiero con un agente."
      GOTO: escalate_to_human

# Step 1: Pre-check — validate user type from phone number
pre_check:
  REASONING: false
  CALL: user_validation(telePhoneNum: session.phoneNumber, inboundNumber: session.inboundNumber, channel: session.channel, sessionId: session.sessionId)
  ON_SUCCESS:
    SET: userType = user_validation.userType
    SET: timeSlot = user_validation.timeSlot
    SET: title = user_validation.title
    SET: surName = user_validation.surName
    - IF: userType IN ["Broker", "Business Representative"]
      THEN: ask_broker_id
    - ELSE:
      THEN: role_identification

# Step 2: Role identification — unknown user type, ask for role
role_identification:
  REASONING: false
  RESPOND: "{timeSlot}! Para continuar, por favor confirme su rol seleccionando una de las siguientes opciones:\n1. Representante de Negocios (RN)\n2. Broker\nIndique el numero correspondiente a su rol, o escribalo directamente."
  GATHER:
    - selectedRole
      TYPE: string
      ASK: ""
  SET: userRole = selectedRole
  THEN: ask_broker_id

# Step 3: Ask broker for national ID or passport
ask_broker_id:
  REASONING: false
  RESPOND: "Hola, {title}. {surName}, me puede proporcionar su cedula / pasaporte? La conversacion se almacenara y monitoreara por seguridad."
  GATHER:
    - brokerCedula
      TYPE: string
      ASK: ""
      VALIDATE: length >= 6
  THEN: validate_broker_id

# Step 4: Validate broker ID
validate_broker_id:
  REASONING: false
  CALL: broker_id_validator(idCardOrPassport: brokerCedula, userRole: userRole)
  ON_SUCCESS:
    - IF: broker_id_validator.userDetails.apiError == true
      CALL: handle_service_failure()
      THEN: ESCALATE
    - ELSE IF: broker_id_validator.userDetails.message != "No Broker details Found" AND broker_id_validator.userDetails.message != "Invalid number"
      THEN: generate_otp
    - ELSE:
      SET: idInvalidCountBR = broker_id_validator.userDetails.idInvalidCountBR
      - IF: idInvalidCountBR >= 2
        THEN: broker_session_closed
      - ELSE:
        RESPOND: "Proporcione un numero de identificacion de corredor/pasaporte valido"
        GATHER:
          - brokerCedula
            TYPE: string
            ASK: ""
        THEN: validate_broker_id

# Step 5: Generate OTP
generate_otp:
  REASONING: false
  CALL: otp_generator()
  ON_SUCCESS:
    THEN: ask_otp
  ON_FAIL:
    CALL: handle_service_failure()
    THEN: ESCALATE

# Step 6: Ask user for OTP code
ask_otp:
  REASONING: false
  RESPOND: "Hemos enviado un codigo OTP a su numero registrado. Por favor, ingrese el codigo."
  GATHER:
    - otpCode
      TYPE: string
      ASK: ""
  THEN: validate_otp

# Step 7: Validate OTP
validate_otp:
  REASONING: false
  CALL: otp_validator(userProvidedCodigoOtp: otpCode)
  ON_SUCCESS:
    - IF: otp_validator.userDetails.otpValidated == true
      THEN: ask_client_id
    - ELSE:
      SET: otpInvalidCount = otp_validator.userDetails.otpInvalidCount
      - IF: otpInvalidCount >= 2
        CALL: otp_failure_sac_transfer()
        THEN: ESCALATE
      - ELSE:
        RESPOND: "El codigo OTP no es valido. Por favor, intente nuevamente."
        GATHER:
          - otpCode
            TYPE: string
            ASK: ""
        THEN: validate_otp

# Step 8: Ask for client ID
ask_client_id:
  REASONING: false
  RESPOND: "Por favor, indiqueme la identificacion o numero de contrato de su cliente para quien desea realizar la gestion, para continuar de manera segura con el servicio."
  GATHER:
    - clientCedula
      TYPE: string
      ASK: ""
  THEN: validate_client_id

# Step 9: Validate client ID — this is the ONLY step that sets userValidation = true
validate_client_id:
  REASONING: false
  CALL: client_id_validator(idCard: clientCedula)
  ON_SUCCESS:
    - IF: client_id_validator.userDetails.userValidation == true
      SET: userValidation = true
      SET: priorityTransfer = client_id_validator.userDetails.priorityTransfer
      SET: customerDetails = client_id_validator.userDetails.customerDetails
      THEN: check_client_priority
    - ELSE IF: client_id_validator.userDetails.BRNotEligibleCount > 0
      SET: BRNotEligibleCount = client_id_validator.userDetails.BRNotEligibleCount
      - IF: BRNotEligibleCount >= 2
        THEN: portfolio_closed
      - ELSE:
        RESPOND: "La identificacion ingresada no corresponde a su cartera de clientes. Por favor, intente nuevamente."
        GATHER:
          - clientCedula
            TYPE: string
            ASK: ""
        THEN: validate_client_id
    - ELSE:
      SET: idInvalidCountC = client_id_validator.userDetails.idInvalidCountC
      - IF: idInvalidCountC >= 2
        THEN: client_session_closed
      - ELSE:
        RESPOND: "Proporcione un numero de identificacion de cliente/pasaporte valido"
        GATHER:
          - clientCedula
            TYPE: string
            ASK: ""
        THEN: validate_client_id

# Step 10: Check client priority transfer
check_client_priority:
  REASONING: false
  - IF: priorityTransfer IN ["XPR", "PCA", "SAC"]
    THEN: COMPLETE
  - ELSE:
    THEN: validation_success

# Step 11: Validation success — all 3 steps passed
validation_success:
  REASONING: false
  RESPOND: "Gracias, su identidad ha sido validada. En que le puedo servir?"
  THEN: COMPLETE

# Step 12: Broker session closed — too many invalid broker ID attempts
broker_session_closed:
  REASONING: false
  RESPOND: "Para cuidar su seguridad y su informacion, hemos cerrado esta sesion luego de varios intentos fallidos. Puede volver a intentarlo mas adelante."
  SET: closeConversation = "yes"
  THEN: COMPLETE

# Step 13: Client session closed — too many invalid client ID attempts
client_session_closed:
  REASONING: false
  RESPOND: "Para cuidar su seguridad y su informacion, hemos cerrado esta sesion luego de varios intentos fallidos. Puede volver a intentarlo mas adelante."
  SET: closeConversation = "yes"
  THEN: COMPLETE

# Step 14: Portfolio closed — client not in broker portfolio after max attempts
portfolio_closed:
  REASONING: false
  RESPOND: "Lamentablemente, la identificacion ingresada no corresponde a su cartera de clientes y se ha superado el numero maximo de intentos permitidos. Para cuidar la seguridad de la informacion, esta conversacion se ha cerrado de forma automatica. Por favor, intentelo nuevamente mas tarde"
  SET: closeConversation = "yes"
  THEN: COMPLETE

# ─────────────────────────────────────────────────────────────────────────────
# CONSTRAINTS
# ─────────────────────────────────────────────────────────────────────────────

CONSTRAINTS:
  always:
    - REQUIRE userValidation != true IMPLIES intent_routing_disabled
      ON_FAIL: "Intent routing is disabled until full 3-step validation completes"

# ─────────────────────────────────────────────────────────────────────────────
# ESCALATION
# ─────────────────────────────────────────────────────────────────────────────

ESCALATE:
  triggers:
    - WHEN: apiError == true
      REASON: "API failure during broker validation"
      PRIORITY: high
    - WHEN: otpInvalidCount >= 2
      REASON: "OTP validation failed after 2 attempts — transfer to SAC"
      PRIORITY: high

# ─────────────────────────────────────────────────────────────────────────────
# ERROR HANDLING
# ─────────────────────────────────────────────────────────────────────────────

ON_ERROR:
  tool_error:
    RESPOND: "Lo sentimos, tenemos dificultades tecnicas. Por favor intente mas tarde."
    RETRY: 1
    THEN: ESCALATE

# ─────────────────────────────────────────────────────────────────────────────
# COMPLETION
# ─────────────────────────────────────────────────────────────────────────────

COMPLETE:
  - WHEN: userValidation == true
    RESPOND: ""
  - WHEN: closeConversation == "yes"
    RESPOND: ""
