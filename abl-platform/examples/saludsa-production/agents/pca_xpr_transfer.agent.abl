AGENT: PCA_XPR_Transfer
VERSION: "1.0"
DESCRIPTION: "Priority product routing agent for XPR (Experience), PCA/ServiAlamo, Fideval, TRK/TRANKI, and JAPI/Hunter products. Detects product type from priorityTransfer, routes by channel (voice vs digital), and provides partner contact information or transfers calls."

GOAL: |
  Route priority product requests (XPR, PCA, JAPI, Hunter, Fideval, TRK/TRANKI) to the
  correct provider or channel. Prioritize Experience (XPR) when present. For voice channels,
  perform call transfers. For digital channels, provide contact information.
  All communication in Spanish only.

PERSONA: |
  Agente de Transferencia de Productos Prioritarios de Saludsa. Gestiona solicitudes
  de productos Experience (XPR), PCA, JAPI, Hunter, Fideval y TRK/TRANKI. Detecta
  el producto, valida la elegibilidad, y enruta al proveedor correcto o canal
  apropiado. No menciona tickets de Zendesk, roles ni validaciones al usuario.
  Espanol formal con tratamiento de "usted".

EXECUTION:

  temperature: 0.1
  top_p: 0.5
  max_tokens: 10000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Do NOT mention Zendesk tickets, roles, or validations to the user"
  - "NEVER ask for channel type — read from session"
  - "All communication in Spanish only"
  - "If handsOffStatus is already true, do NOT generate any user-facing message — trigger handoff silently"
  - "Do not call tools in parallel — call one tool at a time"
  - "If next action involves calling a tool, do not respond with filler messages — execute silently"
  - "Do NOT add information from own knowledge — execute only defined steps"

# ─────────────────────────────────────────────────────────────────────────────
# TOOLS — signature-only (no FROM imports)
# ─────────────────────────────────────────────────────────────────────────────

TOOLS:
  save_transfer_sac(channel: string = "", intent_identication: boolean = false, sacReason: string = "", ticketNumber: number = 0) -> {success: string, data: object}
    description: "Save transfer to SAC details for PCA queue routing. Checks business hours and updates Zendesk."

  create_zendesk_ticket(usecase: string = "new", channel: string = "web", subject: string = "Nuevo Ticket", sessionId: string) -> {success: boolean, ticketId: string}
    description: "Create Zendesk ticket for priority product tracking."

  handle_priority_product_transfer(priorityTransfer: string = "") -> {success: string, data: object}
    description: "Mandatory product detection and eligibility tool. Evaluates priorityTransfer flag, routes to appropriate queue: SAC for SAC/PCA, XPR for Experience, returns plan details for PCA, Fideval flag for Fideval. Must be called first without input parameters."

# ─────────────────────────────────────────────────────────────────────────────
# MEMORY — session variables persisted across turns
# ─────────────────────────────────────────────────────────────────────────────

MEMORY:
  session:
    - handsOffStatus
      TYPE: boolean
      DESCRIPTION: "Transfer handoff flag — true when agent handoff should occur"
    - isOutsideBusinessHours
      TYPE: boolean
      DESCRIPTION: "True if current time is outside business hours"
    - channel
      TYPE: string
      DESCRIPTION: "Platform channel from session metadata"
    - priorityTransfer
      TYPE: string
      DESCRIPTION: "Priority product flag (XPR, PCA, SAC, Fideval, TRK, TRANKI, JAPI, Hunter)"
    - nombre_titular
      TYPE: string
      DESCRIPTION: "Account holder name from session metadata"
    - ticketId
      TYPE: string
      DESCRIPTION: "Active Zendesk ticket ID"
    - timeSlot
      TYPE: string
      DESCRIPTION: "Time-of-day greeting slot"
    - isPCAExist
      TYPE: boolean
      DESCRIPTION: "True if PCA product exists for the user"
    - isXPRExist
      TYPE: boolean
      DESCRIPTION: "True if XPR/Experience product exists"
    - isFidevalExist
      TYPE: boolean
      DESCRIPTION: "True if Fideval product exists"
    - contactNumber
      TYPE: string
      DESCRIPTION: "Provider contact number from handle_priority_product_transfer response"
    - planName
      TYPE: string
      DESCRIPTION: "Plan name from handle_priority_product_transfer response"
    - contractNumber
      TYPE: string
      DESCRIPTION: "Contract number from handle_priority_product_transfer response"

# ─────────────────────────────────────────────────────────────────────────────
# FLOW — check_handoff -> detect_product -> route_by_channel -> contact_or_transfer
# ─────────────────────────────────────────────────────────────────────────────

FLOW:
  entry_point: check_handoff_status

  steps:
    - check_handoff_status
    - detect_product
    - route_xpr
    - route_pca_voice
    - route_pca_digital
    - route_fideval_voice
    - route_fideval_digital
    - route_sac
    - farewell

  global_digressions:
    REASONING: false
    - INTENT: "hablar_con_agente"
      RESPOND: "Le transfiero con un agente."
      GOTO: escalate_to_human

  # ──────────────── Pre-check: handsOffStatus ────────────────
  check_handoff_status:
    REASONING: false
    - IF: handsOffStatus == true
      THEN: ESCALATE
    - ELSE:
      THEN: detect_product

  # ──────────────── STEP 1: Product detection and eligibility ────────────────
  detect_product:
    REASONING: false
    CALL: handle_priority_product_transfer()
    ON_SUCCESS:
      # XPR takes priority — if XPR exists, route to Experience queue
      - IF: handle_priority_product_transfer.data.handsOffStatus == true
        SET: handsOffStatus = true
        NOTE: "XPR transfer — handsOffStatus already set by tool."
        THEN: ESCALATE
      - ELSE IF: handle_priority_product_transfer.data.priorityTransfer == "PCA"
        SET: isPCAExist = true
        SET: contactNumber = handle_priority_product_transfer.data.contactNumber
        SET: planName = handle_priority_product_transfer.data.planName
        SET: contractNumber = handle_priority_product_transfer.data.contractNumber
        - IF: session.channel == "voice"
          THEN: route_pca_voice
        - ELSE:
          THEN: route_pca_digital
      - ELSE IF: handle_priority_product_transfer.data.priorityTransfer == "Fideval"
        SET: isFidevalExist = true
        - IF: session.channel == "voice"
          THEN: route_fideval_voice
        - ELSE:
          THEN: route_fideval_digital
      - ELSE IF: handle_priority_product_transfer.data.isOutsideBusinessHours == true
        SET: isOutsideBusinessHours = true
        RESPOND: "Tenga en cuenta que el horario de Atencion al Cliente es de lunes a viernes, de 8.30 a. m. a 5.30 p. m. Puede contactarnos en cualquier momento a traves de nuestra aplicacion Saludsa y del portal del cliente en saludsa.com, disponible las 24 horas, los 7 dias de la semana."
        THEN: COMPLETE
      - ELSE:
        NOTE: "SAC or complementary services — tool already handled routing."
        - IF: handle_priority_product_transfer.data.handsOffStatus == true
          SET: handsOffStatus = true
          THEN: ESCALATE
        - ELSE:
          THEN: route_sac

  # ──────────────── XPR: Voice → call transfer; Digital → Experience queue ────────────────
  route_xpr:
    REASONING: false
    NOTE: "XPR routing is handled by handle_priority_product_transfer tool which sets handsOffStatus:true and appropriate queue."
    - IF: session.channel == "voice"
      NOTE: "Voice: transfer call to Experience queue."
      THEN: ESCALATE
    - ELSE:
      RESPOND: "En este momento realizamos la transferencia a nuestra linea exclusiva Experience, para brindarle atencion preferencial. Por favor, mantengase en este chat."
      THEN: ESCALATE

  # ──────────────── PCA: Voice → call transfer ────────────────
  route_pca_voice:
    REASONING: false
    RESPOND: "Estimado/a {nombre_titular}, le voy a transferir con un agente especializado que atendera su solicitud."
    NOTE: "Transfer the call to provider at contactNumber."
    THEN: ESCALATE

  # ──────────────── PCA: Digital → provide contact info ────────────────
  route_pca_digital:
    REASONING: false
    RESPOND: "Estimado/a {nombre_titular}, para recibir informacion sobre el producto PCA, por favor comuniquese con ServiAlamo al {contactNumber}."
    NOTE: "After providing information, ask if user needs anything else."
    RESPOND: "Puedo ayudarle en algo mas?"
    GATHER:
      - needsMore
        TYPE: string
        ASK: ""
    - IF: needsMore IN ["no", "No", "NO", "nada", "no gracias"]
      THEN: farewell
    - ELSE IF: needsMore matches "certificado"
      NOTE: "User requests certificate issuance — call handle_priority_product_transfer with priorityTransfer=SAC."
      CALL: handle_priority_product_transfer(priorityTransfer: "SAC")
      ON_SUCCESS:
        - IF: handle_priority_product_transfer.data.handsOffStatus == true
          SET: handsOffStatus = true
          THEN: ESCALATE
    - ELSE:
      NOTE: "Re-evaluate product detection for new request."
      THEN: detect_product

  # ──────────────── Fideval: Voice → call transfer ────────────────
  route_fideval_voice:
    REASONING: false
    RESPOND: "Estimado/a {nombre_titular}, le voy a transferir con un representante especializado que atendera su solicitud."
    NOTE: "Transfer the call to Fideval line 1-800-022945301."
    THEN: ESCALATE

  # ──────────────── Fideval: Digital → provide contact info ────────────────
  route_fideval_digital:
    REASONING: false
    - IF: session.channel IN ["WEB", "web"]
      RESPOND: "Estimado/a {nombre_titular}, para acceder a la informacion de su producto Fideval, puede llamar al 1-800-022945301 o escribir aqui:\n[https://wa.me/593985613739](https://wa.me/593985613739)"
      THEN: farewell
    - ELSE:
      RESPOND: "Estimado/a {nombre_titular}, para acceder a la informacion de su producto Fideval, puede llamar al 1-800-022945301 o escribir aqui:\nhttps://wa.me/593985613739"
      THEN: farewell

  # ──────────────── SAC: Route to SAC queue ────────────────
  route_sac:
    REASONING: false
    CALL: save_transfer_sac(channel: session.channel, intent_identication: true, sacReason: "sac_by_rule", ticketNumber: session.ticketId)
    ON_SUCCESS:
      - IF: save_transfer_sac.data.isOutsideBusinessHours == true
        SET: isOutsideBusinessHours = true
        RESPOND: "Tenga en cuenta que el horario de Atencion al Cliente es de lunes a viernes, de 8.30 a. m. a 5.30 p. m. Puede contactarnos en cualquier momento a traves de nuestra aplicacion Saludsa y del portal del cliente en saludsa.com, disponible las 24 horas, los 7 dias de la semana."
        THEN: COMPLETE
      - ELSE IF: save_transfer_sac.data.handsOffStatus == true
        SET: handsOffStatus = true
        THEN: ESCALATE

  # ──────────────── Farewell ────────────────
  farewell:
    REASONING: false
    RESPOND: "Ha sido un placer asistirle. Que tenga un excelente {timeSlot}."
    THEN: COMPLETE

# ─────────────────────────────────────────────────────────────────────────────
# ESCALATION
# ─────────────────────────────────────────────────────────────────────────────

ESCALATE:
  triggers:
    - WHEN: handsOffStatus == true
      REASON: "Priority product transfer — handoff to appropriate queue"
      PRIORITY: high
    - WHEN: apiError == true
      REASON: "API failure during priority product handling"
      PRIORITY: high

# ─────────────────────────────────────────────────────────────────────────────
# ERROR HANDLING
# ─────────────────────────────────────────────────────────────────────────────

ON_ERROR:
  tool_error:
    RESPOND: "Lo sentimos, tenemos dificultades tecnicas. Por favor intente mas tarde."
    RETRY: 1
    THEN: ESCALATE

# ─────────────────────────────────────────────────────────────────────────────
# COMPLETION
# ─────────────────────────────────────────────────────────────────────────────

COMPLETE:
  - WHEN: isOutsideBusinessHours == true
    RESPOND: ""
  - WHEN: isFidevalExist == true
    RESPOND: ""
