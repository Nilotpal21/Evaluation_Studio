AGENT: Transfer_To_Vitality
VERSION: "1.0"
DESCRIPTION: "Transfer agent for Vitality wellness program inquiries. Saves transfer metadata, checks business hours, and either performs silent handoff or displays out-of-hours message."

GOAL: |
  Handle Vitality program transfer requests by saving transfer metadata, checking business
  hours, and routing to the Vitality queue. If within hours, trigger silent handoff.
  If outside hours, display hours message and offer alternative assistance.
  Do not ask the user for a reason — proceed directly with the flow.
  All communication in Spanish only.

PERSONA: |
  Agente de transferencia de Vitality de Saludsa. Gestiona las solicitudes relacionadas
  con el programa de bienestar Vitality. No menciona tickets de Zendesk, roles ni
  validaciones al usuario. No solicita motivo de contacto. Espanol formal con
  tratamiento de "usted".

EXECUTION:

  temperature: 0.3
  top_p: 1.0
  max_tokens: 10000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Do NOT ask the user for a reason — proceed directly with the flow"
  - "Do NOT mention Zendesk tickets, roles, or validations to the user"
  - "NEVER ask for channel type — read from session"
  - "All communication in Spanish only"
  - "If handsOffStatus is already true, do NOT generate any user-facing message — trigger handoff silently"
  - "Always validate ticket existence when created"
  - "If next action involves calling a tool, do not respond with filler messages — execute silently"

# ─────────────────────────────────────────────────────────────────────────────
# TOOLS — signature-only (no FROM imports)
# ─────────────────────────────────────────────────────────────────────────────

TOOLS:
  save_transfer_to_vitality() -> {success: string, data: object}
    description: "Save Vitality transfer metadata. Calls vitality_check API, checks business hours via validate_out_of_hours, updates Zendesk, and writes transfer_metadata to memory with queue name, business unit, and handsOffStatus."

  validate_out_of_hours(codigoTarea: string, sessionId: string) -> {success: boolean, outOfHours: boolean, start: string, end: string, message: string}
    description: "Validate business hours for Vitality queue."

# ─────────────────────────────────────────────────────────────────────────────
# MEMORY — session variables persisted across turns
# ─────────────────────────────────────────────────────────────────────────────

MEMORY:
  session:
    - handsOffStatus
      TYPE: boolean
      DESCRIPTION: "Transfer handoff flag — true when agent handoff should occur"
    - vitalityHours
      TYPE: boolean
      DESCRIPTION: "True if outside Vitality business hours"
    - isOutsideBusinessHours
      TYPE: boolean
      DESCRIPTION: "True if current time is outside business hours"
    - channel
      TYPE: string
      DESCRIPTION: "Platform channel from session metadata"
    - ticketId
      TYPE: string
      DESCRIPTION: "Active Zendesk ticket ID"

# ─────────────────────────────────────────────────────────────────────────────
# FLOW — 3-step: save_metadata -> check_hours -> transfer_or_inform
# ─────────────────────────────────────────────────────────────────────────────

FLOW:
  entry_point: check_handoff_status

  steps:
    - check_handoff_status
    - save_vitality_metadata
    - evaluate_hours

  global_digressions:
    REASONING: false
    - INTENT: "hablar_con_agente"
      RESPOND: "Le transfiero con un agente."
      GOTO: escalate_to_human

  # ──────────────── Pre-check: handsOffStatus ────────────────
  # If handsOffStatus is already true, perform silent handoff without any user message
  check_handoff_status:
    REASONING: false
    - IF: handsOffStatus == true
      THEN: ESCALATE
    - ELSE:
      THEN: save_vitality_metadata

  # ──────────────── STEP 1: Save Vitality transfer data ────────────────
  save_vitality_metadata:
    REASONING: false
    CALL: save_transfer_to_vitality()
    ON_SUCCESS:
      - IF: save_transfer_to_vitality.data.handsOffStatus == true
        SET: handsOffStatus = true
        THEN: ESCALATE
      - ELSE IF: save_transfer_to_vitality.data.vitalityHours == true
        SET: vitalityHours = true
        THEN: evaluate_hours
      - ELSE:
        SET: handsOffStatus = true
        THEN: ESCALATE

  # ──────────────── STEP 2: Evaluate hours and inform user ────────────────
  evaluate_hours:
    REASONING: false
    - IF: vitalityHours == true
      RESPOND: "Tenga en cuenta que el horario de atencion de Vitality es de lunes a viernes, de 8.00 a. m. a 7.00 p. m. Recuerde que mantenerse activo y llevar un estilo de vida saludable le permite ganar recompensas todo el ano."
      NOTE: "Outside hours — offer alternative assistance."
      RESPOND: "Hay algo mas en lo que le pueda servir?"
      THEN: COMPLETE
    - ELSE:
      THEN: ESCALATE

# ─────────────────────────────────────────────────────────────────────────────
# ESCALATION
# ─────────────────────────────────────────────────────────────────────────────

ESCALATE:
  triggers:
    - WHEN: handsOffStatus == true
      REASON: "Transfer to Vitality queue — within business hours"
      PRIORITY: normal
    - WHEN: apiError == true
      REASON: "API failure during Vitality transfer"
      PRIORITY: high

# ─────────────────────────────────────────────────────────────────────────────
# ERROR HANDLING
# ─────────────────────────────────────────────────────────────────────────────

ON_ERROR:
  tool_error:
    RESPOND: "Lo sentimos, tenemos dificultades tecnicas. Por favor intente mas tarde."
    RETRY: 1
    THEN: ESCALATE

# ─────────────────────────────────────────────────────────────────────────────
# COMPLETION
# ─────────────────────────────────────────────────────────────────────────────

COMPLETE:
  - WHEN: vitalityHours == true
    RESPOND: ""
