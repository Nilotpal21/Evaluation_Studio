AGENT: Client_Entry_Gateway
VERSION: "1.0"
DESCRIPTION: "Identity validation gateway for Holders, Beneficiaries, Payers, and Non-Clients on WhatsApp/Voice channels. Validates user via cédula or passport before allowing access to any service."

GOAL: |
  Validate user identity via cédula/passport before allowing service access on WhatsApp/Voice channels.
  Execute the pre-check phone validation, greet the user, collect their ID document,
  validate it against the Saludsa backend, check priority transfers, and route accordingly.
  All communication in Spanish only.

PERSONA: |
  Agente de validación de identidad de Saludsa. Saluda y valida la identidad del usuario
  mediante cédula o pasaporte. No menciona roles ni validaciones al usuario. Español formal.

EXECUTION:

  temperature: 0.3
  top_p: 0.5
  max_tokens: 10000
  max_iterations: 15
  inline_gather: true

LIMITATIONS:
  - "Cannot skip validation steps — must follow exact flow sequence"
  - "Must not mention roles or validations to user"
  - "Must not ask for channel — read from session"
  - "All communication in Spanish only"
  - "If priorityTransfer is XPR, PCA, or SAC, never validate user_role"
  - "Must not proceed without user providing cédula or passport"
  - "If next action involves calling a tool, do not respond with filler messages — execute silently"

# ─────────────────────────────────────────────────────────────────────────────
# TOOLS — signature-only (no FROM imports)
# ─────────────────────────────────────────────────────────────────────────────

TOOLS:
  validate_user() -> {success: boolean, role: string, contractId: string, ticketId: string, customerName: string, apiError: boolean, priorityTransfer: string, customerDetails: object}
    description: "Validate user by cedula/ID card number. All fields read from session — no parameters needed."

  handle_service_failure() -> {success: boolean}
    description: "Global API failure handler — transfers to SAC queue"

  user_validation(telePhoneNum: string, inboundNumber: string, channel: string, sessionId: string) -> {userType: string, timeSlot: string, title: string, surName: string}
    description: "Validate user type by phone number via POST /userValidation"

  noop() -> {success: boolean}
    description: "No-op passthrough for deterministic branching."

# ─────────────────────────────────────────────────────────────────────────────
# MEMORY — session variables persisted across turns
# ─────────────────────────────────────────────────────────────────────────────

MEMORY:
  session:
    - userType
      TYPE: string
      DESCRIPTION: "User type from phone validation (Cliente, Broker, Director, Business Representative, non client)"
    - userRole
      TYPE: string
      DESCRIPTION: "Validated user role (Holder, Beneficiary, Payer, Non Client)"
    - invalidCount
      TYPE: number
      DESCRIPTION: "Number of failed ID validation attempts"
    - userValidation
      TYPE: boolean
      DESCRIPTION: "Primary validation flag — true when cédula is validated"
    - priorityTransfer
      TYPE: string
      DESCRIPTION: "Priority product flag (XPR, PCA, SAC, or NA)"
    - errorMessage
      TYPE: string
      DESCRIPTION: "Error message from API failures"
    - customerDetails
      TYPE: object
      DESCRIPTION: "Customer details returned by validate_user_id"
    - contractNumber
      TYPE: string
      DESCRIPTION: "Active contract number"
    - ticketId
      TYPE: string
      DESCRIPTION: "Active Zendesk ticket ID"
    - timeSlot
      TYPE: string
      DESCRIPTION: "Time-of-day greeting slot from user_validation"
    - title
      TYPE: string
      DESCRIPTION: "User title from user_validation"
    - surName
      TYPE: string
      DESCRIPTION: "User surname from user_validation"
    - customerName
      TYPE: string
      DESCRIPTION: "Customer display name from validation"
    - closeConversation
      TYPE: string
      DESCRIPTION: "Session termination flag (yes to close)"

# ─────────────────────────────────────────────────────────────────────────────
# FLOW — 7-step deterministic identity validation
# ─────────────────────────────────────────────────────────────────────────────

FLOW:
  entry_point: pre_check

  steps:
    - pre_check
    - greet_and_ask_cedula
    - validate_id
    - check_priority
    - validation_success
    - non_client_offer
    - session_closed

  global_digressions:
    REASONING: false
    - INTENT: "hablar_con_agente"
      RESPOND: "Le transfiero con un agente."
      GOTO: escalate_to_human

  # Step 1: Pre-check — validate user type by phone number
  pre_check:
    REASONING: false
    CALL: user_validation(telePhoneNum: session.phoneNumber, inboundNumber: session.inboundNumber, channel: session.channel, sessionId: session.sessionId)
    ON_SUCCESS:
      - IF: user_validation.userType IN ["Broker", "Director", "Business Representative"]
        RESPOND: "Este número está asociado a un perfil de Broker. Por favor utilice el número de WhatsApp correspondiente."
        SET: closeConversation = "yes"
        THEN: COMPLETE
      - ELSE:
        SET: userType = user_validation.userType
        SET: timeSlot = user_validation.timeSlot
        SET: title = user_validation.title
        SET: surName = user_validation.surName
        THEN: greet_and_ask_cedula

  # Step 2: Greet and collect cédula/passport
  greet_and_ask_cedula:
    REASONING: false
    RESPOND: "Hola, soy Samy, su asistente virtual de Saludsa.\n¿Me puede proporcionar su cédula o pasaporte?\nLa conversación se almacenará y monitoreará por seguridad."
    GATHER:
      - cedula
        TYPE: string
        ASK: ""
        VALIDATE: length >= 6
    THEN: prepare_validation

  # Step 2b: Prepare session data for validate_user body_template
  prepare_validation:
    REASONING: false
    SET: session.idCard = cedula
    THEN: validate_id

  # Step 3: Validate the provided ID against Saludsa backend
  validate_id:
    REASONING: false
    CALL: validate_user()
    ON_SUCCESS:
      - IF: validate_user.success == true
        SET: userValidation = true
        SET: userRole = validate_user.role
        SET: priorityTransfer = validate_user.priorityTransfer
        SET: contractNumber = validate_user.contractId
        SET: customerName = validate_user.customerName
        SET: ticketId = validate_user.ticketId
        SET: customerDetails = validate_user.customerDetails
        THEN: check_priority
      - ELSE IF: validate_user.apiError == true
        CALL: handle_service_failure()
        THEN: ESCALATE
      - ELSE:
        SET: invalidCount = invalidCount + 1
        - IF: invalidCount >= 2
          THEN: session_closed
        - ELSE:
          RESPOND: "Proporcione el número de identificación válido / número de pasaporte"
          GATHER:
            - cedula
              TYPE: string
              ASK: ""
          THEN: validate_id

  # Step 4: Check priority transfer before role validation
  # Uses noop() CALL because the compiler only supports IF/ELSE IF branches inside ON_SUCCESS.
  check_priority:
    REASONING: false
    CALL: noop()
    ON_SUCCESS:
      - IF: priorityTransfer IN ["XPR", "PCA", "SAC"]
        THEN: COMPLETE
      - IF: userRole == "Non Client"
        THEN: non_client_offer
      - ELSE:
        THEN: validation_success
    ON_FAIL:
      THEN: validation_success

  # Step 5: Validation success — user is Holder, Beneficiary, or Payer
  validation_success:
    REASONING: false
    RESPOND: "Gracias, su identidad ha sido validada. ¿En qué le puedo servir?"
    THEN: COMPLETE

  # Step 6: Non-client offer — ask if they want to buy a plan
  non_client_offer:
    REASONING: false
    RESPOND: "¿Quieres comprar un plan?"
    THEN: COMPLETE

  # Step 7: Session closed — too many failed attempts
  session_closed:
    REASONING: false
    RESPOND: "Para cuidar su seguridad y su información, hemos cerrado esta sesión luego de varios intentos fallidos. Puede volver a intentarlo más adelante."
    SET: closeConversation = "yes"
    THEN: COMPLETE

# ─────────────────────────────────────────────────────────────────────────────
# ESCALATION — API failures trigger transfer to SAC
# ─────────────────────────────────────────────────────────────────────────────

ESCALATE:
  triggers:
    - WHEN: apiError == true
      REASON: "API failure during validation"
      PRIORITY: high

# ─────────────────────────────────────────────────────────────────────────────
# ERROR HANDLING
# ─────────────────────────────────────────────────────────────────────────────

ON_ERROR:
  tool_error:
    RESPOND: "Lo sentimos, tenemos dificultades técnicas. Por favor intente más tarde."
    RETRY: 1
    THEN: ESCALATE

# ─────────────────────────────────────────────────────────────────────────────
# COMPLETION — silent returns to supervisor
# ─────────────────────────────────────────────────────────────────────────────

COMPLETE:
  - WHEN: userValidation == true
    RESPOND: ""
  - WHEN: closeConversation == "yes"
    RESPOND: ""
