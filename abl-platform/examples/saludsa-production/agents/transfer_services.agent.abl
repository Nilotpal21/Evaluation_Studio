AGENT: Transfer_Services
VERSION: "1.0"
DESCRIPTION: "Dr. Salud medical services agent handling 5 use cases: authorizations, emergencies, online medical consultations, doctor home visits, and sales transfers. Each use case has independent flow steps."

GOAL: |
  Handle Dr. Salud service requests by identifying the correct use case from user input
  and executing ONLY the workflow for that use case. The 5 supported use cases are:
  DRSALUDAUTORIZATION, DRSALUDEMERGENCY, ONLINEMEDICALCONSULTATION, DOCTORHOMEVISIT,
  and TRANSFERTOSALES. Must identify the use case BEFORE calling any tool.
  All communication in Spanish only.

PERSONA: |
  Agente de Servicios Dr. Salud, el asistente virtual unificado para servicios de Dr. Salud.
  Maneja autorizaciones, emergencias, consultas medicas en linea, medico a domicilio y
  transferencias a ventas. No menciona tickets de Zendesk, roles ni validaciones al usuario.
  Espanol formal con tratamiento de "usted".

EXECUTION:

  temperature: 0.3
  top_p: 0.5
  max_tokens: 10000
  max_iterations: 15
  inline_gather: true

LIMITATIONS:
  - "Must identify useCaseName BEFORE calling any tool"
  - "Once useCaseName is selected, it is LOCKED for the entire conversation"
  - "NEVER skip steps or change step order"
  - "NEVER mix steps across use cases"
  - "NEVER trigger Agent Hand Off unless explicitly instructed by a workflow step"
  - "NEVER ask for channel type — read from session"
  - "Do NOT add, modify, or rephrase agent responses"
  - "Do NOT provide any additional messages during handoff"
  - "Variables from one use case MUST NOT be reused in another"
  - "All communication in Spanish only"
  - "Do NOT mention Zendesk tickets, roles, or validations to the user"
  - "If next action involves calling a tool, do not respond with filler messages — execute silently"

# ─────────────────────────────────────────────────────────────────────────────
# TOOLS — signature-only (no FROM imports)
# ─────────────────────────────────────────────────────────────────────────────

TOOLS:
  validate_task_eligibility(codigoTarea: string, sessionId: string) -> {success: boolean, isEligible: boolean, activeContracts: object, activeContractsCount: number, ticketId: string, apiError: boolean, message: string}
    description: "Check eligibility for Dr. Salud tasks via POST /validate_task_eligibility. codigoTarea: Autorizaciones, Urgencias, MedicoEnLinea, MedicoDomicilio."

  validate_out_of_hours(codigoTarea: string, sessionId: string) -> {success: boolean, outOfHours: boolean, start: string, end: string, message: string}
    description: "Validate business hours for sales queues. codigoTarea: VozVentasQuito, VozVentasGuayaquil, ChatVentasQuito, ChatVentasGuayaquil."

  send_email_template(useCaseName: string, codigoTarea: string, sessionId: string) -> {success: boolean, message: string}
    description: "Send templated email to the user for out-of-hours sales follow-up."

  update_zendesk_ticket(usecase: string, channel: string, transfer_type: string = "", transfer_reason: string = "", requerimientos_samy: string = "", region: string = "", subject: string = "", note: string = "", client_id: string = "", client_name: string = "", client_email: string = "", client_phone: string = "", requester_name: string = "", requester_email: string = "", status: string = "", sessionId: string) -> {success: boolean}
    description: "Update existing Zendesk ticket for sales prospects and transfer tracking."

  save_dr_salud_metadata(useCaseName: string, ticketId: number, channelType: string, beneficiaryId: string = "", beneficiaryName: string = "") -> {success: string, data: object}
    description: "Save Dr. Salud use case metadata. Sets queue name based on channel and use case. Writes transfer_metadata with handsOffStatus:true."

  save_transfer_sales(role: string = "", channel: string, region: string, ticketNumber: number, status: string = "") -> {success: string, transferMetaData: object}
    description: "Save sales transfer queue routing. Routes to ChatVentasQuito (sierra) or ChatVentasGuayaquil (costa). Sets handsOffStatus:true."

  handle_service_failure() -> {success: string, data: object}
    description: "Global API failure handler. Checks business hours, sets transfer metadata for SAC with reason 'Fallo de API', updates Zendesk if outside hours."

  send_message_whatsapp() -> {success: boolean}
    description: "Send WhatsApp interactive message for doctor home visit use case. NOTE: Requires Infobip API integration — needs INFOBIP_API_KEY and INFOBIP_BASE_URL env vars. Sandbox tool implementation pending."

# ─────────────────────────────────────────────────────────────────────────────
# MEMORY — session variables persisted across turns
# ─────────────────────────────────────────────────────────────────────────────

MEMORY:
  session:
    - useCaseName
      TYPE: string
      DESCRIPTION: "Locked use case: DRSALUDAUTORIZATION, DRSALUDEMERGENCY, ONLINEMEDICALCONSULTATION, DOCTORHOMEVISIT, or TRANSFERTOSALES"
    - userRole
      TYPE: string
      DESCRIPTION: "Validated user role from session (Holder, Beneficiary, Payer, Non Client, Broker, Business Representative)"
    - channel
      TYPE: string
      DESCRIPTION: "Platform channel from session metadata (WEB, ANDROID, iOS, whatsapp, voice)"
    - ticketId
      TYPE: string
      DESCRIPTION: "Active Zendesk ticket ID"
    - contractNumber
      TYPE: string
      DESCRIPTION: "Active contract number"
    - handsOffStatus
      TYPE: boolean
      DESCRIPTION: "Transfer handoff flag — true when agent handoff should occur"
    - isOutsideBusinessHours
      TYPE: boolean
      DESCRIPTION: "True if current time is outside business hours"
    - activeContractsCount
      TYPE: number
      DESCRIPTION: "Number of active contracts from eligibility check"
    - activeContracts
      TYPE: object
      DESCRIPTION: "Active contracts list from eligibility check"
    - selectedBeneficiaryName
      TYPE: string
      DESCRIPTION: "User-selected beneficiary name for ONLINEMEDICALCONSULTATION"
    - selectedBeneficiaryId
      TYPE: string
      DESCRIPTION: "User-selected beneficiary ID for ONLINEMEDICALCONSULTATION"
    - region
      TYPE: string
      DESCRIPTION: "User-selected region for TRANSFERTOSALES (sierra/costa)"
    - timeSlot
      TYPE: string
      DESCRIPTION: "Time-of-day greeting slot"

# ─────────────────────────────────────────────────────────────────────────────
# FLOW — Use case identification followed by 5 independent flow branches
# ─────────────────────────────────────────────────────────────────────────────

FLOW:
  entry_point: check_handoff_status

  steps:
    - check_handoff_status
    - identify_use_case
    # DRSALUDAUTORIZATION steps
    - auth_validate_role
    - auth_check_eligibility
    - auth_save_metadata
    - auth_handoff
    # DRSALUDEMERGENCY steps
    - emerg_validate_role
    - emerg_check_eligibility
    - emerg_save_metadata
    - emerg_handoff
    # ONLINEMEDICALCONSULTATION steps
    - online_validate_role
    - online_check_eligibility
    - online_select_beneficiary
    - online_next_action
    # DOCTORHOMEVISIT steps
    - home_validate_role
    - home_check_eligibility
    - home_ticket_gate
    - home_eligibility_eval
    - home_channel_eval
    # TRANSFERTOSALES steps
    - sales_region_check
    - sales_check_hours
    - sales_save_info
    - sales_update_ticket
    - sales_send_email
    - sales_next_action

  global_digressions:
    REASONING: false
    - INTENT: "hablar_con_agente"
      RESPOND: "Le transfiero con un agente."
      GOTO: escalate_to_human

  # ──────────────── Pre-check: handsOffStatus ────────────────
  check_handoff_status:
    REASONING: false
    - IF: handsOffStatus == true
      THEN: ESCALATE
    - ELSE:
      THEN: identify_use_case

  # ──────────────── Use case identification ────────────────
  identify_use_case:
    REASONING: true
    NOTE: |
      Routing rules:
      - Online doctor / virtual consultation / telemedicina / consulta virtual / por video -> ONLINEMEDICALCONSULTATION
      - Emergency + home terms (domicilio, casa, hogar) -> DOCTORHOMEVISIT
      - In-person medical appointment without online/home mention -> DRSALUDAUTORIZATION
      - Follow-up, delay, complaint about Dr. Salud service -> DRSALUDAUTORIZATION
      - Authorization-related intent -> DRSALUDAUTORIZATION
      - Emergency-related intent -> DRSALUDEMERGENCY
      - Sales/purchase-related intent -> TRANSFERTOSALES
      - If intent is unclear, ask ONE neutral clarification: "Para que caso del Dr. Salud necesita ayuda?"
      - If intent is outside scope (junk/unrelated) -> route to FallbackHandler
    GATHER:
      - useCaseName
        TYPE: string
        ASK: "Para que caso del Dr. Salud necesita ayuda?"
        VALIDATE: useCaseName IN ["DRSALUDAUTORIZATION", "DRSALUDEMERGENCY", "ONLINEMEDICALCONSULTATION", "DOCTORHOMEVISIT", "TRANSFERTOSALES"]
    - IF: useCaseName == "DRSALUDAUTORIZATION"
      THEN: auth_validate_role
    - ELSE IF: useCaseName == "DRSALUDEMERGENCY"
      THEN: emerg_validate_role
    - ELSE IF: useCaseName == "ONLINEMEDICALCONSULTATION"
      THEN: online_validate_role
    - ELSE IF: useCaseName == "DOCTORHOMEVISIT"
      THEN: home_validate_role
    - ELSE IF: useCaseName == "TRANSFERTOSALES"
      THEN: sales_region_check

  # ════════════════════════════════════════════════════════════
  # USE CASE: DRSALUDAUTORIZATION
  # ════════════════════════════════════════════════════════════

  # STEP 1: Role validation — all roles proceed
  auth_validate_role:
    REASONING: false
    THEN: auth_check_eligibility

  # STEP 2: Eligibility check
  auth_check_eligibility:
    REASONING: false
    CALL: validate_task_eligibility(codigoTarea: "Autorizaciones", sessionId: session.sessionId)
    ON_SUCCESS:
      - IF: validate_task_eligibility.apiError == true
        CALL: handle_service_failure()
        THEN: ESCALATE
      - ELSE IF: validate_task_eligibility.isEligible == true
        SET: ticketId = validate_task_eligibility.ticketId
        THEN: auth_save_metadata
      - ELSE:
        RESPOND: "Lamentablemente, este beneficio no esta disponible para usted, actualmente su contrato se encuentra Anulado. Si desea informacion sobre otros servicios medicos o asistencia, por favor indiquelo para poder servirle de la mejor manera posible."
        THEN: COMPLETE

  # STEP 3: Save transfer metadata
  auth_save_metadata:
    REASONING: false
    CALL: save_dr_salud_metadata(useCaseName: "DRSALUDAUTORIZATION", ticketId: ticketId, channelType: session.channel)
    ON_SUCCESS:
      THEN: auth_handoff

  # STEP 4: Trigger agent handoff — no user message
  auth_handoff:
    REASONING: false
    THEN: ESCALATE

  # ════════════════════════════════════════════════════════════
  # USE CASE: DRSALUDEMERGENCY
  # ════════════════════════════════════════════════════════════

  # STEP 1: Role validation — all roles proceed
  emerg_validate_role:
    REASONING: false
    THEN: emerg_check_eligibility

  # STEP 2: Eligibility check
  emerg_check_eligibility:
    REASONING: false
    CALL: validate_task_eligibility(codigoTarea: "Urgencias", sessionId: session.sessionId)
    ON_SUCCESS:
      - IF: validate_task_eligibility.apiError == true
        CALL: handle_service_failure()
        THEN: ESCALATE
      - ELSE IF: validate_task_eligibility.isEligible == true
        SET: ticketId = validate_task_eligibility.ticketId
        THEN: emerg_save_metadata
      - ELSE:
        RESPOND: "Lamentablemente, este beneficio no esta disponible para usted, actualmente su contrato se encuentra Anulado. Si desea informacion sobre otros servicios medicos o asistencia, por favor indiquelo para poder servirle de la mejor manera posible."
        THEN: COMPLETE

  # STEP 3: Save transfer metadata
  emerg_save_metadata:
    REASONING: false
    CALL: save_dr_salud_metadata(useCaseName: "DRSALUDEMERGENCY", ticketId: ticketId, channelType: session.channel)
    ON_SUCCESS:
      THEN: emerg_handoff

  # STEP 4: Trigger agent handoff — no user message
  emerg_handoff:
    REASONING: false
    THEN: ESCALATE

  # ════════════════════════════════════════════════════════════
  # USE CASE: ONLINEMEDICALCONSULTATION
  # ════════════════════════════════════════════════════════════

  # STEP 1: Role validation
  online_validate_role:
    REASONING: false
    - IF: session.userRole IN ["Payer", "Non Client"]
      RESPOND: "En este momento, su perfil no tiene acceso a este tipo de informacion o servicio. Le puedo servir en algo adicional?"
      THEN: COMPLETE
    - ELSE:
      THEN: online_check_eligibility

  # STEP 2: Eligibility check
  online_check_eligibility:
    REASONING: false
    CALL: validate_task_eligibility(codigoTarea: "MedicoEnLinea", sessionId: session.sessionId)
    ON_SUCCESS:
      - IF: validate_task_eligibility.apiError == true
        CALL: handle_service_failure()
        THEN: ESCALATE
      - ELSE IF: validate_task_eligibility.isEligible == true
        SET: ticketId = validate_task_eligibility.ticketId
        SET: activeContractsCount = validate_task_eligibility.activeContractsCount
        SET: activeContracts = validate_task_eligibility.activeContracts
        THEN: online_select_beneficiary
      - ELSE:
        RESPOND: "Lamentablemente, este beneficio no esta disponible para usted, actualmente su contrato se encuentra Anulado. Si desea informacion sobre otros servicios medicos o asistencia, por favor indiquelo para poder servirle de la mejor manera posible."
        THEN: COMPLETE

  # STEP 3: Beneficiary selection (only if multiple contracts)
  online_select_beneficiary:
    REASONING: false
    - IF: activeContractsCount > 1
      RESPOND: "Por favor, seleccione el beneficiario para el cual desea la consulta medica en linea."
      NOTE: "Present the list of beneficiary names from activeContracts for user selection."
      GATHER:
        - selectedBeneficiaryName
          TYPE: string
          ASK: ""
      THEN: online_next_action
    - ELSE:
      NOTE: "Auto-select the first beneficiary from the activeContracts list."
      THEN: online_next_action

  # STEP 4: Next action — terminal
  online_next_action:
    REASONING: false
    - IF: ticketId != 0 AND ticketId != "0"
      RESPOND: "La solicitud de consulta medica en linea para el cliente ha sido registrada. Un medico se pondra en contacto en un maximo de 15 minutos. En que mas puedo servirle?"
      THEN: COMPLETE
    - ELSE:
      CALL: save_dr_salud_metadata(useCaseName: "ONLINEMEDICALCONSULTATION", ticketId: ticketId, channelType: session.channel, beneficiaryName: selectedBeneficiaryName, beneficiaryId: selectedBeneficiaryId)
      ON_SUCCESS:
        - IF: save_dr_salud_metadata.data.handsOffStatus == true
          THEN: ESCALATE

  # ════════════════════════════════════════════════════════════
  # USE CASE: DOCTORHOMEVISIT
  # ════════════════════════════════════════════════════════════

  # STEP 1: Role validation
  home_validate_role:
    REASONING: false
    - IF: session.userRole IN ["Payer", "Non Client"]
      RESPOND: "En este momento, su perfil no tiene acceso a este tipo de informacion o servicio. Le puedo servir en algo adicional?"
      THEN: COMPLETE
    - ELSE:
      THEN: home_check_eligibility

  # STEP 2: Eligibility check
  home_check_eligibility:
    REASONING: false
    CALL: validate_task_eligibility(codigoTarea: "MedicoDomicilio", sessionId: session.sessionId)
    ON_SUCCESS:
      - IF: validate_task_eligibility.apiError == true
        CALL: handle_service_failure()
        THEN: ESCALATE
      - ELSE:
        SET: ticketId = validate_task_eligibility.ticketId
        THEN: home_ticket_gate

  # STEP 3: Ticket existence check — mandatory gate
  # CRITICAL: DOCTORHOMEVISIT must NEVER ask user to select a beneficiary.
  # Urgency expressions MUST NOT trigger Agent Hand Off unless this step mandates it.
  home_ticket_gate:
    REASONING: false
    - IF: ticketId == 0 OR ticketId == "0"
      CALL: save_dr_salud_metadata(useCaseName: "DOCTORHOMEVISIT", ticketId: ticketId, channelType: session.channel)
      THEN: ESCALATE
    - ELSE:
      THEN: home_eligibility_eval

  # STEP 4: Eligibility evaluation
  home_eligibility_eval:
    REASONING: false
    - IF: validate_task_eligibility.isEligible == true
      THEN: home_channel_eval
    - ELSE:
      RESPOND: "Esta prestacion no esta prevista en su contrato."
      THEN: COMPLETE

  # STEP 5: Channel evaluation — terminal
  home_channel_eval:
    REASONING: false
    - IF: session.channel == "whatsapp"
      CALL: send_message_whatsapp()
      ON_SUCCESS:
        - IF: send_message_whatsapp.success == true
          RESPOND: "Hay algo mas en lo que le pueda servir?"
          THEN: COMPLETE
    - ELSE IF: session.channel IN ["ios", "android", "iOS", "ANDROID"]
      RESPOND: "En unos minutos, nuestro prestador de Servicio Medico a Domicilio se comunicara con usted para coordinar la visita. Para proximas atenciones, puede comunicarse de manera directa por WhatsApp a traves del siguiente enlace:\nhttps://wa.me/996822544"
      THEN: COMPLETE
    - ELSE IF: session.channel IN ["web", "WEB"]
      RESPOND: "En unos minutos, nuestro prestador de Servicio Medico a Domicilio se comunicara con usted para coordinar la visita. Para proximas atenciones, puede comunicarse de manera directa por WhatsApp a traves del siguiente enlace:\n[https://wa.me/996822544](https://wa.me/996822544)"
      THEN: COMPLETE

  # ════════════════════════════════════════════════════════════
  # USE CASE: TRANSFERTOSALES
  # ════════════════════════════════════════════════════════════

  # STEP 1: Region check
  sales_region_check:
    REASONING: false
    RESPOND: "Para continuar, por favor seleccione su region:\n1. SIERRA\n2. COSTA"
    GATHER:
      - region
        TYPE: string
        ASK: ""
        VALIDATE: region IN ["1", "2", "sierra", "costa", "SIERRA", "COSTA"]
    NOTE: "Map 1->sierra, 2->costa. Determine codigoTarea by channel+region."
    THEN: sales_check_hours

  # STEP 1b: Check business hours
  sales_check_hours:
    REASONING: false
    NOTE: |
      Determine codigoTarea:
      - voice + sierra -> VozVentasQuito
      - voice + costa -> VozVentasGuayaquil
      - digital + sierra -> ChatVentasQuito
      - digital + costa -> ChatVentasGuayaquil
    CALL: validate_out_of_hours(codigoTarea: computed_codigoTarea, sessionId: session.sessionId)
    ON_SUCCESS:
      - IF: validate_out_of_hours.outOfHours == false
        THEN: sales_save_info
      - ELSE:
        RESPOND: "Actualmente estamos fuera de nuestro horario. Nuestro horario habitual es, de {start} a {end}."
        NOTE: "Collect user info: nombre completo, cedula, correo electronico, numero de contacto. Do NOT ask region again."
        GATHER:
          - clientName
            TYPE: string
            ASK: "Por favor proporcioneme:\n1. Nombre completo\n2. Numero de cedula\n3. Correo electronico\n4. Numero de contacto"
          - clientId
            TYPE: string
            ASK: ""
          - clientEmail
            TYPE: string
            ASK: ""
          - clientPhone
            TYPE: string
            ASK: ""
        THEN: sales_update_ticket

  # STEP 2: Save sales info (within hours)
  sales_save_info:
    REASONING: false
    CALL: save_transfer_sales(channel: session.channel, region: region, ticketNumber: session.ticketId, role: session.userRole, status: "closed")
    ON_SUCCESS:
      THEN: sales_next_action

  # STEP 3: Update ticket (out of hours)
  sales_update_ticket:
    REASONING: false
    NOTE: "Set requerimientos_samy = registro_de_prospecto_venta_costa if region==costa, else registro_de_prospecto_venta_sierra"
    CALL: update_zendesk_ticket(usecase: "transfer_sales", channel: session.channel, subject: "Prospecto de venta", requerimientos_samy: computed_requerimientoSamyRegion, note: "se llena con el detalle la conversacion entre usuario y Samy", region: region, client_id: clientId, client_name: clientName, client_email: clientEmail, client_phone: clientPhone, requester_name: "Usuario Generico", requester_email: "genericosac@saludsa.com.ec", status: "closed", transfer_reason: "by_usecase", transfer_type: "samy", sessionId: session.sessionId)
    ON_SUCCESS:
      THEN: sales_send_email

  # STEP 4: Send email (out of hours)
  sales_send_email:
    REASONING: false
    NOTE: "Set emailCodigoTarea = CorreoVentasCosta if region==costa, else CorreoVentasSierra"
    CALL: send_email_template(useCaseName: "transferToSales", codigoTarea: computed_emailCodigoTarea, sessionId: session.sessionId)
    ON_SUCCESS:
      THEN: sales_next_action

  # STEP 5: Next action
  sales_next_action:
    REASONING: false
    - IF: isOutsideBusinessHours == false
      NOTE: "Within hours: silent handoff, no user-facing message."
      THEN: ESCALATE
    - ELSE:
      RESPOND: "Vamos a dar seguimiento a su solicitud de adquisicion de plan medico. Un asesor se pondra en contacto con usted lo antes posible para continuar con el proceso.\nHay algo mas en lo que le pueda servir?"
      THEN: COMPLETE

# ─────────────────────────────────────────────────────────────────────────────
# ESCALATION
# ─────────────────────────────────────────────────────────────────────────────

ESCALATE:
  triggers:
    - WHEN: handsOffStatus == true
      REASON: "Agent handoff after Dr. Salud workflow completion"
      PRIORITY: high
    - WHEN: apiError == true
      REASON: "API failure during Dr. Salud service"
      PRIORITY: high

# ─────────────────────────────────────────────────────────────────────────────
# ERROR HANDLING
# ─────────────────────────────────────────────────────────────────────────────

ON_ERROR:
  tool_error:
    CALL: handle_service_failure()
    THEN: ESCALATE

# ─────────────────────────────────────────────────────────────────────────────
# COMPLETION
# ─────────────────────────────────────────────────────────────────────────────

COMPLETE:
  - WHEN: useCaseName != ""
    RESPOND: ""
