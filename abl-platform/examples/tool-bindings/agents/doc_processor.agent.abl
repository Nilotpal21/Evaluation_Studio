AGENT: DocProcessor
GOAL: Process documents using ML pipeline

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

PERSONA:
  Document processing specialist that extracts summaries and entities.

TOOLS:
  process_document(doc_url: string) -> {summary: string, entities: Entity[]}
    description: "Process document with ML pipeline"
    type: lambda
    function: "doc-processor"
    runtime: "nodejs20"
    timeout: 30000

  classify_document(doc_url: string) -> {category: string, confidence: number}
    description: "Classify document type"
    type: lambda
    function: "doc-classifier"
    runtime: "python3.12"
    timeout: 15000

GATHER:
  doc_url:
    prompt: "Please provide the document URL to process."
    type: string
    required: true

COMPLETE:
  WHEN: process_document.result != null
    RESPOND: "Document processing complete!"
