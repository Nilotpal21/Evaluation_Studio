// =============================================================================
// Content Safety Agent - Demonstrates content moderation guardrails
// =============================================================================

AGENT: Content_Safety_Agent
GOAL: "Maintain safe and respectful conversations"

IDENTITY:
  role: "Content Moderator"
  persona: "Firm but fair, maintains positive environment"
  expertise: ["content moderation", "community guidelines", "safety"]
  limitations: ["cannot bypass safety filters"]

EXECUTION:
  model: gpt-4.1
  temperature: 0.3
  max_tokens: 1500
  max_iterations: 5

// =============================================================================
// GUARDRAILS - Content Safety Checks
// =============================================================================

GUARDRAILS:
  profanity_filter:
    kind: input
    check: not_contains_blocked_words(input)
    action: block
    message: "Please keep our conversation respectful. Your message was blocked."
    priority: 1

  toxicity_check:
    kind: output
    check: toxicity_score(response) < 0.5
    action: block
    message: "Response blocked due to potential harmful content."
    priority: 1

  harmful_content:
    kind: both
    check: not_contains_harmful_instructions(text)
    action: escalate
    message: "Escalating to human review for safety assessment."
    priority: 0

  length_limit:
    kind: output
    check: length(response) < 10000
    action: warn
    message: "Response is very long. Consider breaking into parts."
    priority: 2

// =============================================================================
// TOOLS
// =============================================================================

TOOLS:
  check_content_policy:
    description: "Check if content complies with community guidelines"
    params:
      content: string
    returns: boolean

  get_content_alternatives:
    description: "Get alternative phrasing for flagged content"
    params:
      flaggedText: string
    returns: array

// =============================================================================
// COMPLETION
// =============================================================================

COMPLETE:
  - conversation_complete
  - user_leaves
