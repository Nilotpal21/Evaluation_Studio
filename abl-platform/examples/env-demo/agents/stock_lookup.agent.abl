AGENT: Stock_Lookup
VERSION: "2.0"
DESCRIPTION: "Looks up stock prices and market news using external APIs configured via environment variables"
GOAL: "Help users check stock prices and read market news using API services configured through environment variables"

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

PERSONA: |
  Helpful financial assistant that provides stock quotes and market news.
  Always shows the data source and disclaims that prices may be delayed.

LIMITATIONS:
  - "Prices may be delayed up to 15 minutes"
  - "Not financial advice — for informational purposes only"
  - "Cannot execute trades"

# ─────────────────────────────────────────────────────────────────────────────
# TOOLS — HTTP bindings with {{env.X}} placeholders
#
# These tools demonstrate environment variables:
#   {{env.STOCK_API_URL}}   — Base URL for the stock price API (per-environment)
#   {{env.STOCK_API_KEY}}   — API key (secret, per-environment)
#   {{env.NEWS_API_URL}}    — Base URL for the news API (per-environment)
#   {{env.NEWS_API_KEY}}    — API key for news (secret, per-environment)
#   {{env.CLIENT_NAME}}     — Non-secret identifier shown in request headers
#
# In Studio → Deployments → Environments, set these for dev / staging / prod.
# The runtime resolves {{env.X}} at request time via the SecretsProvider chain.
# ─────────────────────────────────────────────────────────────────────────────

TOOLS:
  get_stock_quote(symbol: string) -> {symbol: string, price: number, change: number, change_pct: number, volume: number, currency: string}
    description: "Get the current price quote for a stock symbol"
    type: http
    endpoint: "{{env.STOCK_API_URL}}/v1/quote"
    method: GET
    headers:
      X-Api-Key: "{{env.STOCK_API_KEY}}"
      X-Client-Name: "{{env.CLIENT_NAME}}"
    timeout: 5000

  get_market_news(topic: string, limit: number = 5) -> {articles: object[]}
    description: "Search for recent market news articles on a topic"
    type: http
    endpoint: "{{env.NEWS_API_URL}}/v1/search"
    method: GET
    headers:
      X-Api-Key: "{{env.NEWS_API_KEY}}"
      X-Client-Name: "{{env.CLIENT_NAME}}"
    timeout: 5000

  get_market_summary() -> {indices: object[], trending: string[], market_status: string}
    description: "Get an overview of major market indices and trending tickers"
    type: http
    endpoint: "{{env.STOCK_API_URL}}/v1/market/summary"
    method: GET
    headers:
      X-Api-Key: "{{env.STOCK_API_KEY}}"
      X-Client-Name: "{{env.CLIENT_NAME}}"
    timeout: 5000

GATHER:
  symbol:
    prompt: "Which stock symbol would you like to look up? (e.g., AAPL, TSLA, GOOGL)"
    type: string
    required: false

MEMORY:
  session:
    - last_symbol
    - last_quote

COMPLETE:
  - WHEN: user.done == true
    RESPOND: "Happy investing! Remember — this is not financial advice."

ON_ERROR:
  tool_timeout:
    RESPOND: "The market data service is slow right now. Let me try again..."
    RETRY: 1
    THEN: CONTINUE

  tool_error:
    RESPOND: "I had trouble reaching the market data service. This may mean the API environment variables are not configured. Please check your deployment environment variables in Studio."
    RETRY: 0
    THEN: CONTINUE
