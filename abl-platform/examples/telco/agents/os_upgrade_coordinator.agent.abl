AGENT: OS_Upgrade_Coordinator
VERSION: "1.0"
DESCRIPTION: "Specialist agent for coordinating large-scale OS upgrades across the network using canary deployment strategy with automated health verification and rollback"
GOAL: "Plan and execute safe OS upgrades across hundreds of sites using canary strategy with automated health checks and rollback capability"

PERSONA: |
  Senior network deployment engineer specializing in large-scale rollouts.
  Extremely cautious — always uses canary strategy and verifies health before proceeding.
  Automatically triggers rollback on any health check failure.

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Cannot upgrade sites with active P1/P2 incidents"
  - "Cannot skip canary phase — minimum 5 sites must pass before broader rollout"
  - "Cannot override health check failures — must rollback and investigate"
  - "Upgrades only during maintenance windows (02:00-06:00 IST)"

TOOLS:
  get_upgrade_candidates(region: string, current_os: string, target_os: string) -> {candidates: array, total_eligible: number}
    description: "Identify sites eligible for OS upgrade"
    type: http
    endpoint: "http://localhost:4100/api/tools/get_upgrade_candidates"
    method: POST
    auth: bearer

  create_upgrade_plan(target_os: string, strategy: string = "canary") -> {plan_id: string, phases: array, total_sites: number}
    description: "Create a phased upgrade plan with rollback criteria"
    type: http
    endpoint: "http://localhost:4100/api/tools/create_upgrade_plan"
    method: POST
    auth: bearer

  execute_upgrade_batch(plan_id: string, batch: number) -> {status: string, sites_succeeded: number, sites_failed: number}
    description: "Execute an upgrade batch within a plan"
    type: http
    endpoint: "http://localhost:4100/api/tools/execute_upgrade_batch"
    method: POST
    auth: bearer

  verify_upgrade_health(site_code: string) -> {health_check: object, overall_status: string, rollback_recommended: boolean}
    description: "Run post-upgrade health verification on a site"
    type: http
    endpoint: "http://localhost:4100/api/tools/verify_upgrade_health"
    method: POST
    auth: bearer

  rollback_upgrade(site_code: string, reason: string) -> {status: string, rolled_back_to: string}
    description: "Rollback a site to previous OS version"
    type: http
    endpoint: "http://localhost:4100/api/tools/rollback_upgrade"
    method: POST
    auth: bearer

  send_notification(type: string, recipients: array, subject: string) -> {notification_id: string, status: string}
    description: "Send upgrade status notifications"
    type: http
    endpoint: "http://localhost:4100/api/tools/send_notification"
    method: POST
    auth: bearer

FLOW:
  steps:
    - scope
    - plan
    - approve
    - execute_canary
    - verify_canary
    - execute_rollout
    - report

  scope:
    REASONING: false
    GATHER:
      - region: required
        prompt: "Which region should we upgrade? (e.g., Mumbai, Delhi, all)"
      - target_os: required
        prompt: "Target OS version? (e.g., v24.1.0)"
      - current_os:
        prompt: "Current OS to upgrade from? (e.g., v23.4.1)"
        default: "v23.4.1"

    CALL: get_upgrade_candidates(region, current_os, target_os)
    ON_SUCCESS:
      RESPOND: |
        Upgrade Scope:
        - Region: {{region}}
        - Target OS: {{target_os}}
        - Eligible Sites: {{total_eligible}}
        - Excluded: {{total_excluded}} (active alarms: {{exclusion_reasons.active_alarms}}, recent maintenance: {{exclusion_reasons.recent_maintenance}}, manual hold: {{exclusion_reasons.manual_hold}})
      THEN: plan
    ON_FAIL:
      RESPOND: "Unable to query upgrade candidates. Check NMS connectivity."
      THEN: COMPLETE

  plan:
    REASONING: false
    CALL: create_upgrade_plan(target_os, "canary")
    ON_SUCCESS:
      RESPOND: |
        Upgrade Plan Created: {{plan_id}}
        Strategy: Canary → Early Adopter → General Rollout
        {{#each phases}}
        Phase {{phase}}: {{name}} — {{sites}} sites ({{start}}, {{duration_hours}}h)
        {{/each}}
        Rollback Criteria:
        - Health check failures: ≥{{rollback_criteria.health_check_failures}}
        - KPI degradation: ≥{{rollback_criteria.kpi_degradation_pct}}%
        - Subscriber complaints: ≥{{rollback_criteria.subscriber_complaints}}
      THEN: approve
    ON_FAIL:
      RESPOND: "Failed to create upgrade plan."
      THEN: COMPLETE

  approve:
    REASONING: false
    GATHER:
      - approval: required
        prompt: "Approve upgrade plan {{plan_id}}? (approve/reject)"
    ON_INPUT:
      - IF: approval == "approve" OR approval == "yes"
        RESPOND: "Plan approved. Starting canary phase..."
        THEN: execute_canary
      - ELSE:
        RESPOND: "Upgrade plan rejected. No changes made."
        THEN: COMPLETE

  execute_canary:
    REASONING: false
    RESPOND: "Executing canary batch (5 sites)..."
    CALL: execute_upgrade_batch(plan_id, 1)
    ON_SUCCESS:
      RESPOND: |
        Canary Batch Complete:
        - Attempted: {{sites_attempted}}
        - Succeeded: {{sites_succeeded}}
        - Failed: {{sites_failed}}
        Running health verification...
      THEN: verify_canary
    ON_FAIL:
      RESPOND: "Canary batch execution failed. Aborting upgrade campaign."
      THEN: COMPLETE

  verify_canary:
    REASONING: false
    CALL: verify_upgrade_health(canary_sites[0])
    ON_SUCCESS:
      - IF: overall_status == "healthy" AND rollback_recommended == false
        RESPOND: |
          Canary Health Check: PASSED
          - System: {{health_check.system.status}}
          - Radio: {{health_check.radio.status}}
          - Transport: {{health_check.transport.status}}
          - KPI Impact: {{health_check.kpi_comparison.status}}
          Proceeding with general rollout...
        THEN: execute_rollout
      - IF: rollback_recommended == true
        RESPOND: |
          Canary Health Check: FAILED
          Rolling back canary sites...
        CALL: rollback_upgrade(canary_sites[0], "Health check failure during canary phase")
        RESPOND: "Rollback complete. Upgrade campaign aborted. Investigation required."
        THEN: COMPLETE
    ON_FAIL:
      RESPOND: "Health verification failed. Rolling back as precaution."
      THEN: COMPLETE

  execute_rollout:
    REASONING: false
    RESPOND: "Executing general rollout (remaining batches)..."
    CALL: execute_upgrade_batch(plan_id, 2)
    ON_SUCCESS:
      RESPOND: |
        Rollout Progress:
        - Batch 2: {{sites_succeeded}}/{{sites_attempted}} succeeded
        {{#if sites_failed > 0}}
        ⚠ {{sites_failed}} sites failed — auto-rolled back
        {{/if}}
      THEN: report
    ON_FAIL:
      RESPOND: "Rollout batch failed. Pausing campaign."
      THEN: report

  report:
    REASONING: false
    CALL: send_notification("email", ["noc-team@telco.in", "network-eng@telco.in"], "OS Upgrade Campaign Report: " + plan_id)
    RESPOND: |
      Upgrade Campaign Report:
      - Plan: {{plan_id}}
      - Target OS: {{target_os}}
      - Total Sites Upgraded: {{total_succeeded}}
      - Failed/Rolled Back: {{total_failed}}
      - Campaign Status: {{campaign_status}}
      - Notification sent to engineering team.
    THEN: COMPLETE

CONSTRAINTS:
  pre_execute:
    - REQUIRE approval == "approve"
      ON_FAIL: "Upgrade requires explicit approval before execution."

COMPLETE:
  - WHEN: campaign_complete == true
    RESPOND: "OS Upgrade Campaign {{plan_id}} complete. Report generated."

ON_ERROR:
  tool_error:
    RESPOND: "Upgrade system error. Pausing all activities for safety."
    RETRY: 0
    THEN: ESCALATE

  tool_timeout:
    RESPOND: "Upgrade system timeout. Verifying site health before proceeding..."
    RETRY: 1
    THEN: ESCALATE
