AGENT: Network_Triage
VERSION: "1.0"
DESCRIPTION: "First-line triage agent that assesses incoming alarms, gathers details, classifies severity, and routes to the appropriate specialist"
GOAL: "Rapidly assess and classify network alarms, then route to the correct specialist agent"

PERSONA: |
  Experienced L1 NOC analyst who quickly triages incoming alarms.
  Methodical and thorough — always gathers full context before classifying.
  Uses standard telecom severity classifications (P1-P4).

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

TOOLS:
  get_alarm_details(alarm_id: string) -> {alarm_id: string, severity: string, category: string, site: object, equipment: object, metrics: object, affected_links: array}
    description: "Get full details of an alarm including site, equipment, and metrics"
    type: http
    endpoint: "http://localhost:4100/api/tools/get_alarm_details"
    method: POST
    auth: bearer

  get_site_inventory(site_code: string) -> {site_code: string, equipment: array, technologies: array}
    description: "Get equipment inventory for a site"
    type: http
    endpoint: "http://localhost:4100/api/tools/get_site_inventory"
    method: POST
    auth: bearer

  get_affected_services(site_code: string) -> {affected_subscribers: number, enterprise_customers: array, sla_risk: object}
    description: "Determine subscriber and service impact"
    type: http
    endpoint: "http://localhost:4100/api/tools/get_affected_services"
    method: POST
    auth: bearer

  acknowledge_alarm(alarm_id: string, operator: string, notes: string) -> {acknowledged: boolean}
    description: "Acknowledge an alarm in the NMS"
    type: http
    endpoint: "http://localhost:4100/api/tools/acknowledge_alarm"
    method: POST
    auth: bearer

MEMORY:
  session:
    - alarm_id
    - severity
    - category
    - site_code
    - site_name
    - region
    - equipment_type
    - affected_links
    - affected_subscribers
    - sla_risk
    - routing_complete
    - target_agent

GATHER:
  alarm_id:
    prompt: "What alarm ID should I triage?"
    type: string
    required: true

FLOW:
  steps:
    - assess_alarm
    - get_alarm_details_step
    - get_site_inventory_step
    - get_affected_services_step
    - classify
    - route

  assess_alarm:
    REASONING: false
    RESPOND: |
      Triaging alarm {{alarm_id}}...
      Retrieving alarm details and site information.
    THEN: get_alarm_details_step

  get_alarm_details_step:
    REASONING: false
    CALL: get_alarm_details
      WITH:
        alarm_id: alarm_id
      AS: alarmResult
    ON_SUCCESS:
      SET:
        severity = alarmResult.severity
        category = alarmResult.category
        site_code = alarmResult.site.code
        site_name = alarmResult.site.name
        region = alarmResult.site.region
        equipment_type = alarmResult.equipment.type
        affected_links = alarmResult.affected_links
      THEN: get_site_inventory_step
    ON_FAIL:
      RESPOND: "Unable to retrieve alarm details. Escalating to supervisor."
      THEN: COMPLETE

  get_site_inventory_step:
    REASONING: false
    CALL: get_site_inventory
      WITH:
        site_code: site_code
      AS: inventoryResult
    ON_SUCCESS:
      THEN: get_affected_services_step
    ON_FAIL:
      RESPOND: "Site inventory is unavailable. Continuing with alarm details."
      THEN: get_affected_services_step

  get_affected_services_step:
    REASONING: false
    CALL: get_affected_services
      WITH:
        site_code: site_code
      AS: servicesResult
    ON_SUCCESS:
      SET:
        affected_subscribers = servicesResult.affected_subscribers
        sla_risk = servicesResult.sla_risk
      RESPOND: |
        Alarm Assessment:
        - Alarm: {{alarm_id}} ({{severity}})
        - Site: {{site_code}} — {{site_name}}
        - Category: {{category}}
        - Equipment: {{equipment_type}}
        - Affected Subscribers: {{affected_subscribers}}
        - SLA Risk: {{sla_risk.platinum_breach_eta_min}} min to platinum breach
      THEN: classify
    ON_FAIL:
      RESPOND: "Partial data retrieved. Proceeding with available information."
      THEN: classify

  classify:
    REASONING: false
    CALL: acknowledge_alarm
      WITH:
        alarm_id: alarm_id
        operator: "Network_Triage_Agent"
        notes: "Auto-triaged — classifying and routing"
      AS: acknowledgeResult
    RESPOND: |
      Classification complete:
      {{#if severity == "critical"}}
      PRIORITY: P1 — Critical service impact. Immediate specialist attention required.
      {{/if}}
      {{#if severity == "major"}}
      PRIORITY: P2 — Significant degradation. Specialist attention within 30 minutes.
      {{/if}}
      {{#if severity == "minor"}}
      PRIORITY: P3 — Minor issue. Scheduled specialist review.
      {{/if}}
      Routing to appropriate specialist...
    THEN: route

  route:
    REASONING: false
    ON_INPUT:
      - IF: category == "link_degradation" OR category == "fiber_cut"
        SET:
          target_agent = "Link_Analyzer"
          routing_complete = true
        RESPOND: "Routing to Link Analyzer for transport diagnostics."
        THEN: COMPLETE
      - IF: category == "capacity_threshold" OR category == "congestion"
        SET:
          target_agent = "Capacity_Planner"
          routing_complete = true
        RESPOND: "Routing to Capacity Planner for traffic analysis."
        THEN: COMPLETE
      - IF: category == "hardware_warning" OR category == "power_failure"
        SET:
          target_agent = "Maintenance_Scheduler"
          routing_complete = true
        RESPOND: "Routing to Maintenance Scheduler for hardware assessment."
        THEN: COMPLETE
      - IF: category == "interference"
        SET:
          target_agent = "Link_Analyzer"
          routing_complete = true
        RESPOND: "Routing to Link Analyzer for RF analysis."
        THEN: COMPLETE
      - ELSE:
        RESPOND: "Category not matched to specialist. Escalating to supervisor."
        THEN: COMPLETE

HANDOFF:
  - TO: Link_Analyzer
    WHEN: category == "link_degradation" OR category == "fiber_cut" OR category == "interference"
    CONTEXT:
      pass: [alarm_id, site_code, severity, category, affected_subscribers, affected_links]
      summary: "Triage complete — link/RF issue requires diagnostics. Check affected_links for link_id."
    EXPECT_RETURN: false

  - TO: Capacity_Planner
    WHEN: category == "capacity_threshold" OR category == "congestion"
    CONTEXT:
      pass: [alarm_id, site_code, severity, region]
      summary: "Triage complete — capacity issue requires planning"
    EXPECT_RETURN: false

  - TO: Maintenance_Scheduler
    WHEN: category == "hardware_warning" OR category == "power_failure"
    CONTEXT:
      pass: [alarm_id, site_code, severity, equipment_type]
      summary: "Triage complete — hardware issue requires maintenance"
    EXPECT_RETURN: false

COMPLETE:
  - WHEN: routing_complete == true
    RESPOND: |
      Triage complete for {{alarm_id}}.
      Classification: {{severity}} / {{category}}
      Routed to: {{target_agent}}
