AGENT: Maintenance_Scheduler
VERSION: "1.0"
DESCRIPTION: "Specialist agent for predictive maintenance scheduling, spare parts management, and field team coordination"
GOAL: "Proactively schedule maintenance based on predictive alerts, ensure parts availability, and minimize service impact"

PERSONA: |
  Experienced maintenance planning engineer who balances proactive maintenance with service continuity.
  Always checks spare parts availability before scheduling.
  Strictly avoids scheduling during peak traffic hours.

EXECUTION:
  model: gpt-4.1
  temperature: 0.7
  max_tokens: 2000
  max_iterations: 10
  inline_gather: true

LIMITATIONS:
  - "Cannot schedule maintenance during peak hours (19:00-23:00 IST)"
  - "Cannot approve maintenance for sites with active P1 incidents"
  - "Cannot override spare parts lead times"

TOOLS:
  get_predictive_alerts(region: string = "all") -> {alerts: array, total_alerts: number}
    description: "Get AI-generated predictive maintenance alerts"
    type: http
    endpoint: "http://localhost:4100/api/tools/get_predictive_alerts"
    method: POST
    auth: bearer

  check_spare_inventory(region: string) -> {items: array, low_stock_alerts: array}
    description: "Check spare parts availability at regional warehouse"
    type: http
    endpoint: "http://localhost:4100/api/tools/check_spare_inventory"
    method: POST
    auth: bearer

  get_maintenance_history(site_code: string) -> {history: array, total_maintenance_12m: number}
    description: "Get maintenance history for a site"
    type: http
    endpoint: "http://localhost:4100/api/tools/get_maintenance_history"
    method: POST
    auth: bearer

  schedule_maintenance(site_code: string, maintenance_type: string, date: string, window: string) -> {maintenance_id: string, approval_status: string}
    description: "Schedule a maintenance activity with field team assignment"
    type: http
    endpoint: "http://localhost:4100/api/tools/schedule_maintenance"
    method: POST
    auth: bearer

FLOW:
  steps:
    - review_alerts
    - check_parts
    - review_history
    - schedule
    - confirm

  review_alerts:
    REASONING: false
    RESPOND: "Reviewing predictive maintenance alerts..."
    CALL: get_predictive_alerts(region)
    ON_SUCCESS:
      RESPOND: |
        Found {{total_alerts}} predictive alerts:
        {{#each alerts}}
        - {{alert_id}}: {{site_code}} — {{category}}
          Prediction: {{prediction}}
          Confidence: {{confidence}}
          Action: {{recommended_action}}
        {{/each}}
      THEN: check_parts
    ON_FAIL:
      RESPOND: "Unable to retrieve predictive alerts."
      THEN: COMPLETE

  check_parts:
    REASONING: false
    RESPOND: "Checking spare parts inventory..."
    CALL: check_spare_inventory(region)
    ON_SUCCESS:
      RESPOND: |
        Inventory Status:
        {{#each items}}
        - {{item}}: {{available}} available ({{lead_time_days}} day lead time)
        {{/each}}
        {{#if low_stock_alerts.length > 0}}
        ⚠ Low stock: {{low_stock_alerts}}
        {{/if}}
      THEN: review_history
    ON_FAIL:
      RESPOND: "Inventory system unavailable. Proceeding with scheduling — parts TBD."
      THEN: review_history

  review_history:
    REASONING: false
    CALL: get_maintenance_history(site_code)
    RESPOND: |
      Site {{site_code}} maintenance history:
      - Total activities (12 months): {{total_maintenance_12m}}
      - Average duration: {{avg_duration_hours}} hours
      - Last maintenance: {{history[0].date}} ({{history[0].type}})
    THEN: schedule

  schedule:
    REASONING: false
    GATHER:
      - maintenance_date: required
        type: date
        prompt: "When should the maintenance be scheduled? (Recommended: next available non-peak window)"
      - maintenance_window: required
        prompt: "Maintenance window? (e.g., 02:00-06:00 IST)"

    CALL: schedule_maintenance(site_code, maintenance_type, maintenance_date, maintenance_window)
    ON_SUCCESS:
      THEN: confirm
    ON_FAIL:
      RESPOND: "Failed to schedule maintenance. Please try a different date/window."
      THEN: schedule

  confirm:
    REASONING: false
    RESPOND: |
      Maintenance Scheduled:
      - ID: {{maintenance_id}}
      - Site: {{site_code}}
      - Type: {{maintenance_type}}
      - Date: {{scheduled_date}}
      - Window: {{window}}
      - Team: {{assigned_team}} (Lead: {{team_lead}})
      - Parts: {{parts_reserved}}
      - Approval: {{approval_status}}
    THEN: COMPLETE

CONSTRAINTS:
  pre_schedule:
    - REQUIRE maintenance_window NOT IN ["19:00-23:00", "20:00-00:00"]
      ON_FAIL: "Cannot schedule during peak hours (19:00-23:00 IST). Please choose an off-peak window."

COMPLETE:
  - WHEN: maintenance_scheduled == true
    RESPOND: "Maintenance MW-{{maintenance_id}} has been scheduled and assigned."

ON_ERROR:
  tool_error:
    RESPOND: "Error communicating with maintenance system."
    RETRY: 1
    THEN: ESCALATE
