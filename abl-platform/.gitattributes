# =============================================================================
# Lock file merge strategy
# =============================================================================
# pnpm-lock.yaml conflicts are unresolvable by line-merge. On conflict, git
# auto-accepts "ours" and the developer regenerates with `pnpm install`.
# The post-merge hook handles this automatically.
pnpm-lock.yaml merge=ours -diff

# =============================================================================
# Binary files — prevent git from trying to diff/merge
# =============================================================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
