{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended"],
  "rules": {
    "no-restricted-syntax": [
      "error",
      {
        "selector": "CallExpression[callee.property.name='findById']",
        "message": "Use findOne({_id, tenantId}) instead of findById() for tenant isolation. See CLAUDE.md Core Invariants."
      },
      {
        "selector": "CallExpression[callee.property.name='findByIdAndUpdate']",
        "message": "Use findOneAndUpdate({_id, tenantId}) instead of findByIdAndUpdate() for tenant isolation."
      },
      {
        "selector": "CallExpression[callee.property.name='findByIdAndDelete']",
        "message": "Use findOneAndDelete({_id, tenantId}) instead of findByIdAndDelete() for tenant isolation."
      },
      {
        "selector": "CallExpression[callee.type='MemberExpression'][callee.property.name='keys'][arguments.length=1]:matches([callee.object.name='redis'], [callee.object.name='client'], [callee.object.name='redisClient'], [callee.object.property.name='redis'], [callee.object.property.name='client'], [callee.object.property.name='redisClient'])",
        "message": "Use scanKeys() from @agent-platform/redis instead of .keys(pattern). Top-level KEYS returns partial results in Redis Cluster (silent data loss)."
      },
      {
        "selector": "CallExpression[callee.type='MemberExpression'][callee.property.name='duplicate']:matches([callee.object.name='redis'], [callee.object.name='client'], [callee.object.name='redisClient'], [callee.object.name='subscriber'], [callee.object.property.name='redis'], [callee.object.property.name='client'], [callee.object.property.name='redisClient'])",
        "message": "Use createSubscriber() or createBullMQPair() from @agent-platform/redis instead of .duplicate() on a Redis client. ioredis Cluster instances do not expose .duplicate(). Calling .duplicate() on a RedisConnectionHandle is allowed (it is cluster-aware)."
      }
    ],
    "@typescript-eslint/no-explicit-any": "off",
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  },
  "overrides": [
    {
      "files": ["packages/redis/**/*.ts", "**/__tests__/**/*.ts", "**/*.test.ts"],
      "rules": {
        "no-restricted-syntax": "off"
      }
    }
  ],
  "ignorePatterns": ["dist/", "node_modules/", "*.js", "*.d.ts"]
}
