{
  "ociVersion": "1.0.0",
  "process": {
    "user": {
      "uid": 1024,
      "gid": 1024
    },
    "args": ["exec_env/bin/python3", "execute_code.py"],
    "env": [
      "PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
      "TERM=xterm",
      "WORKSPACE_DIR=/tmp"
    ],
    "cwd": "/",
    "rlimits": [
      {
        "type": "RLIMIT_NOFILE",
        "hard": 1024,
        "soft": 1024
      }
    ]
  },
  "root": {
    "path": "rootfs",
    "readonly": true
  },
  "hostname": "runsc",
  "mounts": [
    {
      "destination": "/proc",
      "type": "proc",
      "source": "proc"
    },
    {
      "destination": "/dev",
      "type": "tmpfs",
      "source": "tmpfs",
      "options": ["nosuid", "noexec", "size=1m", "mode=755"]
    },
    {
      "destination": "/sys",
      "type": "sysfs",
      "source": "sysfs",
      "options": ["nosuid", "noexec", "nodev", "ro"]
    },
    {
      "destination": "/tmp",
      "type": "tmpfs",
      "source": "tmpfs",
      "options": ["nosuid", "noexec", "nodev", "size=64m"]
    }
  ],
  "linux": {
    "namespaces": [
      {
        "type": "pid"
      },
      {
        "type": "ipc"
      },
      {
        "type": "uts"
      },
      {
        "type": "mount"
      }
    ],
    "seccomp": {
      "defaultAction": "SCMP_ACT_ERRNO",
      "defaultErrnoRet": 1,
      "syscalls": [
        {
          "names": [
            "brk",
            "mmap",
            "munmap",
            "mprotect",
            "mremap",
            "madvise",
            "msync",
            "read",
            "write",
            "close",
            "openat",
            "lseek",
            "pread64",
            "readv",
            "writev",
            "exit",
            "exit_group",
            "getpid",
            "gettid",
            "getppid",
            "clock_gettime",
            "clock_getres",
            "gettimeofday",
            "nanosleep",
            "socket",
            "socketpair",
            "bind",
            "listen",
            "accept",
            "accept4",
            "connect",
            "sendto",
            "recvfrom",
            "sendmsg",
            "recvmsg",
            "shutdown",
            "getsockname",
            "getpeername",
            "setsockopt",
            "getsockopt",
            "epoll_create1",
            "epoll_ctl",
            "epoll_wait",
            "poll",
            "ppoll",
            "pselect6",
            "select",
            "clone",
            "futex",
            "rt_sigaction",
            "rt_sigprocmask",
            "set_robust_list",
            "set_tid_address",
            "fstat",
            "newfstatat",
            "stat",
            "lstat",
            "readlink",
            "readlinkat",
            "mkdir",
            "mkdirat",
            "rmdir",
            "getcwd",
            "chdir",
            "unlink",
            "unlinkat",
            "rename",
            "renameat",
            "chmod",
            "fchmod",
            "chown",
            "fchown",
            "fsync",
            "fdatasync",
            "execve",
            "fork",
            "vfork",
            "wait4",
            "waitid",
            "waitpid",
            "pipe",
            "pipe2",
            "dup",
            "dup2",
            "dup3",
            "kill",
            "tgkill",
            "tkill",
            "rt_sigsuspend",
            "rt_sigtimedwait",
            "uname",
            "getuid",
            "getgid",
            "geteuid",
            "getegid",
            "getgroups",
            "getrlimit",
            "setrlimit",
            "prlimit64",
            "arch_prctl",
            "prctl",
            "getrandom",
            "access",
            "fcntl",
            "ioctl",
            "getdents64",
            "times",
            "sysinfo",
            "personality",
            "rseq",
            "clone3",
            "getcpu",
            "getrusage",
            "sched_getaffinity",
            "sched_setaffinity",
            "mincore",
            "sendmmsg",
            "fadvise64",
            "statx",
            "getresgid",
            "getpgrp",
            "setpgid",
            "setsid",
            "getpgid",
            "getsid",
            "rt_sigreturn",
            "faccessat2",
            "statfs",
            "capget",
            "eventfd2",
            "quotactl",
            "epoll_create",
            "epoll_pwait",
            "faccessat"
          ],
          "action": "SCMP_ACT_ALLOW"
        }
      ]
    }
  }
}
