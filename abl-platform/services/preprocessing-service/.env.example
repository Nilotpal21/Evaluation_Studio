# Preprocessing Service Configuration

# Flask
FLASK_ENV=production
PORT=8003

# Redis
# Standalone (default): set REDIS_HOST + REDIS_PORT, or REDIS_URL.
# Cluster mode: set REDIS_CLUSTER=true and REDIS_URL as a comma-separated seed list.
#   e.g. REDIS_URL=redis-0:6379,redis-1:6379,redis-2:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_CLUSTER=false
REDIS_TLS_ENABLED=false

# Logging
LOG_LEVEL=INFO

# Preprocessing Settings
ENABLE_SPELL_CORRECTION=true
ENABLE_SYNONYM_EXPANSION=true
ENABLE_ENTITY_EXTRACTION=true
MAX_SYNONYMS=3

# Cache Settings
CACHE_TTL=3600
TENANT_DICT_TTL=7200

# Performance
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
