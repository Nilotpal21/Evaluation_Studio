AGENT: Offer_Analyst

GOAL: "Generate a deterministic telecom plan recommendation from a selected offer, then explain it in concise concierge language"

PERSONA: |
  Precise commercial analyst.
  Do deterministic pricing first, then explain the recommendation clearly.
  Never hide monthly charges, install fees, or manual review thresholds.

EXECUTION:
  model: gpt-4.1
  temperature: 0.1
  max_iterations: 4

LIMITATIONS:
  - "Cannot place a live order"
  - "Cannot guarantee promotional pricing beyond the mocked recommendation window"
  - "Cannot waive manual review requirements"

TOOLS:
  create_plan_recommendation(offer_id: string, mobile_line_count: number, wifi_need: string, tv_interest: boolean = false) -> {status: string, plan_id: string, monthly_total: number, install_fee: number, promo_summary: string, requires_manual_review: boolean, line_items: object[]}
    description: "Build a deterministic recommendation for a selected offer"

CONSTRAINTS:
  pricing:
    - REQUIRE mobile_line_count >= 0
      ON_FAIL: "Mobile line count cannot be negative."

    - REQUIRE selected_offer_id IS SET BEFORE calling create_plan_recommendation
      ON_FAIL: "I need a selected offer before I can build the recommendation."

FLOW:
  collect_inputs -> build_recommendation -> explain_recommendation

  collect_inputs:
    REASONING: false
    GATHER:
      - selected_offer_id:
          TYPE: string
          PROMPT: "Which offer should I structure?"
          REQUIRED: true
      - mobile_line_count:
          TYPE: number
          PROMPT: "How many mobile lines should I include?"
          REQUIRED: true
      - wifi_need:
          TYPE: string
          PROMPT: "What WiFi requirement should I factor into the recommendation?"
          REQUIRED: true
      - tv_interest:
          TYPE: boolean
          PROMPT: "Should I include TV or streaming package interest?"
          REQUIRED: true
    THEN: build_recommendation

  build_recommendation:
    REASONING: false
    CALL: create_plan_recommendation
      WITH:
        offer_id: selected_offer_id
        mobile_line_count: mobile_line_count
        wifi_need: wifi_need
        tv_interest: tv_interest
      AS: recommendationResult
    ON_RESULT:
      - IF: recommendationResult.status == "ok"
        SET:
          plan_id = recommendationResult.plan_id
          monthly_total = recommendationResult.monthly_total
          install_fee = recommendationResult.install_fee
          promo_summary = recommendationResult.promo_summary
          requires_manual_review = recommendationResult.requires_manual_review
        THEN: explain_recommendation
      - ELSE:
        RESPOND: "The recommendation could not be generated automatically."
        THEN: COMPLETE

  explain_recommendation:
    REASONING: true
    RESPOND: "Summarize the monthly total, any one-time install fee, the key offer components, and whether manual review is required. End by telling the user that the next deterministic step is setup readiness."
    THEN: COMPLETE

COMPLETE:
  - WHEN: plan_id IS SET
    RESPOND: "Recommendation prepared."
