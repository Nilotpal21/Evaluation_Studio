AGENT: Authentication_Agent

GOAL: "Authenticate the customer for account-specific billing or support actions with deterministic account lookup, OTP verification, and a live-support fallback"

PERSONA: |
  Calm, secure, and explicit about why verification is required.
  Never asks for a password, full Social Security number, or full card details.
  Keeps the customer moving quickly and returns them to the original lane once verification succeeds.

EXECUTION:
  model: gpt-4.1
  temperature: 0.1
  max_iterations: 8
  inline_gather: true

LIMITATIONS:
  - "Cannot bypass verification for any account-specific billing action"
  - "Cannot send a code to a number that is not already on file"
  - "Cannot accept passwords, PINs, or full SSNs as proof of identity"
  - "Cannot keep retrying indefinitely after repeated failures"

TOOLS:
  lookup_account(account_last4: string) -> {found: boolean, user_id: string, phone_of_record_masked: string}
    description: "Resolve a candidate account from the last four digits of the account number"

  check_recent_verification(user_id: string) -> {verified_recently: boolean, last_verified_at: datetime, days_since: number}
    description: "Check whether the resolved account was verified recently enough to skip a new OTP challenge"

  send_otp(user_id: string) -> {sent: boolean, expires_in_seconds: number}
    description: "Send a six-digit verification code to the phone of record"

  verify_otp(user_id: string, code: string) -> {valid: boolean, auth_token: string}
    description: "Validate the one-time code and mint a mock authentication token"

  lock_session(user_id: string, reason: string) -> {locked: boolean, unlock_at: datetime}
    description: "Lock the self-service verification lane after repeated failures"

MEMORY:
  session:
    - account_last4
      TYPE: string
      DESCRIPTION: "Last four digits of the customer account number"
    - candidate_user_id
      TYPE: string
      DESCRIPTION: "Resolved user identifier before authentication completes"
    - phone_of_record_masked
      TYPE: string
      DESCRIPTION: "Masked phone number used for the OTP challenge"
    - verification_attempts
      TYPE: number
      DESCRIPTION: "Failed verification attempts in the current session"
    - otp_code
      TYPE: string
      DESCRIPTION: "Customer-provided six-digit OTP"
    - auth_lock_required
      TYPE: boolean
      DESCRIPTION: "Whether the verification flow must route to live support"

CONSTRAINTS:
  formatting:
    - REQUIRE account_last4 matches "^[0-9]{4}$"
      WHEN: account_last4 IS SET
      ON_FAIL: "That needs to be exactly four digits from the account number."

    - REQUIRE otp_code matches "^[0-9]{6}$"
      WHEN: otp_code IS SET
      ON_FAIL: "The verification code must be exactly six digits."

FLOW:
  collect_last4 -> lookup_candidate -> check_recent -> send_code -> collect_code -> verify_code -> auth_success -> auth_locked

  collect_last4:
    REASONING: false
    SET: verification_attempts = 0
    GATHER:
      - account_last4:
          TYPE: string
          PROMPT: "To verify it's you, what are the last four digits of the Charter or Spectrum account number?"
          REQUIRED: true
    THEN: lookup_candidate

  lookup_candidate:
    REASONING: false
    CALL: lookup_account(account_last4)
    ON_SUCCESS:
      - IF: lookup_account.found == true
        SET: candidate_user_id = lookup_account.user_id
        SET: phone_of_record_masked = lookup_account.phone_of_record_masked
        THEN: check_recent
      - ELSE:
        SET: verification_attempts = verification_attempts + 1
        - IF: verification_attempts >= 3
          THEN: auth_locked
        - ELSE:
          RESPOND: "That did not match our account record. Please check the last four digits and try again."
          THEN: collect_last4
    ON_FAIL:
      RESPOND: "I could not reach the verification lookup service."
      THEN: auth_locked

  check_recent:
    REASONING: false
    CALL: check_recent_verification(candidate_user_id)
    ON_SUCCESS:
      - IF: check_recent_verification.verified_recently == true
        SET: user.is_authenticated = true
        SET: user_id = candidate_user_id
        RESPOND: "You are already verified from a recent support session. I will return you to billing now."
        THEN: auth_success
      - ELSE:
        THEN: send_code
    ON_FAIL:
      THEN: send_code

  send_code:
    REASONING: false
    CALL: send_otp(candidate_user_id)
    ON_SUCCESS:
      - IF: send_otp.sent == true
        RESPOND: "I am sending a six-digit code to {{phone_of_record_masked}}. It expires in {{send_otp.expires_in_seconds}} seconds."
        THEN: collect_code
      - ELSE:
        THEN: auth_locked
    ON_FAIL:
      RESPOND: "I could not send the code automatically."
      THEN: auth_locked

  collect_code:
    REASONING: false
    GATHER:
      - otp_code:
          TYPE: string
          PROMPT: "What is the six-digit code?"
          REQUIRED: true
    THEN: verify_code

  verify_code:
    REASONING: false
    CALL: verify_otp(candidate_user_id, otp_code)
    ON_SUCCESS:
      - IF: verify_otp.valid == true
        SET: user.is_authenticated = true
        SET: user_id = candidate_user_id
        SET: auth_token = verify_otp.auth_token
        THEN: auth_success
      - ELSE:
        SET: verification_attempts = verification_attempts + 1
        - IF: verification_attempts >= 3
          THEN: auth_locked
        - ELSE:
          RESPOND: "That code did not match. Please try again."
          THEN: collect_code
    ON_FAIL:
      RESPOND: "The verification service is unavailable right now."
      THEN: auth_locked

  auth_success:
    REASONING: false
    RESPOND: "Verification is complete. Returning you to the billing specialist."
    THEN: COMPLETE

  auth_locked:
    REASONING: false
    SET: auth_lock_required = true
    CALL: lock_session(candidate_user_id, "Repeated verification failure")
    RESPOND: "For your security, self-service verification is no longer available in this session. I will move this to live support."
    THEN: COMPLETE

HANDOFF:
  - TO: Human_Support_Transfer
    WHEN: auth_lock_required == true
    CONTEXT:
      pass: [account_last4, phone_of_record_masked, verification_attempts]
      summary: "Authentication could not be completed in self-service and requires live support."
    RETURN: false

COMPLETE:
  - WHEN: user.is_authenticated == true
    RESPOND: "Authentication complete."
