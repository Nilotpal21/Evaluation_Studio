# Secret scanning — required for all commits
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "ERROR: gitleaks is not installed. Install via: brew install gitleaks"
  exit 1
fi
gitleaks protect --staged --verbose

# Ban Zod ID format validators that don't match our data
# Our IDs are UUIDs or custom strings (proj-*, tenant-*), never CUIDs/NANOIDs/ULIDs
BANNED_ZOD=$(git diff --cached --diff-filter=ACM -- '*.ts' '*.tsx' | grep -E '^\+.*\.(cuid|cuid2|nanoid|ulid)\(' || true)
if [ -n "$BANNED_ZOD" ]; then
  echo ""
  echo "ERROR: Banned Zod ID validators found in staged changes:"
  echo "$BANNED_ZOD"
  echo ""
  echo "This codebase uses z.string().min(1) for ID fields."
  echo "Project IDs are UUIDs or custom strings, not CUIDs/NANOIDs/ULIDs."
  echo ""
  exit 1
fi

# Ban bare mongoose.model() without HMR guard
# Safe: mongoose.models.Name || mongoose.model('Name', schema)
# Safe: mongoose.model(name) — retrieval-only, no schema arg
# Banned: mongoose.model('Name', schema) — will throw OverwriteModelError on HMR
BARE_MODEL=$(git diff --cached --diff-filter=ACM -- '*.ts' | grep -E '^\+.*mongoose\.model\(' | grep -v 'mongoose\.models\.' | grep -E ',' | grep -v '^\+.*//.*mongoose\.model\(' || true)
if [ -n "$BARE_MODEL" ]; then
  echo ""
  echo "ERROR: Bare mongoose.model() found (missing HMR guard):"
  echo "$BARE_MODEL"
  echo ""
  echo "Use: mongoose.models.Name || mongoose.model('Name', schema)"
  exit 1
fi

# Ban .lean() on encrypted Mongoose models (LLMCredential)
# The encryption plugin decrypts fields in post-find hooks; .lean() may skip these hooks
LEAN_ON_CRED=$(git diff --cached --diff-filter=ACM -- '*.ts' | grep -E '^\+.*LLMCredential.*\.lean\(\)' || true)
if [ -n "$LEAN_ON_CRED" ]; then
  echo ""
  echo "ERROR: .lean() used on LLMCredential query (encryption hooks may be skipped):"
  echo "$LEAN_ON_CRED"
  echo ""
  echo "Remove .lean() — the encryption plugin decrypts encryptedApiKey/encryptedEndpoint"
  echo "in a post-find hook. .lean() may return raw encrypted blobs."
  echo ""
  exit 1
fi

# Ban Mongoose findById/findByIdAndUpdate/findByIdAndDelete for tenant isolation
# Use findOne({_id, tenantId}), findOneAndUpdate({_id, tenantId}), findOneAndDelete({_id, tenantId}) instead
BANNED_FINDBYID=$(git diff --cached --diff-filter=ACM -- '*.ts' '*.tsx' | grep -E '^\+.*\.(findById|findByIdAndUpdate|findByIdAndDelete)\(' || true)
if [ -n "$BANNED_FINDBYID" ]; then
  echo ""
  echo "ERROR: Banned Mongoose methods found in staged changes:"
  echo "$BANNED_FINDBYID"
  echo ""
  echo "Use findOne({_id, tenantId}) instead of findById() for tenant isolation."
  echo "Use findOneAndUpdate({_id, tenantId}, ...) instead of findByIdAndUpdate()."
  echo "Use findOneAndDelete({_id, tenantId}) instead of findByIdAndDelete()."
  echo "See CLAUDE.md Core Invariants."
  echo ""
  exit 1
fi

# Warn about WebSocket usage outside useEffect in React components
WS_IN_RENDER=$(git diff --cached --diff-filter=ACM -- 'apps/studio/src/**/*.ts' 'apps/studio/src/**/*.tsx' | grep -E '^\+.*new WebSocket\(' || true)
if [ -n "$WS_IN_RENDER" ]; then
  echo ""
  echo "WARNING: new WebSocket() found in staged React code."
  echo "Ensure it's inside useEffect() with proper cleanup to prevent infinite re-render loops."
  echo "$WS_IN_RENDER"
  echo ""
  # Non-blocking warning
fi

# Warn about unbounded Map/Set in services
UNBOUNDED=$(git diff --cached --diff-filter=ACM -- 'apps/*/src/services/**/*.ts' 'packages/*/src/**/*.ts' | grep -E '^\+.*new (Map|Set)\(' | grep -v 'test\|spec\|__tests__' || true)
if [ -n "$UNBOUNDED" ]; then
  echo ""
  echo "WARNING: new Map()/Set() found. Ensure max size, TTL, and eviction are configured."
  echo "$UNBOUNDED"
  echo ""
  # Non-blocking warning
fi

# Warn about project-scoped routes missing projectId in queries
PROJECT_GAPS=$(git diff --cached --diff-filter=ACM -- 'apps/runtime/src/routes/*.ts' | grep -E '^\+.*\.(findOne|find|updateOne|deleteOne)\(' | grep -v 'projectId' || true)
if [ -n "$PROJECT_GAPS" ]; then
  echo ""
  echo "WARNING: Route query may be missing projectId scoping:"
  echo "$PROJECT_GAPS"
  echo "Verify the resource is scoped to the project. See CLAUDE.md Core Invariant #1."
  echo ""
fi

# Warn about user-owned resource queries missing userId/createdBy
USER_GAPS=$(git diff --cached --diff-filter=ACM -- '*.ts' | grep -E '^\+.*\.(findOne|find|updateOne|deleteOne)\(' | grep -v 'userId\|createdBy\|ownerId' || true)
# Only warn if the changed files are session/apikey/token/mfa related
USER_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' | grep -iE '(session|api-key|apikey|token|mfa)' | grep -v '__tests__\|\.test\.\|\.spec\.' || true)
if [ -n "$USER_FILES" ] && [ -n "$USER_GAPS" ]; then
  echo ""
  echo "WARNING: User-owned resource query may be missing userId/createdBy scoping:"
  echo "$USER_GAPS"
  echo "Verify user-owned resources filter by userId/createdBy. See CLAUDE.md Core Invariant #1."
  echo ""
fi

# Dockerfile package.json sync check
if git diff --cached --name-only | grep -qE 'Dockerfile|packages/.*/package\.json|pnpm-workspace'; then
  ./tools/verify-dockerfile-copies.sh
fi

# TODO: Add semgrep security scanning when semgrep is installed project-wide
# Run: ./tools/run-semgrep.sh

# i18n key verification — warn if studio code references missing translation keys
if git diff --cached --name-only | grep -qE 'apps/studio/src/.*\.(ts|tsx)$'; then
  ./tools/verify-i18n-keys.sh || echo "WARNING: Missing i18n keys detected (non-blocking)"
fi

# Field propagation check — warns when a staged diff adds a property to an
# exported interface/type in a type-defining or cross-boundary file without
# also touching the type's downstream consumers.
#
# Catches edits from any committer (Claude, Codex, Cursor, Aider, human) —
# the .claude/hooks/field-propagation-lint.sh equivalent only fires for Claude.
# See CLAUDE.md "Cross-Boundary Field Propagation" rule.
if git diff --cached --name-only --diff-filter=ACM | grep -qE '\.(ts|tsx)$'; then
  ./tools/field-propagation-check.sh || true
fi

# Repro quality check — blocks repro tests that do not execute real evidence:
# skipped/todo tests, missing ticket markers, internal package mocks, missing
# future imports, early-return setup escapes, or @ts-expect-error suppressions.
#
# These failures caused several May 2026 triage repros to pass or fail for the
# wrong reason. Repros should be executable bug contracts that later graduate
# into regression tests.
if git diff --cached --name-only --diff-filter=ACM | grep -qE '\.repro\.(test|spec)\.(ts|tsx)$'; then
  node ./tools/repro-test-quality-check.mjs --staged
fi

# Public response leak check — blocks raw trace/debug internals from being
# returned in route JSON responses unless they are explicitly debug-gated.
if git diff --cached --name-only --diff-filter=ACM | grep -qE '\.(ts|tsx)$'; then
  node ./tools/public-response-leak-check.mjs --staged
fi

# Structured diagnostics check — blocks module publish diagnostics from being
# collapsed into one user-facing string at package/API/client/UI boundaries.
if git diff --cached --name-only --diff-filter=ACM | grep -qE '\.(ts|tsx)$'; then
  node ./tools/structured-diagnostics-check.mjs --staged
fi

# Flow-change audit trigger — when a commit crosses 2+ boundary categories
# (schema, types, route, serializer, store, sdk, worker, ui, middleware,
# handler) without a parity test or data-flow-audit log, suggests running the
# /data-flow-audit skill before merging.
#
# Catches the commit shape that historically led to ABLP-791/654/540/612
# hardening sweeps. Skip with: SKIP_FLOW_AUDIT=1 git commit ...
./tools/flow-change-audit-trigger.sh || true

# Formatting
export PATH="/usr/local/node/bin:$PATH"
pnpm lint-staged

# ---------------------------------------------------------------------------
# Diff-aware typecheck — runs tsc --noEmit on packages with staged .ts/.tsx
# changes. Adds ~5-15s to commit time but catches type errors BEFORE they
# land. The 2.8:1 fix-to-feat ratio from the March 21-25 audit was largely
# caused by type errors slipping through commits. This gate prevents that.
#
# Skip with: SKIP_TYPECHECK=1 git commit ...
# ---------------------------------------------------------------------------
if [ "${SKIP_TYPECHECK:-0}" = "1" ]; then
  echo "SKIP_TYPECHECK=1 — skipping pre-commit typecheck"
else
  STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.tsx' || true)

  if [ -n "$STAGED_TS_FILES" ]; then
    # Extract unique package roots (apps/X or packages/X) from staged files
    PACKAGES=$(echo "$STAGED_TS_FILES" | sed -n 's|\(\(apps\|packages\)/[^/]*\)/.*|\1|p' | sort -u)

    if [ -n "$PACKAGES" ]; then
      TYPECHECK_FAILED=0

      for pkg in $PACKAGES; do
        if [ -f "$pkg/tsconfig.json" ]; then
          echo "Typechecking $pkg ..."
          if ! npx tsc --noEmit -p "$pkg/tsconfig.json" 2>&1; then
            TYPECHECK_FAILED=1
          fi
        fi
      done

      if [ "$TYPECHECK_FAILED" -eq 1 ]; then
        echo ""
        echo "ERROR: TypeScript typecheck failed. Fix type errors before committing."
        echo "To skip (not recommended): SKIP_TYPECHECK=1 git commit ..."
        echo ""
        exit 1
      fi
    fi
  fi
fi
