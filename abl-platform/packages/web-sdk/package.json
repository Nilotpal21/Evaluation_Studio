{
  "name": "@agent-platform/web-sdk",
  "version": "0.1.0",
  "description": "Embeddable Web SDK for voice and chat interactions with AI agents",
  "type": "module",
  "main": "./dist/agent-sdk.umd.js",
  "module": "./dist/agent-sdk.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/agent-sdk.esm.js",
      "require": "./dist/agent-sdk.umd.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly && node scripts/create-react-entry.mjs && node scripts/validate-embed-bundle.mjs",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run --passWithNoTests",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@twilio/voice-sdk": "^2.10.0",
    "isomorphic-dompurify": "^2.16.0"
  },
  "peerDependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@ricky0123/vad-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agent-platform/shared-kernel": "workspace:*",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.6.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "ai",
    "agent",
    "chat",
    "voice",
    "webrtc",
    "twilio",
    "sdk",
    "widget"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
