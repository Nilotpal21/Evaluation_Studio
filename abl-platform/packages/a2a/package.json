{
  "name": "@agent-platform/a2a",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run --passWithNoTests --config vitest.fast.config.ts",
    "test:repro": "vitest run --passWithNoTests \"src/**/*.repro.test.ts\"",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@a2a-js/sdk": "0.3.13",
    "@abl/compiler": "workspace:*",
    "@agent-platform/redis": "workspace:*",
    "@agent-platform/shared": "workspace:*",
    "@agent-platform/shared-kernel": "workspace:*",
    "ioredis": "^5.4.0"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "express": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
