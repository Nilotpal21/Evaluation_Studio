{
  "name": "@agent-platform/shared-auth",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Auth middleware extracted from @agent-platform/shared",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware/index.js",
      "types": "./dist/middleware/index.d.ts"
    },
    "./rbac": {
      "import": "./dist/rbac/index.js",
      "types": "./dist/rbac/index.d.ts"
    },
    "./idp": {
      "import": "./dist/idp/index.js",
      "types": "./dist/idp/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "jose": "^5.10.0",
    "jwks-rsa": "^3.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  }
}
