{
  "name": "Per-Message Guardrail",
  "description": "Real-time check on each incoming user message. Edit the LLM Evaluate prompt to define your policy. Results default to the shared custom pipeline results table.",
  "supportedTriggers": [
    {
      "id": "user-message",
      "type": "kafka",
      "kafkaTopic": "abl.message.user",
      "strategy": "default",
      "label": "User Message Received",
      "description": "Fires on each incoming user message.",
      "inputSchema": {
        "required": ["tenantId", "sessionId"],
        "properties": {
          "tenantId": { "type": "string", "description": "Tenant ID from message event" },
          "sessionId": { "type": "string", "description": "Session the message belongs to" }
        }
      },
      "exampleOutput": {
        "tenantId": "tenant-dev-001",
        "sessionId": "sess-abc-123",
        "payload": {
          "role": "user",
          "content": "Hello, I need help with my account.",
          "messageId": "msg-user-001",
          "messageIndex": 0
        }
      }
    }
  ],
  "defaultTriggerIds": ["user-message"],
  "nodes": [
    {
      "id": "read-message-window",
      "type": "read-message-window",
      "label": "Read Message Window",
      "config": {
        "windowSize": 5,
        "includeToolCalls": false
      },
      "transitions": [{ "target": "llm-evaluate" }],
      "position": { "x": -280, "y": 0 },
      "contractVersion": 1
    },
    {
      "id": "llm-evaluate",
      "type": "llm-evaluate",
      "label": "Check Policy",
      "config": {
        "systemPrompt": "You are a content policy enforcement agent. Evaluate the user message and recent context for policy violations. Return a JSON object with: { \"violation\": boolean, \"category\": string, \"reason\": string }",
        "userPrompt": "Recent messages:\n{{steps.read-message-window.output.windowMessages}}\n\nTriggering message:\n{{steps.read-message-window.output.triggeringMessage}}\n\nCheck for policy violations and return your evaluation.",
        "tag": "guardrail",
        "strict": true,
        "outputSchema": {
          "type": "object",
          "required": ["violation", "category", "reason"],
          "properties": {
            "violation": { "type": "boolean" },
            "category": { "type": "string" },
            "reason": { "type": "string" }
          }
        }
      },
      "transitions": [{ "target": "store-results" }],
      "position": { "x": 0, "y": 0 },
      "contractVersion": 1
    },
    {
      "id": "store-results",
      "type": "store-results",
      "label": "Store Results",
      "config": {
        "destination": "mongodb",
        "storageStrategy": "document_only",
        "sourceStep": "llm-evaluate",
        "documentPath": "steps.llm-evaluate.output"
      },
      "transitions": [],
      "position": { "x": 280, "y": 0 },
      "contractVersion": 1
    }
  ],
  "entryNodeId": "read-message-window",
  "configSchema": { "fields": [] }
}
