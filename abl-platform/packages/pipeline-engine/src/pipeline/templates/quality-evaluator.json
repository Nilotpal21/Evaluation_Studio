{
  "name": "Quality Evaluator",
  "description": "LLM-as-judge quality evaluation over a complete session. Runs after each session ends. Results default to the shared custom pipeline results table.",
  "supportedTriggers": [
    {
      "id": "session-ended",
      "type": "kafka",
      "kafkaTopic": "abl.session.ended",
      "strategy": "default",
      "label": "Session Ended",
      "description": "Fires when a conversation session ends.",
      "inputSchema": {
        "required": ["tenantId", "sessionId"],
        "properties": {
          "tenantId": { "type": "string", "description": "Tenant ID from session event" },
          "sessionId": { "type": "string", "description": "Session ID to analyze" }
        }
      },
      "exampleOutput": {
        "tenantId": "tenant-dev-001",
        "sessionId": "sess-abc-123"
      }
    }
  ],
  "defaultTriggerIds": ["session-ended"],
  "nodes": [
    {
      "id": "read-conversation",
      "type": "read-conversation",
      "label": "Read Conversation",
      "config": {
        "enrichWithTraces": true
      },
      "transitions": [{ "target": "compute-quality" }],
      "position": { "x": -280, "y": 0 },
      "contractVersion": 1
    },
    {
      "id": "compute-quality",
      "type": "compute-quality",
      "label": "Evaluate Quality",
      "config": {},
      "transitions": [{ "target": "store-results" }],
      "position": { "x": 0, "y": 0 },
      "contractVersion": 1
    },
    {
      "id": "store-results",
      "type": "store-results",
      "label": "Store Results",
      "config": {
        "destination": "clickhouse",
        "storageStrategy": "score_and_document",
        "sourceStep": "compute-quality",
        "scorePath": "steps.compute-quality.output.overallScore",
        "scoreName": "overallScore",
        "documentPath": "steps.compute-quality.output"
      },
      "transitions": [],
      "position": { "x": 280, "y": 0 },
      "contractVersion": 1
    }
  ],
  "entryNodeId": "read-conversation",
  "configSchema": { "fields": [] }
}
