{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022"
  },
  "include": ["src/**/*", "src/pipeline/seed-data/*.json", "src/pipeline/templates/*.json"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
