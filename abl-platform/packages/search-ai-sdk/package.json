{
  "name": "@agent-platform/search-ai-sdk",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Search AI SDK — shared types, client, vector store interface, schema mapping types",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./types/search-query": {
      "import": "./dist/types/search-query.js",
      "types": "./dist/types/search-query.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@abl/compiler": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
