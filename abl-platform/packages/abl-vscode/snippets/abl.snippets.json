{
  "Agent Scaffold": {
    "prefix": "agent",
    "body": [
      "agent: ${1:agent_name}",
      "mode: ${2|reasoning,scripted|}",
      "goal: ${3:Describe the agent's goal}",
      "",
      "tools:",
      "  - ${4:tool_name}",
      "",
      "constraints:",
      "  - ${5:Always be helpful and accurate}",
      "$0"
    ],
    "description": "Scaffold a new ABL agent"
  },
  "Tool Definition": {
    "prefix": "tool",
    "body": [
      "- name: ${1:tool_name}",
      "  type: ${2|api,mcp,function,lambda,sandbox|}",
      "  description: ${3:What this tool does}",
      "  parameters:",
      "    ${4:param_name}:",
      "      type: ${5|string,number,boolean,object|}",
      "      required: ${6|true,false|}",
      "$0"
    ],
    "description": "Define a tool"
  },
  "Flow Step": {
    "prefix": "step",
    "body": ["${1:step_name}:", "  respond: ${2:Message to user}", "  then: ${3:next_step}", "$0"],
    "description": "Add a flow step"
  },
  "Constraint": {
    "prefix": "constraint",
    "body": ["- ${1:Always follow safety guidelines}", "$0"],
    "description": "Add a constraint"
  },
  "Handoff": {
    "prefix": "handoff",
    "body": [
      "- to: ${1:target_agent}",
      "  when: ${2:context.needs_transfer}",
      "  reason: ${3:Reason for handoff}",
      "$0"
    ],
    "description": "Add a handoff target"
  },
  "Gather Field": {
    "prefix": "field",
    "body": [
      "- name: ${1:field_name}",
      "  type: ${2|string,number,boolean,date,email,phone|}",
      "  required: ${3|true,false|}",
      "  prompt: ${4:Ask the user for this information}",
      "$0"
    ],
    "description": "Add a gather field"
  },
  "Flow Section": {
    "prefix": "flow",
    "body": [
      "flow:",
      "  entry_point: ${1:start}",
      "  steps:",
      "    ${1:start}:",
      "      respond: ${2:Welcome message}",
      "      then: ${3:next_step}",
      "    ${3:next_step}:",
      "      respond: ${4:Follow-up message}",
      "      then: complete",
      "$0"
    ],
    "description": "Add a complete flow section"
  },
  "Delegate": {
    "prefix": "delegate",
    "body": [
      "- agent: ${1:target_agent}",
      "  task: ${2:Description of delegated task}",
      "  context:",
      "    ${3:key}: ${4:value}",
      "$0"
    ],
    "description": "Add a delegate target"
  }
}
