{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ABL Legacy",
  "scopeName": "source.abl.legacy",
  "patterns": [
    { "include": "#comments" },
    { "include": "#section-keywords" },
    { "include": "#sub-keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#strings" },
    { "include": "#arrows" },
    { "include": "#template-variables" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.abl",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.abl",
          "match": "//.*$"
        }
      ]
    },
    "section-keywords": {
      "patterns": [
        {
          "name": "keyword.control.section.abl",
          "match": "\\b(AGENT|SUPERVISOR|MODE|GOAL|PERSONA|IDENTITY|LIMITATIONS|TOOLS|GATHER|MEMORY|CONSTRAINTS|FLOW|STEPS|DELEGATE|HANDOFF|ESCALATE|COMPLETE|ON_ERROR|ON_START|GUARDRAILS|TESTS)\\b"
        }
      ]
    },
    "sub-keywords": {
      "patterns": [
        {
          "name": "entity.name.tag.abl",
          "match": "\\b(WHEN|TO|RESPOND|STORE|RETURN|REQUIRE|ON_FAIL|ON_SUCCESS|THEN|CALL|CHECK|COLLECT|INPUT|RETURNS|PURPOSE|REASON|PRIORITY|TIMEOUT|TTL|CONTEXT|ON_INPUT|PROMPT|PRESENT|SET|IF|ELSE|FIELDS|STRATEGY|AS)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.abl",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.abl",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.abl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.abl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.abl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.abl",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "arrows": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.abl",
          "match": "->|=>|→"
        }
      ]
    },
    "template-variables": {
      "patterns": [
        {
          "name": "variable.other.template.abl",
          "match": "\\{\\{[^}]+\\}\\}"
        },
        {
          "name": "variable.other.template.abl",
          "match": "\\$\\{[^}]+\\}"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.abl",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    }
  }
}
