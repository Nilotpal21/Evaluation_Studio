{
  "name": "kore-abl",
  "displayName": "Kore ABL",
  "description": "Language support for ABL (Agent Blueprint Language) — syntax highlighting, completions, hover, and diagnostics",
  "version": "0.1.0",
  "publisher": "kore-ai",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:abl-yaml",
    "onLanguage:abl-legacy",
    "workspaceContains:**/*.agent.yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "abl-yaml",
        "aliases": [
          "ABL YAML",
          "abl-yaml"
        ],
        "extensions": [
          ".agent.yaml"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "abl-legacy",
        "aliases": [
          "ABL Legacy",
          "abl-legacy"
        ],
        "extensions": [
          ".agent.abl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "abl-yaml",
        "scopeName": "source.abl.yaml",
        "path": "./syntaxes/abl-yaml.tmLanguage.json"
      },
      {
        "language": "abl-legacy",
        "scopeName": "source.abl.legacy",
        "path": "./syntaxes/abl-legacy.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "abl-yaml",
        "path": "./snippets/abl.snippets.json"
      },
      {
        "language": "abl-legacy",
        "path": "./snippets/abl.snippets.json"
      }
    ],
    "commands": [
      {
        "command": "abl.validate",
        "title": "ABL: Validate Document"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "package": "vsce package --no-dependencies",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
