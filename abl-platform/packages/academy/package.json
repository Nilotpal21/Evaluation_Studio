{
  "name": "@agent-platform/academy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Learning Academy — portable package with zero ABL dependencies",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
