{
  "name": "@abl/nl-parser",
  "version": "1.0.0",
  "description": "Natural language to DSL conversion using LLM",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:fast": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@abl/core": "workspace:*",
    "@anthropic-ai/sdk": "^0.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "esbuild": "0.25.0",
    "postcss": "8.5.10",
    "rollup": "4.59.0",
    "vite": "8.0.5"
  }
}
