{
  "name": "@agent-platform/cli",
  "version": "0.1.0",
  "description": "CLI tool for Kore Platform - debug, deploy, and manage agents",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./mcp/analysis": "./dist/mcp/analysis/index.js"
  },
  "bin": {
    "kore-platform-cli": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:fast": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@abl/language-service": "workspace:*",
    "@agent-platform/arch-ai": "workspace:*",
    "@agent-platform/shared": "workspace:*",
    "@agent-platform/sizing-calculator": "workspace:*",
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^12.0.0",
    "eventsource-parser": "^3.0.6",
    "handlebars": "^4.7.8",
    "md-to-pdf": "^5.2.5",
    "open": "^10.1.0",
    "ora": "^8.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kore",
    "agent",
    "abl",
    "cli",
    "debug"
  ]
}
