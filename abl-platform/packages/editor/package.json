{
  "name": "@abl/editor",
  "version": "1.0.0",
  "description": "Visual editor for Agent ABL",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-styles.js",
    "dev": "tsc --watch",
    "lint": "echo 'no eslint config — skipping'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@abl/core": "workspace:*",
    "@monaco-editor/react": "^4.6.0",
    "@xyflow/react": "^12.10.1",
    "monaco-editor": "^0.45.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  }
}
