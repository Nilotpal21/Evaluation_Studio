{
  "name": "@agent-platform/search-ai-internal",
  "version": "0.1.0",
  "description": "Internal shared code for Search-AI service and runtime",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./services": {
      "import": "./dist/services/index.js",
      "types": "./dist/services/index.d.ts"
    },
    "./chunking": {
      "import": "./dist/chunking/index.js",
      "types": "./dist/chunking/index.d.ts"
    },
    "./embedding": {
      "import": "./dist/embedding/index.js",
      "types": "./dist/embedding/index.d.ts"
    },
    "./vector-store": {
      "import": "./dist/vector-store/index.js",
      "types": "./dist/vector-store/index.d.ts"
    },
    "./vector-store/*": {
      "import": "./dist/vector-store/*.js",
      "types": "./dist/vector-store/*.d.ts"
    },
    "./permissions": {
      "import": "./dist/permissions/index.js",
      "types": "./dist/permissions/index.d.ts"
    },
    "./canonical": {
      "import": "./dist/canonical/index.js",
      "types": "./dist/canonical/index.d.ts"
    },
    "./tokenizer": {
      "import": "./dist/tokenizer/index.js",
      "types": "./dist/tokenizer/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@abl/compiler": "workspace:*",
    "@agent-platform/config": "workspace:*",
    "@agent-platform/shared-observability": "workspace:*",
    "@agent-platform/database": "workspace:*",
    "@agent-platform/search-ai-sdk": "workspace:*",
    "@opensearch-project/opensearch": "^3.1.0",
    "@qdrant/js-client-rest": "^1.12.0",
    "neo4j-driver": "^5.28.0",
    "openai": "^4.77.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "tiktoken": "^1.0.0",
    "unified": "^11.0.4",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.1",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
