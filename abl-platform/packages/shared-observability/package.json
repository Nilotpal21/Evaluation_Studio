{
  "name": "@agent-platform/shared-observability",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "Observability primitives for Agent Platform: distributed locks, tracing helpers, metrics utilities",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware/index.js",
      "types": "./dist/middleware/index.d.ts"
    },
    "./distributed-lock": {
      "import": "./dist/distributed-lock.js",
      "types": "./dist/distributed-lock.d.ts"
    },
    "./logger": {
      "import": "./dist/logger.js",
      "types": "./dist/logger.d.ts"
    },
    "./tracing": {
      "import": "./dist/tracing/index.js",
      "types": "./dist/tracing/index.d.ts"
    },
    "./context": {
      "import": "./dist/context.js",
      "types": "./dist/context.d.ts"
    },
    "./sti": {
      "import": "./dist/sti/index.js",
      "types": "./dist/sti/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run --exclude 'dist/**'"
  },
  "dependencies": {
    "@agent-platform/redis": "workspace:*",
    "ioredis": "^5.3.2",
    "pino": "^9.6.0"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
