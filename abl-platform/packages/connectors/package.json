{
  "name": "@agent-platform/connectors",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Connector SDK for Agent Platform — types, registry, executor, and auth resolution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./executor": {
      "import": "./dist/executor/index.js",
      "types": "./dist/executor/index.d.ts"
    },
    "./registry": {
      "import": "./dist/registry.js",
      "types": "./dist/registry.d.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "types": "./dist/auth/index.d.ts"
    },
    "./triggers": {
      "import": "./dist/triggers/index.js",
      "types": "./dist/triggers/index.d.ts"
    },
    "./compiler": {
      "import": "./dist/compiler/connector-to-tool.js",
      "types": "./dist/compiler/connector-to-tool.d.ts"
    },
    "./services": {
      "import": "./dist/services/index.js",
      "types": "./dist/services/index.d.ts"
    },
    "./catalog": {
      "import": "./dist/catalog/extract-entry.js",
      "types": "./dist/catalog/extract-entry.d.ts"
    },
    "./catalog/json": {
      "import": "./dist/generated/connector-catalog.json"
    },
    "./oauth/parse-token-response": {
      "import": "./dist/oauth/parse-token-response.js",
      "types": "./dist/oauth/parse-token-response.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm run validate-generated && tsc && mkdir -p dist/adapters/nango/generated dist/generated && cp src/adapters/nango/generated/providers.json dist/adapters/nango/generated/ && cp src/generated/connector-catalog.json dist/generated/",
    "generate-catalog": "tsx ../../scripts/generate-connector-catalog.ts",
    "validate-generated": "tsx ../../scripts/validate-connectors-generated.ts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@activepieces/piece-airtable": "^0.6.5",
    "@activepieces/piece-amazon-s3": "^0.5.4",
    "@activepieces/piece-amazon-ses": "^0.1.3",
    "@activepieces/piece-amazon-sns": "^0.1.3",
    "@activepieces/piece-amazon-sqs": "^0.1.3",
    "@activepieces/piece-asana": "^0.4.4",
    "@activepieces/piece-azure-blob-storage": "^0.1.4",
    "@activepieces/piece-claude": "^0.4.4",
    "@activepieces/piece-clickup": "^0.7.4",
    "@activepieces/piece-discord": "^0.4.4",
    "@activepieces/piece-github": "^0.6.6",
    "@activepieces/piece-gmail": "^0.11.4",
    "@activepieces/piece-google-calendar": "^0.8.4",
    "@activepieces/piece-google-drive": "^0.6.5",
    "@activepieces/piece-google-sheets": "^0.14.6",
    "@activepieces/piece-hubspot": "^0.8.4",
    "@activepieces/piece-jira-cloud": "^0.2.6",
    "@activepieces/piece-linear": "^0.2.3",
    "@activepieces/piece-microsoft-dynamics-365-business-central": "^0.2.1",
    "@activepieces/piece-microsoft-onedrive": "^0.3.1",
    "@activepieces/piece-microsoft-outlook": "^0.3.2",
    "@activepieces/piece-microsoft-outlook-calendar": "^0.2.1",
    "@activepieces/piece-microsoft-power-bi": "^0.2.1",
    "@activepieces/piece-microsoft-sharepoint": "^0.3.1",
    "@activepieces/piece-microsoft-teams": "^0.3.12",
    "@activepieces/piece-notion": "^0.5.4",
    "@activepieces/piece-openai": "^0.7.5",
    "@activepieces/piece-pipedrive": "^0.8.4",
    "@activepieces/piece-postgres": "^0.2.3",
    "@activepieces/piece-salesforce": "^0.6.1",
    "@activepieces/piece-sendgrid": "^0.4.4",
    "@activepieces/piece-shopify": "^0.2.4",
    "@activepieces/piece-slack": "^0.12.5",
    "@activepieces/piece-stripe": "^0.6.5",
    "@activepieces/piece-twilio": "^0.4.5",
    "@activepieces/piece-service-now": "^0.1.3",
    "@activepieces/piece-zendesk": "^0.2.7",
    "@abl/piece-azure-document-intelligence": "workspace:*",
    "@abl/piece-claude": "workspace:*",
    "@abl/piece-google-drive": "workspace:*",
    "@abl/piece-jira-cloud": "workspace:*",
    "@abl/piece-openai": "workspace:*",
    "@abl/piece-shopify": "workspace:*",
    "@agent-platform/database": "workspace:*",
    "@agent-platform/shared": "workspace:*",
    "@agent-platform/shared-kernel": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "rate-limiter-flexible": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^9.3.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
