{
  "name": "@agent-platform/circuit-breaker",
  "version": "1.0.0",
  "description": "Redis-backed hierarchical circuit breaker with Lua scripts for atomic state transitions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/lua"
  ],
  "scripts": {
    "build": "node scripts/generate-lua-module.mjs && tsc && mkdir -p dist && cp -r src/lua dist/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@agent-platform/redis": "workspace:*",
    "@agent-platform/shared": "workspace:*",
    "ioredis": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "ioredis-mock": "^8.9.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
