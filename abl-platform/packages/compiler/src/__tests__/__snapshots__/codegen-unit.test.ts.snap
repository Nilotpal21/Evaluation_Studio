exports[`snapshot tests for generated code > routing function with multiple rule types 1`] = `
"# =============================================================================
# ROUTING FUNCTION
# =============================================================================
# Generated from ABL routing table

AgentTarget = Literal["general", "__end__"]

def route_supervisor(state: OrchestratorState) -> AgentTarget:
    """
    Route to appropriate agent based on state conditions.
    Rules are evaluated in priority order (lower number = higher priority).
    """
    # Priority 1: ActiveAgent
    if state["conversation"]["active_agent"] is not None:
        return state["conversation"]["active_agent"]

    # Priority 99: DefaultRoute (default)
    return "general"
    # Fallback
    return "__end__"
"
`;

exports[`snapshot tests for generated code > state schema with multiple namespaces 1`] = `
"# =============================================================================
# STATE SCHEMA
# =============================================================================
# Generated from ABL state definition

class UserState(TypedDict):
    name: str  # User name
    loyalty_tier: str

class SessionState(TypedDict):
    booking_id: str
    is_active: bool

class OrchestratorState(MessagesState):
    """Main orchestrator state combining all namespaces"""

    user: UserState
    session: SessionState
    signal: Optional[str]
    current_agent: Optional[str]
    handoff_data: Optional[dict]

def create_initial_state() -> OrchestratorState:
    """Create initial state with defaults"""
    return OrchestratorState(
        messages=[],
        user={
            "name": "Guest",
            "loyalty_tier": "standard",
        },
        session={
            "booking_id": None,
            "is_active": True,
        },
        signal=None,
        current_agent=None,
        handoff_data=None,
    )
"
`;
