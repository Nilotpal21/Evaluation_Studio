exports[`snapshot tests for generated code > agent class with multiple step types 1`] = `
"class HotelBookingAgent:
    """Hotel Booking Agent"""


    def __init__(self, llm, tools: Dict[str, callable] = None):
        self.llm = llm
        self.tools = tools or {}
        self.role = "Hotel Booking Agent"
        self.persona = """Helpful and efficient"""

    async def _step_greet(self, state: OrchestratorState) -> Dict[str, Any]:
        """Greet the user"""
        response = "Welcome!"
        state["messages"].append(AIMessage(content=response))
        return {"state": state, "next_step": None}

    async def _step_collect_info(self, state: OrchestratorState) -> Dict[str, Any]:
        """Collect booking info"""
        # Wait for user input - return to supervisor
        return {"state": state, "signal": "CONTINUE"}

    async def _step_search(self, state: OrchestratorState) -> Dict[str, Any]:
        try:
            tool = self.tools.get("search_hotels")
            if tool:
                result = await tool({"city": state["user"]["city"]})
                state["_tool_result"] = result
                return {"state": state, "next_step": "show_results"}
        except Exception as e:
            state["user"]["api_error"] = True
            return {"state": state, "next_step": "error_handler"}

    async def _step_farewell(self, state: OrchestratorState) -> Dict[str, Any]:
        response = "Goodbye!"
        state["messages"].append(AIMessage(content=response))
        return {"state": state, "signal": "COMPLETE"}

    async def invoke(self, state: OrchestratorState) -> OrchestratorState:
        """Execute the agent flow"""
        current_step = "greet"
        max_iterations = 20
        iterations = 0

        while iterations < max_iterations:
            iterations += 1

            # Dispatch to step handler
            if current_step == "greet" or current_step == "1":
                result = await self._step_greet(state)
                state = result["state"]
                next_step = result.get("next_step")
                signal = result.get("signal")

                if signal:
                    state["signal"] = signal
                    return state

                if next_step is None:
                    return state

                current_step = next_step
                continue

            if current_step == "collect_info" or current_step == "2":
                result = await self._step_collect_info(state)
                state = result["state"]
                next_step = result.get("next_step")
                signal = result.get("signal")

                if signal:
                    state["signal"] = signal
                    return state

                if next_step is None:
                    return state

                current_step = next_step
                continue

            if current_step == "search" or current_step == "3":
                result = await self._step_search(state)
                state = result["state"]
                next_step = result.get("next_step")
                signal = result.get("signal")

                if signal:
                    state["signal"] = signal
                    return state

                if next_step is None:
                    return state

                current_step = next_step
                continue

            if current_step == "farewell" or current_step == "4":
                result = await self._step_farewell(state)
                state = result["state"]
                next_step = result.get("next_step")
                signal = result.get("signal")

                if signal:
                    state["signal"] = signal
                    return state

                if next_step is None:
                    return state

                current_step = next_step
                continue

            # Unknown step
            break

        return state
"
`;

exports[`snapshot tests for generated code > graph composition with two agents 1`] = `
"# =============================================================================
# GRAPH COMPOSITION
# =============================================================================
# Generated LangGraph state machine

def create_orchestrator_graph():
    """Create the main orchestrator graph"""

    # Initialize graph with state schema
    graph = StateGraph(OrchestratorState)

    # Add supervisor node
    graph.add_node("supervisor", supervisor_node)

    # Add agent nodes
    booking_agent = BookingAgent(llm=get_llm(), tools=TOOL_REGISTRY)
    graph.add_node("booking", booking_agent.invoke)
    support_agent = SupportAgent(llm=get_llm(), tools=TOOL_REGISTRY)
    graph.add_node("support", support_agent.invoke)

    # Set entry point
    graph.set_entry_point("supervisor")

    # Add conditional routing from supervisor
    graph.add_conditional_edges(
        "supervisor",
        route_supervisor,
        {
            "booking": "booking",
            "support": "support",
            "__end__": END,
        }
    )

    # Add edges from agents back to supervisor
    graph.add_conditional_edges(
        "booking",
        lambda state: route_agent_result(state, "booking"),
        {
            "supervisor": "supervisor",
            "__end__": END,
        }
    )
    graph.add_conditional_edges(
        "support",
        lambda state: route_agent_result(state, "support"),
        {
            "supervisor": "supervisor",
            "__end__": END,
        }
    )

    # Compile with checkpointing
    checkpointer = MemorySaver()
    compiled = graph.compile(checkpointer=checkpointer)

    return compiled

async def supervisor_node(state: OrchestratorState) -> OrchestratorState:
    """Supervisor node - handles routing decisions"""
    # Reset signal for new turn
    state["signal"] = None
    return state

def route_agent_result(state: OrchestratorState, agent_name: str) -> str:
    """Route based on agent signal"""
    signal = state.get("signal")

    if signal == "COMPLETE":
        # Clear active agent on completion
        state["conversation"]["active_agent"] = None
        return "__end__"

    if signal == "HANDOFF_READY":
        # Prepare for handoff
        state["transfer"]["handoff_pending"] = True
        return "supervisor"

    if signal == "ESCALATE":
        # Handle escalation
        return "supervisor"

    # Default: continue conversation
    state["conversation"]["active_agent"] = agent_name
    return "supervisor"
"
`;

