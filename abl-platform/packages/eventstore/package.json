{
  "name": "@abl/eventstore",
  "version": "1.0.0",
  "description": "Unified event storage framework with pluggable storage and queuing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "import": "./dist/interfaces/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./migration": {
      "types": "./dist/migration/index.d.ts",
      "import": "./dist/migration/index.js"
    },
    "./queues": {
      "types": "./dist/queues/index.d.ts",
      "import": "./dist/queues/index.js"
    },
    "./queues/buffered-kafka-topic-publisher": {
      "types": "./dist/queues/buffered-kafka-topic-publisher.d.ts",
      "import": "./dist/queues/buffered-kafka-topic-publisher.js"
    },
    "./queues/env-utils": {
      "types": "./dist/queues/env-utils.d.ts",
      "import": "./dist/queues/env-utils.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@abl/compiler": "workspace:*",
    "@agent-platform/config": "workspace:*",
    "@agent-platform/database": "workspace:*",
    "@agent-platform/redis": "workspace:*",
    "@agent-platform/shared": "workspace:*",
    "@agent-platform/shared-observability": "workspace:*",
    "bullmq": "^5.34.3",
    "kafkajs": "^2.2.4",
    "lz4js": "^0.2.0",
    "pino": "^9.6.0",
    "ulid": "^2.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@clickhouse/client": "^1.17.0",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
