{
  "name": "@agent-platform/project-io",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Project export/import, dependency management, ownership, and git integration for Agent Platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./diff": {
      "import": "./dist/diff/index.js",
      "types": "./dist/diff/index.d.ts"
    },
    "./dependencies": {
      "import": "./dist/dependencies/index.js",
      "types": "./dist/dependencies/index.d.ts"
    },
    "./export": {
      "import": "./dist/export/index.js",
      "types": "./dist/export/index.d.ts"
    },
    "./import": {
      "import": "./dist/import/index.js",
      "types": "./dist/import/index.d.ts"
    },
    "./ownership": {
      "import": "./dist/ownership/index.js",
      "types": "./dist/ownership/index.d.ts"
    },
    "./git": {
      "import": "./dist/git/index.js",
      "types": "./dist/git/index.d.ts"
    },
    "./project-agent-export-readiness": {
      "import": "./dist/project-agent-export-readiness.js",
      "types": "./dist/project-agent-export-readiness.d.ts"
    },
    "./project-agent-draft-metadata": {
      "import": "./dist/project-agent-draft-metadata.js",
      "types": "./dist/project-agent-draft-metadata.d.ts"
    },
    "./export/layer-assemblers": {
      "import": "./dist/export/layer-assemblers/index.js",
      "types": "./dist/export/layer-assemblers/index.d.ts"
    },
    "./import/layer-disassemblers": {
      "import": "./dist/import/layer-disassemblers/index.js",
      "types": "./dist/import/layer-disassemblers/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:fast": "vitest run",
    "test:repro": "vitest run --passWithNoTests \"src/**/*.repro.test.ts\"",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@abl/compiler": "workspace:^",
    "@abl/core": "workspace:*",
    "@abl/language-service": "workspace:^",
    "@agent-platform/circuit-breaker": "workspace:^",
    "@agent-platform/database": "workspace:^",
    "@agent-platform/shared": "workspace:*",
    "@agent-platform/shared-auth": "workspace:*",
    "@agent-platform/shared-kernel": "workspace:*",
    "js-yaml": "^4.1.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
