{
  "name": "@agent-platform/helix",
  "version": "0.1.0",
  "description": "HELIX — Harness for Engineering Loops and Intelligent eXecution for multi-model agentic engineering workflows",
  "type": "module",
  "bin": {
    "helix": "./dist/cli.js",
    "helix-mcp": "./dist/mcp-cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "pnpm exec vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "pnpm exec vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ajv": "^8.18.0",
    "openai": "^4.77.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-morph": "^27.0.2",
    "yaml": "^2.8.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  }
}
