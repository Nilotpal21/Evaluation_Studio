{
  "name": "@abl/crawler",
  "version": "0.1.0",
  "description": "ABL Platform - Autonomous Web Crawler Intelligence Layer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./profiler": {
      "import": "./dist/profiler/index.js",
      "types": "./dist/profiler/index.d.ts"
    },
    "./pattern-store": {
      "import": "./dist/pattern-store/index.js",
      "types": "./dist/pattern-store/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@abl/compiler": "workspace:*",
    "@agent-platform/database": "workspace:*",
    "@agent-platform/llm": "workspace:*",
    "@agent-platform/shared-kernel": "workspace:*",
    "axios": "^1.15.2",
    "cheerio": "^1.0.0-rc.12",
    "robots-parser": "^3.0.1",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "socket.io-client": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "abl",
    "crawler",
    "site-profiler",
    "autonomous",
    "intelligence"
  ],
  "author": "ABL Platform Team",
  "license": "UNLICENSED",
  "private": true
}
