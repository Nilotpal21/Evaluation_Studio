{
  "name": "@agent-platform/config",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared configuration management for Agent Platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./dist/constants.js"
    },
    "./constants/deepgram-models": {
      "types": "./dist/constants/deepgram-models.d.ts",
      "default": "./dist/constants/deepgram-models.js"
    },
    "./constants/voice-providers": {
      "types": "./dist/constants/voice-providers.d.ts",
      "default": "./dist/constants/voice-providers.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./vault": {
      "types": "./dist/vault/index.d.ts",
      "default": "./dist/vault/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "default": "./dist/validation/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:fast": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
