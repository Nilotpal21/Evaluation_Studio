{
  "name": "@agent-platform/openapi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Auto-generated OpenAPI specs from Zod schemas for Agent Platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./express": {
      "import": "./dist/express/index.js",
      "types": "./dist/express/index.d.ts"
    },
    "./nextjs": {
      "import": "./dist/nextjs/index.js",
      "types": "./dist/nextjs/index.d.ts"
    },
    "./nextjs/scanner": {
      "import": "./dist/nextjs/scanner.js",
      "types": "./dist/nextjs/scanner.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:fast": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  }
}
