{
  "name": "@agent-platform/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared middleware and types for Agent Platform apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware/index.js",
      "types": "./dist/middleware/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./rbac": {
      "import": "./dist/rbac/index.js",
      "types": "./dist/rbac/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    },
    "./repos": {
      "import": "./dist/repos/index.js",
      "types": "./dist/repos/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation/index.js",
      "types": "./dist/validation/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tools/index.js",
      "types": "./dist/tools/index.d.ts"
    },
    "./tools/resolve": {
      "import": "./dist/tools/resolve-tool-implementations.js",
      "types": "./dist/tools/resolve-tool-implementations.d.ts"
    },
    "./tools/resolve-module-tool": {
      "import": "./dist/tools/resolve-module-tool.js",
      "types": "./dist/tools/resolve-module-tool.d.ts"
    },
    "./tools/standalone-tool-adapter": {
      "import": "./dist/tools/standalone-tool-adapter.js",
      "types": "./dist/tools/standalone-tool-adapter.d.ts"
    },
    "./encryption": {
      "import": "./dist/encryption/index.js",
      "types": "./dist/encryption/index.d.ts"
    },
    "./services/mcp-registry": {
      "import": "./dist/services/mcp-server-registry.js",
      "types": "./dist/services/mcp-server-registry.d.ts"
    },
    "./security": {
      "import": "./dist/security/index.js",
      "types": "./dist/security/index.d.ts"
    },
    "./build-info": {
      "import": "./dist/build-info.js",
      "types": "./dist/build-info.d.ts"
    },
    "./services/mcp-auth-resolver": {
      "import": "./dist/services/mcp-auth-resolver.js",
      "types": "./dist/services/mcp-auth-resolver.d.ts"
    },
    "./websocket-auth": {
      "import": "./dist/websocket-auth.js",
      "types": "./dist/websocket-auth.d.ts"
    },
    "./sdk-widget-capabilities": {
      "import": "./dist/sdk-widget-capabilities.js",
      "types": "./dist/sdk-widget-capabilities.d.ts"
    },
    "./services/lambda": {
      "import": "./dist/services/lambda/index.js",
      "types": "./dist/services/lambda/index.d.ts"
    },
    "./model-pricing": {
      "import": "./dist/model-pricing.js",
      "types": "./dist/model-pricing.d.ts"
    },
    "./prompts": {
      "import": "./dist/prompts/index.js",
      "types": "./dist/prompts/index.d.ts"
    },
    "./prompts/builtin-runtime": {
      "import": "./dist/prompts/builtin-runtime.js",
      "types": "./dist/prompts/builtin-runtime.d.ts"
    },
    "./services/auth-profile": {
      "import": "./dist/services/auth-profile/index.js",
      "types": "./dist/services/auth-profile/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agent-platform/database": "workspace:*",
    "@agent-platform/i18n": "workspace:*",
    "@agent-platform/redis": "workspace:*",
    "@agent-platform/shared-auth": "workspace:*",
    "@agent-platform/shared-auth-profile": "workspace:*",
    "@agent-platform/shared-encryption": "workspace:*",
    "@agent-platform/shared-kernel": "workspace:*",
    "@agent-platform/shared-observability": "workspace:*",
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-lambda": "^3.998.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/client-ses": "^3.500.0",
    "@aws-sdk/lib-storage": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@aws-sdk/signature-v4": "^3.374.0",
    "@azure/identity": "^4.13.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.1",
    "rate-limiter-flexible": "^5.0.0",
    "sanitize-html": "^2.13.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/nodemailer": "^7.0.9",
    "@types/sanitize-html": "^2.13.0",
    "@types/ssh2": "^1.15.5",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "express": "^4.18.0",
    "mongoose": "^8.0.0",
    "zod": "^3.20.0"
  }
}
