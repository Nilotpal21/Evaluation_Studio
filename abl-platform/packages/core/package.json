{
  "name": "@abl/core",
  "version": "1.0.0",
  "description": "Core ABL types, parser, and AST utilities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:fast": "vitest run",
    "test:repro": "vitest run --config vitest.repro.config.ts --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "chevrotain": "^11.0.0",
    "js-yaml": "^4.1.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.4",
    "ajv": "^8.18.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "esbuild": "0.25.0",
    "lodash-es": "4.18.0",
    "postcss": "8.5.10",
    "rollup": "4.59.0",
    "vite": "8.0.5"
  }
}
