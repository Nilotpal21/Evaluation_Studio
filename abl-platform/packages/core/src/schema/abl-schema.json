{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://abl-platform.kore.ai/schemas/abl-agent.json",
  "title": "ABL Agent Definition",
  "description": "JSON Schema for validating ABL YAML-format agent definitions. Covers identity, tools, gather, constraints, coordination (handoff/delegate/escalate), flow, memory, execution, messages, templates, and guardrails.",
  "type": "object",
  "required": ["agent", "mode"],
  "additionalProperties": false,
  "properties": {
    "agent": {
      "type": "string",
      "minLength": 1,
      "description": "Agent name (unique identifier within a project)"
    },
    "supervisor": {
      "type": "string",
      "minLength": 1,
      "description": "Supervisor agent name (alternative to 'agent' for supervisor mode)"
    },
    "mode": {
      "type": "string",
      "enum": ["reasoning", "scripted", "supervisor"],
      "description": "Execution mode: reasoning (LLM-driven), scripted (deterministic flow), or supervisor (routing)"
    },
    "version": {
      "type": "string",
      "description": "Agent version (semver format recommended)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the agent's purpose"
    },
    "language": {
      "type": "string",
      "description": "BCP 47 locale code for the agent's primary language (e.g., 'en', 'es-EC')"
    },
    "goal": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "description": { "type": "string" },
            "measurable": { "type": "boolean" }
          },
          "required": ["description"],
          "additionalProperties": false
        }
      ],
      "description": "Agent's primary goal or objective"
    },
    "persona": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "description": { "type": "string" }
          },
          "required": ["description"],
          "additionalProperties": false
        }
      ],
      "description": "Agent persona description (tone, style, personality)"
    },
    "identity": {
      "type": "object",
      "description": "Alternative identity block (maps to goal, persona, limitations)",
      "properties": {
        "role": { "type": "string" },
        "persona": { "type": "string" },
        "expertise": {
          "type": "array",
          "items": { "type": "string" }
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "limitations": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "properties": {
              "description": { "type": "string" }
            },
            "required": ["description"],
            "additionalProperties": false
          }
        ]
      },
      "description": "List of things the agent cannot do"
    },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/definitions/tool" },
      "description": "Tools available to the agent"
    },
    "gather": {
      "oneOf": [
        {
          "type": "array",
          "items": { "$ref": "#/definitions/gatherField" }
        },
        {
          "type": "object",
          "properties": {
            "fields": {
              "type": "array",
              "items": { "$ref": "#/definitions/gatherField" }
            }
          },
          "required": ["fields"],
          "additionalProperties": false
        }
      ],
      "description": "Information to collect from the user"
    },
    "constraints": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/constraintRequirement" },
          { "$ref": "#/definitions/constraintPhase" }
        ]
      },
      "description": "Runtime constraints enforced during execution"
    },
    "guardrails": {
      "type": "array",
      "items": { "$ref": "#/definitions/guardrail" },
      "description": "Input/output safety checks"
    },
    "flow": {
      "type": "object",
      "description": "Flow definition for scripted mode",
      "properties": {
        "entry_point": { "type": "string" },
        "steps": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "handoff": {
      "type": "array",
      "items": { "$ref": "#/definitions/handoff" },
      "description": "Handoff configurations for routing to other agents"
    },
    "return_handlers": {
      "type": "object",
      "description": "Named post-return handlers for RETURN:true handoffs",
      "additionalProperties": { "$ref": "#/definitions/returnHandler" }
    },
    "delegate": {
      "type": "array",
      "items": { "$ref": "#/definitions/delegate" },
      "description": "Delegate configurations for sub-agent invocations"
    },
    "escalate": {
      "type": "object",
      "description": "Escalation configuration for human handoff",
      "properties": {
        "triggers": {
          "type": "array",
          "items": { "$ref": "#/definitions/escalateTrigger" }
        },
        "context_for_human": {
          "type": "array",
          "items": { "$ref": "#/definitions/escalateContextItem" }
        },
        "routing": { "type": "object" },
        "on_human_complete": {
          "type": "array",
          "items": { "$ref": "#/definitions/onHumanCompleteAction" }
        }
      },
      "additionalProperties": false
    },
    "complete": {
      "type": "array",
      "items": { "$ref": "#/definitions/completeCondition" },
      "description": "Conditions that mark the agent's task as complete"
    },
    "memory": {
      "type": "object",
      "description": "Memory configuration (session vars, persistent paths, remember/recall)",
      "properties": {
        "session": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "initial_value": {}
                },
                "required": ["name"],
                "additionalProperties": false
              }
            ]
          }
        },
        "persistent": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "path": { "type": "string" },
                  "description": { "type": "string" },
                  "scope": {
                    "type": "string",
                    "enum": ["user", "project", "execution_tree"]
                  },
                  "access": {
                    "type": "string",
                    "enum": ["read", "write", "readwrite"]
                  },
                  "type": {
                    "type": "string",
                    "enum": ["string", "number", "boolean", "date", "array", "object"]
                  },
                  "unit": { "type": "string" },
                  "default_value": {}
                },
                "required": ["path"],
                "additionalProperties": false
              }
            ]
          }
        },
        "remember": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "when": { "type": "string" },
              "store": {
                "type": "object",
                "properties": {
                  "value": { "type": "string" },
                  "target": { "type": "string" }
                },
                "required": ["value", "target"],
                "additionalProperties": false
              },
              "ttl": { "type": "string" }
            },
            "required": ["when", "store"],
            "additionalProperties": false
          }
        },
        "recall": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "event": { "type": "string" },
              "instruction": { "type": "string" }
            },
            "required": ["event", "instruction"],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "description": "Execution configuration (model, temperature, timeouts)",
      "properties": {
        "model": { "type": "string" },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "tool_timeout": { "type": "number", "minimum": 0 },
        "llm_timeout": { "type": "number", "minimum": 0 },
        "session_idle_timeout": { "type": "number", "minimum": 0 },
        "max_reasoning_iterations": { "type": "integer", "minimum": 1 },
        "max_flow_iterations": { "type": "integer", "minimum": 1 },
        "voice_latency_target": { "type": "number", "minimum": 0 },
        "fallback_model": { "type": "string" },
        "operation_models": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "messages": {
      "type": "object",
      "description": "Configurable agent messages (error_default, gather_prompt, etc.)",
      "additionalProperties": { "type": "string" }
    },
    "templates": {
      "type": "array",
      "items": { "$ref": "#/definitions/template" },
      "description": "Named response templates"
    },
    "on_error": {
      "type": "array",
      "items": { "$ref": "#/definitions/errorHandler" },
      "description": "Error handlers"
    },
    "on_start": {
      "type": "object",
      "description": "Lifecycle handler executed on session start",
      "properties": {
        "respond": { "type": "string" },
        "call": { "type": "string" },
        "set": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "delegate": { "type": "string" }
      },
      "additionalProperties": false
    },
    "system_prompt": {
      "type": "string",
      "description": "Custom system prompt template"
    },
    "hooks": {
      "type": "object",
      "description": "Lifecycle hooks (before_agent, after_agent, before_turn, after_turn)",
      "properties": {
        "before_agent": { "$ref": "#/definitions/hookAction" },
        "after_agent": { "$ref": "#/definitions/hookAction" },
        "before_turn": { "$ref": "#/definitions/hookAction" },
        "after_turn": { "$ref": "#/definitions/hookAction" }
      },
      "additionalProperties": false
    },
    "nlu": {
      "type": "object",
      "description": "NLU configuration (intents, entities, categories)",
      "properties": {
        "models": {
          "type": "object",
          "properties": {
            "fast": { "type": "string" },
            "balanced": { "type": "string" }
          },
          "additionalProperties": false
        },
        "languages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "default_language": { "type": "string" },
        "allow_code_switching": { "type": "boolean" },
        "language_models": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "intents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "patterns": {
                "type": "array",
                "items": { "type": "string" }
              },
              "examples": {
                "type": "array",
                "items": { "type": "string" }
              },
              "examples_file": { "type": "string" },
              "entities": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["name", "patterns"],
            "additionalProperties": false
          }
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "patterns": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["name", "patterns"],
            "additionalProperties": false
          }
        },
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["enum", "pattern", "location", "date", "number", "free_text"]
              },
              "values": {
                "type": "array",
                "items": { "type": "string" }
              },
              "synonyms": {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "pattern": { "type": "string" },
              "validation": { "type": "string" }
            },
            "required": ["name", "type"],
            "additionalProperties": false
          }
        },
        "glossary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evaluation": {
          "type": "object",
          "properties": {
            "log_predictions": { "type": "boolean" },
            "ab_test": { "type": "boolean" },
            "confidence_threshold": { "type": "number" }
          },
          "additionalProperties": false
        },
        "embeddings": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "provider": { "type": "string" },
            "model": { "type": "string" },
            "base_url": { "type": "string" },
            "threshold": { "type": "number" },
            "cache_ttl": { "type": "number" }
          },
          "required": ["enabled"],
          "additionalProperties": false
        },
        "config_file": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "tool": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Tool name (must be unique within the agent)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what the tool does"
        },
        "type": {
          "type": "string",
          "enum": ["http", "mcp", "lambda", "sandbox"],
          "description": "Tool execution type"
        },
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/definitions/toolParam" },
          "description": "Input parameters"
        },
        "returns": {
          "oneOf": [{ "type": "string" }, { "$ref": "#/definitions/toolReturn" }],
          "description": "Return type specification"
        },
        "hints": {
          "type": "object",
          "properties": {
            "cacheable": { "type": "boolean" },
            "latency": {
              "type": "string",
              "enum": ["fast", "medium", "slow"]
            },
            "side_effects": { "type": "boolean" },
            "requires_auth": { "type": "boolean" },
            "timeout": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "http_binding": {
          "type": "object",
          "properties": {
            "endpoint": { "type": "string" },
            "method": {
              "type": "string",
              "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
            },
            "auth": {
              "type": "string",
              "enum": [
                "none",
                "api_key",
                "bearer",
                "oauth2_client",
                "oauth2_user",
                "saml",
                "custom"
              ]
            },
            "auth_config": {
              "type": "object",
              "properties": {
                "token_url": { "type": "string" },
                "client_id": { "type": "string" },
                "client_secret": { "type": "string" },
                "scopes": { "type": "string" },
                "header_name": { "type": "string" },
                "provider": { "type": "string" },
                "custom_headers": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              },
              "additionalProperties": false
            },
            "timeout": { "type": "number", "minimum": 0 },
            "retry": { "type": "integer", "minimum": 0 },
            "retry_delay": { "type": "number", "minimum": 0 },
            "headers": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "rate_limit": { "type": "number", "minimum": 0 },
            "circuit_breaker": {
              "type": "object",
              "properties": {
                "threshold": { "type": "integer", "minimum": 1 },
                "reset_ms": { "type": "number", "minimum": 0 }
              },
              "required": ["threshold", "reset_ms"],
              "additionalProperties": false
            }
          },
          "required": ["endpoint", "method"],
          "additionalProperties": false
        },
        "mcp_binding": {
          "type": "object",
          "properties": {
            "server": { "type": "string" },
            "tool": { "type": "string" }
          },
          "required": ["server"],
          "additionalProperties": false
        },
        "lambda_binding": {
          "type": "object",
          "properties": {
            "function": { "type": "string" },
            "runtime": { "type": "string" },
            "timeout": { "type": "number", "minimum": 0 }
          },
          "required": ["function"],
          "additionalProperties": false
        },
        "sandbox_binding": {
          "type": "object",
          "properties": {
            "runtime": {
              "type": "string",
              "enum": ["javascript", "python"]
            },
            "code": { "type": "string" },
            "timeout": { "type": "number", "minimum": 0 },
            "memory_mb": { "type": "number", "minimum": 0 }
          },
          "required": ["runtime"],
          "additionalProperties": false
        }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "toolParam": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "description": "Parameter type (string, number, boolean, date, array, object, etc.)"
        },
        "required": { "type": "boolean" },
        "default": {},
        "description": { "type": "string" },
        "validate": { "type": "string" }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "toolReturn": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [{ "type": "string" }, { "$ref": "#/definitions/toolReturn" }]
          }
        },
        "items": {
          "oneOf": [{ "type": "string" }, { "$ref": "#/definitions/toolReturn" }]
        },
        "optional": { "type": "boolean" }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "gatherField": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "prompt": { "type": "string" },
        "type": {
          "type": "string",
          "description": "Field type (string, number, boolean, date, email, phone, etc.)"
        },
        "required": { "type": "boolean" },
        "default": {},
        "validate": { "type": "string" },
        "validation_process": {
          "type": "string",
          "enum": ["REGEX", "CODE", "LLM"]
        },
        "retry_prompt": { "type": "string" },
        "max_retries": { "type": "integer", "minimum": 0 },
        "infer": { "type": "boolean" },
        "range": { "type": "boolean" },
        "list": { "type": "boolean" },
        "preferences": { "type": "boolean" },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prompt_mode": {
          "type": "string",
          "enum": ["ask", "extract_only"]
        },
        "activation": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["required", "optional", "progressive"]
            },
            {
              "type": "object",
              "properties": {
                "when": { "type": "string" }
              },
              "required": ["when"],
              "additionalProperties": false
            }
          ]
        },
        "semantics": {
          "type": "object",
          "properties": {
            "format": { "type": "string" },
            "components": {
              "type": "array",
              "items": { "type": "string" }
            },
            "unit": { "type": "string" },
            "lookup": { "type": "string" },
            "convert_to": { "type": "string" },
            "locale": { "type": "string" },
            "kore_entity_type": { "type": "string" },
            "enum_set": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "extraction_hints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "constraintRequirement": {
      "type": "object",
      "properties": {
        "condition": {
          "type": "string",
          "description": "Condition expression to evaluate"
        },
        "kind": {
          "type": "string",
          "enum": ["require", "limit", "restrict"],
          "description": "Original constraint keyword from the DSL"
        },
        "when": {
          "type": "string",
          "description": "Applicability guard for the requirement"
        },
        "before": {
          "$ref": "#/definitions/constraintBeforeTarget",
          "description": "Structural checkpoint gate from REQUIRE ... BEFORE ..."
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning"],
          "description": "Whether a failure blocks execution or only emits a warning"
        },
        "on_fail": {
          "oneOf": [{ "type": "string" }, { "$ref": "#/definitions/constraintAction" }],
          "description": "Action to take when condition fails"
        }
      },
      "required": ["condition", "on_fail"],
      "additionalProperties": false
    },
    "constraintBeforeTarget": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["tool_call", "respond", "unsupported"]
            },
            "raw": {
              "type": "string"
            },
            "target": {
              "type": "string"
            }
          },
          "required": ["kind", "raw"],
          "additionalProperties": false
        }
      ]
    },
    "constraintPhase": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Phase name (e.g., 'always', 'pre_search', 'pre_booking')"
        },
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/definitions/constraintRequirement" }
        }
      },
      "required": ["name", "requirements"],
      "additionalProperties": false
    },
    "constraintAction": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "respond",
            "escalate",
            "handoff",
            "block",
            "collect_field",
            "goto_step",
            "retry_step"
          ]
        },
        "message": { "type": "string" },
        "reason": { "type": "string" },
        "target": { "type": "string" },
        "collect_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "step": { "type": "string" },
        "respond": { "type": "string" },
        "then": {
          "type": "string",
          "enum": ["continue", "retry"]
        }
      },
      "required": ["action"],
      "additionalProperties": false
    },
    "guardrail": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["input", "output", "both"]
        },
        "check": { "type": "string" },
        "action": {
          "type": "string",
          "enum": ["block", "warn", "redact", "escalate"]
        },
        "message": { "type": "string" },
        "priority": { "type": "integer" }
      },
      "required": ["name", "check", "action"],
      "additionalProperties": false
    },
    "handoff": {
      "type": "object",
      "properties": {
        "to": {
          "type": "string",
          "minLength": 1,
          "description": "Target agent name"
        },
        "when": {
          "type": "string",
          "description": "Condition for triggering the handoff"
        },
        "priority": {
          "type": "integer",
          "description": "Evaluation priority (lower = evaluated first)"
        },
        "context": {
          "type": "object",
          "properties": {
            "pass": {
              "type": "array",
              "items": { "type": "string" }
            },
            "summary": { "type": "string" },
            "memory_grants": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "access": {
                    "type": "string",
                    "enum": ["read", "readwrite"]
                  }
                },
                "required": ["path"],
                "additionalProperties": false
              }
            },
            "history": {
              "oneOf": [
                {
                  "type": "string",
                  "enum": ["auto", "none", "summary_only", "full"]
                },
                {
                  "type": "string",
                  "pattern": "^last_[1-9][0-9]*$"
                },
                {
                  "type": "object",
                  "properties": {
                    "mode": {
                      "type": "string",
                      "enum": ["auto", "none", "summary_only", "full"]
                    }
                  },
                  "required": ["mode"],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "mode": {
                      "type": "string",
                      "const": "last_n"
                    },
                    "count": {
                      "type": "integer",
                      "minimum": 1
                    }
                  },
                  "required": ["mode", "count"],
                  "additionalProperties": false
                }
              ]
            }
          },
          "additionalProperties": false
        },
        "return": { "type": "boolean" },
        "on_return": { "$ref": "#/definitions/onReturnConfig" },
        "remote": { "$ref": "#/definitions/remoteAgentConfig" }
      },
      "required": ["to", "when"],
      "additionalProperties": false
    },
    "onReturnConfig": {
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "handler": { "type": "string", "minLength": 1 },
        "map": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "anyOf": [{ "required": ["action"] }, { "required": ["handler"] }],
      "additionalProperties": false
    },
    "returnHandler": {
      "type": "object",
      "properties": {
        "respond": { "type": "string" },
        "clear": {
          "type": "array",
          "items": { "type": "string" }
        },
        "continue": { "type": "boolean" },
        "resume_intent": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "delegate": {
      "type": "object",
      "properties": {
        "agent": {
          "type": "string",
          "minLength": 1,
          "description": "Sub-agent to delegate to"
        },
        "when": {
          "type": "string",
          "description": "Condition for triggering delegation"
        },
        "purpose": { "type": "string" },
        "input": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "returns": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "use_result": { "type": "string" },
        "timeout": { "type": "string" },
        "on_failure": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["respond", "continue", "escalate", "retry"]
                },
                "message": { "type": "string" },
                "count": { "type": "integer", "minimum": 1 }
              },
              "required": ["type"],
              "additionalProperties": false
            }
          ]
        },
        "remote": { "$ref": "#/definitions/remoteAgentConfig" }
      },
      "required": ["agent", "when"],
      "additionalProperties": false
    },
    "escalateTrigger": {
      "type": "object",
      "properties": {
        "when": { "type": "string" },
        "reason": { "type": "string" },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["when", "reason"],
      "additionalProperties": false
    },
    "escalateContextItem": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "template": { "type": "string" },
        "include": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "onHumanCompleteAction": {
      "type": "object",
      "properties": {
        "condition": { "type": "string" },
        "action": {
          "oneOf": [{ "type": "string" }, { "type": "object" }]
        }
      },
      "required": ["condition", "action"],
      "additionalProperties": false
    },
    "completeCondition": {
      "type": "object",
      "properties": {
        "when": {
          "type": "string",
          "description": "Condition expression for completion"
        },
        "respond": {
          "type": "string",
          "description": "Response message on completion"
        },
        "store": {
          "type": "string",
          "description": "Store name for persisting completion data"
        }
      },
      "required": ["when"],
      "additionalProperties": false
    },
    "errorHandler": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Error type (tool_timeout, tool_error, invalid_input, etc.)"
        },
        "subtypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "respond": { "type": "string" },
        "retry": { "type": "integer", "minimum": 0 },
        "retry_delay": { "type": "number", "minimum": 0 },
        "retry_backoff": {
          "type": "string",
          "enum": ["fixed", "exponential", "linear"]
        },
        "retry_max_delay": { "type": "number", "minimum": 0 },
        "then": {
          "oneOf": [{ "type": "string" }, { "type": "object" }]
        },
        "backtrack_to": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "template": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "content": { "type": "string" },
        "formats": {
          "type": "object",
          "properties": {
            "markdown": { "type": "string" },
            "adaptive_card": { "type": "string" },
            "html": { "type": "string" },
            "slack": { "type": "string" },
            "ag_ui": { "type": "string" },
            "whatsapp": { "type": "string" }
          },
          "additionalProperties": false
        },
        "actions": { "$ref": "#/definitions/actionSet" }
      },
      "required": ["name", "content"],
      "additionalProperties": false
    },
    "actionSet": {
      "type": "object",
      "properties": {
        "elements": {
          "type": "array",
          "items": { "$ref": "#/definitions/actionElement" }
        },
        "submit_label": { "type": "string" },
        "submit_id": { "type": "string" }
      },
      "required": ["elements"],
      "additionalProperties": false
    },
    "actionElement": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["button", "select", "input"]
        },
        "label": { "type": "string" },
        "value": { "type": "string" },
        "description": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "description": { "type": "string" }
            },
            "required": ["id", "label"],
            "additionalProperties": false
          }
        },
        "input_type": {
          "type": "string",
          "enum": ["text", "number", "date", "time", "email"]
        },
        "placeholder": { "type": "string" },
        "required": { "type": "boolean" }
      },
      "required": ["id", "type", "label"],
      "additionalProperties": false
    },
    "hookAction": {
      "type": "object",
      "properties": {
        "call": { "type": "string" },
        "set": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "respond": { "type": "string" }
      },
      "additionalProperties": false
    },
    "remoteAgentConfig": {
      "type": "object",
      "properties": {
        "location": {
          "type": "string",
          "enum": ["local", "remote"]
        },
        "endpoint": { "type": "string" },
        "protocol": {
          "type": "string",
          "enum": ["a2a", "rest"]
        },
        "auth": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["api_key", "bearer"]
            },
            "header": { "type": "string" }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        "timeout": { "type": "string" }
      },
      "required": ["location"],
      "additionalProperties": false
    }
  }
}
