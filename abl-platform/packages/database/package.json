{
  "name": "@agent-platform/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared database layer (MongoDB + ClickHouse) for Agent Platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./clickhouse": {
      "types": "./dist/clickhouse.d.ts",
      "default": "./dist/clickhouse.js"
    },
    "./clickhouse.js": {
      "types": "./dist/clickhouse.d.ts",
      "default": "./dist/clickhouse.js"
    },
    "./platform-access-policy": {
      "types": "./dist/platform-access-policy.d.ts",
      "default": "./dist/platform-access-policy.js"
    },
    "./clickhouse-schemas/init": {
      "types": "./dist/clickhouse-schemas/init.d.ts",
      "default": "./dist/clickhouse-schemas/init.js"
    },
    "./clickhouse-schemas/database": {
      "types": "./dist/clickhouse-schemas/database.d.ts",
      "default": "./dist/clickhouse-schemas/database.js"
    },
    "./clickhouse-schemas/migrations/eval-retention-ttl-columns": {
      "types": "./dist/clickhouse-schemas/migrations/eval-retention-ttl-columns.d.ts",
      "default": "./dist/clickhouse-schemas/migrations/eval-retention-ttl-columns.js"
    },
    "./clickhouse-schemas/migrations/add-cost-breakdown-to-eval-conversations": {
      "types": "./dist/clickhouse-schemas/migrations/add-cost-breakdown-to-eval-conversations.d.ts",
      "default": "./dist/clickhouse-schemas/migrations/add-cost-breakdown-to-eval-conversations.js"
    },
    "./clickhouse-schemas/init-all": {
      "types": "./dist/clickhouse-schemas/init-all.d.ts",
      "default": "./dist/clickhouse-schemas/init-all.js"
    },
    "./clickhouse-schemas/ddl-transform": {
      "types": "./dist/clickhouse-schemas/ddl-transform.d.ts",
      "default": "./dist/clickhouse-schemas/ddl-transform.js"
    },
    "./clickhouse-schemas/tables/analytics": {
      "types": "./dist/clickhouse-schemas/tables/analytics.d.ts",
      "default": "./dist/clickhouse-schemas/tables/analytics.js"
    },
    "./clickhouse-schemas/tables/eval": {
      "types": "./dist/clickhouse-schemas/tables/eval.d.ts",
      "default": "./dist/clickhouse-schemas/tables/eval.js"
    },
    "./clickhouse-schemas/tables/experiment": {
      "types": "./dist/clickhouse-schemas/tables/experiment.d.ts",
      "default": "./dist/clickhouse-schemas/tables/experiment.js"
    },
    "./clickhouse-schemas/tables/workflow": {
      "types": "./dist/clickhouse-schemas/tables/workflow.d.ts",
      "default": "./dist/clickhouse-schemas/tables/workflow.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "default": "./dist/models/index.js"
    },
    "./models/search-chunk": {
      "types": "./dist/models/search-chunk.model.d.ts",
      "default": "./dist/models/search-chunk.model.js"
    },
    "./models/domain-vocabulary": {
      "types": "./dist/models/domain-vocabulary.model.d.ts",
      "default": "./dist/models/domain-vocabulary.model.js"
    },
    "./models/user": {
      "types": "./dist/models/user.model.d.ts",
      "default": "./dist/models/user.model.js"
    },
    "./models/tenant-member": {
      "types": "./dist/models/tenant-member.model.d.ts",
      "default": "./dist/models/tenant-member.model.js"
    },
    "./models/api-key": {
      "types": "./dist/models/api-key.model.d.ts",
      "default": "./dist/models/api-key.model.js"
    },
    "./models/search-index": {
      "types": "./dist/models/search-index.model.d.ts",
      "default": "./dist/models/search-index.model.js"
    },
    "./models/search-source": {
      "types": "./dist/models/search-source.model.d.ts",
      "default": "./dist/models/search-source.model.js"
    },
    "./models/search-document": {
      "types": "./dist/models/search-document.model.d.ts",
      "default": "./dist/models/search-document.model.js"
    },
    "./models/discovered-schema": {
      "types": "./dist/models/discovered-schema.model.d.ts",
      "default": "./dist/models/discovered-schema.model.js"
    },
    "./mongo": {
      "types": "./dist/mongo/index.d.ts",
      "default": "./dist/mongo/index.js"
    },
    "./cascade": {
      "types": "./dist/cascade/index.d.ts",
      "default": "./dist/cascade/index.js"
    },
    "./kms": {
      "types": "./dist/kms/index.d.ts",
      "default": "./dist/kms/index.js"
    },
    "./kms/facade": {
      "types": "./dist/kms/dek-facade-factory.d.ts",
      "default": "./dist/kms/dek-facade-factory.js"
    },
    "./kms/providers/external": {
      "types": "./dist/kms/providers/external-kms-provider.d.ts",
      "default": "./dist/kms/providers/external-kms-provider.js"
    },
    "./templates/eval-persona-templates": {
      "types": "./dist/templates/eval-persona-templates.d.ts",
      "default": "./dist/templates/eval-persona-templates.js"
    },
    "./templates/eval-rubric-templates": {
      "types": "./dist/templates/eval-rubric-templates.d.ts",
      "default": "./dist/templates/eval-rubric-templates.js"
    },
    "./constants/eval-limits": {
      "types": "./dist/constants/eval-limits.d.ts",
      "default": "./dist/constants/eval-limits.js"
    },
    "./constants/system-roles": {
      "types": "./dist/constants/system-roles.d.ts",
      "default": "./dist/constants/system-roles.js"
    },
    "./constants/guardrail-adapters": {
      "types": "./dist/constants/guardrail-adapters.d.ts",
      "default": "./dist/constants/guardrail-adapters.js"
    },
    "./seed-inline-tools": {
      "types": "./dist/tool-extractor.d.ts",
      "default": "./dist/tool-extractor.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:fast": "vitest run --config vitest.fast.config.ts",
    "test:fast:all": "pnpm run test:fast && pnpm run test:fast:infra",
    "test:fast:infra": "vitest run --config vitest.infra.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:seed": "tsx seed-mongo.ts --dev",
    "db:seed:fresh": "tsx seed-mongo.ts --fresh --dev",
    "db:seed:core": "tsx seed-mongo.ts",
    "db:seed:status": "tsx seed-mongo.ts --status",
    "db:seed:validate": "tsx seed-mongo.ts --validate",
    "db:migrate:mongo": "tsx src/migrations/cli.ts migrate",
    "db:migrate:mongo:status": "tsx src/migrations/cli.ts status",
    "db:migrate:mongo:validate": "tsx src/migrations/cli.ts validate",
    "db:migrate:mongo:rollback": "tsx src/migrations/cli.ts rollback"
  },
  "dependencies": {
    "@agent-platform/shared-kernel": "workspace:*",
    "@agent-platform/shared-auth": "workspace:*",
    "@agent-platform/shared-encryption": "workspace:*",
    "@clickhouse/client": "^1.8.0",
    "mongoose": "^8.23.0"
  },
  "optionalDependencies": {
    "@azure/identity": "^4.13.0",
    "@azure/keyvault-keys": "^4.10.0",
    "@aws-sdk/client-kms": "^3.1030.0",
    "@google-cloud/kms": "^4.0.0"
  },
  "peerDependencies": {
    "undici": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "undici": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "mongodb-memory-server": "^11.0.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
