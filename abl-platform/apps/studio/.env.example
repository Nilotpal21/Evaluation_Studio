# ═══════════════════════════════════════════════════════════════════════════════
# STUDIO (Next.js Frontend) - Development Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env.local and adjust as needed:  cp .env.example .env.local

# ─────────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5173

# ─────────────────────────────────────────────────────────────────────────────────
# URLs & Endpoints
# ─────────────────────────────────────────────────────────────────────────────────
# Runtime URL (REQUIRED) - Base URL for runtime API
# WebSocket URLs are derived automatically from this
NEXT_PUBLIC_RUNTIME_URL=http://localhost:3112
# Server-side Runtime URL for Studio API route proxying (falls back to http://localhost:3112)
RUNTIME_URL=http://localhost:3112

# Studio URL (for OAuth redirects, share links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:5173

# Workflow Engine URL (optional) - Base URL for workflow-engine API
# Used by Studio proxy routes for workflow CRUD, executions, connections, approvals
# Default: http://localhost:9080
WORKFLOW_ENGINE_URL=http://localhost:9080

# ─────────────────────────────────────────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017/abl_platform
MONGODB_DATABASE=abl_platform

# ─────────────────────────────────────────────────────────────────────────────────
# Redis (Optional for development)
# ─────────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_CLUSTER=false
# REDIS_TLS_ENABLED=false
# --- cluster mode: set REDIS_CLUSTER=true and provide comma-separated seed list ---
# REDIS_URL=redis-0:6379,redis-1:6379,redis-2:6379

# ─────────────────────────────────────────────────────────────────────────────────
# Authentication & Security
# ─────────────────────────────────────────────────────────────────────────────────
# JWT Secret - MUST match Runtime's JWT_SECRET
# In production: openssl rand -base64 64
JWT_SECRET=development-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Preview Token Secret (optional - falls back to JWT_SECRET)
# Used for SDK preview tokens. In production: openssl rand -base64 64
# PREVIEW_TOKEN_SECRET=

# Encryption key - MUST match Runtime's key (required for tool secrets)
# In production: openssl rand -hex 32
# ENCRYPTION_ENABLED=true  # Set to 'false' to disable encryption even when key is set
# ENCRYPTION_MASTER_KEY=   # Generate with: openssl rand -hex 32

# ─────────────────────────────────────────────────────────────────────────────────
# Sandbox Tool Testing (required for testing sandbox/code tools from Studio)
# ─────────────────────────────────────────────────────────────────────────────────
# SANDBOX_PYTHON_POD_URL=http://kr-python-svc
SANDBOX_JAVASCRIPT_POD_URL=https://usaz-dev-agent-platform.kore.ai/gvisor
# SANDBOX_JWT_SECRET=
# SANDBOX_POD_PATH=/execute-script

# SDK Bootstrap Signing Secret — shared between Studio and Runtime
# Signs bootstrap artifacts for preview/share token exchange
# MUST match Runtime's AUTH_SDK_BOOTSTRAP_SIGNING_SECRET
# Generate with: openssl rand -base64 48
AUTH_SDK_BOOTSTRAP_SIGNING_SECRET=

# NextAuth secret (for session management)
# In production: openssl rand -base64 32
NEXTAUTH_SECRET=development-nextauth-secret
NEXTAUTH_URL=http://localhost:5173

# Dev login endpoint (allows login without OAuth in development)
ENABLE_DEV_LOGIN=true

# ─────────────────────────────────────────────────────────────────────────────────
# OAuth Providers
# ─────────────────────────────────────────────────────────────────────────────────

# Google OAuth (Optional for dev - dev-login endpoint available)
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (Optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────────
# Connector OAuth Credentials (for connector connection OAuth flows)
# ─────────────────────────────────────────────────────────────────────────────────
# Pattern: OAUTH_PROVIDER_<PROVIDER>_CLIENT_ID / _CLIENT_SECRET
# OAUTH_PROVIDER_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# OAUTH_PROVIDER_GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# OAUTH_PROVIDER_SLACK_CLIENT_ID=
# OAUTH_PROVIDER_SLACK_CLIENT_SECRET=
# OAUTH_PROVIDER_GITHUB_CLIENT_ID=
# OAUTH_PROVIDER_GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────────
# Voice Services (passed to SDK for client-side Twilio)
# ─────────────────────────────────────────────────────────────────────────────────

# Twilio (Optional - for voice token generation)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_API_KEY=
# TWILIO_API_SECRET=
# TWILIO_TWIML_APP_SID=

# ─────────────────────────────────────────────────────────────────────────────────
# LLM Keys (for server-side API routes that need direct LLM access)
# ─────────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# Storage (Optional - local filesystem used in dev)
# ─────────────────────────────────────────────────────────────────────────────────
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# Email Provider (Optional in dev — pick one, priority: SES > Resend > SMTP > Console)
# ─────────────────────────────────────────────────────────────────────────────────
# AWS SES (requires verified sender identity)
# AWS_SES_REGION=us-east-1
# AWS credentials: use AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY or IAM role
#
# Resend (alternative)
# RESEND_API_KEY=
#
# SMTP via Nodemailer (works with any SMTP server — Gmail, Mailgun, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
#
# Sender address (must be verified with your provider). Default: noreply@koreplatform.com
# EMAIL_FROM=noreply@koreplatform.com

# ─────────────────────────────────────────────────────────────────────────────────
# Observability (disabled by default in dev)
# ─────────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# LiveKit (WebRTC voice — alternative to Twilio, connects to runtime LiveKit worker)
# ─────────────────────────────────────────────────────────────────────────────────
# Used for CSP connect-src (allows browser WebRTC to reach LiveKit server)
# NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ─────────────────────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_VOICE=false
NEXT_PUBLIC_FEATURE_MULTI_AGENT=true
NEXT_PUBLIC_FEATURE_DEBUG_PANEL=true
NEXT_PUBLIC_FEATURE_BILLING=false

# Arch-AI integrations-in-project rollout (ABLP-162).
# Enabled by default after Phase 7 rollout (2026-05-05). Phases 1-6 shipped
# without runtime gating, so this variable is documentation-only today and
# does not gate any code path. Set to `false` to opt out once gating is wired.
ARCH_INTEGRATIONS_V1=true

# ─────────────────────────────────────────────────────────────────────────────────
# Rate Limiting (disabled in dev)
# ─────────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false
