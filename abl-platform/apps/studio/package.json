    "@xyflow/react": "^12.0.0",
    "ai": "^6.0.99",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "elkjs": "^0.11.0",
    "fflate": "^0.8.2",
    "framer-motion": "^12.31.0",
