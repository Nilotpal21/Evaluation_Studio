    "@agent-platform/shared-auth": "workspace:*",
    "@agent-platform/shared-kernel": "workspace:*",
    "@agent-platform/web-sdk": "workspace:*",
    "@ai-sdk/anthropic": "^3.0.47",
    "@ai-sdk/google": "^3.0.31",
    "@ai-sdk/openai": "^3.0.33",
    "@ai-sdk/react": "^3.0.118",
