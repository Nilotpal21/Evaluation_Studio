{
  "name": "@agent-platform/studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Agent Studio - Visual IDE for Agent ABL (Next.js)",
  "scripts": {
    "ensure:web-sdk": "node ./scripts/ensure-web-sdk.mjs",
    "dev": "pnpm run ensure:web-sdk && next dev --webpack -p 5173",
    "dev:turbo": "pnpm run ensure:web-sdk && next dev --turbopack -p 5173",
    "dev:light": "LIGHT_DEV=1 next dev --turbopack -p 5173",
    "dev:workflows": "LIGHT_DEV=1 next dev --turbopack -p 5173",
    "build": "pnpm run ensure:web-sdk && next build --webpack",
    "start": "next start -p 5173",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:full",
    "test:fast": "node --import tsx ./run-tests.ts",
    "test:full": "vitest run",
    "test:light": "vitest run --config vitest.light.config.ts",
    "test:node": "vitest run --config vitest.node.config.ts",
    "test:api-routes": "vitest run --config vitest.node.config.ts src/__tests__/api-routes/ --passWithNoTests",
    "test:arch-ai": "node --import tsx ./run-tests.ts src/__tests__/arch-ai/ --passWithNoTests",
    "test:components": "node --import tsx ./run-tests.ts src/__tests__/components/ --passWithNoTests",
    "test:docs": "node --import tsx ./run-tests.ts src/__tests__/docs/ --passWithNoTests",
    "test:hooks": "node --import tsx ./run-tests.ts src/__tests__/hooks/ --passWithNoTests",
    "test:observatory": "node --import tsx ./run-tests.ts src/__tests__/live-trace-event-ingestion.test.ts src/__tests__/observatory-event-normalization.test.ts src/__tests__/observatory-metrics.test.ts src/__tests__/observatory-span-end.test.ts src/__tests__/observatory-span-lifecycle.test.ts src/__tests__/session-message-synthesis.test.ts src/__tests__/span-summary-tree.test.ts src/__tests__/span-synthesis.test.ts src/__tests__/studio-transport.test.ts src/__tests__/trace-event-adapter.test.ts --passWithNoTests",
    "test:search-ai": "node --import tsx ./run-tests.ts src/__tests__/search-ai/ --passWithNoTests",
    "test:stores": "node --import tsx ./run-tests.ts src/__tests__/stores/ --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "node --import tsx ./run-coverage.ts",
    "test:e2e": "playwright test --config=e2e-playwright.config.ts",
    "test:e2e:searchai": "playwright test e2e/searchai/document-pipeline.spec.ts --config=e2e-playwright.config.ts",
    "test:e2e:sdk-browser": "playwright test e2e/sdk-preview-share.spec.ts e2e/sdk-widget.spec.ts --config=e2e-playwright.config.ts",
    "test:e2e:sdk-browser:isolated": "SDK_BROWSER_E2E_ISOLATED=true SDK_BROWSER_E2E_STRICT=true playwright test e2e/sdk-preview-share.spec.ts e2e/sdk-widget.spec.ts --config=e2e-playwright.config.ts",
    "test:e2e:sdk-preview": "playwright test e2e/sdk-preview-share.spec.ts --config=e2e-playwright.config.ts",
    "test:e2e:sdk-widget": "playwright test e2e/sdk-widget.spec.ts --config=e2e-playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e-playwright.config.ts --ui",
    "analyze": "pnpm run ensure:web-sdk && ANALYZE=true next build --webpack"
  },
  "dependencies": {
    "@abl/compiler": "workspace:*",
    "@abl/core": "workspace:*",
    "@abl/language-service": "workspace:*",
    "@agent-platform/cli": "workspace:*",
    "@agent-platform/config": "workspace:*",
    "@agent-platform/connectors": "workspace:*",
    "@agent-platform/arch-ai": "workspace:*",
