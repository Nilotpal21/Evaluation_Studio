    "graphology": "^0.26.0",
    "graphology-layout": "^0.6.1",
    "graphology-types": "^0.24.8",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "livekit-client": "^2.17.1",
    "lucide-react": "^0.303.0",
    "mermaid": "^11.4.0",
    "next": "^16.2.3",
    "next-intl": "^4.8.3",
    "next-mdx-remote": "^6.0.0",
