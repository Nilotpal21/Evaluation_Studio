{
  "name": "@agent-platform/template-store",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Template Store - Public template marketplace and management API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agent-platform/config": "workspace:*",
    "@agent-platform/database": "workspace:*",
    "@agent-platform/project-io": "workspace:*",
    "@agent-platform/shared-auth": "workspace:*",
    "@agent-platform/shared-kernel": "workspace:*",
    "@agent-platform/shared-observability": "workspace:*",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "mongoose": "^8.23.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "mongodb-memory-server": "^11.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
