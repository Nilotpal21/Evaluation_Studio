{
  "name": "@agent-platform/search-ai-runtime",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SearchAI Runtime - Query, retrieval, vocabulary resolution",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:fast": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@abl/compiler": "workspace:*",
    "@agent-platform/config": "workspace:*",
    "@agent-platform/database": "workspace:*",
    "@agent-platform/llm": "workspace:*",
    "@agent-platform/redis": "workspace:*",
    "@agent-platform/search-ai-internal": "workspace:*",
    "@agent-platform/search-ai-sdk": "workspace:*",
    "@agent-platform/shared": "workspace:*",
    "@agent-platform/shared-auth": "workspace:*",
    "@agent-platform/shared-observability": "workspace:*",
    "@azure/identity": "^4.13.0",
    "@azure/keyvault-keys": "^4.10.0",
    "@clickhouse/client": "^1.17.0",
    "bullmq": "^5.41.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "lru-cache": "^11.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "mongodb-memory-server": "^10.4.0",
    "mongoose": "^8.23.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
