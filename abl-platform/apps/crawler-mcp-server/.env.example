# MCP Crawler Server Configuration

# Browser settings
HEADLESS=true                    # Run browser in headless mode (false for debugging)
MAX_BROWSERS=1                   # Number of browser instances
MAX_PAGES_PER_BROWSER=50         # Max pages per browser instance
SESSION_TIMEOUT=1800000          # Session timeout in ms (30 minutes)

# Playwright settings
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright  # Browser binaries path (for Docker)

# Logging
LOG_LEVEL=info                   # Log level (debug, info, warn, error)
