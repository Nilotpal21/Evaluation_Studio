  "attributes": [
    {
      "id": "unit_cost",
      "name": "Unit Cost",
      "dataType": "currency",
      "applicableTo": ["raw-material", "finished-good", "spare-part", "packaging-material"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "\\$[\\d,.]+\\s*/\\s*(unit|piece|kg|lb)",
          "\\$[\\d,.]+\\s*per\\s*(unit|piece)"
        ],
        "keywords": ["unit cost", "cost per unit", "price per piece", "material cost", "unit price"]
      }
    },
    {
      "id": "lead_time_days",
      "name": "Lead Time",
      "dataType": "number",
      "applicableTo": ["raw-material", "spare-part", "packaging-material"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "\\d+\\s*days?\\s*lead\\s*time",
          "lead\\s*time\\s*\\d+\\s*days?",
          "\\d+\\s*weeks?\\s*lead"
        ],
        "keywords": ["lead time", "delivery time", "procurement time", "order-to-delivery"]
      }
    },
    {
      "id": "defect_rate",
      "name": "Defect Rate",
      "dataType": "percentage",
      "applicableTo": ["finished-good", "work-in-progress", "quality-inspection"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+\\.?\\d*%\\s*defect", "defect\\s*rate\\s*\\d+", "\\d+\\s*ppm"],
        "keywords": [
          "defect rate",
          "rejection rate",
          "scrap rate",
          "PPM",
          "parts per million",
          "yield"
        ]
      }
    },
    {
      "id": "batch_number",
      "name": "Batch Number",
      "dataType": "identifier",
      "applicableTo": ["raw-material", "finished-good", "work-in-progress"],
      "extraction": {
        "method": "regex",
        "patterns": ["batch\\s*#?\\s*[A-Z0-9-]+", "lot\\s*#?\\s*[A-Z0-9-]+", "[A-Z]{2,3}-\\d{6,}"],
        "keywords": ["batch number", "lot number", "batch ID", "lot ID", "production batch"]
      }
    },
    {
      "id": "cycle_time",
      "name": "Cycle Time",
      "dataType": "duration",
      "applicableTo": ["finished-good", "work-in-progress", "tooling-equipment"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "\\d+\\s*(seconds?|minutes?|hours?)\\s*cycle",
          "cycle\\s*time\\s*\\d+",
          "takt\\s*time\\s*\\d+"
        ],
        "keywords": [
          "cycle time",
          "takt time",
          "processing time",
          "production time",
          "throughput time"
        ]
      }
    },
    {
      "id": "safety_stock",
      "name": "Safety Stock",
      "dataType": "number",
      "applicableTo": ["raw-material", "spare-part", "packaging-material", "finished-good"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "safety\\s*stock\\s*\\d+",
          "\\d+\\s*units?\\s*safety",
          "minimum\\s*stock\\s*\\d+"
        ],
        "keywords": [
          "safety stock",
          "buffer stock",
          "minimum inventory",
          "reorder point",
          "min stock"
        ]
      }
    },
    {
      "id": "mtbf",
      "name": "Mean Time Between Failures",
      "dataType": "duration",
      "applicableTo": ["tooling-equipment", "preventive-maintenance", "corrective-maintenance"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "MTBF\\s*\\d+",
          "\\d+\\s*hours?\\s*MTBF",
          "mean\\s*time\\s*between\\s*failures?\\s*\\d+"
        ],
        "keywords": [
          "MTBF",
          "mean time between failures",
          "reliability",
          "failure rate",
          "uptime hours"
        ]
      }
    },
    {
      "id": "weight",
      "name": "Weight",
      "dataType": "string",
      "applicableTo": ["raw-material", "finished-good", "packaging-material", "spare-part"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+\\.?\\d*\\s*(kg|lb|g|oz|tons?)", "weight\\s*\\d+"],
        "keywords": ["weight", "mass", "kg", "lbs", "gross weight", "net weight"]
      }
    },
    {
      "id": "tolerance",
      "name": "Tolerance",
      "dataType": "string",
      "applicableTo": [
        "finished-good",
        "work-in-progress",
        "quality-inspection",
        "calibration-service"
      ],
      "extraction": {
        "method": "regex",
        "patterns": ["\\u00b1\\s*\\d+\\.?\\d*\\s*(mm|in|%)", "tolerance\\s*\\d+"],
        "keywords": [
          "tolerance",
          "specification limit",
          "deviation",
          "dimensional tolerance",
          "precision"
        ]
      }
    }
  ],
  "departmentBoundaries": [
    {
      "product1": "raw-material",
      "product2": "work-in-progress",
      "reasoning": "Raw materials are procured by Supply Chain Management and become work-in-progress once they enter Production Operations. The handoff point is the production floor receiving dock."
    },
    {
      "product1": "quality-inspection",
      "product2": "finished-good",
      "reasoning": "Quality inspections (Quality Assurance) validate finished goods (Production Operations). A product cannot ship without QA sign-off but the departments operate independently."
    },
    {
      "product1": "preventive-maintenance",
      "product2": "tooling-equipment",
      "reasoning": "Preventive maintenance (Facilities & Maintenance) services tooling and equipment (Production Operations). Maintenance schedules directly impact production capacity."
    }
  ]
}
