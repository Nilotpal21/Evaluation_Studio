  "attributes": [
    {
      "id": "price_per_unit",
      "name": "Price Per Unit",
      "dataType": "currency",
      "applicableTo": ["compute-instance", "object-storage", "managed-database"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\$[\\d.]+\\s*/\\s*(hour|month|GB)", "\\$[\\d.]+\\s*per\\s*(hour|month|GB)"],
        "keywords": ["price", "cost", "per hour", "per month", "per GB", "pricing"]
      }
    },
    {
      "id": "uptime_sla",
      "name": "Uptime SLA",
      "dataType": "percentage",
      "applicableTo": [
        "compute-instance",
        "managed-database",
        "crm-platform",
        "erp-system",
        "siem-platform"
      ],
      "extraction": {
        "method": "regex",
        "patterns": [
          "\\d{2,3}\\.\\d+%\\s*uptime",
          "\\d{2,3}\\.\\d+%\\s*SLA",
          "\\d{2,3}\\.\\d+%\\s*availability"
        ],
        "keywords": ["uptime", "SLA", "availability", "service level", "guaranteed uptime"]
      }
    },
    {
      "id": "storage_capacity",
      "name": "Storage Capacity",
      "dataType": "string",
      "applicableTo": ["object-storage", "managed-database", "data-warehouse"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+\\s*(GB|TB|PB)", "up\\s*to\\s*\\d+\\s*(GB|TB|PB)"],
        "keywords": ["storage", "capacity", "disk size", "volume size", "data limit"]
      }
    },
    {
      "id": "user_seats",
      "name": "User Seats",
      "dataType": "number",
      "applicableTo": ["crm-platform", "erp-system", "siem-platform", "bi-tool"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+\\s*users?", "\\d+\\s*seats?", "up\\s*to\\s*\\d+\\s*licenses?"],
        "keywords": ["users", "seats", "licenses", "per user", "user limit"]
      }
    },
    {
      "id": "throughput",
      "name": "Throughput",
      "dataType": "string",
      "applicableTo": ["streaming-platform", "managed-database", "data-warehouse"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "\\d+\\s*(MB|GB)/s",
          "\\d+\\s*messages?/s",
          "\\d+\\s*events?/s",
          "\\d+\\s*QPS"
        ],
        "keywords": ["throughput", "messages per second", "events per second", "QPS", "bandwidth"]
      }
    },
    {
      "id": "response_time",
      "name": "Response Time",
      "dataType": "duration",
      "applicableTo": ["compute-instance", "managed-database", "crm-platform"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+\\s*ms\\s*latency", "p99\\s*\\d+\\s*ms", "\\d+\\s*ms\\s*response"],
        "keywords": ["latency", "response time", "p99", "p95", "milliseconds"]
      }
    },
    {
      "id": "compliance_cert",
      "name": "Compliance Certification",
      "dataType": "string",
      "applicableTo": [
        "compute-instance",
        "object-storage",
        "managed-database",
        "endpoint-protection",
        "siem-platform"
      ],
      "extraction": {
        "method": "llm",
        "keywords": ["SOC 2", "ISO 27001", "HIPAA", "PCI DSS", "FedRAMP", "GDPR", "compliance"]
      }
    },
    {
      "id": "api_rate_limit",
      "name": "API Rate Limit",
      "dataType": "number",
      "applicableTo": ["crm-platform", "erp-system", "bi-tool"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+\\s*requests?\\s*/\\s*(min|hour|day)", "rate\\s*limit\\s*\\d+"],
        "keywords": ["rate limit", "API limit", "requests per", "throttle", "quota"]
      }
    },
    {
      "id": "encryption_standard",
      "name": "Encryption Standard",
      "dataType": "string",
      "applicableTo": [
        "object-storage",
        "managed-database",
        "endpoint-protection",
        "siem-platform"
      ],
      "extraction": {
        "method": "llm",
        "keywords": [
          "AES-256",
          "TLS 1.3",
          "encryption at rest",
          "encryption in transit",
          "KMS",
          "envelope encryption"
        ]
      }
    }
  ],
  "departmentBoundaries": [
    {
      "product1": "managed-database",
      "product2": "data-warehouse",
      "reasoning": "Managed databases are operational OLTP stores (Cloud Infrastructure) while data warehouses are analytical OLAP stores (Data Engineering). Often data flows from managed databases into warehouses."
    },
    {
      "product1": "endpoint-protection",
      "product2": "siem-platform",
      "reasoning": "Endpoint protection generates security events (Endpoint Security) that feed into SIEM for analysis (Security Analytics). Both are security products but serve different operational roles."
    },
    {
      "product1": "compute-instance",
      "product2": "crm-platform",
      "reasoning": "CRM platforms may run on compute instances, but the compute is infrastructure (Cloud Infrastructure) while CRM is an application layer (Enterprise Solutions)."
    }
  ]
}
