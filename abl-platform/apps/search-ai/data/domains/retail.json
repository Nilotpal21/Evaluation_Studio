  "attributes": [
    {
      "id": "price",
      "name": "Price",
      "dataType": "currency",
      "applicableTo": ["physical-product", "digital-product", "gift-card"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\$[\\d,.]+", "price\\s*\\$[\\d,.]+", "MSRP\\s*\\$[\\d,.]+"],
        "keywords": ["price", "cost", "MSRP", "retail price", "sale price", "list price"]
      }
    },
    {
      "id": "sku",
      "name": "SKU",
      "dataType": "identifier",
      "applicableTo": ["physical-product", "digital-product", "gift-card"],
      "extraction": {
        "method": "regex",
        "patterns": ["SKU\\s*#?\\s*[A-Z0-9-]+", "[A-Z]{2,4}-\\d{4,8}"],
        "keywords": ["SKU", "stock keeping unit", "item number", "product code", "article number"]
      }
    },
    {
      "id": "discount_percentage",
      "name": "Discount Percentage",
      "dataType": "percentage",
      "applicableTo": ["promotional-campaign", "coupon", "physical-product", "digital-product"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+%\\s*off", "\\d+%\\s*discount", "save\\s*\\d+%"],
        "keywords": ["discount", "percent off", "savings", "markdown", "price reduction"]
      }
    },
    {
      "id": "points_value",
      "name": "Points Value",
      "dataType": "number",
      "applicableTo": ["loyalty-program", "physical-product", "digital-product"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+\\s*points?", "earn\\s*\\d+\\s*points?", "\\d+\\s*rewards?\\s*points?"],
        "keywords": ["points", "reward points", "loyalty points", "bonus points", "points earned"]
      }
    },
    {
      "id": "shipping_cost",
      "name": "Shipping Cost",
      "dataType": "currency",
      "applicableTo": ["shipping-service"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\$[\\d,.]+\\s*shipping", "shipping\\s*\\$[\\d,.]+", "free\\s*shipping"],
        "keywords": [
          "shipping cost",
          "delivery fee",
          "shipping charge",
          "freight cost",
          "free shipping"
        ]
      }
    },
    {
      "id": "delivery_time",
      "name": "Delivery Time",
      "dataType": "duration",
      "applicableTo": ["shipping-service", "in-store-pickup"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "\\d+-\\d+\\s*(business\\s*)?days?",
          "within\\s*\\d+\\s*days?",
          "\\d+\\s*hours?\\s*delivery"
        ],
        "keywords": [
          "delivery time",
          "shipping time",
          "estimated delivery",
          "business days",
          "arrives by"
        ]
      }
    },
    {
      "id": "return_window",
      "name": "Return Window",
      "dataType": "duration",
      "applicableTo": ["return-service", "physical-product", "digital-product"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "\\d+\\s*days?\\s*return",
          "return\\s*within\\s*\\d+",
          "\\d+-day\\s*return\\s*policy"
        ],
        "keywords": [
          "return window",
          "return period",
          "return policy",
          "days to return",
          "exchange period"
        ]
      }
    },
    {
      "id": "inventory_count",
      "name": "Inventory Count",
      "dataType": "number",
      "applicableTo": ["physical-product", "gift-card"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+\\s*in\\s*stock", "\\d+\\s*available", "stock\\s*\\d+"],
        "keywords": ["in stock", "inventory", "available quantity", "stock level", "on hand"]
      }
    },
    {
      "id": "expiration_date",
      "name": "Expiration Date",
      "dataType": "date",
      "applicableTo": ["coupon", "promotional-campaign", "gift-card", "store-credit"],
      "extraction": {
        "method": "llm",
        "keywords": [
          "expires",
          "valid until",
          "expiration date",
          "offer ends",
          "use by",
          "redemption deadline"
        ]
      }
    }
  ],
  "departmentBoundaries": [
    {
      "product1": "physical-product",
      "product2": "shipping-service",
      "reasoning": "Physical products are managed by Merchandising while shipping is handled by Supply Chain & Logistics. Product purchase triggers fulfillment but they are separate operational concerns."
    },
    {
      "product1": "loyalty-program",
      "product2": "promotional-campaign",
      "reasoning": "Loyalty programs (Customer Experience) and promotional campaigns (Marketing & Promotions) often interact — loyalty members may get exclusive promotions — but they are managed by different teams."
    },
    {
      "product1": "coupon",
      "product2": "physical-product",
      "reasoning": "Coupons are marketing instruments (Marketing & Promotions) applied to products (Merchandising). Coupon creation is marketing-driven while product pricing is merchandising-driven."
    }
  ]
