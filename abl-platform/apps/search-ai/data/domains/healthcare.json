  "attributes": [
    {
      "id": "copay",
      "name": "Copay",
      "dataType": "currency",
      "applicableTo": [
        "primary-care",
        "specialist-consultation",
        "emergency-care",
        "prescription-drug"
      ],
      "extraction": {
        "method": "regex",
        "patterns": ["\\$\\d+\\s*copay", "copay\\s*of\\s*\\$\\d+", "\\$\\d+\\s*per\\s*visit"],
        "keywords": ["copay", "co-pay", "co-payment", "office visit fee"]
      }
    },
    {
      "id": "deductible",
      "name": "Deductible",
      "dataType": "currency",
      "applicableTo": ["health-plan-hmo", "health-plan-ppo", "dental-plan"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "\\$[\\d,]+\\s*deductible",
          "deductible\\s*of\\s*\\$[\\d,]+",
          "annual\\s*deductible"
        ],
        "keywords": [
          "deductible",
          "annual deductible",
          "individual deductible",
          "family deductible"
        ]
      }
    },
    {
      "id": "premium",
      "name": "Monthly Premium",
      "dataType": "currency",
      "applicableTo": ["health-plan-hmo", "health-plan-ppo", "dental-plan"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "\\$[\\d,]+\\s*per\\s*month",
          "monthly\\s*premium\\s*of\\s*\\$[\\d,]+",
          "\\$[\\d,]+/mo"
        ],
        "keywords": ["premium", "monthly premium", "monthly cost", "plan cost"]
      }
    },
    {
      "id": "dosage",
      "name": "Dosage",
      "dataType": "string",
      "applicableTo": ["prescription-drug", "over-the-counter"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+\\s*mg", "\\d+\\s*ml", "\\d+\\s*mcg", "\\d+\\s*units?"],
        "keywords": ["dosage", "dose", "strength", "mg", "milligrams", "tablets"]
      }
    },
    {
      "id": "coverage_percentage",
      "name": "Coverage Percentage",
      "dataType": "percentage",
      "applicableTo": ["health-plan-hmo", "health-plan-ppo", "dental-plan"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+%\\s*coverage", "covers\\s*\\d+%", "plan\\s*pays\\s*\\d+%"],
        "keywords": ["coverage", "coinsurance", "plan pays", "covered at"]
      }
    },
    {
      "id": "out_of_pocket_max",
      "name": "Out-of-Pocket Maximum",
      "dataType": "currency",
      "applicableTo": ["health-plan-hmo", "health-plan-ppo"],
      "extraction": {
        "method": "regex",
        "patterns": [
          "\\$[\\d,]+\\s*out-of-pocket",
          "out-of-pocket\\s*max\\s*\\$[\\d,]+",
          "OOP\\s*max"
        ],
        "keywords": ["out-of-pocket maximum", "OOP max", "maximum out-of-pocket", "MOOP"]
      }
    },
    {
      "id": "wait_time",
      "name": "Wait Time",
      "dataType": "duration",
      "applicableTo": ["primary-care", "specialist-consultation", "emergency-care"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d+\\s*minutes?\\s*wait", "wait\\s*time\\s*\\d+", "\\d+\\s*day\\s*wait"],
        "keywords": ["wait time", "waiting period", "appointment wait", "average wait"]
      }
    },
    {
      "id": "ndc_code",
      "name": "NDC Code",
      "dataType": "identifier",
      "applicableTo": ["prescription-drug", "over-the-counter"],
      "extraction": {
        "method": "regex",
        "patterns": ["\\d{4,5}-\\d{3,4}-\\d{1,2}", "NDC\\s*#?\\s*\\d+"],
        "keywords": ["NDC", "national drug code", "drug code", "NDC number"]
      }
    },
    {
      "id": "cpt_code",
      "name": "CPT Code",
      "dataType": "identifier",
      "applicableTo": [
        "primary-care",
        "specialist-consultation",
        "emergency-care",
        "lab-test",
        "imaging-study"
      ],
      "extraction": {
        "method": "regex",
        "patterns": ["CPT\\s*\\d{5}", "\\d{5}\\s*CPT", "procedure\\s*code\\s*\\d{5}"],
        "keywords": ["CPT code", "procedure code", "CPT", "billing code"]
      }
    }
  ],
  "departmentBoundaries": [
    {
      "product1": "health-plan-hmo",
      "product2": "primary-care",
      "reasoning": "HMO plans require selecting a primary care physician. The plan is an insurance product (Insurance & Benefits) while primary care is a clinical service (Clinical Operations). Often discussed together in enrollment contexts."
    },
    {
      "product1": "prescription-drug",
      "product2": "health-plan-ppo",
      "reasoning": "Prescription drug coverage is part of health plans but pharmacy is a separate department. Drug formularies, tiers, and copays are plan-specific but managed by pharmacy services."
    },
    {
      "product1": "lab-test",
      "product2": "specialist-consultation",
      "reasoning": "Lab tests are diagnostic services often ordered during specialist consultations. The test itself is a diagnostic product while the consultation is a clinical service."
    }
  ]
}
