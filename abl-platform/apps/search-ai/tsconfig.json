{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "downlevelIteration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/__tests__", "src/scripts"],
  "references": [
    { "path": "../../packages/compiler" },
    { "path": "../../packages/config" },
    { "path": "../../packages/database" },
    { "path": "../../packages/eventstore" },
    { "path": "../../packages/search-ai-internal" },
    { "path": "../../packages/search-ai-sdk" },
    { "path": "../../packages/shared" }
  ]
}
