{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": ".",
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@abl/core": ["../../packages/core/dist/index.d.ts"],
      "@abl/core/*": ["../../packages/core/dist/*"],
      "@abl/analyzer": ["../../packages/analyzer/dist/index.d.ts"],
      "@abl/analyzer/*": ["../../packages/analyzer/dist/*"],
      "@abl/compiler": ["../../packages/compiler/dist/index.d.ts"],
      "@abl/compiler/*": ["../../packages/compiler/dist/*"],
      "@abl/nl-parser": ["../../packages/nl-parser/dist/index.d.ts"],
      "@abl/nl-parser/*": ["../../packages/nl-parser/dist/*"],
      "@abl/editor": ["../../packages/editor/dist/index.d.ts"],
      "@abl/editor/*": ["../../packages/editor/dist/*"],
      "@abl/language-service": ["../../packages/language-service/dist/index.d.ts"],
      "@abl/language-service/*": ["../../packages/language-service/dist/*"]
      // @agent-platform/* paths are inherited from the root tsconfig and
      // intentionally not overridden here. Admin does not redeclare baseUrl,
      // so the inherited "." stays anchored to the root tsconfig's directory.
      // Local "../../packages/<pkg>/dist/*" entries resolved relative to that
      // root baseUrl walked OUT of the checkout; from a `.worktrees/<name>/`
      // checkout they landed in the parent main-repo's packages/, pulling in
      // a stale build of the workspace packages. Falling back to the root
      // paths (and to node_modules workspace symlinks) is symmetric with
      // apps/studio and works in both main and worktree checkouts.
    },
    "isolatedModules": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "references": []
}
