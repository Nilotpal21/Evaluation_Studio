# ═══════════════════════════════════════════════════════════════════════════════
# ADMIN DASHBOARD - Development Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env.local and adjust as needed:  cp .env.example .env.local

# ─────────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────────
# URLs & Endpoints
# ─────────────────────────────────────────────────────────────────────────────────
# Studio API URL (REQUIRED) - connects admin to studio backend
STUDIO_API_URL=http://localhost:5173

# Public Studio URL (optional) - used for browser redirects during Google/Microsoft/SSO login.
# Prefer the same canonical Studio public-origin envs used by Studio itself.
# FRONTEND_URL is primary; NEXT_PUBLIC_APP_URL is the legacy alias.
# NEXT_PUBLIC_STUDIO_URL remains available as an admin-specific override if needed.
# FRONTEND_URL=https://agents-dev.kore.ai
# NEXT_PUBLIC_APP_URL=https://agents-dev.kore.ai
# NEXT_PUBLIC_STUDIO_URL=https://agents-dev.kore.ai

# Admin base URL (for logout redirects, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3003

# ─────────────────────────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────────────────────────
# JWT Secret - MUST match Runtime and Studio JWT_SECRET
# In production: openssl rand -base64 64
JWT_SECRET=development-secret-change-in-production

# ─────────────────────────────────────────────────────────────────────────────────
# External Links (Optional - for dashboard navigation)
# ─────────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_BITBUCKET_REPO_URL=
# NEXT_PUBLIC_ARGOCD_URL=
