# Git attributes for Go crawler worker

# Mark shell scripts as executable
*.sh text eol=lf
scripts/*.sh text eol=lf

# Go files
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# Makefiles
Makefile text eol=lf

# Markdown
*.md text eol=lf

# Dockerfiles
Dockerfile text eol=lf
.dockerignore text eol=lf
