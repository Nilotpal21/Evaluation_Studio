# Redis Configuration
# Standalone (default): REDIS_URL is a single redis://host:port URL.
# Cluster mode: set REDIS_CLUSTER=true and provide a comma-separated seed list in REDIS_URL.
#   e.g. REDIS_URL=redis-0:6379,redis-1:6379,redis-2:6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CLUSTER=false
REDIS_TLS_ENABLED=false

# Queue Configuration
QUEUE_NAME=static-crawl
POLL_INTERVAL=1s
MAX_CONCURRENCY=10
MAX_RETRIES=3

# Crawler Configuration
USER_AGENT=SearchAI-Bot/1.0 (+https://searchai.com/bot)
MAX_DEPTH=5
REQUEST_TIMEOUT=30s
PARALLELISM=100
DELAY_BETWEEN=100ms
RESPECT_ROBOTS_TXT=true

# Worker Configuration
WORKER_ID=auto
MAX_JOB_DURATION=10m
SHUTDOWN_TIMEOUT=30s

# Processing Configuration
MAX_HTML_SIZE=10485760  # 10MB
MAX_TEXT_SIZE=1048576   # 1MB
EXTRACT_HTML=true
EXTRACT_TEXT=true
EXTRACT_LINKS=true
EXTRACT_METADATA=true

# Logging
LOG_LEVEL=info
