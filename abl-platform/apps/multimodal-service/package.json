{
  "name": "@agent-platform/multimodal-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Multimodal Service - file upload, storage, scanning, processing pipeline",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:fast": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agent-platform/config": "workspace:*",
    "@agent-platform/database": "workspace:*",
    "@agent-platform/redis": "workspace:*",
    "@agent-platform/search-ai-sdk": "workspace:*",
    "@abl/compiler": "workspace:*",
    "@agent-platform/shared": "workspace:*",
    "@agent-platform/shared-observability": "workspace:*",
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/lib-storage": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "bullmq": "^5.0.0",
    "clamscan": "^2.4.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "file-type": "^21.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "multer": "^2.0.2",
    "rate-limiter-flexible": "^5.0.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/clamscan": "^2.4.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.0.0",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "mongodb-memory-server": "^10.4.0",
    "mongoose": "^8.23.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
