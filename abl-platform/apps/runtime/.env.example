# ═══════════════════════════════════════════════════════════════════════════════
# RUNTIME API - Development Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and adjust as needed:  cp .env.example .env

# ─────────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3112
HOST=localhost
LOG_LEVEL=debug

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ─────────────────────────────────────────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://abl_admin:abl_dev_password@localhost:27018/abl_platform?authSource=admin&directConnection=true
MONGODB_DATABASE=abl_platform

# ─────────────────────────────────────────────────────────────────────────────────
# ClickHouse (Analytics — traces, messages, metrics, audit, facts)
# ─────────────────────────────────────────────────────────────────────────────────
# Docker Compose default: http://localhost:8124 (maps to container port 8123)
CLICKHOUSE_URL=http://localhost:8124
CLICKHOUSE_USER=abl_admin
CLICKHOUSE_PASSWORD=abl_dev_password
CLICKHOUSE_DATABASE=abl_platform
# Set to 'true' only if ClickHouse Keeper is available (prod)
# CLICKHOUSE_REPLICATED=false

# ─────────────────────────────────────────────────────────────────────────────────
# Fact Store Backend (sqlite or clickhouse)
# ─────────────────────────────────────────────────────────────────────────────────
# FACT_STORE_BACKEND=sqlite

# ─────────────────────────────────────────────────────────────────────────────────
# Redis (Optional for development - falls back to in-memory)
# ─────────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_CLUSTER=false
# REDIS_TLS_ENABLED=false
# --- cluster mode: set REDIS_CLUSTER=true and provide comma-separated seed list ---
# REDIS_URL=redis-0:6379,redis-1:6379,redis-2:6379
REDIS_KEY_PREFIX=agent:

# ─────────────────────────────────────────────────────────────────────────────────
# Restate (Durable Execution — pipeline scheduler management)
# ─────────────────────────────────────────────────────────────────────────────────
# HTTP ingress endpoint for calling Restate service handlers (start/stop PipelineScheduler).
# Used by pipeline activate/deactivate and builtin pipeline toggle routes.
RESTATE_INGRESS_URL=http://localhost:8091

# ─────────────────────────────────────────────────────────────────────────────────
# Kafka (Runtime event bus + deploy-time seed-kafka)
# ─────────────────────────────────────────────────────────────────────────────────
# Comma-separated Kafka bootstrap brokers (local docker-compose default)
EVENT_KAFKA_BROKERS=localhost:19092

# Topic defaults used by packages/eventstore/seed-kafka.ts (deploy/init + manual runs)
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_TOPIC_MIN_INSYNC_REPLICAS=1
KAFKA_TOPIC_RETENTION_MS=604800000
KAFKA_TOPIC_COMPRESSION=lz4

# ─── Kafka auth — DEPLOY ENVIRONMENTS ONLY ───────────────────────────────────────
# Local docker-compose runs an unauthenticated PLAINTEXT broker. Leave ALL
# variables below UNSET in local .env files — resolveKafkaAuth() returns {}
# and clients connect plain.
#
# In deploy environments (Helm + ArgoCD), inject from a Kubernetes Secret.
# KAFKA_AUTH_ENABLED=true is the master toggle — credentials alone do NOT
# enable auth. All three (KAFKA_AUTH_ENABLED, USERNAME, PASSWORD) must be set.
#
# KAFKA_AUTH_ENABLED=true           # master toggle — must be "true" to activate SASL
# KAFKA_SASL_MECHANISM=plain        # plain | scram-sha-256 | scram-sha-512 (default: plain)
# KAFKA_SASL_USERNAME=              # required when KAFKA_AUTH_ENABLED=true
# KAFKA_SASL_PASSWORD=              # required when KAFKA_AUTH_ENABLED=true
# KAFKA_SSL_ENABLED=false           # "true" to enable TLS (independent of SASL)

# ─────────────────────────────────────────────────────────────────────────────────
# Authentication & Security
# ─────────────────────────────────────────────────────────────────────────────────
# JWT Secret - MUST match Studio's JWT_SECRET
# In production: openssl rand -base64 64
JWT_SECRET=development-secret-change-in-production

# SDK Session Signing Secret — Runtime-only, signs sdk_session JWTs
# MUST NOT be shared with Studio. Generate with: openssl rand -base64 48
AUTH_SDK_SESSION_SIGNING_SECRET=

# SDK Bootstrap Signing Secret — shared between Studio and Runtime
# Signs bootstrap artifacts for preview/share token exchange
# MUST match Studio's AUTH_SDK_BOOTSTRAP_SIGNING_SECRET
# Generate with: openssl rand -base64 48
AUTH_SDK_BOOTSTRAP_SIGNING_SECRET=

# Encryption key for secrets at rest - MUST match Studio's key
# In production: openssl rand -hex 32
# ENCRYPTION_ENABLED=true  # Set to 'false' to disable encryption even when key is set
# ENCRYPTION_MASTER_KEY=   # Generate with: openssl rand -hex 32

# API key for internal service-to-service communication
# INTERNAL_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# Workflow-as-Tool (agent invokes workflows; workflow pushes completion callbacks)
# ─────────────────────────────────────────────────────────────────────────────────
# Workflow Engine HTTP base URL — runtime calls this to execute workflow tools
WORKFLOW_ENGINE_URL=http://localhost:9080

# Public base URL where workflow-engine can reach this runtime for push callbacks
# Used as the callbackUrl in async workflow executions (triggerMetadata.callbackUrl)
RUNTIME_URL=http://localhost:3112

# HMAC secret for signing/verifying workflow completion callbacks
# MUST match the value set in apps/workflow-engine/.env
# Generate with: openssl rand -hex 32
INTERNAL_CALLBACK_SECRET=

# TTL (hours) for async workflow results persisted in Redis when session is inactive
ASYNC_RESULT_TTL_HOURS=24

# ─────────────────────────────────────────────────────────────────────────────────
# Workflow Execution Event-Sourcing — Mongo → Kafka → ClickHouse
# ─────────────────────────────────────────────────────────────────────────────────
# Runtime-owned flags (consumer + reader side). All default OFF.
# Full flag matrix lives in the root .env.example; ops doc:
#   docs/guides/workflow-execution-event-sourcing-ops.md

# Kafka consumer that projects workflow events → CH `_latest` tables.
# Flip ON only after workflow-engine WORKFLOW_OUTBOX_ENABLED=true is publishing healthily.
# WORKFLOW_CH_SINK_ENABLED=false

# Read path unions Mongo + ClickHouse responses. Only useful once CH has data.
# WORKFLOW_DUAL_READ_ENABLED=false

# Kafka broker (consumer side — must match the workflow-engine producer).
# EVENT_KAFKA_BROKERS=127.0.0.1:19092

# Sync-response timeout for runtime → workflow-engine proxy calls (ms, default 30000).
# WORKFLOW_PROXY_SYNC_TIMEOUT_MS=30000

# ─────────────────────────────────────────────────────────────────────────────────
# /diagnose endpoint — optional shared-secret gate (defense-in-depth)
# ─────────────────────────────────────────────────────────────────────────────────
# When set, /diagnose additionally requires `X-Diagnose-Key: <secret>` on the
# request (layered on top of the internal-network IP gate). Unset ⇒ internal
# network gate alone, current behaviour preserved.
# Generate with: openssl rand -hex 32
# DIAGNOSE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# LLM Providers
# ─────────────────────────────────────────────────────────────────────────────────

# Anthropic (Primary - at least one LLM key required)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096
# ANTHROPIC_RATE_LIMIT_RPM=1000

# OpenAI (Fallback - Optional)
# OPENAI_API_KEY=
# OPENAI_DEFAULT_MODEL=gpt-4o

# Google Gemini (Optional)
# GOOGLE_AI_API_KEY=

# Azure OpenAI (Enterprise - Optional)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# AWS Bedrock (Enterprise - Optional)
# AWS_BEDROCK_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────────
# Voice Services (WebRTC/Twilio + STT/TTS)
# ─────────────────────────────────────────────────────────────────────────────────

# Twilio (Optional - for voice features)
# Get from: https://console.twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_API_KEY=
# TWILIO_API_SECRET=
# TWILIO_TWIML_APP_SID=
# TWILIO_TRUNK_SID=TKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deepgram (Speech-to-Text - Optional)
# DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-2
# DEEPGRAM_LANGUAGE=en-US

# ElevenLabs (Text-to-Speech - Optional)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_turbo_v2

# LiveKit (WebRTC voice via LiveKit Agent Framework — alternative to Twilio)
# Local dev: brew install livekit && livekit-server --dev
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
# LIVEKIT_TOKEN_TTL_SECONDS=3600
# LIVEKIT_MAX_CONCURRENT_ROOMS=50

# ─────────────────────────────────────────────────────────────────────────────────
# Channel OAuth — Slack
# ─────────────────────────────────────────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps, enable OAuth, and set the
# redirect URL to: <RUNTIME_BASE_URL>/api/channel-oauth/slack/callback
# CHANNEL_OAUTH_SLACK_CLIENT_ID=
# CHANNEL_OAUTH_SLACK_CLIENT_SECRET=
# CHANNEL_OAUTH_SLACK_SIGNING_SECRET=
# CHANNEL_OAUTH_SLACK_SCOPES=chat:write,chat:write.public,im:history,im:write,channels:read,channels:history,groups:read,groups:history,users:read,users:read.email,app_mentions:read,commands

# ─────────────────────────────────────────────────────────────────────────────────
# Rate Limiting & Circuit Breakers (defaults are fine for dev)
# ─────────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────────
# Observability (disabled by default in dev)
# ─────────────────────────────────────────────────────────────────────────────────
OTEL_ENABLED=false
# OTEL_SERVICE_NAME=agent-runtime
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# SENTRY_DSN=
# LANGFUSE_ENABLED=false
METRICS_ENABLED=false

# Observability feature flags (enable in dev to exercise new trace/metrics paths)
OBS_TRACE_CANONICAL_READ=true
OBS_STRICT_READINESS_GATES=true
OBS_METRIC_LABEL_GUARDRAILS=true
OBS_EVENTBUS_TRACE_HEADERS=true

# ─────────────────────────────────────────────────────────────────────────────────
# Checkpointing & State Persistence (memory by default, redis if REDIS_URL set)
# ─────────────────────────────────────────────────────────────────────────────────
CHECKPOINT_STORE=memory
# CHECKPOINT_TTL_SECONDS=86400
# CHECKPOINT_MAX_PER_SESSION=50

# ─────────────────────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────────────────────
FEATURE_VOICE_ENABLED=false
FEATURE_LIVEKIT_ENABLED=false
FEATURE_STREAMING_ENABLED=true
FEATURE_TOOL_SANDBOXING=true
FEATURE_MULTI_AGENT=true
FEATURE_DEBUG_TRACES=true
# Mock LLM provider for benchmarks — returns canned responses without real API calls
FEATURE_ENABLE_MOCK_LLM=false

# ─────────────────────────────────────────────────────────────────────────────────
# Sandbox / Gvisor Pod Configuration (direct pod communication)
# ─────────────────────────────────────────────────────────────────────────────────
SANDBOX_PYTHON_POD_URL=http://kr-python-svc
SANDBOX_JAVASCRIPT_POD_URL=https://usaz-dev-agent-platform.kore.ai/gvisor
# SANDBOX_POD_PATH=/execute-script
# SANDBOX_CODE_BASE_PATH=./sandbox-tools
# SANDBOX_TIMEOUT_MS=60000
# SANDBOX_JWT_SECRET=              # Set to enable JWT auth for gvisor memory access
# SANDBOX_JWT_EXPIRY_SECONDS=300

# ─────────────────────────────────────────────────────────────────────────────────
# Governance Dashboard
# ─────────────────────────────────────────────────────────────────────────────────
GOVERNANCE_ENABLED=true                     # Set false to disable governance routes without redeploy
GOVERNANCE_STATUS_CACHE_TTL_SECONDS=300     # Redis TTL for /status responses (5 minutes)
GOVERNANCE_REPORT_MAX_ROWS=10000            # Maximum audit events in CSV/PDF export

# ─────────────────────────────────────────────────────────────────────────────────
# External Agent Registry (A2A — ABLP-162 Spec 1)
# ─────────────────────────────────────────────────────────────────────────────────
# Emergency rollback for auth-aware test_connection. Default unset = enabled.
# Set to the literal string 'false' to bypass the auth-aware factory and fall
# back to legacy unauthenticated test_connection behavior (empty string or
# other values do NOT trigger bypass). Each call in fallback mode emits a
# structured log.warn carrying tenantId + externalAgentId for SIEM
# correlation. Fleet-wide bypass — only flip in incident response.
# EXTERNAL_AGENT_TEST_AUTH=false
