# ==========================================
# ABL Platform Runtime — Environment Config
# ==========================================

# --- Server ---
NODE_ENV=development
PORT=3112
HOST=0.0.0.0
LOG_LEVEL=debug

# --- Database (MongoDB) --- docker-compose: abl-mongo on port 27018
MONGODB_URL=mongodb://abl_admin:abl_dev_password@localhost:27018/abl_platform?authSource=admin&directConnection=true

# --- Analytics (ClickHouse) --- docker-compose: abl-clickhouse on port 8124
CLICKHOUSE_URL=http://localhost:8124

# --- Cache (Redis) --- docker-compose: abl-redis on port 6380
REDIS_URL=redis://localhost:6380

# --- Kafka (Runtime event bus + deploy-time seed-kafka) ---
EVENT_KAFKA_BROKERS=localhost:19092
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_TOPIC_MIN_INSYNC_REPLICAS=1
KAFKA_TOPIC_RETENTION_MS=604800000
KAFKA_TOPIC_COMPRESSION=lz4
# Kafka auth is OFF for local docker-compose (plain broker). In deploy
# environments inject from a Kubernetes Secret. KAFKA_AUTH_ENABLED=true is
# the master toggle — credentials alone do NOT activate auth. Leave UNSET here.
# KAFKA_AUTH_ENABLED=true
# KAFKA_SASL_MECHANISM=plain        # plain | scram-sha-256 | scram-sha-512
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
# KAFKA_SSL_ENABLED=false

# --- Authentication ---
JWT_SECRET=development-secret-change-in-production
# SDK signing secrets (required for startup) — see .env.example for details
AUTH_SDK_SESSION_SIGNING_SECRET=
AUTH_SDK_BOOTSTRAP_SIGNING_SECRET=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=abl-platform-runtime
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# --- Feature Flags ---
FEATURE_MULTI_TENANT=false
FEATURE_AUDIT_LOG=true

# --- API Keys (fill in as needed) ---
OPENAI_API_KEY=
GOOGLE_AI_KEY=
