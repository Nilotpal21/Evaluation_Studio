# ═══════════════════════════════════════════════════════════════════════════════
# WORKFLOW ENGINE - Development Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and adjust as needed:  cp .env.example .env

# ─────────────────────────────────────────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────────────────────────────────────────
MONGODB_URL="mongodb://abl_admin:abl_dev_password@localhost:27018/abl_platform?authSource=admin&directConnection=true"

# ─────────────────────────────────────────────────────────────────────────────────
# Redis (shared with runtime — same instance)
# ─────────────────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:localdev@localhost:6380"

# ─────────────────────────────────────────────────────────────────────────────────
# Restate (durable workflow orchestration)
# ─────────────────────────────────────────────────────────────────────────────────
RESTATE_INGRESS_URL="http://localhost:8091"

# Bearer token sent on every outbound Restate ingress call (start/cancel/resolve).
# When set, the Restate deployment (or its auth sidecar) must verify it so that
# only workflow-engine pods — not arbitrary cluster peers — can trigger workflows.
# Leave unset in local dev; REQUIRED in production (missing token emits a WARN at startup).
# Generate with: openssl rand -hex 32
# RESTATE_INGRESS_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────────
# Authentication & Encryption
# ─────────────────────────────────────────────────────────────────────────────────
# JWT Secret — MUST match runtime's JWT_SECRET
# In production: openssl rand -base64 64
JWT_SECRET=

# Encryption key for secrets at rest — MUST match runtime's ENCRYPTION_MASTER_KEY
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# Runtime Integration (agent_invocation steps + workflow-as-tool callbacks)
# ─────────────────────────────────────────────────────────────────────────────────
# Runtime base URL — used for agent_invocation steps and callback delivery targets
RUNTIME_URL=http://localhost:3112

# HMAC secret for signing workflow completion callbacks (agent-tool source)
# MUST match the value set in apps/runtime/.env
# Generate with: openssl rand -hex 32
# INTERNAL_CALLBACK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────────
# Public URL (used when building callback URLs for external webhook triggers)
# ─────────────────────────────────────────────────────────────────────────────────
# WORKFLOW_ENGINE_PUBLIC_URL=http://localhost:9080

# ═══════════════════════════════════════════════════════════════════════════════
# Workflow Execution Event-Sourcing — Mongo → Kafka → ClickHouse
# ═══════════════════════════════════════════════════════════════════════════════
# Flags owned by the workflow-engine (writer side). All default OFF.
# Full flag matrix lives in the root .env.example; ops doc:
#   docs/guides/workflow-execution-event-sourcing-ops.md

# ─────────────────────────────────────────────────────────────────────────────────
# Rollout Gates — flip order: OUTBOX → (runtime CH_SINK) → DUAL_READ → MONGO_TTL
# ─────────────────────────────────────────────────────────────────────────────────
# Dual-writes domain + outbox row in one Mongo tx; BullMQ poller drains outbox → Kafka.
# Requires EVENT_KAFKA_BROKERS and the Kafka topics to exist before flipping on.
# WORKFLOW_OUTBOX_ENABLED=false

# Read path unions Mongo + ClickHouse responses (tolerates either source lagging).
# Only useful once runtime WORKFLOW_CH_SINK_ENABLED=true has backfilled CH.
# WORKFLOW_DUAL_READ_ENABLED=false

# Writes `expiresAt` on terminal rows; TTL partial-filter index reaps them.
# IRREVERSIBLE per row. Requires OUTBOX + CH_SINK healthy first.
# TTL index is declared at model-load time — flag flip requires pod restart.
# WORKFLOW_MONGO_TTL_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────────
# Outbox Poller Tuning (only read when WORKFLOW_OUTBOX_ENABLED=true)
# ─────────────────────────────────────────────────────────────────────────────────
# WORKFLOW_OUTBOX_POLL_INTERVAL_MS=1000    # BullMQ poller cadence in ms (default 1000)
# WORKFLOW_OUTBOX_BATCH_SIZE=100           # rows drained per tick (default 100)
# WORKFLOW_OUTBOX_TTL_HOURS=72             # drained-row retention before cleanup (default 72h)
# WORKFLOW_OUTBOX_ALERT_THRESHOLD=10000    # warn at startup if unpublished > N (default 10000)

# ─────────────────────────────────────────────────────────────────────────────────
# Mongo TTL Retention (only read when WORKFLOW_MONGO_TTL_ENABLED=true)
# ─────────────────────────────────────────────────────────────────────────────────
# Window after a row turns terminal before the TTL index deletes it.
# Default 14 days; narrow to 172800 (48h) after staging observation.
# WORKFLOW_MONGO_TTL_SECONDS=1209600

# ─────────────────────────────────────────────────────────────────────────────────
# Kafka Broker (producer side)
# ─────────────────────────────────────────────────────────────────────────────────
# EVENT_KAFKA_BROKERS=127.0.0.1:19092

# ─────────────────────────────────────────────────────────────────────────────────
# /diagnose endpoint — optional shared-secret gate (defense-in-depth)
# ─────────────────────────────────────────────────────────────────────────────────
# When set, /diagnose additionally requires `X-Diagnose-Key: <secret>` on the
# request (layered on top of the internal-network IP gate). Unset ⇒ internal
# network gate alone, current behaviour preserved.
# Generate with: openssl rand -hex 32
# DIAGNOSE_API_KEY=
