{
  "name": "@agent-platform/workflow-engine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:workflows": "tsx watch src/index.ts",
    "test": "pnpm run test:fast && vitest run --config vitest.http.config.ts --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run --config vitest.fast.config.ts --passWithNoTests && vitest run --config vitest.forks.config.ts --passWithNoTests",
    "test:forks": "vitest run --config vitest.forks.config.ts --passWithNoTests",
    "test:http": "vitest run --config vitest.http.config.ts --passWithNoTests",
    "test:system": "vitest run --config vitest.system.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@abl/compiler": "workspace:*",
    "@abl/eventstore": "workspace:*",
    "@agent-platform/arch-ai": "workspace:*",
    "@agent-platform/circuit-breaker": "workspace:*",
    "@agent-platform/config": "workspace:*",
    "@agent-platform/connectors": "workspace:*",
    "@agent-platform/database": "workspace:*",
    "@agent-platform/redis": "workspace:*",
    "@agent-platform/shared": "workspace:*",
    "@agent-platform/shared-auth": "workspace:*",
    "@agent-platform/shared-encryption": "workspace:*",
    "@agent-platform/shared-kernel": "workspace:*",
    "@agent-platform/shared-observability": "workspace:*",
    "@azure/identity": "^4.13.0",
    "@azure/keyvault-keys": "^4.10.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.217.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.217.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@restatedev/restate-sdk": "^1.10.4",
    "@types/ws": "^8.5.10",
    "bullmq": "^5.70.1",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "ioredis": "^5.4.0",
    "isolated-vm": "6.1.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.0.0",
    "semver": "^7.7.4",
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/semver": "^7.5.8",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.4",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
