{
  "name": "@agent-platform/observatory-cli",
  "version": "1.0.0",
  "description": "Remote debugging CLI for Agent DSL Observatory",
  "type": "module",
  "bin": {
    "agent-debug": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@agent-platform/observatory": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0"
  }
}
