{
  "environment": "agents-dev",
  "namespace": "abl-platform-dev",
  "capturedAt": "2026-04-15",
  "sourceOfTruth": {
    "cluster": "aks-abl-dev-centralus",
    "statefulSet": "abl-platform-dev-mongodb",
    "storageClass": "default"
  },
  "mongodb": {
    "replicas": 3,
    "nodePool": {
      "name": "database",
      "vmSku": "Standard_D16s_v5"
    },
    "dataDisk": {
      "storageClassSku": "StandardSSD_LRS",
