    "logDisk": {
      "storageClassSku": "StandardSSD_LRS",
      "requestedCapacityGiB": 2
    },
    "clusterCapacity": {
      "dataDisksTotalGiB": 60,
      "logDisksTotalGiB": 6
    },
    "currentObservedUsage": {
      "status": "warning",
      "maxDataVolumeUsagePercent": 84,
      "note": "Coroot reported all 3 Mongo data volumes over 80% full."
