  },
  "mathNotes": {
    "diskTiering": "Azure Standard SSD pricing and performance follow fixed E-series tiers. A 20 GiB disk maps to the E4 tier, which has 32 GiB effective tier capacity for billing and performance assumptions.",
    "unitConventions": {
      "capacity": "GiB",
      "throughput": "MB/s",
      "iops": "operations/s"
    }
  }
