      "cpuPeakMilliCores": 22,
      "memoryPeakMiB": 265,
      "connectionsPeak": 44,
      "storageMetricsAvailable": false
    }
  },
  "mathNotes": {
    "diskTiering": "Azure Standard SSD pricing and performance follow fixed E-series tiers. An 8 GiB disk maps directly to the E2 tier.",
    "unitConventions": {
      "capacity": "GiB",
      "throughput": "MB/s",
      "iops": "operations/s"
    }
  }
