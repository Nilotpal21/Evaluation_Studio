  "mappingNotes": {
    "whyRunsAreSeparated": "The math totals, Redis command attribution, and Mongo namespace attribution were captured in separate bounded runs to avoid conflating theoretical sizing inputs with explanatory attribution detail.",
    "redisWriteInflationExplanation": [
      "One logical turn updates session state and conversation state.",
      "One logical turn also enqueues an LLM BullMQ job.",
      "The completed turn then enqueues user message, assistant message, and turn metrics into a second BullMQ pipeline.",
      "Trace events also write to Redis streams and publish to Pub/Sub.",
      "TTL refreshes happen on multiple session-related keys."
    ],
    "mongoWriteExplanation": [
      "Message-persistence BullMQ worker inserts persisted chat messages into abl_platform.messages.",
      "The same worker updates session aggregates in abl_platform.sessions via applySessionTurnUpdate.",
      "Profiler also observed writes to abl_platform.session_states, abl_platform.audit_logs, and occasionally other stateful collections."
    ]
  },
  "knownUnknowns": [
    "Redis PUBLISH traffic exists in the trace path but was intentionally not counted in read/write totals.",
    "Redis EVAL and EVALSHA are opaque compound operations and may perform both reads and writes internally.",
    "BullMQ internal Redis command attribution is inferred from command signatures and queue initialization paths rather than from BullMQ source-level instrumentation.",
    "Mongo namespace attribution was captured in a separate run from the primary math-count run, so namespace counts should be read as explanatory shape rather than strict addends for the primary totals.",
    "Small amounts of background worker activity can overlap the measurement window in local-dev and slightly perturb exact counts.",
    "The baseline excludes attachments, KB retrieval, explicit tool execution, multi-agent delegation, real provider latency, and multimodal/voice payloads."
  ]
