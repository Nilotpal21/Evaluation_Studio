{
  "version": 1,
  "status": "proposed",
  "purpose": "Recommended practical experiment matrix for estimating smooth chat message throughput and identifying Mongo write degradation onset for /api/v1/chat/agent on agents-dev.",
  "targetEnvironment": "agents-dev",
  "benchmarkScript": "benchmarks/multi-turn-saturation.ts",
  "requiredExecutionInputs": {
    "runtimePinnedReplicas": "<fill-before-run>",
    "runtimeRestoreReplicas": "<fill-before-run>",
    "runtimeRestoreMinReplicas": "<fill-before-run>",
    "runtimeRestoreMaxReplicas": "<fill-before-run>"
  },
  "sharedConfig": {
    "llmMode": "mock-1000ms-fixed",
    "multiTenant": false,
    "stepDurationMinutes": 10,
    "rampSeconds": 30,
    "maxTurnP95Ms": 1300,
    "maxTurnP99Ms": 2000,
    "minTurnSuccessRate": 0.99,
    "maxHttpFailureRate": 0.01,
    "holdWindowSourceOfTruth": "k6 Cloud hold windows",
    "throughputMetric": "chat_turn_success_total rate",
    "latencyMetric": "chat_turn_latency_ms",
    "datastoreMetricSource": "Coroot"
  },
  "decisionRules": {
    "smoothThroughput": {
      "errorRate": "< 1%",
      "p95Latency": "<= 1300ms",
      "mongoWriteLatency": "< 10ms",
      "mongoWriteIops": "< 300",
      "redisStatus": "no critical CPU or latency warning",
      "runtimeStatus": "no sustained CPU delay or throttle warning"
    },
    "mongoWriteDegrading": {
      "mongoWriteLatency": ">= 10ms",
      "mongoWriteIops": ">= 300",
      "or": "sustained upward slope vs previous hold window"
    }
  },
  "recommendedExecutionOrder": [
    "followup_only",
    "create_only",
    "mixed_10_90",
    "mixed_25_75",
    "mixed_50_50",
    "confirmation_repeat_best_candidate"
  ],
  "scenarios": [
    {
      "id": "followup_only",
      "goal": "Measure steady-state existing-session cost with no new session creation in the measured loop.",
      "messageMix": {
        "createShare": 0.0,
        "followUpShare": 1.0
      },
      "env": {
        "SINGLE_SESSION": "true",
        "TURNS": "1",
        "STEPS": "10,20,30,40,50,60,80",
        "MAX_VUS": "80",
        "STEP_DURATION_MINUTES": "10",
        "RAMP_SECONDS": "30",
        "MAX_TURN_P95_MS": "1300",
        "MAX_TURN_P99_MS": "2000",
        "MIN_TURN_SUCCESS_RATE": "0.99",
        "MAX_HTTP_FAILURE_RATE": "0.01"
      },
      "analysisFocus": [
        "steady-state messages/sec",
        "Mongo write latency under existing sessions",
        "Redis queue churn without session-create tax"
      ]
    },
    {
      "id": "create_only",
      "goal": "Measure pure session-creation cost where every message creates a fresh session.",
      "messageMix": {
        "createShare": 1.0,
        "followUpShare": 0.0
      },
      "env": {
        "SINGLE_SESSION": "false",
        "TURNS": "1",
        "STEPS": "5,10,15,20,25,30,40",
        "MAX_VUS": "40",
        "STEP_DURATION_MINUTES": "10",
        "RAMP_SECONDS": "30",
        "MAX_TURN_P95_MS": "1300",
        "MAX_TURN_P99_MS": "2000",
        "MIN_TURN_SUCCESS_RATE": "0.99",
        "MAX_HTTP_FAILURE_RATE": "0.01"
      },
      "analysisFocus": [
        "session-create ceiling",
        "Mongo bootstrap reads and writes",
        "create-path amplification in Redis"
      ]
    },
    {
      "id": "mixed_10_90",
      "goal": "Approximate workloads where new sessions are rare and most messages are follow-up turns.",
      "messageMix": {
        "createShare": 0.1,
        "followUpShare": 0.9
      },
      "env": {
        "SINGLE_SESSION": "false",
        "TURNS": "10",
        "STEPS": "10,20,30,40,50,60",
        "MAX_VUS": "60",
        "STEP_DURATION_MINUTES": "10",
        "RAMP_SECONDS": "30",
        "MAX_TURN_P95_MS": "1300",
        "MAX_TURN_P99_MS": "2000",
        "MIN_TURN_SUCCESS_RATE": "0.99",
        "MAX_HTTP_FAILURE_RATE": "0.01"
      },
      "analysisFocus": [
        "practical near-steady-state message mix",
        "smooth throughput candidate for normal chat traffic"
      ]
    },
    {
      "id": "mixed_25_75",
      "goal": "Measure a moderate session-churn workload.",
      "messageMix": {
        "createShare": 0.25,
        "followUpShare": 0.75
      },
      "env": {
        "SINGLE_SESSION": "false",
        "TURNS": "4",
        "STEPS": "10,20,30,40,50,60",
        "MAX_VUS": "60",
        "STEP_DURATION_MINUTES": "10",
        "RAMP_SECONDS": "30",
        "MAX_TURN_P95_MS": "1300",
        "MAX_TURN_P99_MS": "2000",
        "MIN_TURN_SUCCESS_RATE": "0.99",
        "MAX_HTTP_FAILURE_RATE": "0.01"
      },
      "analysisFocus": [
        "moderate session churn",
        "Mongo write degradation onset with more create traffic"
      ]
    },
    {
      "id": "mixed_50_50",
      "goal": "Stress a high session-churn workload where every second message is effectively a new session.",
      "messageMix": {
        "createShare": 0.5,
        "followUpShare": 0.5
      },
      "env": {
        "SINGLE_SESSION": "false",
        "TURNS": "2",
        "STEPS": "5,10,15,20,25,30,40",
        "MAX_VUS": "40",
        "STEP_DURATION_MINUTES": "10",
        "RAMP_SECONDS": "30",
        "MAX_TURN_P95_MS": "1300",
        "MAX_TURN_P99_MS": "2000",
        "MIN_TURN_SUCCESS_RATE": "0.99",
        "MAX_HTTP_FAILURE_RATE": "0.01"
      },
      "analysisFocus": ["high session churn", "earliest Mongo write degradation point"]
    },
    {
      "id": "confirmation_repeat_best_candidate",
      "goal": "Repeat the best candidate scenario at the identified ceiling to confirm stability and remove one-off noise.",
      "messageMix": {
        "createShare": "<copy-from-best-scenario>",
        "followUpShare": "<copy-from-best-scenario>"
      },
      "env": {
        "SINGLE_SESSION": "<copy-from-best-scenario>",
        "TURNS": "<copy-from-best-scenario>",
        "STEPS": "<best-single-step-only>",
        "MAX_VUS": "<same-as-best-step>",
        "STEP_DURATION_MINUTES": "15",
        "RAMP_SECONDS": "30",
        "MAX_TURN_P95_MS": "1300",
        "MAX_TURN_P99_MS": "2000",
        "MIN_TURN_SUCCESS_RATE": "0.99",
        "MAX_HTTP_FAILURE_RATE": "0.01"
      },
      "analysisFocus": ["repeatability", "stability at the candidate smooth throughput"]
    }
  ]
}
