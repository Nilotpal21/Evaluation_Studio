# Grafana k6 Cloud credentials
# Get your token from: Grafana Cloud portal → k6 → Settings → API tokens
K6_CLOUD_TOKEN=your-api-token-here

# k6 Cloud project ID
# Get from: Grafana Cloud portal → k6 → Projects → your project → URL contains the ID
K6_CLOUD_PROJECT_ID=your-project-id

# Optional Grafana Cloud stack ID for the current /cloud/v6 REST API.
# stop-k6.sh uses this for POST /cloud/v6/test_runs/<id>/abort when present.
K6_STACK_ID=your-stack-id

# Optional current Grafana Cloud API token. If omitted, scripts fall back to K6_CLOUD_TOKEN.
K6_CLOUD_API_TOKEN=your-grafana-cloud-api-token-here

# Target environment — public ingress base URL
STAGING_URL=https://staging.abl-platform.com

# Per-service URL overrides (optional — defaults derived from STAGING_URL)
# Uncomment and customize if your ingress uses different path prefixes
# RUNTIME_URL=https://staging.abl-platform.com
# STUDIO_URL=https://staging.abl-platform.com
# SEARCH_AI_URL=https://staging.abl-platform.com/search-ai
# SEARCH_AI_RUNTIME_URL=https://staging.abl-platform.com/search-ai-runtime
# BGE_M3_URL=https://staging.abl-platform.com/bge-m3
# ADMIN_URL=https://staging.abl-platform.com/admin

# Environment label (used in k6 Cloud dashboard tags)
ENV=staging

# Load tier: s, m, l, xl (controls VU count and duration)
TIER=m

# Auth credentials for the benchmark user on the target environment
# SDK API key (long-lived, chat permission) — create via Studio UI or POST /api/sdk/keys
SDK_API_KEY=your-sdk-api-key-here

# JWT access token (short-lived, 15 min) — use for admin operations only
# AUTH_TOKEN=your-staging-auth-token

TENANT_ID=benchmark-tenant
PROJECT_ID=benchmark-project

# Dev-login credentials (used when AUTH_TOKEN is not set and dev-login is enabled)
DEV_LOGIN_USER_ID=user-dev-001
DEV_LOGIN_EMAIL=dev@example.com
DEV_LOGIN_NAME=Developer

# Health check before benchmarks (true/false)
HEALTH_CHECK=true

# Coroot — infrastructure metrics (CPU, memory, connections, disk, OOM, restarts)
# Used by `sizing load-test` and `sizing saturation-test` to auto-collect infra metrics.
# Falls back to `kubectl top` if Coroot is not configured or unreachable.
# COROOT_BASE_URL=https://coroot.example.com
# COROOT_USERNAME=admin
# COROOT_PASSWORD=your-password
# COROOT_PROJECT_ID=your-coroot-project-id

# Kubernetes namespace for infra metrics collection (default: abl)
# NAMESPACE=abl

# Deployment name prefix — matches the Helm release name prefix.
# Full deployment name = {prefix}-{service} (e.g., abl-platform-dev-runtime)
# Default: abl (gives abl-runtime, abl-bge-m3, etc.)
# DEPLOYMENT_PREFIX=abl-platform-dev
