    "ws": "^8.16.0",
    "zod": "^3.22.0",
    "uuid": "^11.1.0",
    "@agent-platform/shared": "workspace:*",
    "@agent-platform/shared-observability": "workspace:*"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
