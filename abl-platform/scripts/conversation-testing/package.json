{
  "name": "@abl/conversation-testing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "LLM-driven conversation testing for insights pipeline seeding",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
