{
  "version": "2.0.0",
  "description": "ABL Platform secrets manifest — declares all secrets for production deployment (MongoDB + ClickHouse)",
  "scopes": {
    "shared": {
      "description": "Shared platform secrets (all auto-generated by OpenTofu)",
      "secrets": [
        {
          "key": "JWT_SECRET",
          "generator": "random:64",
          "description": "JWT signing key for access tokens",
          "required": true
        },
        {
          "key": "ENCRYPTION_MASTER_KEY",
          "generator": "hex:32",
          "description": "AES-256 master key (32-byte hex) for field-level encryption",
          "required": true
        },
        {
          "key": "MONGODB_URL",
          "generator": "kv-bridge",
          "description": "MongoDB connection string (written by OpenTofu kv-bridge module)",
          "required": true
        },
        {
          "key": "CLICKHOUSE_URL",
          "generator": "kv-bridge",
          "description": "ClickHouse connection string (written by OpenTofu kv-bridge module)",
          "required": true
        }
      ]
    },
    "runtime": {
      "description": "Runtime service secrets",
      "secrets": [
        {
          "key": "OPENAI_API_KEY",
          "generator": "manual",
          "description": "OpenAI API fallback key (per-tenant keys managed from UI)",
          "required": false
        },
        {
          "key": "GOOGLE_AI_API_KEY",
          "generator": "manual",
          "description": "Google AI (Gemini) API fallback key",
          "required": false
        },
        {
          "key": "AZURE_OPENAI_KEY",
          "generator": "manual",
          "description": "Azure OpenAI API fallback key",
          "required": false
        },
        {
          "key": "TWILIO_ACCOUNT_SID",
          "generator": "manual",
          "description": "Twilio account SID for voice",
          "required": false
        },
        {
          "key": "TWILIO_AUTH_TOKEN",
          "generator": "manual",
          "description": "Twilio auth token",
          "required": false
        },
        {
          "key": "TWILIO_API_KEY_SID",
          "generator": "manual",
          "description": "Twilio API key SID for voice SDK tokens",
          "required": false
        },
        {
          "key": "TWILIO_API_KEY_SECRET",
          "generator": "manual",
          "description": "Twilio API key secret for voice SDK tokens",
          "required": false
        },
        {
          "key": "TWILIO_TWIML_APP_SID",
          "generator": "manual",
          "description": "Twilio TwiML application SID",
          "required": false
        },
        {
          "key": "DEEPGRAM_API_KEY",
          "generator": "manual",
          "description": "Deepgram API key for STT",
          "required": false
        },
        {
          "key": "ELEVENLABS_API_KEY",
          "generator": "manual",
          "description": "ElevenLabs API key for TTS",
          "required": false
        },
        {
          "key": "INTERNAL_API_KEY",
          "generator": "random:48",
          "description": "Internal service-to-service API key (auto-generated by OpenTofu)",
          "required": true
        }
      ]
    },
    "studio": {
      "description": "Studio application secrets",
      "secrets": [
        {
          "key": "NEXTAUTH_SECRET",
          "generator": "random:64",
          "description": "NextAuth session signing secret (auto-generated by OpenTofu)",
          "required": true
        },
        {
          "key": "GOOGLE_CLIENT_ID",
          "generator": "manual",
          "description": "Google OAuth client ID for SSO",
          "required": false
        },
        {
          "key": "GOOGLE_CLIENT_SECRET",
          "generator": "manual",
          "description": "Google OAuth client secret for SSO",
          "required": false
        },
        {
          "key": "S3_ACCESS_KEY_ID",
          "generator": "manual",
          "description": "S3/Azure Blob access key for file uploads",
          "required": false
        },
        {
          "key": "S3_SECRET_ACCESS_KEY",
          "generator": "manual",
          "description": "S3/Azure Blob secret key for file uploads",
          "required": false
        },
        {
          "key": "TWILIO_ACCOUNT_SID",
          "generator": "manual",
          "description": "Twilio account SID (shared with runtime)",
          "required": false
        },
        {
          "key": "TWILIO_API_KEY_SID",
          "generator": "manual",
          "description": "Twilio API key SID",
          "required": false
        },
        {
          "key": "TWILIO_API_KEY_SECRET",
          "generator": "manual",
          "description": "Twilio API key secret",
          "required": false
        },
        {
          "key": "TWILIO_TWIML_APP_SID",
          "generator": "manual",
          "description": "Twilio TwiML application SID",
          "required": false
        },
        {
          "key": "DEEPGRAM_API_KEY",
          "generator": "manual",
          "description": "Deepgram API key for STT",
          "required": false
        },
        {
          "key": "ELEVENLABS_API_KEY",
          "generator": "manual",
          "description": "ElevenLabs API key for TTS",
          "required": false
        }
      ]
    }
  }
}
