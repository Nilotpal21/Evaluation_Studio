<!--
  ClickHouse Storage Policy Configuration
  Mount at: /etc/clickhouse-server/config.d/storage.xml

  Tiered storage: Hot (local SSD) -> Warm (attached SSD, 30d) -> Cold (S3, 90d)
  Dev single-disk policy uses "default" volume.
-->
<clickhouse>
  <storage_configuration>
    <disks>
      <local>
        <path>/var/lib/clickhouse/</path>
      </local>
      <warm_ssd>
        <path>/mnt/warm/clickhouse/</path>
      </warm_ssd>
      <cold_s3>
        <type>s3</type>
        <endpoint from_env="CLICKHOUSE_S3_ENDPOINT"/>
        <access_key_id from_env="AWS_ACCESS_KEY_ID"/>
        <secret_access_key from_env="AWS_SECRET_ACCESS_KEY"/>
        <metadata_path>/var/lib/clickhouse/disks/cold_s3/</metadata_path>
      </cold_s3>
    </disks>
    <policies>
      <!-- Production: tiered hot -> warm -> cold -->
      <tiered>
        <volumes>
          <hot>
            <disk>local</disk>
          </hot>
          <warm>
            <disk>warm_ssd</disk>
          </warm>
          <cold>
            <disk>cold_s3</disk>
          </cold>
        </volumes>
        <move_factor>0.1</move_factor>
      </tiered>
      <!-- Dev: single-disk fallback -->
      <default>
        <volumes>
          <main>
            <disk>local</disk>
          </main>
        </volumes>
      </default>
    </policies>
  </storage_configuration>
</clickhouse>
